---
/**
 * Breadcrumb — accessible breadcrumb nav + JSON-LD schema.
 * Pass crumbs as array of { label, href }. Last item is current page (no link).
 */

export interface Crumb {
  label: string;
  href?: string;
}

export interface Props {
  crumbs: Crumb[];
  baseUrl?: string;
}

const { crumbs, baseUrl = 'https://pupwiki.com' } = Astro.props;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.label,
    ...(crumb.href ? { item: `${baseUrl}${crumb.href}` } : {}),
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

<nav aria-label="Breadcrumb" class="breadcrumb">
  <ol class="breadcrumb__list">
    {crumbs.map((crumb, i) => {
      const isLast = i === crumbs.length - 1;
      return (
        <li class="breadcrumb__item">
          {isLast || !crumb.href
            ? <span class="breadcrumb__current" aria-current="page">{crumb.label}</span>
            : <a href={crumb.href} class="breadcrumb__link">{crumb.label}</a>
          }
          {!isLast && (
            <span class="breadcrumb__sep" aria-hidden="true">
              <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          )}
        </li>
      );
    })}
  </ol>
</nav>

<style>
.breadcrumb {
  padding-block: var(--space-3);
}

.breadcrumb__list {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-1);
  list-style: none;
  padding: 0;
  margin: 0;
}

.breadcrumb__item {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
}

.breadcrumb__link {
  font-size: var(--text-sm);
  color: var(--color-muted);
  transition: color var(--transition-base);
}

.breadcrumb__link:hover {
  color: var(--color-heading);
}

.breadcrumb__current {
  font-size: var(--text-sm);
  color: var(--color-body-soft);
  font-weight: var(--weight-medium);
}

.breadcrumb__sep {
  display: inline-flex;
  color: var(--color-placeholder);
}
</style>
