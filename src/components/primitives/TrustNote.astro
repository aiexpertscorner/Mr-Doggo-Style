---
/**
 * TrustNote — editorial/trust callout with icon, label, and body text.
 * Used for disclaimers, editorial promises, methodology notes.
 */

export interface Props {
  label?: string;
  icon?: 'check' | 'shield' | 'info' | 'award' | 'heart';
  variant?: 'primary' | 'warm' | 'success' | 'warning';
  compact?: boolean;
}

const {
  label,
  icon = 'shield',
  variant = 'primary',
  compact = false,
} = Astro.props;

const icons = {
  check:  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M5 13l4 4L19 7"/>',
  shield: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>',
  info:   '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>',
  award:  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>',
  heart:  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>',
};

const variantClass = {
  primary: 'trust-note--primary',
  warm:    'trust-note--warm',
  success: 'trust-note--success',
  warning: 'trust-note--warning',
}[variant];
---

<div class={`trust-note ${variantClass}${compact ? ' trust-note--compact' : ''}`}>
  <div class="trust-note__icon" aria-hidden="true">
    <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={`<svg>${icons[icon]}</svg>`}></svg>
  </div>
  <div class="trust-note__body">
    {label && <p class="trust-note__label">{label}</p>}
    <div class="trust-note__text">
      <slot />
    </div>
  </div>
</div>

<style>
.trust-note {
  display: flex;
  gap: var(--space-3);
  padding: var(--space-4);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-primary-light);
  background: var(--color-primary-subtle);
}

.trust-note--compact {
  padding: var(--space-3);
}

.trust-note--warm {
  background: var(--color-bg-warm);
  border-color: var(--color-border-warm);
}

.trust-note--success {
  background: var(--color-success-light);
  border-color: rgba(4, 120, 87, 0.18);
}

.trust-note--warning {
  background: var(--color-warning-light);
  border-color: rgba(217, 119, 6, 0.2);
}

.trust-note__icon {
  flex-shrink: 0;
  width: 2rem;
  height: 2rem;
  border-radius: var(--radius-lg);
  display: grid;
  place-items: center;
  background: var(--color-primary);
  color: white;
}

.trust-note--warm   .trust-note__icon { background: var(--color-accent); }
.trust-note--success .trust-note__icon { background: var(--color-success); }
.trust-note--warning .trust-note__icon { background: var(--color-warning); }

.trust-note__body {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  min-width: 0;
}

.trust-note__label {
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  text-transform: uppercase;
  letter-spacing: var(--tracking-label);
  color: var(--color-primary);
  line-height: 1;
}

.trust-note--warm   .trust-note__label { color: var(--color-accent-hover); }
.trust-note--success .trust-note__label { color: var(--color-success); }
.trust-note--warning .trust-note__label { color: var(--color-warning); }

.trust-note__text {
  font-size: var(--text-sm);
  line-height: var(--leading-relaxed);
  color: var(--color-body-soft);
}
</style>
