---
/**
 * CTAInline — inline call-to-action block within content.
 * Lighter than a full section; sits between paragraphs or at section ends.
 */

export interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  variant?: 'default' | 'accent' | 'warm';
}

const {
  eyebrow,
  title,
  body,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  variant = 'default',
} = Astro.props;
---

<div class={`cta-inline cta-inline--${variant}`}>
  <div class="cta-inline__content">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <p class="cta-inline__title">{title}</p>
    {body && <p class="cta-inline__body">{body}</p>}
  </div>
  <div class="cta-inline__actions">
    <a href={primaryHref} class="btn btn--primary">{primaryLabel}</a>
    {secondaryLabel && secondaryHref && (
      <a href={secondaryHref} class="btn btn--outline">{secondaryLabel}</a>
    )}
  </div>
</div>

<style>
.cta-inline {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-5) var(--space-6);
  border-radius: var(--radius-2xl);
  border: 1px solid var(--color-border);
  background: var(--color-bg-soft);
}

.cta-inline--accent {
  background: var(--color-accent-subtle);
  border-color: var(--color-border-accent);
}

.cta-inline--warm {
  background: var(--color-bg-warm);
  border-color: var(--color-border-warm);
}

.cta-inline__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.cta-inline__title {
  font-size: var(--text-lg);
  font-weight: var(--weight-bold);
  color: var(--color-heading);
  line-height: var(--leading-snug);
}

.cta-inline__body {
  font-size: var(--text-sm);
  color: var(--color-body-soft);
  line-height: var(--leading-relaxed);
}

.cta-inline__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
}

@media (min-width: 640px) {
  .cta-inline {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }

  .cta-inline__actions {
    flex-shrink: 0;
  }
}
</style>
