---
/**
 * StateAgeSelector.astro
 * Token-driven selector for state + dog age insurance estimates.
 *
 * Dispatches custom DOM events on document:
 * - stateChange → { code, name, multiplier, instanceId }
 * - ageChange   → { key, displayAge, factor, lifeStage, instanceId }
 */

import statesIndex from '../data/us-states-insurance-index.json';
import ageFactors from '../data/actuarial-age-factors.json';

export interface Props {
  defaultState?: string;
  defaultAge?: string;
  showAgeSelector?: boolean;
  compact?: boolean;
  id?: string;
}

const {
  defaultState = 'CA',
  defaultAge = '3',
  showAgeSelector = true,
  compact = false,
  id = `state-age-selector-${defaultState}-${defaultAge}`,
} = Astro.props;

const states = (statesIndex as any).states as {
  code: string;
  name: string;
  cost_multiplier: number;
}[];

const ages = (ageFactors as any).age_factors as {
  age_key: string;
  display_age: string;
  premium_factor: number;
  life_stage: string;
}[];

const initState = states.find((s) => s.code === defaultState) ?? states.find((s) => s.code === 'CA')!;
const initAge = ages.find((a) => a.age_key === defaultAge) ?? ages.find((a) => a.age_key === '3')!;

const stateSelectId = `${id}-state`;
const ageSelectId = `${id}-age`;

const statesJson = JSON.stringify(states);
const agesJson = JSON.stringify(ages);
---

<div
  class:list={['pw-state-age', compact && 'pw-state-age--compact']}
  data-component="state-age-selector"
  data-instance-id={id}
>
  <div class="pw-state-age__grid">
    <div class="pw-state-age__field">
      <label for={stateSelectId}>State</label>
      <select id={stateSelectId} data-ins-state-select aria-label="Select your state">
        {states.map((state) => (
          <option value={state.code} selected={state.code === initState.code}>
            {state.name} ({state.code}) — ×{state.cost_multiplier.toFixed(2)}
          </option>
        ))}
      </select>
    </div>

    {showAgeSelector && (
      <div class="pw-state-age__field">
        <label for={ageSelectId}>Dog age</label>
        <select id={ageSelectId} data-ins-age-select aria-label="Select your dog's age">
          {ages.map((age) => (
            <option value={age.age_key} selected={age.age_key === initAge.age_key}>
              {age.display_age} ({age.life_stage.replace(/_/g, ' ')})
            </option>
          ))}
        </select>
      </div>
    )}
  </div>

  <p class="pw-state-age__status">
    Showing estimates for:
    <strong data-ins-status-state>{initState.name}</strong>
    {showAgeSelector && (
      <>
        <span aria-hidden="true"> · </span>
        Dog age:
        <strong data-ins-status-age>{initAge.display_age}</strong>
      </>
    )}
  </p>
</div>

<script define:vars={{ statesJson, agesJson }}>
  const STATES = JSON.parse(statesJson);
  const AGES = JSON.parse(agesJson);

  document.querySelectorAll('[data-component="state-age-selector"]').forEach((root) => {
    if (root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    const instanceId = root.dataset.instanceId || '';
    const stateSelect = root.querySelector('[data-ins-state-select]');
    const ageSelect = root.querySelector('[data-ins-age-select]');
    const statusState = root.querySelector('[data-ins-status-state]');
    const statusAge = root.querySelector('[data-ins-status-age]');

    const dispatchState = (code) => {
      const state = STATES.find((item) => item.code === code);
      if (!state) return;

      if (statusState) statusState.textContent = state.name;

      document.dispatchEvent(
        new CustomEvent('stateChange', {
          detail: {
            code: state.code,
            name: state.name,
            multiplier: state.cost_multiplier,
            instanceId,
          },
        })
      );
    };

    const dispatchAge = (key) => {
      const age = AGES.find((item) => item.age_key === key);
      if (!age) return;

      if (statusAge) statusAge.textContent = age.display_age;

      document.dispatchEvent(
        new CustomEvent('ageChange', {
          detail: {
            key: age.age_key,
            displayAge: age.display_age,
            factor: age.premium_factor,
            lifeStage: age.life_stage,
            instanceId,
          },
        })
      );
    };

    stateSelect?.addEventListener('change', () => dispatchState(stateSelect.value));
    ageSelect?.addEventListener('change', () => dispatchAge(ageSelect.value));
  });
</script>

<style>
  .pw-state-age {
    display: grid;
    gap: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(248, 250, 252, 0.84));
    padding: var(--space-4);
    box-shadow: var(--shadow-xs);
  }

  .pw-state-age--compact {
    padding: var(--space-3);
    border-radius: var(--radius-xl);
  }

  .pw-state-age__grid {
    display: grid;
    gap: var(--space-3);
  }

  .pw-state-age__field {
    display: grid;
    gap: var(--space-2);
    min-width: 0;
  }

  .pw-state-age__field label {
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-none);
    text-transform: uppercase;
  }

  .pw-state-age__field select {
    width: 100%;
    min-height: 2.85rem;
    appearance: auto;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-xl);
    background: #ffffff;
    color: var(--color-heading);
    padding: 0.75rem 0.85rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-semi);
    line-height: var(--leading-tight);
    box-shadow: var(--shadow-xs);
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .pw-state-age__field select:hover {
    border-color: var(--color-border-accent);
  }

  .pw-state-age__field select:focus {
    border-color: var(--color-accent);
    outline: none;
    box-shadow: var(--ring-accent);
  }

  .pw-state-age__status {
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    line-height: var(--leading-relaxed);
  }

  .pw-state-age__status strong {
    color: var(--color-heading);
    font-weight: var(--weight-bold);
  }

  @media (min-width: 620px) {
    .pw-state-age__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: end;
    }
  }
</style>