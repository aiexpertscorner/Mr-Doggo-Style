---
/**
 * BreedImage.astro — resilient breed image / mini-gallery component
 *
 * Reads:
 * - breed.image_gallery[].url
 * - breed.image_urls[]
 * - breed.image_url
 * - breed.image_url_candidates[]
 * - breed.image_url_parent_1 / image_url_parent_2
 *
 * Features:
 * - Uses first valid URL as primary.
 * - Shows optional thumbnail rail when multiple images exist.
 * - If an image fails, JS advances to the next available URL.
 * - If all fail, token-driven emoji fallback is shown.
 */

export interface BreedImageGalleryItem {
  url?: string;
  image_url?: string;
  source?: string;
  role?: string;
  dog_ceo_path?: string;
  parent_breed_name?: string;
}

export interface Props {
  breed: {
    slug: string;
    name: string;
    size_category?: string;
    image_url?: string;
    image_urls?: string[];
    image_gallery?: BreedImageGalleryItem[];
    image_url_candidates?: BreedImageGalleryItem[];
    image_url_parent_1?: string;
    image_url_parent_2?: string;
    image_alt?: string;
  };
  width?: number;
  height?: number;
  class?: string;
  priority?: boolean;
  style?: string;
  showGallery?: boolean;
  variant?: 'single' | 'hero' | 'card';
}

const {
  breed,
  width = 640,
  height = 640,
  class: className = '',
  priority = false,
  style = '',
  showGallery = false,
  variant = 'single',
} = Astro.props;

const SIZE_EMOJI: Record<string, string> = {
  small: '🐕',
  medium: '🐕‍🦺',
  large: '🐕‍🦺',
  giant: '🦮',
};

function uniqueUrls(urls: unknown[]) {
  const seen = new Set<string>();

  return urls
    .filter((url): url is string => typeof url === 'string' && /^https?:\/\//.test(url))
    .filter((url) => {
      if (seen.has(url)) return false;
      seen.add(url);
      return true;
    });
}

const galleryUrls = uniqueUrls([
  ...(Array.isArray(breed.image_gallery) ? breed.image_gallery.map((item) => item.url || item.image_url) : []),
  ...(Array.isArray(breed.image_urls) ? breed.image_urls : []),
  breed.image_url,
  ...(Array.isArray(breed.image_url_candidates) ? breed.image_url_candidates.map((item) => item.url || item.image_url) : []),
  breed.image_url_parent_1,
  breed.image_url_parent_2,
]).slice(0, 5);

const primaryUrl = galleryUrls[0] || '';
const emoji = SIZE_EMOJI[breed.size_category || ''] || '🐾';
const alt = breed.image_alt || `${breed.name} dog`;
const loading = priority ? 'eager' : 'lazy';
const fetchpriority = priority ? 'high' : 'auto';
const hasImages = galleryUrls.length > 0;
const galleryJson = JSON.stringify(galleryUrls);
---

<div
  class:list={[
    'breed-image',
    `breed-image--${variant}`,
    showGallery && galleryUrls.length > 1 && 'breed-image--with-gallery',
    !hasImages && 'breed-image--fallback-only',
    className,
  ]}
  style={style}
  data-breed-image
  data-gallery={galleryJson}
>
  {hasImages ? (
    <>
      <div class="breed-image__main">
        <img
          src={primaryUrl}
          alt={alt}
          width={width}
          height={height}
          loading={loading}
          fetchpriority={fetchpriority}
          decoding="async"
          class="breed-image__img"
          data-breed-image-main
        />

        <div class="breed-image__fallback" hidden data-breed-image-fallback aria-hidden="true">
          <span>{emoji}</span>
        </div>
      </div>

      {showGallery && galleryUrls.length > 1 && (
        <div class="breed-image__thumbs" aria-label={`${breed.name} image gallery`}>
          {galleryUrls.map((url, index) => (
            <button
              type="button"
              class:list={['breed-image__thumb', index === 0 && 'is-active']}
              data-breed-image-thumb
              data-src={url}
              aria-label={`Show ${breed.name} image ${index + 1}`}
            >
              <img src={url} alt="" loading="lazy" decoding="async" />
            </button>
          ))}
        </div>
      )}
    </>
  ) : (
    <div class="breed-image__fallback breed-image__fallback--visible" aria-hidden="true">
      <span>{emoji}</span>
    </div>
  )}
</div>

<script>
  document.querySelectorAll('[data-breed-image]').forEach((root) => {
    if ((root as HTMLElement).dataset.initialized === 'true') return;
    (root as HTMLElement).dataset.initialized = 'true';

    const main = root.querySelector('[data-breed-image-main]') as HTMLImageElement | null;
    const fallback = root.querySelector('[data-breed-image-fallback]') as HTMLElement | null;
    const thumbs = Array.from(root.querySelectorAll('[data-breed-image-thumb]')) as HTMLButtonElement[];

    let gallery: string[] = [];

    try {
      gallery = JSON.parse((root as HTMLElement).dataset.gallery || '[]');
    } catch {
      gallery = [];
    }

    let activeIndex = 0;

    const showFallback = () => {
      if (main) main.hidden = true;
      if (fallback) fallback.hidden = false;
      thumbs.forEach((thumb) => (thumb.hidden = true));
    };

    const setActiveThumb = (src: string) => {
      thumbs.forEach((thumb) => {
        thumb.classList.toggle('is-active', thumb.dataset.src === src);
      });
    };

    const setImage = (src: string) => {
      if (!main || !src) return;

      main.hidden = false;
      if (fallback) fallback.hidden = true;
      main.src = src;
      setActiveThumb(src);
    };

    const tryNextImage = () => {
      if (!main || !gallery.length) {
        showFallback();
        return;
      }

      activeIndex += 1;

      if (activeIndex >= gallery.length) {
        showFallback();
        return;
      }

      setImage(gallery[activeIndex]);
    };

    if (main) {
      if (main.complete && main.naturalWidth > 0) main.classList.add('is-loaded');

      main.addEventListener('load', () => {
        main.classList.add('is-loaded');
      });

      main.addEventListener('error', tryNextImage);
    }

    thumbs.forEach((thumb, index) => {
      const thumbImage = thumb.querySelector('img') as HTMLImageElement | null;

      thumb.addEventListener('click', () => {
        activeIndex = index;
        setImage(thumb.dataset.src || '');
      });

      thumbImage?.addEventListener('error', () => {
        thumb.hidden = true;
      });
    });
  });
</script>

<style>
  .breed-image {
    position: relative;
    display: grid;
    gap: var(--space-3, 0.75rem);
    min-width: 0;
  }

  .breed-image__main {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: 100%;
    min-height: 12rem;
    border-radius: inherit;
    background:
      radial-gradient(circle at 30% 20%, var(--color-accent-light), transparent 55%),
      var(--color-bg-muted);
  }

  .breed-image__img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    opacity: 0;
    transform: scale(1.01);
    transition:
      opacity 220ms ease,
      transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .breed-image__img.is-loaded {
    opacity: 1;
    transform: scale(1);
  }

  .breed-image__fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 30% 20%, var(--color-accent-light), transparent 55%),
      var(--color-bg-muted);
  }

  .breed-image__fallback--visible {
    position: relative;
    min-height: 12rem;
    border-radius: inherit;
  }

  .breed-image__fallback span {
    font-size: clamp(3rem, 14vw, 6rem);
    line-height: 1;
  }

  .breed-image__thumbs {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: var(--space-2, 0.5rem);
  }

  .breed-image__thumb {
    overflow: hidden;
    aspect-ratio: 1;
    border: 2px solid transparent;
    border-radius: var(--radius-xl);
    background: var(--color-bg-muted);
    padding: 0;
    box-shadow: var(--shadow-xs);
    cursor: pointer;
    transition: var(--transition-smooth);
  }

  .breed-image__thumb:hover,
  .breed-image__thumb.is-active {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .breed-image__thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .breed-image--hero {
    border-radius: var(--radius-3xl);
  }

  .breed-image--hero .breed-image__main {
    min-height: clamp(17rem, 52vw, 26rem);
    border: 1px solid var(--color-border-warm);
    box-shadow: var(--shadow-xl);
  }

  .breed-image--card {
    border-radius: var(--radius-2xl);
  }

  .breed-image--card .breed-image__main {
    min-height: 10rem;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
  }

  @media (prefers-reduced-motion: reduce) {
    .breed-image__img,
    .breed-image__thumb {
      transition: none;
      transform: none !important;
    }
  }
</style>
