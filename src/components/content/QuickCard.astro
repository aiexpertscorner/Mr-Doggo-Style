---
/**
 * QuickCard.astro — "Jump straight in" section links.
 * Uses .quick-card CSS classes from cards.css.
 */

export interface Props {
  label: string;
  value: string;
  href:  string;
  icon?: string;
}

const { label, value, href, icon } = Astro.props;
---

<a href={href} class="quick-card" style="text-decoration:none">
  <div class="quick-card__inner">
    {icon && <span class="quick-card__icon" aria-hidden="true">{icon}</span>}
    <div>
      <span class="quick-card__label">{label}</span>
      <span class="quick-card__value">{value}</span>
    </div>
  </div>
  <span class="quick-card__arrow" aria-hidden="true">→</span>
</a>
