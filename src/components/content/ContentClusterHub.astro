---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AwinProductSlot from '../affiliate/AwinProductSlot.astro';
import AmazonProductSlot from '../amazon/AmazonProductSlot.astro';
import { type ContentCluster } from '../../lib/content/contentClusterConfig';

export interface Props {
  cluster: ContentCluster;
}

const { cluster } = Astro.props;
const SITE = 'https://pupwiki.com';
const canonicalUrl = `${SITE}/categories/${cluster.slug}`;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: cluster.title,
    description: cluster.description,
    url: canonicalUrl,
    about: cluster.primaryKeywords.map((name) => ({ '@type': 'Thing', name })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${cluster.title} topic plan`,
    itemListElement: [...cluster.primaryKeywords, ...cluster.secondaryKeywords].slice(0, 10).map((name, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name,
    })),
  },
];

const showCommerce = cluster.monetizationAllowed;
const isSensitive = cluster.claimSensitivity === 'high';
---

<BaseLayout
  title={`${cluster.title} — PupWiki Guides, Products & Planning`}
  description={cluster.description}
  canonicalUrl={canonicalUrl}
  pageType="collection"
  bodyClass="pw-page"
  structuredData={structuredData}
>
  <main class="pw-page">
    <section class="pw-section pw-section--soft">
      <div class="pw-container pw-stack pw-stack--lg">
        <nav class="pw-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a><span aria-hidden="true">›</span><a href="/categories">Categories</a><span aria-hidden="true">›</span><span>{cluster.shortTitle}</span>
        </nav>

        <div class="pw-page-header pw-stack">
          <p class="pw-eyebrow">{cluster.icon} {cluster.type} cluster</p>
          <h1 class="pw-title-xl">{cluster.title}</h1>
          <p class="pw-lede">{cluster.description}</p>
        </div>

        <div class="pw-grid pw-grid--3">
          <article class="pw-stat-card"><strong>{cluster.primaryKeywords.length}</strong><span>Primary intents</span></article>
          <article class="pw-stat-card"><strong>{cluster.amazonSearches.length}</strong><span>Amazon search modules</span></article>
          <article class="pw-stat-card"><strong>{cluster.relatedClusters.length}</strong><span>Related clusters</span></article>
        </div>
      </div>
    </section>

    <section class="pw-section">
      <div class="pw-container pw-stack pw-stack--lg">
        <div class="pw-section-head">
          <p class="pw-eyebrow">Rich content plan</p>
          <h2 class="pw-title-md">What this hub should cover</h2>
          <p>This page is powered by PupWiki’s central intent graph. It can support generated guides, product modules, partner placements and internal links without hardcoding every page manually.</p>
        </div>

        <div class="pw-grid pw-grid--2">
          <article class="pw-card pw-stack partner-rule-card">
            <span class="pw-chip pw-chip--accent">Primary keywords</span>
            <div class="pw-cluster">
              {cluster.primaryKeywords.map((keyword) => <span class="pw-chip">{keyword}</span>)}
            </div>
          </article>

          <article class="pw-card pw-stack partner-rule-card">
            <span class="pw-chip pw-chip--primary">Secondary keywords</span>
            <div class="pw-cluster">
              {cluster.secondaryKeywords.slice(0, 10).map((keyword) => <span class="pw-chip">{keyword}</span>)}
            </div>
          </article>
        </div>

        {isSensitive && (
          <aside class="pw-commercial-safe-note">
            <strong>Health-sensitive content note:</strong> this hub can include product and service resources, but copy should stay conservative. Use planning, comparison and “questions to ask your vet” language rather than treatment claims.
          </aside>
        )}
      </div>
    </section>

    {showCommerce && (
      <section class="pw-section pw-section--muted pw-section--bordered">
        <div class="pw-container pw-stack pw-stack--lg">
          <div class="pw-section-head">
            <p class="pw-eyebrow">Commerce modules</p>
            <h2 class="pw-title-md">Relevant partner and Amazon.com resources</h2>
            <p>Validated product links are preferred when available. If no validated product matches, PupWiki can safely show Amazon.com search deeplinks with the site tracking tag and clear affiliate disclosure.</p>
          </div>

          <div class="pw-money-grid pw-money-grid--wide">
            <AwinProductSlot
              topicTags={cluster.awinTopicTags}
              pageType="category"
              category={cluster.slug}
              headline={`AWIN partner resources for ${cluster.shortTitle.toLowerCase()}`}
            />

            <AmazonProductSlot
              topicTags={cluster.amazonTopicTags}
              pageType="category"
              pageSlug={`/categories/${cluster.slug}`}
              category={cluster.slug}
              breedLifeStage={cluster.type === 'lifecycle' ? cluster.slug : undefined}
              headline={`Amazon.com searches for ${cluster.shortTitle.toLowerCase()}`}
              limit={3}
            />
          </div>
        </div>
      </section>
    )}

    <section class="pw-section">
      <div class="pw-container pw-stack pw-stack--lg">
        <div class="pw-section-head">
          <p class="pw-eyebrow">Internal linking</p>
          <h2 class="pw-title-md">Related PupWiki clusters</h2>
        </div>

        <div class="pw-grid pw-grid--3">
          {cluster.relatedClusters.map((slug) => (
            <a class="pw-card pw-card--interactive pw-stack partner-rule-card" href={`/categories/${slug}`}>
              <span class="pw-chip pw-chip--accent">Related</span>
              <h3>{slug.replace(/-/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase())}</h3>
              <p>Continue the journey with a related PupWiki topic cluster.</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
