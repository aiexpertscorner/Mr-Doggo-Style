---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AwinProductSlot from '../affiliate/AwinProductSlot.astro';
import AmazonProductSlot from '../amazon/AmazonProductSlot.astro';
import { type ContentCluster } from '../../lib/content/contentClusterConfig';

export interface Props {
  cluster: ContentCluster;
}

const { cluster } = Astro.props;
const SITE = 'https://pupwiki.com';
const canonicalUrl = `${SITE}/categories/${cluster.slug}`;
const keywordCount = [...cluster.primaryKeywords, ...cluster.secondaryKeywords].filter(Boolean).length;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: cluster.title,
    description: cluster.description,
    url: canonicalUrl,
    about: cluster.primaryKeywords.map((name) => ({ '@type': 'Thing', name })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${cluster.title} dog-care topics`,
    itemListElement: [...cluster.primaryKeywords, ...cluster.secondaryKeywords].slice(0, 10).map((name, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name,
    })),
  },
];

const showResources = cluster.monetizationAllowed;
const isSensitive = cluster.claimSensitivity === 'high';
---

<BaseLayout
  title={`${cluster.title} — PupWiki Dog Guides & Resources`}
  description={cluster.description}
  canonicalUrl={canonicalUrl}
  pageType="collection"
  bodyClass="pw-page"
  structuredData={structuredData}
>
  <main class="pw-page">
    <section class="pw-section pw-section--soft">
      <div class="pw-container pw-stack pw-stack--lg">
        <nav class="pw-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a><span aria-hidden="true">›</span><a href="/categories">Categories</a><span aria-hidden="true">›</span><span>{cluster.shortTitle}</span>
        </nav>

        <div class="pw-page-header pw-stack">
          <p class="pw-eyebrow">{cluster.icon} Dog care guide</p>
          <h1 class="pw-title-xl">{cluster.title}</h1>
          <p class="pw-lede">{cluster.description}</p>
        </div>

        <div class="pw-grid pw-grid--3">
          <article class="pw-stat-card"><strong>{keywordCount}</strong><span>Dog-care topics</span></article>
          <article class="pw-stat-card"><strong>{cluster.relatedClusters.length}</strong><span>Related guide areas</span></article>
          <article class="pw-stat-card"><strong>{isSensitive ? 'Vet-aware' : 'Practical'}</strong><span>Reader-first advice</span></article>
        </div>
      </div>
    </section>

    <section class="pw-section">
      <div class="pw-container pw-stack pw-stack--lg">
        <div class="pw-section-head">
          <p class="pw-eyebrow">Start here</p>
          <h2 class="pw-title-md">What to compare before you choose</h2>
          <p>Use this hub to compare dog-care needs, product fit, safety questions, costs, routines, and related PupWiki guides before making a purchase or care decision.</p>
        </div>

        <div class="pw-grid pw-grid--2">
          <article class="pw-card pw-stack partner-rule-card">
            <span class="pw-chip pw-chip--accent">Top questions</span>
            <div class="pw-cluster">
              {cluster.primaryKeywords.map((keyword) => <span class="pw-chip">{keyword}</span>)}
            </div>
          </article>

          <article class="pw-card pw-stack partner-rule-card">
            <span class="pw-chip pw-chip--primary">Helpful subtopics</span>
            <div class="pw-cluster">
              {cluster.secondaryKeywords.slice(0, 10).map((keyword) => <span class="pw-chip">{keyword}</span>)}
            </div>
          </article>
        </div>

        {isSensitive && (
          <aside class="pw-commercial-safe-note">
            <strong>Health note:</strong> product and service resources can be useful for planning, but health, diet, supplement, insurance, and vet-related decisions should stay conservative and be discussed with a qualified professional when needed.
          </aside>
        )}
      </div>
    </section>

    {showResources && (
      <section class="pw-section pw-section--muted pw-section--bordered">
        <div class="pw-container pw-stack pw-stack--lg">
          <div class="pw-section-head">
            <p class="pw-eyebrow">Helpful resources</p>
            <h2 class="pw-title-md">Dog products and brand resources to review</h2>
            <p>These resources are selected for topic fit. Confirm current details, ingredients, sizing, materials, shipping, subscription terms, and availability on the brand or retailer site before buying.</p>
          </div>

          <div class="pw-money-grid pw-money-grid--wide">
            <AwinProductSlot
              topicTags={cluster.awinTopicTags}
              pageType="category"
              category={cluster.slug}
              headline={`Dog resources for ${cluster.shortTitle.toLowerCase()}`}
            />

            <AmazonProductSlot
              topicTags={cluster.amazonTopicTags}
              pageType="category"
              pageSlug={`/categories/${cluster.slug}`}
              category={cluster.slug}
              breedLifeStage={cluster.type === 'lifecycle' ? cluster.slug : undefined}
              headline={`Amazon.com resources for ${cluster.shortTitle.toLowerCase()}`}
              limit={3}
            />
          </div>
        </div>
      </section>
    )}

    <section class="pw-section">
      <div class="pw-container pw-stack pw-stack--lg">
        <div class="pw-section-head">
          <p class="pw-eyebrow">Keep exploring</p>
          <h2 class="pw-title-md">Related PupWiki guides</h2>
        </div>

        <div class="pw-grid pw-grid--3">
          {cluster.relatedClusters.map((slug) => (
            <a class="pw-card pw-card--interactive pw-stack partner-rule-card" href={`/categories/${slug}`}>
              <span class="pw-chip pw-chip--accent">Related</span>
              <h3>{slug.replace(/-/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase())}</h3>
              <p>Continue with another dog-care guide that connects to this topic.</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
