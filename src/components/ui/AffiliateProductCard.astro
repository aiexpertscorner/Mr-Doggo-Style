---
/**
 * AffiliateProductCard.astro
 * Renders a single AWIN affiliate product/partner card using global monetization styles.
 */

export interface Props {
  product: {
    id: string;
    name: string;
    description?: string;
    price?: number;
    currency?: string;
    url: string;
    image?: string;
    merchant?: string;
    category?: string;
    source?: string;
    topicTags?: string[];
    availability?: string;
  };
  headline?: string;
  variant?: 'card' | 'compact';
}

const { product, headline, variant = 'card' } = Astro.props;
const numericPrice = Number(product.price);
const hasPrice = Number.isFinite(numericPrice) && numericPrice > 0;
const formattedPrice = hasPrice ? numericPrice.toFixed(2) : '';
const merchant = product.merchant || 'AWIN partner';
const category = product.category || 'Partner resource';
const description = product.description || `Explore ${merchant} for current products, services, offers, and availability related to this PupWiki guide.`;
const sourceLabel = product.source === 'awin-product-feed' ? 'Live AWIN feed' : product.source === 'awin-program-fallback' ? 'Partner deeplink' : 'Affiliate partner';
const tags = Array.isArray(product.topicTags) ? product.topicTags.slice(0, 4) : [];
const fitText = product.source === 'awin-program-fallback'
  ? `${merchant} is matched as a relevant partner for this page intent. Use the partner site to confirm details, availability, and fit.`
  : `Matched from PupWiki affiliate data using page topic, category, and product/service intent.`;
---

{variant === 'card' ? (
  <article class="affiliate-card">
    {headline && <div class="affiliate-card__headline">{headline}</div>}

    <div class="affiliate-card__media">
      {product.image ? (
        <img src={product.image} alt={product.name} width="150" height="130" loading="lazy" decoding="async" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
      ) : null}
      <span class="affiliate-card__fallback" style={product.image ? 'display:none' : ''}>🐾</span>
    </div>

    <div class="affiliate-card__body">
      <span class="affiliate-card__eyebrow">{sourceLabel} · {merchant}</span>
      <h3 class="affiliate-card__title">{product.name}</h3>
      <p class="affiliate-card__desc">{description.slice(0, 165)}{description.length > 165 ? '…' : ''}</p>

      <div class="affiliate-card__fit">
        <strong>Why this appears here</strong>
        <span>{fitText}</span>
      </div>

      <div class="affiliate-card__chips" aria-label="Partner fit tags">
        <span class="pw-chip pw-chip--accent">{category}</span>
        {tags.map((tag) => <span class="pw-chip">{String(tag).replace(/[-_]+/g, ' ')}</span>)}
      </div>

      <div class="affiliate-card__footer">
        <span class="affiliate-card__price">{hasPrice ? `$${formattedPrice}` : 'Partner site'}</span>
        <a href={product.url} rel="nofollow sponsored noopener" target="_blank" class="affiliate-card__cta" data-affiliate-merchant={merchant} data-affiliate-product={product.id} data-affiliate-placement="card">
          View partner offer →
        </a>
      </div>

      <p class="affiliate-card__note">Affiliate link — PupWiki may earn from qualifying partner links at no extra cost to you.</p>
    </div>
  </article>
) : (
  <article class="affiliate-card affiliate-card--compact">
    <div class="affiliate-card__media">
      {product.image ? <img src={product.image} alt={product.name} width="56" height="56" loading="lazy" decoding="async" onerror="this.style.display='none'" /> : <span class="affiliate-card__fallback">🐾</span>}
    </div>

    <div class="affiliate-card__body">
      <span class="affiliate-card__eyebrow">{sourceLabel}</span>
      <h3 class="affiliate-card__title">{product.name}</h3>
      <p class="affiliate-card__desc">{merchant}</p>
    </div>

    <div class="affiliate-card__footer">
      <a href={product.url} rel="nofollow sponsored noopener" target="_blank" class="affiliate-card__cta" data-affiliate-merchant={merchant} data-affiliate-product={product.id} data-affiliate-placement="compact">View →</a>
    </div>
  </article>
)}
