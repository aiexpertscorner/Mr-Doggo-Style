---
/**
 * AffiliateProductCard.astro
 * Renders a single partner product/resource card using global monetization styles.
 * Visible copy must stay dog-related and reader-facing. Network/tracking language
 * belongs in data/code only, not in rendered page copy.
 */

export interface Props {
  product: {
    id: string;
    name: string;
    description?: string;
    price?: number;
    currency?: string;
    url: string;
    image?: string;
    merchant?: string;
    category?: string;
    source?: string;
    topicTags?: string[];
    availability?: string;
  };
  headline?: string;
  variant?: 'card' | 'compact';
}

const { product, headline, variant = 'card' } = Astro.props;
const numericPrice = Number(product.price);
const hasPrice = Number.isFinite(numericPrice) && numericPrice > 0;
const formattedPrice = hasPrice ? numericPrice.toFixed(2) : '';
const merchant = product.merchant || 'Brand';
const category = product.category || 'Dog care resource';
const description = product.description || `Visit ${merchant} to review current products, services, offers, and availability.`;
const eyebrow = `Dog resource · ${merchant}`;
const tags = Array.isArray(product.topicTags) ? product.topicTags.slice(0, 4) : [];
const fitText = `Review current details, availability, shipping, sizing, ingredients or materials, and whether it fits your dog’s needs.`;
---

{variant === 'card' ? (
  <article class="affiliate-card">
    {headline && <div class="affiliate-card__headline">{headline}</div>}

    <div class="affiliate-card__media">
      {product.image ? (
        <img src={product.image} alt={product.name} width="150" height="130" loading="lazy" decoding="async" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
      ) : null}
      <span class="affiliate-card__fallback" style={product.image ? 'display:none' : ''}>🐾</span>
    </div>

    <div class="affiliate-card__body">
      <span class="affiliate-card__eyebrow">{eyebrow}</span>
      <h3 class="affiliate-card__title">{product.name}</h3>
      <p class="affiliate-card__desc">{description.slice(0, 165)}{description.length > 165 ? '…' : ''}</p>

      <div class="affiliate-card__fit">
        <strong>Before you click</strong>
        <span>{fitText}</span>
      </div>

      <div class="affiliate-card__chips" aria-label="Resource fit tags">
        <span class="pw-chip pw-chip--accent">{category}</span>
        {tags.map((tag) => <span class="pw-chip">{String(tag).replace(/[-_]+/g, ' ')}</span>)}
      </div>

      <div class="affiliate-card__footer">
        <span class="affiliate-card__price">{hasPrice ? `$${formattedPrice}` : 'Brand site'}</span>
        <a href={product.url} rel="nofollow sponsored noopener" target="_blank" class="affiliate-card__cta" data-partner-merchant={merchant} data-partner-product={product.id} data-partner-placement="card">
          Review on brand site →
        </a>
      </div>

      <p class="affiliate-card__note">PupWiki may earn from some product and brand links at no extra cost to you.</p>
    </div>
  </article>
) : (
  <article class="affiliate-card affiliate-card--compact">
    <div class="affiliate-card__media">
      {product.image ? <img src={product.image} alt={product.name} width="56" height="56" loading="lazy" decoding="async" onerror="this.style.display='none'" /> : <span class="affiliate-card__fallback">🐾</span>}
    </div>

    <div class="affiliate-card__body">
      <span class="affiliate-card__eyebrow">Dog resource</span>
      <h3 class="affiliate-card__title">{product.name}</h3>
      <p class="affiliate-card__desc">{merchant}</p>
    </div>

    <div class="affiliate-card__footer">
      <a href={product.url} rel="nofollow sponsored noopener" target="_blank" class="affiliate-card__cta" data-partner-merchant={merchant} data-partner-product={product.id} data-partner-placement="compact">Review →</a>
    </div>
  </article>
)}
