---
import {
  SITE_NAME,
  SITE_URL,
  SITE_EMAIL,
  SITE_TAGLINE,
  SITE_DESCRIPTION,
  AFFILIATE_DISCLOSURE_SHORT,
  BREEDS_PAGE_PATH,
  DOG_NAMES_PAGE_PATH,
  COST_CALCULATOR_PAGE_PATH,
  ABOUT_PAGE_PATH,
  METHODOLOGY_PAGE_PATH,
  DISCLOSURE_PAGE_PATH,
  PRIVACY_PAGE_PATH,
  CONTACT_PAGE_PATH,
  SITE_STATS,
} from '../../lib/site-config';

const year = new Date().getFullYear();

const trustStats = [
  `${SITE_STATS?.breedCount ?? 277} breed guides`,
  `${SITE_STATS?.mixedBreedCount ?? 75} mixed breeds`,
  `${SITE_STATS?.dogNameCount ?? 5000}+ dog names`,
  'Cost and care tools',
];

const navSections = [
  {
    title: 'Discover',
    links: [
      { label: 'All Breeds',    href: BREEDS_PAGE_PATH },
      { label: 'Mixed Breeds',  href: BREEDS_PAGE_PATH },
      { label: 'Dog Names',     href: DOG_NAMES_PAGE_PATH },
      { label: 'Blog',          href: '/blog' },
    ],
  },
  {
    title: 'Care & Planning',
    links: [
      { label: 'Health & Care',    href: '/categories/health' },
      { label: 'Training',         href: '/categories/training' },
      { label: 'Cost & Insurance', href: COST_CALCULATOR_PAGE_PATH },
      { label: 'Reviews',          href: '/blog' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About',       href: ABOUT_PAGE_PATH },
      { label: 'Methodology', href: METHODOLOGY_PAGE_PATH },
      { label: 'Disclosure',  href: DISCLOSURE_PAGE_PATH },
      { label: 'Privacy',     href: PRIVACY_PAGE_PATH },
      { label: 'Contact',     href: CONTACT_PAGE_PATH },
    ],
  },
];
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__inner">

      <div class="site-footer__grid">

        <!-- Brand column -->
        <div class="site-footer__brand">
          <a href="/" aria-label={`${SITE_NAME} home`}>
            <img
              src="/Pupwiki-logo.png"
              alt={SITE_NAME}
              class="site-brand__logo"
              loading="lazy"
              decoding="async"
            />
          </a>

          <p class="site-footer__tagline">{SITE_TAGLINE}</p>
          <p class="site-footer__desc">{SITE_DESCRIPTION}</p>

          <div class="site-footer__stats">
            {trustStats.map(item => (
              <span class="badge">{item}</span>
            ))}
          </div>

          <div class="site-footer__promise">
            <p class="site-footer__promise-label">Editorial promise</p>
            <p class="site-footer__promise-text">
              PupWiki gives dog parents practical, transparent guidance for breed research,
              care decisions, cost planning, and everyday dog ownership.
            </p>
          </div>
        </div>

        <!-- Nav columns -->
        {navSections.map(section => (
          <div>
            <h3 class="site-footer__nav-title">{section.title}</h3>
            <ul class="site-footer__nav-list">
              {section.links.map(link => (
                <li>
                  <a href={link.href} class="site-footer__nav-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}

      </div>

      <!-- Bottom bar -->
      <div class="site-footer__bottom">
        <div>
          <p class="site-footer__disclosure">{AFFILIATE_DISCLOSURE_SHORT}</p>
          <p class="site-footer__disclaimer">
            PupWiki content is for educational and informational purposes only and does not replace
            professional veterinary, behavioral, legal, or financial advice.
          </p>
        </div>
        <div class="site-footer__meta">
          <a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a>
          <p>&copy; {year} {SITE_NAME}. All rights reserved.</p>
          <a href={SITE_URL}>{SITE_URL.replace(/^https?:\/\//, '')}</a>
        </div>
      </div>

    </div>
  </div>
</footer>
