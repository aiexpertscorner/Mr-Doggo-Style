---
/**
 * Footer.astro — Site footer, light theme.
 */

const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__grid">

    <!-- Brand column -->
    <div>
      <a href="/" class="site-footer__brand-name" aria-label="PupWiki home">
        <img src="/Logo-pupwiki.png" alt="PupWiki" height="40" style="height:40px;width:auto;display:block" loading="lazy" />
      </a>
      <p class="site-footer__tagline">
        The authoritative dog wiki — breed guides, names, costs, and gear.
        We earn small commissions from qualifying purchases — this never influences our editorial independence.
      </p>
      <div class="site-footer__trust">
        <span class="site-footer__trust-item">277 Breeds</span>
        <span class="site-footer__trust-sep">·</span>
        <span class="site-footer__trust-item">125+ Products</span>
        <span class="site-footer__trust-sep">·</span>
        <span class="site-footer__trust-item">No paid placements</span>
      </div>
    </div>

    <!-- Categories -->
    <div>
      <h3 class="site-footer__heading">Categories</h3>
      <ul class="site-footer__links">
        <li><a href="/categories/dog-food"  class="site-footer__link">Dog Food</a></li>
        <li><a href="/categories/toys"      class="site-footer__link">Toys &amp; Gear</a></li>
        <li><a href="/categories/health"    class="site-footer__link">Dog Health</a></li>
        <li><a href="/categories/training"  class="site-footer__link">Training</a></li>
        <li><a href="/categories/grooming"  class="site-footer__link">Grooming</a></li>
        <li><a href="/categories/beds"      class="site-footer__link">Beds &amp; Sleep</a></li>
      </ul>
    </div>

    <!-- Resources -->
    <div>
      <h3 class="site-footer__heading">Explore</h3>
      <ul class="site-footer__links">
        <li><a href="/blog/top-picks-2026"  class="site-footer__link">Top Picks 2026</a></li>
        <li><a href="/breeds"               class="site-footer__link">All Breed Guides</a></li>
        <li><a href="/blog"                 class="site-footer__link">Expert Blog</a></li>
        <li><a href="/dog-names"            class="site-footer__link">Dog Name Generator</a></li>
        <li><a href="/cost-calculator"      class="site-footer__link">Cost Calculator</a></li>
      </ul>
    </div>

    <!-- Company -->
    <div>
      <h3 class="site-footer__heading">Company</h3>
      <ul class="site-footer__links">
        <li><a href="/about"        class="site-footer__link">About Us</a></li>
        <li><a href="/how-we-test"  class="site-footer__link">How We Review</a></li>
        <li><a href="/disclosure"   class="site-footer__link">Affiliate Policy</a></li>
        <li><a href="/privacy"      class="site-footer__link">Privacy Policy</a></li>
        <li><a href="/contact"      class="site-footer__link">Contact</a></li>
      </ul>
    </div>

  </div>

  <div class="site-footer__bottom">
    <p class="site-footer__disclaimer">
      As an Amazon Associate and Chewy affiliate, PupWiki earns from qualifying purchases at no extra cost to you.
      Our editorial scores are determined before affiliate relationships are considered.
    </p>
    <p class="site-footer__copy">© {year} PupWiki</p>
  </div>
</footer>
