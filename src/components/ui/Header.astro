---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'All Breeds',   href: '/breeds',             isActive: currentPath === '/breeds' || currentPath.startsWith('/breeds/') },
  { label: 'Dog Names',    href: '/dog-names',           isActive: currentPath === '/dog-names' || currentPath.startsWith('/dog-names/') },
  { label: 'Health & Care',href: '/categories/health',   isActive: currentPath.startsWith('/categories/health') },
  { label: 'Training',     href: '/categories/training', isActive: currentPath.startsWith('/categories/training') },
  { label: 'Reviews',      href: '/blog',                isActive: currentPath === '/blog' || currentPath.startsWith('/blog/') },
  { label: 'Breed Quiz',   href: '/breed-quiz',          isActive: currentPath === '/breed-quiz' },
];

const utilityLinks = [
  { label: 'Methodology', href: '/methodology', isActive: currentPath === '/methodology' },
  { label: 'About',       href: '/about',       isActive: currentPath === '/about' },
];

const primaryCta = {
  label: 'Cost & Insurance',
  href:  '/cost-calculator',
  isActive: currentPath === '/cost-calculator' || currentPath.startsWith('/cost-calculator/'),
};

const allMobileLinks = [...navLinks, ...utilityLinks];
---

<header class="site-header">
  <div class="container">
    <div class="site-header__inner">

      <!-- Brand -->
      <a href="/" class="site-brand" aria-label="PupWiki home">
        <img
          src="/Pupwiki-logo.png"
          alt="PupWiki"
          class="site-brand__logo"
          loading="eager"
          decoding="async"
        />
        <div class="site-brand__meta">
          <span class="site-brand__name">PupWiki</span>
          <span class="site-brand__tagline">Trusted guidance for dog parents</span>
        </div>
      </a>

      <!-- Desktop navigation -->
      <nav class="site-nav" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            aria-current={link.isActive ? 'page' : undefined}
            class="site-nav__link"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop right: utility links + CTA -->
      <div class="site-header__actions">
        {utilityLinks.map(link => (
          <a
            href={link.href}
            aria-current={link.isActive ? 'page' : undefined}
            class="site-nav__link site-nav__link--utility"
          >
            {link.label}
          </a>
        ))}
        <a
          href={primaryCta.href}
          aria-current={primaryCta.isActive ? 'page' : undefined}
          class="btn btn--primary btn--sm"
        >
          {primaryCta.label}
        </a>
      </div>

      <!-- Mobile toggle -->
      <button
        type="button"
        class="site-header__toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-nav-toggle
      >
        <svg data-icon-open  class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg data-icon-close class="hidden h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

    </div>
  </div>

  <!-- Mobile panel -->
  <div id="mobile-nav" class="mobile-panel hidden" data-mobile-nav>
    <div class="container">
      <div class="mobile-panel__inner">

        <div class="mobile-panel__brand-note">
          <p class="mobile-panel__brand-label">PupWiki</p>
          <p class="mobile-panel__brand-sub">Research breeds, compare costs, and care smarter.</p>
        </div>

        <nav class="mobile-panel__nav" aria-label="Mobile navigation">
          {allMobileLinks.map(link => (
            <a
              href={link.href}
              aria-current={link.isActive ? 'page' : undefined}
              class="mobile-panel__link"
            >
              {link.label}
            </a>
          ))}
        </nav>

        <div class="mobile-panel__cta">
          <a href={primaryCta.href} class="btn btn--primary" style="width:100%;justify-content:center;">
            {primaryCta.label}
          </a>
          <a href="/contact" class="btn btn--outline" style="width:100%;justify-content:center;">
            Contact
          </a>
        </div>

        <div class="mobile-panel__legal">
          <a href="/disclosure">Disclosure</a>
          <a href="/privacy">Privacy</a>
          <a href="/methodology">Methodology</a>
        </div>

      </div>
    </div>
  </div>
</header>

<script>
  const toggle   = document.querySelector('[data-nav-toggle]');
  const nav      = document.querySelector('[data-mobile-nav]');
  const iconOpen  = document.querySelector('[data-icon-open]');
  const iconClose = document.querySelector('[data-icon-close]');

  if (toggle && nav && iconOpen && iconClose) {
    const closeMenu = () => {
      nav.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('overflow-hidden');
    };
    const openMenu = () => {
      nav.classList.remove('hidden');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.classList.add('overflow-hidden');
    };

    toggle.addEventListener('click', () => {
      nav.classList.contains('hidden') ? openMenu() : closeMenu();
    });
    nav.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && !nav.classList.contains('hidden')) closeMenu();
    });
  }
</script>
