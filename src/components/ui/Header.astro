---
const navLinks = [
  { label: 'Dog Food',   href: '/categories/dog-food' },
  { label: 'Toys',       href: '/categories/toys' },
  { label: 'Beds',       href: '/categories/beds' },
  { label: 'Health',     href: '/categories/health' },
  { label: 'Grooming',   href: '/categories/grooming' },
  { label: 'All Breeds', href: '/breeds' },
  { label: 'Dog Names',  href: '/dog-names' },
];
---

<header class="bg-white sticky top-0 z-50 shadow-sm" style="border-bottom:1px solid #f5e8d0">
  <div class="max-w-7xl mx-auto px-4 sm:px-5 lg:px-6">
    <div class="flex items-center justify-between h-[72px] lg:h-[84px] gap-4">

      <!-- Logo -->
      <a
        href="/"
        class="flex items-center flex-shrink-0 min-w-0"
        aria-label="Mr. Doggo Style home"
      >
        <img
          src="/Logo-pupwiki.png"
          alt="Mr. Doggo Style"
          class="block h-10 sm:h-11 lg:h-14 w-auto object-contain max-w-[180px] sm:max-w-[220px] lg:max-w-[320px]"
          loading="eager"
          decoding="async"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center justify-center gap-5 xl:gap-6 flex-1 px-6 font-sans text-sm font-medium">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="transition-colors hover:text-bark whitespace-nowrap"
            style="color:#64748b"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-3 flex-shrink-0">
        <a
          href="/how-we-test"
          class="font-sans text-xs font-medium transition-colors hover:underline whitespace-nowrap"
          style="color:#94a3b8"
        >
          How we test
        </a>
        <a
          href="/blog"
          class="font-sans text-sm font-bold text-white px-4 py-2 rounded-xl btn-bark whitespace-nowrap"
          style="background:linear-gradient(135deg,#a0621c,#7d4a10)"
        >
          All Reviews →
        </a>
      </div>

      <!-- Mobile toggle -->
      <button
        id="menu-toggle"
        class="lg:hidden p-2 rounded-lg transition-colors flex-shrink-0"
        style="color:#64748b"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        type="button"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div
    id="mobile-nav"
    class="hidden lg:hidden bg-white px-4 pb-5"
    style="border-top:1px solid #f5e8d0"
  >
    <div class="pt-3 space-y-0.5">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block py-2.5 font-sans text-sm font-medium transition-colors hover:text-bark"
          style="color:#475569;border-bottom:1px solid #fdf8f0"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="pt-4 flex flex-col gap-2">
      <a
        href="/blog"
        class="block text-center font-sans text-sm font-bold text-white py-3 rounded-xl btn-bark"
        style="background:linear-gradient(135deg,#a0621c,#7d4a10)"
      >
        All Reviews →
      </a>

      <div class="flex justify-center gap-4 mt-2 flex-wrap">
        <a href="/about" class="font-sans text-xs" style="color:#94a3b8">About</a>
        <a href="/how-we-test" class="font-sans text-xs" style="color:#94a3b8">How we test</a>
        <a href="/disclosure" class="font-sans text-xs" style="color:#94a3b8">Disclosure</a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  if (toggle && nav && iconOpen && iconClose) {
    toggle.addEventListener('click', () => {
      const isOpen = !nav.classList.contains('hidden');
      nav.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden', !isOpen);
      iconClose.classList.toggle('hidden', isOpen);
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>