---
const shopLinks = [
  { label: 'Dog Food', href: '/categories/dog-food' },
  { label: 'Toys', href: '/categories/toys' },
  { label: 'Beds', href: '/categories/beds' },
  { label: 'Health', href: '/categories/health' },
  { label: 'Grooming', href: '/categories/grooming' },
];

const researchLinks = [
  { label: 'All Breeds', href: '/breeds' },
  { label: 'Dog Names', href: '/dog-names' },
  { label: 'Cost Calculator', href: '/cost-calculator' },
  { label: 'Breed Quiz', href: '/breed-quiz' },
];
---

<header
  class="sticky top-0 z-50 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/90 shadow-sm"
  style="border-bottom:1px solid var(--color-surface-warm)"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-5 lg:px-6">
    <div class="flex items-center justify-between h-[82px] sm:h-[88px] lg:h-[96px] gap-4 lg:gap-6">

      <!-- Logo -->
      <a
        href="/"
        class="flex items-center flex-shrink-0"
        aria-label="PupWiki home"
      >
        <img
          src="/Logo-pupwiki.png"
          alt="PupWiki"
          class="block h-14 sm:h-14 lg:h-16 w-auto object-contain"
          loading="eager"
          decoding="async"
        />
      </a>

      <!-- Desktop Nav -->
      <nav
        class="hidden lg:flex items-center justify-center gap-1 flex-1 px-4 xl:px-8 font-sans text-sm font-medium"
        aria-label="Main navigation"
      >
        {shopLinks.map((link) => (
          <a
            href={link.href}
            class="transition-colors duration-200 whitespace-nowrap hover:text-[#0b153d] px-2.5 py-1"
            style="color:#64748b"
          >
            {link.label}
          </a>
        ))}

        <!-- Separator -->
        <span class="mx-2 h-4 w-px inline-block flex-shrink-0" style="background:var(--color-border)"></span>

        <!-- Research group label -->
        <span class="font-sans text-xs font-bold uppercase tracking-widest mr-1 whitespace-nowrap" style="color:var(--color-accent)">Research:</span>

        {researchLinks.map((link) => (
          <a
            href={link.href}
            class="transition-colors duration-200 whitespace-nowrap hover:text-[#0b153d] px-2 py-1"
            style="color:#64748b"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop secondary CTA -->
      <div class="hidden lg:flex items-center gap-3 xl:gap-4 flex-shrink-0">
        <a
          href="/how-we-test"
          class="font-sans text-xs xl:text-sm font-medium transition-colors hover:text-[#0b153d] whitespace-nowrap"
          style="color:#94a3b8"
        >
          How we test
        </a>

        <a
          href="/cost-calculator"
          class="inline-flex items-center justify-center font-sans text-sm font-bold text-white px-5 py-2.5 rounded-xl whitespace-nowrap transition-transform duration-200 hover:-translate-y-[1px]"
          style="background:linear-gradient(135deg,#0D9488,#0F766E);box-shadow:0 8px 18px rgba(13,148,136,0.22)"
        >
          Cost Calculator
        </a>
      </div>

      <!-- Mobile toggle -->
      <button
        id="menu-toggle"
        class="lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-xl transition-colors flex-shrink-0"
        style="color:#64748b;background:#fff"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        type="button"
      >
        <svg
          id="icon-open"
          class="w-7 h-7"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>

        <svg
          id="icon-close"
          class="w-7 h-7 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.2"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div
    id="mobile-nav"
    class="hidden lg:hidden bg-white"
    style="border-top:1px solid var(--color-surface-warm)"
  >
    <div class="px-4 pb-5 pt-3">

      <!-- Shop section -->
      <p class="font-sans text-xs font-bold uppercase tracking-widest mb-2 mt-1" style="color:var(--color-muted)">Shop</p>
      <nav class="space-y-0.5 mb-4" aria-label="Shop navigation">
        {shopLinks.map((link) => (
          <a
            href={link.href}
            class="block py-3 font-sans text-[15px] font-medium transition-colors hover:text-[#0b153d]"
            style="color:#475569;border-bottom:1px solid var(--color-surface-warm)"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Research section -->
      <p class="font-sans text-xs font-bold uppercase tracking-widest mb-2" style="color:var(--color-accent)">Research</p>
      <nav class="space-y-0.5 mb-4" aria-label="Research navigation">
        {researchLinks.map((link) => (
          <a
            href={link.href}
            class="block py-3 font-sans text-[15px] font-medium transition-colors hover:text-[#0b153d]"
            style="color:#475569;border-bottom:1px solid var(--color-surface-warm)"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="pt-2 flex flex-col gap-2.5">
        <a
          href="/cost-calculator"
          class="block text-center font-sans text-sm font-bold text-white py-3.5 rounded-xl transition-transform duration-200"
          style="background:linear-gradient(135deg,#0D9488,#0F766E);box-shadow:0 8px 18px rgba(13,148,136,0.22)"
        >
          Cost Calculator
        </a>

        <a
          href="/how-we-test"
          class="block text-center font-sans text-sm font-semibold py-3 rounded-xl"
          style="color:#0b153d;background:#f8fafc;border:1px solid #e2e8f0"
        >
          How we test
        </a>

        <div class="flex justify-center gap-4 mt-2 flex-wrap">
          <a href="/about" class="font-sans text-xs" style="color:#94a3b8">About</a>
          <a href="/disclosure" class="font-sans text-xs" style="color:#94a3b8">Disclosure</a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  if (toggle && nav && iconOpen && iconClose) {
    toggle.addEventListener('click', () => {
      const willOpen = nav.classList.contains('hidden');

      nav.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden', willOpen);
      iconClose.classList.toggle('hidden', !willOpen);
      toggle.setAttribute('aria-expanded', String(willOpen));
    });

    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        nav.classList.add('hidden');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
