---
export interface Props { name:string; asin:string; price?:number; rating?:number; label?:string; note?:string; image?:string; tag?:string; }
const { name, asin, price, rating=4.7, label="TOP PICK", note, image, tag="aiexpertscorn-20" } = Astro.props;
const url = `https://www.amazon.com/dp/${asin}/?tag=${tag}`;
---
<div style="border:2px solid #CCFF00;background:rgba(204,255,0,.06);box-shadow:4px 4px 0 #CCFF00;padding:1rem 1.25rem;margin:2.5rem 0;display:flex;flex-wrap:wrap;align-items:center;gap:1rem">
  <a href={url} rel="nofollow sponsored" target="_blank"
     style="display:block;background:#fff;flex-shrink:0;width:72px;height:72px;overflow:hidden;border:1px solid rgba(255,255,255,.1)">
    {image ? (
      <img src={image} alt={name} loading="lazy" width="72" height="72"
           style="width:100%;height:100%;object-fit:contain;padding:.15rem;transition:transform .2s;display:block"
           onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform=''"/>
    ) : (
      <span style="font-size:2rem;display:flex;align-items:center;justify-content:center;height:100%">🐾</span>
    )}
  </a>
  <div style="flex:1;min-width:160px">
    <span style="font-family:'Archivo Black',sans-serif;font-size:.6rem;text-transform:uppercase;letter-spacing:.1em;color:#CCFF00">👑 {label}</span>
    <p style="font-family:'Archivo Black',sans-serif;font-size:.9rem;text-transform:uppercase;color:#F0F0F0;margin:.15rem 0 .15rem;line-height:1.2">{name}</p>
    <div style="display:flex;gap:.5rem;align-items:center">
      <span style="color:#CCFF00;font-size:.75rem">{'★'.repeat(Math.round(rating))}</span>
      {price && <span style="color:#CCFF00;font-family:'Archivo Black',sans-serif;font-size:.85rem">${price.toFixed(2)}</span>}
    </div>
    {note && <p style="font-family:'Barlow Condensed',sans-serif;font-size:.78rem;color:#888;margin:.2rem 0 0">{note}</p>}
  </div>
  <a href={url} rel="nofollow sponsored" target="_blank"
     style="flex-shrink:0;background:#CCFF00;color:#0A0A0A;font-family:'Archivo Black',sans-serif;font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;padding:.7rem 1.25rem;border:2px solid #0A0A0A;box-shadow:3px 3px 0 #0A0A0A;text-decoration:none;white-space:nowrap;transition:all .1s"
     onmouseover="this.style.transform='translate(-2px,-2px)';this.style.boxShadow='5px 5px 0 #0A0A0A'"
     onmouseout="this.style.transform='';this.style.boxShadow='3px 3px 0 #0A0A0A'">
    CHECK PRICE →
  </a>
</div>
