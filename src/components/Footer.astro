---
const year = new Date().getFullYear();
const links = [
  { heading: "REVIEWS", items: [
    { label: "Dog Food", href: "/categories/dog-food" },
    { label: "Toys", href: "/categories/toys" },
    { label: "Beds", href: "/categories/beds" },
    { label: "Training", href: "/categories/training" },
    { label: "Grooming", href: "/categories/grooming" },
  ]},
  { heading: "TOP PICKS", items: [
    { label: "Best Large Breed Food", href: "/blog/best-dog-food-large-breeds" },
    { label: "Indestructible Toys", href: "/blog/best-indestructible-dog-toys" },
    { label: "Orthopedic Beds", href: "/blog/best-dog-beds-orthopedic" },
    { label: "GPS Trackers", href: "/blog/best-gps-dog-trackers" },
    { label: "No-Pull Harnesses", href: "/blog/best-no-pull-harnesses" },
  ]},
  { heading: "INFO", items: [
    { label: "About", href: "/about" },
    { label: "Disclosure", href: "/disclosure" },
    { label: "Breed Guides", href: "/breeds" },
    { label: "RSS Feed", href: "/rss.xml" },
  ]},
];
---
<footer style="background:var(--midnight);border-top:2px solid rgba(255,255,255,0.08);margin-top:4rem">

  <!-- Disclosure bar -->
  <div style="background:rgba(204,255,0,0.08);border-bottom:1px solid rgba(204,255,0,0.2);padding:.6rem 1.5rem;text-align:center">
    <span style="font-family:'Space Mono',monospace;font-size:.65rem;color:var(--lime);text-transform:uppercase;letter-spacing:.06em">
      AFFILIATE DISCLOSURE: As an Amazon Associate, MR. DOGGO STYLE earns from qualifying purchases.
      <a href="/disclosure" style="color:inherit;margin-left:.5rem;text-decoration:underline">FULL POLICY →</a>
    </span>
  </div>

  <div style="max-width:1400px;margin:0 auto;padding:3rem 1.5rem">
    <div style="display:grid;grid-template-columns:1fr;gap:2.5rem;margin-bottom:3rem">

      <!-- Brand -->
      <div>
        <div style="font-family:'Anton',sans-serif;font-size:3rem;color:var(--offwhite);text-transform:uppercase;line-height:0.9;margin-bottom:1rem">
          MR.<span style="color:var(--lime)">DOGGO</span><br/>STYLE
        </div>
        <p style="font-family:'Barlow Condensed',sans-serif;font-size:1rem;color:var(--ash);max-width:280px;line-height:1.5">
          Zero paid placements. Zero fake reviews. Just unfiltered truth for dog owners who give a damn.
        </p>
        <div style="display:flex;gap:.5rem;margin-top:1.25rem;flex-wrap:wrap">
          <span class="sticker sticker-lime">277 BREEDS</span>
          <span class="sticker sticker-white">HONEST REVIEWS</span>
          <span class="sticker sticker-black">NO ADS</span>
        </div>
      </div>

      <!-- Links grid -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:2rem">
        {links.map(col => (
          <div>
            <h4 style="font-family:'Archivo Black',sans-serif;font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;color:var(--lime);margin:0 0 1rem">{col.heading}</h4>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem">
              {col.items.map(item => (
                <li>
                  <a href={item.href} style="font-family:'Barlow Condensed',sans-serif;font-size:.95rem;color:var(--ash);text-decoration:none;text-transform:uppercase;letter-spacing:.03em;transition:color .15s"
                     onmouseover="this.style.color='var(--offwhite)'" onmouseout="this.style.color='var(--ash)'">
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top:1px solid rgba(255,255,255,.08);padding-top:1.5rem;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem">
      <span style="font-family:'Space Mono',monospace;font-size:.65rem;color:var(--ash)">© {year} MR. DOGGO STYLE. ALL RIGHTS RESERVED.</span>
      <span style="font-family:'Space Mono',monospace;font-size:.65rem;color:var(--ash)">PRICES SUBJECT TO CHANGE.</span>
    </div>
  </div>
</footer>
