---
const year = new Date().getFullYear();

const CATEGORIES = [
  { label: 'Dog Food',    href: '/categories/dog-food' },
  { label: 'Dog Toys',    href: '/categories/toys' },
  { label: 'Dog Beds',    href: '/categories/beds' },
  { label: 'Grooming',    href: '/categories/grooming' },
  { label: 'Supplements', href: '/categories/supplements' },
  { label: 'Training',    href: '/categories/training' },
  { label: 'Health',      href: '/categories/health' },
  { label: 'Smart Tech',  href: '/categories/smart-tech' },
];

const POPULAR = [
  { label: 'Labrador Retriever',    href: '/breeds/labrador-retriever' },
  { label: 'German Shepherd',       href: '/breeds/german-shepherd-dog' },
  { label: 'Golden Retriever',      href: '/breeds/golden-retriever' },
  { label: 'French Bulldog',        href: '/breeds/french-bulldog' },
  { label: 'All 277 Breeds →',     href: '/breeds' },
];

const COMPANY = [
  { label: 'About Us',            href: '/about' },
  { label: 'How We Test',         href: '/how-we-test' },
  { label: 'Affiliate Disclosure',href: '/disclosure' },
  { label: 'Privacy Policy',      href: '/privacy' },
  { label: 'Contact',             href: '/contact' },
  { label: 'Dog Names',           href: '/dog-names' },
  { label: 'RSS Feed',            href: '/rss.xml' },
];
---

<footer class="mt-16" style="background:#1e293b;color:#94a3b8">

  <!-- Affiliate disclosure bar -->
  <div class="text-center py-2.5 px-4 font-sans text-xs" style="background:var(--color-accent);color:white">
    <strong>Affiliate Disclosure:</strong> As an Amazon Associate and through selected AWIN affiliate programs, PupWiki earns from qualifying purchases.
    <a href="/disclosure" class="underline ml-1 hover:text-amber-200 transition-colors">Learn more →</a>
  </div>

  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 py-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4 group">
          <span class="text-2xl">🐾</span>
          <span class="font-display font-bold text-xl text-white" style="font-family:'Playfair Display',Georgia,serif">PupWiki</span>
        </a>
        <p class="font-sans text-sm leading-relaxed mb-5" style="color:#64748b">
          Expert-tested dog product reviews. Honest, breed-specific, and data-driven.
        </p>
        <!-- Trust badges -->
        <div class="flex flex-wrap gap-2">
          {[
            '277 Breeds',
            'No paid placements',
            'Updated 2026',
          ].map(badge => (
            <span class="font-sans text-xs font-semibold px-2.5 py-1 rounded-full" style="background:#334155;color:#94a3b8">
              ✓ {badge}
            </span>
          ))}
        </div>
      </div>

      <!-- Categories -->
      <div>
        <h4 class="font-sans font-bold text-xs uppercase tracking-widest mb-4 text-white">Categories</h4>
        <ul class="space-y-2.5 font-sans text-sm">
          {CATEGORIES.map(link => (
            <li>
              <a href={link.href} class="transition-colors hover:text-amber-400" style="color:#94a3b8">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Popular breeds -->
      <div>
        <h4 class="font-sans font-bold text-xs uppercase tracking-widest mb-4 text-white">Popular Breeds</h4>
        <ul class="space-y-2.5 font-sans text-sm">
          {POPULAR.map(link => (
            <li>
              <a href={link.href} class="transition-colors hover:text-amber-400" style="color:#94a3b8">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-sans font-bold text-xs uppercase tracking-widest mb-4 text-white">Company</h4>
        <ul class="space-y-2.5 font-sans text-sm">
          {COMPANY.map(link => (
            <li>
              <a href={link.href} class="transition-colors hover:text-amber-400" style="color:#94a3b8">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col sm:flex-row justify-between items-center gap-3" style="border-top:1px solid #334155">
      <div class="font-sans text-xs" style="color:#475569">
        © {year} PupWiki. All rights reserved.
      </div>
      <div class="font-sans text-xs text-center" style="color:#475569">
        Amazon prices and availability are subject to change. Always verify before purchasing.
      </div>
      <div class="flex gap-4 font-sans text-xs">
        <a href="/privacy" class="hover:text-white transition-colors" style="color:#475569">Privacy</a>
        <a href="/disclosure" class="hover:text-white transition-colors" style="color:#475569">Disclosure</a>
        <a href="/contact" class="hover:text-white transition-colors" style="color:#475569">Contact</a>
      </div>
    </div>
  </div>

</footer>
