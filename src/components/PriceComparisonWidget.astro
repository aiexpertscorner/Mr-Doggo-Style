---
import { ENABLE_CHEWY } from '../lib/site-config';

export interface Props {
  name: string;
  asin: string;
  amazonPrice?: number;
  chewyPrice?: number;
  petcoPrice?: number;
  chewySlug?: string;
  tag?: string;
}

const { name, asin, amazonPrice, chewyPrice, petcoPrice, chewySlug, tag = 'aiexpertscorn-20' } = Astro.props;

const allRows = [
  { store: 'Amazon', url: `https://www.amazon.com/dp/${asin}/?tag=${tag}`, price: amazonPrice, note: 'Prime shipping', color: '#FF9900' },
  ...(ENABLE_CHEWY ? [{
    store: 'Chewy',
    url: chewySlug ? `https://www.chewy.com/${chewySlug}` : `https://www.chewy.com/s?query=${encodeURIComponent(name)}`,
    price: chewyPrice,
    note: 'Autoship savings',
    color: '#00a3e0',
  }] : []),
  { store: 'Petco', url: `https://www.petco.com/shop/en/petcostore/search?query=${encodeURIComponent(name)}`, price: petcoPrice, note: 'In-store pickup', color: '#0073c9' },
];

const lowestIdx = allRows.reduce((li, r, i, a) => (r.price && (!a[li].price || r.price < a[li].price)) ? i : li, 0);
---

<div style="border:1px solid var(--color-border);border-radius:var(--radius-xl);overflow:hidden;margin:2rem 0">
  <div style="background:var(--color-bg-muted);padding:.5rem 1rem;font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--color-muted)">
    💰 Price comparison — {name}
  </div>
  {allRows.map((r, i) => (
    <div style={`display:flex;align-items:center;gap:1rem;padding:.75rem 1rem;border-top:1px solid var(--color-border);${i === lowestIdx && r.price ? 'background:var(--color-accent-subtle)' : ''}`}>
      <span style={`font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:${r.color};width:60px;flex-shrink:0`}>{r.store}</span>
      <div style="flex:1;display:flex;flex-wrap:wrap;align-items:center;gap:.4rem">
        {r.price
          ? <span style={`font-size:1rem;font-weight:700;${i === lowestIdx ? 'color:var(--color-success)' : 'color:var(--color-heading)'}`}>${r.price.toFixed(2)}</span>
          : <span style="font-size:.85rem;color:var(--color-muted)">Check price</span>
        }
        {i === lowestIdx && r.price && (
          <span style="font-size:.55rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;background:var(--color-success);color:#fff;padding:.15rem .45rem;border-radius:var(--radius-sm)">Best price</span>
        )}
        <span style={`font-size:.55rem;text-transform:uppercase;letter-spacing:.04em;color:${r.color};opacity:.7`}>{r.note}</span>
      </div>
      <a href={r.url} rel="nofollow" target="_blank"
        style="font-size:.7rem;font-weight:700;padding:.4rem .8rem;border-radius:var(--radius-lg);background:var(--color-primary);color:#fff;text-decoration:none;flex-shrink:0">
        Shop →
      </a>
    </div>
  ))}
  <div style="padding:.4rem .9rem;font-size:.55rem;color:var(--color-muted);text-transform:uppercase;border-top:1px solid var(--color-border)">
    Prices approximate — verify on retailer site
  </div>
</div>
