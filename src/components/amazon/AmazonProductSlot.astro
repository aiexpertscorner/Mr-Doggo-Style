---
import { matchAmazonProducts, type AmazonPlacementContext } from '../../lib/amazon/matchAmazonProducts';
import AmazonBadge from '../ui/AmazonBadge.astro';

let allProducts: any[] = [];
try {
  const imported = await import('../../data/amazon-products.json');
  allProducts = Array.isArray(imported.default) ? imported.default : [];
} catch {}

export interface Props extends AmazonPlacementContext {
  headline?: string;
  eyebrow?: string;
  note?: string;
  variant?: 'rail' | 'compact';
}

const {
  headline = 'Useful Amazon finds for this guide',
  eyebrow = 'Amazon.com',
  note = 'Amazon links are affiliate links. Product details can change, so confirm fit and availability on Amazon before buying.',
  variant = 'rail',
  limit = variant === 'compact' ? 2 : 3,
  ...context
} = Astro.props;

const products = matchAmazonProducts(allProducts, { ...context, limit });
---

{products.length > 0 && (
  <section class:list={['amazon-slot', variant === 'compact' && 'amazon-slot--compact']} aria-label={headline}>
    <div class="amazon-slot__header">
      <p>{eyebrow}</p>
      <h2>{headline}</h2>
      <span>{note}</span>
    </div>

    <div class="amazon-slot__grid">
      {products.map((product) => (
        <article class="amazon-slot__card">
          <div class="amazon-slot__meta">
            <span>{product.categoryLabel || product.categoryGroup || 'Dog supplies'}</span>
            {product.brand && <strong>{product.brand}</strong>}
          </div>

          <h3>{product.name}</h3>

          {product.recommendedPlacement && (
            <p>{product.recommendedPlacement}</p>
          )}

          {Array.isArray(product.topicTags) && product.topicTags.length > 0 && (
            <div class="amazon-slot__tags" aria-label="Product fit tags">
              {product.topicTags.slice(0, 3).map((tag) => (
                <span>{String(tag).replace(/[-_]+/g, ' ')}</span>
              ))}
            </div>
          )}

          <div class="amazon-slot__actions">
            <AmazonBadge href={product.amazonAffiliateUrl} size={variant === 'compact' ? 'sm' : 'md'} />
          </div>
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .amazon-slot {
    display: grid;
    gap: var(--space-4);
    min-width: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background:
      linear-gradient(180deg, #ffffff 0%, var(--color-bg-muted) 100%);
    padding: var(--space-4);
    box-shadow: var(--shadow-card);
  }

  .amazon-slot__header {
    display: grid;
    gap: var(--space-2);
  }

  .amazon-slot__header p {
    width: fit-content;
    margin: 0;
    border: 1px solid rgba(255, 153, 0, 0.34);
    border-radius: var(--radius-full);
    background: #fff8e8;
    padding: 0.4rem 0.64rem;
    color: #8a5300;
    font-size: var(--text-xs);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: 1;
    text-transform: uppercase;
  }

  .amazon-slot__header h2 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: var(--weight-black);
    letter-spacing: 0;
    line-height: var(--leading-snug);
  }

  .amazon-slot__header span,
  .amazon-slot__card p {
    color: var(--color-body-soft);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .amazon-slot__grid {
    display: grid;
    gap: var(--space-3);
  }

  .amazon-slot__card {
    display: grid;
    gap: var(--space-3);
    min-width: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: #ffffff;
    padding: var(--space-4);
  }

  .amazon-slot__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    justify-content: space-between;
  }

  .amazon-slot__meta span,
  .amazon-slot__meta strong {
    color: var(--color-muted);
    font-size: var(--text-xs);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: 1.3;
    text-transform: uppercase;
  }

  .amazon-slot__meta strong {
    color: var(--color-heading);
    letter-spacing: 0;
    text-transform: none;
  }

  .amazon-slot__card h3 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--weight-black);
    letter-spacing: 0;
    line-height: var(--leading-snug);
  }

  .amazon-slot__card p {
    margin: 0;
  }

  .amazon-slot__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .amazon-slot__tags span {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: var(--color-bg-soft);
    padding: 0.38rem 0.58rem;
    color: var(--color-body-soft);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    line-height: 1;
    text-transform: capitalize;
  }

  .amazon-slot__actions {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-top: var(--space-1);
  }

  @media (min-width: 720px) {
    .amazon-slot:not(.amazon-slot--compact) .amazon-slot__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
