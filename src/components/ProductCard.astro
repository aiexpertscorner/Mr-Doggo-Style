---
export interface Props {
  name: string; asin: string; price?: number;
  chewy_id?: string; chewy_price?: number;
  rating?: number; reviewCount?: number; ourScore?: number;
  verdict?: string; pros?: string[]; cons?: string[];
  badge?: string; features?: string[];
  image?: string; local_image?: string;
  brand_logo?: string; brand_slug?: string; brand_name?: string;
  tag?: string;
}
const {
  name, asin, price, chewy_id, chewy_price, rating = 4.5,
  reviewCount, ourScore, verdict, pros = [], cons = [],
  badge, features = [], image, local_image,
  brand_logo, brand_slug, brand_name, tag = 'aiexpertscorn-20',
} = Astro.props;

const amazonUrl = `https://www.amazon.com/dp/${asin}/?tag=${tag}`;
const chewyUrl  = chewy_id ? `https://www.chewy.com/dp/${chewy_id}?ref=impact` : null;
const stars = Math.round(rating);
const scoreColor = ourScore ? (ourScore>=9?'#16a34a':ourScore>=7?'#d97706':'#dc2626') : '#6b7280';
const showChewyBetter  = chewyUrl && chewy_price && price && chewy_price < price;
const showAmazonBetter = price && chewy_price && price < chewy_price;
const imgSrc = local_image || (image?.includes('media-amazon') ? image : null);
---

<div class="not-prose bg-white rounded-2xl border overflow-hidden shadow-sm hover:shadow-md transition-shadow" style="border-color:var(--color-surface-warm)">
  {badge && <div class="font-sans text-xs font-bold uppercase tracking-wider text-center py-1.5 text-white" style="background:#f59e0b">{badge}</div>}
  <div class="p-5">
    <div class="flex items-start gap-4 mb-4">
      <!-- Image -->
      <div class="flex-shrink-0 w-20 h-20 rounded-xl flex items-center justify-center overflow-hidden" style="background:linear-gradient(135deg,var(--color-surface-warm),#fef3c7)">
        {imgSrc ? (
          <img src={imgSrc} alt={name} width="80" height="80" loading="lazy" class="w-full h-full object-contain"
            onerror="this.style.display='none';this.nextSibling.style.display='block'" />
        ) : null}
        {brand_logo ? (
          <img src={brand_logo} alt={brand_name||''} width="60" height="60" loading="lazy"
            class="object-contain max-h-14 opacity-80"
            style={imgSrc ? 'display:none' : ''}
            onerror="this.style.display='none'" />
        ) : null}
        {!imgSrc && !brand_logo && <span style="font-size:2rem">🐾</span>}
      </div>
      <!-- Meta -->
      <div class="flex-1 min-w-0">
        <h3 class="font-display font-semibold leading-snug mb-1" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b;font-size:0.95rem">{name}</h3>
        {brand_slug && brand_name && (
          <a href={`/brands/${brand_slug}`} class="font-sans text-xs hover:underline mb-1 block" style="color:var(--color-accent)">by {brand_name} →</a>
        )}
        <div class="flex flex-wrap items-center gap-2 font-sans text-sm">
          <span style="color:#f59e0b">{'★'.repeat(stars)}{'☆'.repeat(5-stars)}</span>
          <span style="color:#6b7280">{rating.toFixed(1)}{reviewCount ? ` (${reviewCount.toLocaleString()})` : ''}</span>
        </div>
      </div>
      {ourScore && (
        <div class="text-center flex-shrink-0">
          <div class="font-sans font-black text-2xl leading-none" style={`color:${scoreColor}`}>{ourScore}<span class="text-xs font-normal" style="color:#9ca3af">/10</span></div>
          <div class="font-sans text-xs mt-0.5" style="color:#9ca3af">Score</div>
        </div>
      )}
    </div>

    {verdict && <p class="font-sans text-sm italic mb-3 pl-3" style="color:#374151;border-left:3px solid #fbbf24">{verdict}</p>}

    {features.length > 0 && (
      <ul class="mb-3 space-y-1">
        {features.slice(0,3).map(f => <li class="font-sans text-sm flex items-start gap-2" style="color:#374151"><span style="color:#f59e0b;flex-shrink:0">✓</span>{f}</li>)}
      </ul>
    )}

    {(pros.length > 0 || cons.length > 0) && (
      <div class="grid grid-cols-2 gap-2 mb-3 font-sans text-xs">
        {pros.length > 0 && <div class="rounded-xl p-3" style="background:#f0fdf4"><p class="font-bold mb-1" style="color:#15803d">✅ Pros</p>{pros.slice(0,3).map(p=><p style="color:#166534" class="mb-0.5">{p}</p>)}</div>}
        {cons.length > 0 && <div class="rounded-xl p-3" style="background:#fef2f2"><p class="font-bold mb-1" style="color:#b91c1c">❌ Cons</p>{cons.slice(0,3).map(c=><p style="color:#991b1b" class="mb-0.5">{c}</p>)}</div>}
      </div>
    )}

    <!-- Price comparison row -->
    {(price || chewy_price) && (
      <div class="flex items-center justify-around mb-3 p-2.5 rounded-xl" style="background:var(--color-bg-soft);border:1px solid var(--color-surface-warm)">
        {price && (
          <div class="text-center">
            <p class="font-sans text-xs" style="color:#94a3b8">Amazon</p>
            <p class="font-sans font-black text-lg" style={`color:${showAmazonBetter?'#16a34a':'#1e293b'}`}>${price.toFixed(2)}{showAmazonBetter&&<span class="font-sans text-xs ml-1" style="color:#16a34a"> ✓ Best</span>}</p>
          </div>
        )}
        {price && chewy_price && <span class="font-sans text-xs" style="color:#94a3b8">vs</span>}
        {chewy_price && (
          <div class="text-center">
            <p class="font-sans text-xs" style="color:#94a3b8">Chewy</p>
            <p class="font-sans font-black text-lg" style={`color:${showChewyBetter?'#16a34a':'#1e293b'}`}>${chewy_price.toFixed(2)}{showChewyBetter&&<span class="font-sans text-xs ml-1" style="color:#16a34a"> ✓ Best</span>}</p>
          </div>
        )}
      </div>
    )}

    <!-- Dual CTA -->
    <div class={chewyUrl ? 'grid grid-cols-2 gap-2' : ''}>
      {chewyUrl && (
        <a href={chewyUrl} rel="nofollow sponsored" target="_blank"
          class="block text-center font-sans font-bold text-sm py-2.5 rounded-xl text-white transition-all"
          style="background:linear-gradient(135deg,#0052cc,#003d99)">
          🔵 Chewy{showChewyBetter ? ' ✓' : ''}
        </a>
      )}
      {asin && asin !== 'SUBSCRIPTION' && (
        <a href={amazonUrl} rel="nofollow sponsored" target="_blank"
          class="block text-center font-sans font-bold text-sm py-2.5 rounded-xl text-white transition-all btn-amazon"
          style="background:linear-gradient(135deg,#FF9900,#e88700)">
          🟡 Amazon{showAmazonBetter ? ' ✓' : ''}
        </a>
      )}
      {asin === 'SUBSCRIPTION' && (
        <a href={chewyUrl || '#'} rel="nofollow sponsored" target="_blank"
          class="block text-center font-sans font-bold text-sm py-2.5 rounded-xl text-white col-span-2"
          style="background:linear-gradient(135deg,var(--color-accent),var(--color-accent-hover))">
          View subscription →
        </a>
      )}
    </div>
  </div>
</div>
