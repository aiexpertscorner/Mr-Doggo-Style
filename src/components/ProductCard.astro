---
// ProductCard.astro
// Clean version: just reads product.image from products.json
// Affiliate tag lives here only — never in the data
export interface Props {
  name: string;
  asin: string;
  price?: number;
  rating?: number;
  reviewCount?: number;
  image?: string;
  features?: string[];
  badge?: string;
  badgeStyle?: 'lime' | 'white' | 'red' | 'black';
  tag?: string;
}
const {
  name, asin, price, rating = 4.5, reviewCount,
  image, features = [], badge, badgeStyle = 'lime',
  tag = "aiexpertscorn-20",
} = Astro.props;

const url   = `https://www.amazon.com/dp/${asin}/?tag=${tag}`;
const stars = Math.round(rating);
---
<div
  style="background:#222;border:2px solid rgba(255,255,255,.1);display:flex;flex-direction:column;position:relative;transition:transform .15s,box-shadow .15s,border-color .15s"
  onmouseover="this.style.transform='translate(-2px,-2px)';this.style.boxShadow='4px 4px 0 #CCFF00';this.style.borderColor='#CCFF00'"
  onmouseout="this.style.transform='';this.style.boxShadow='';this.style.borderColor='rgba(255,255,255,.1)'">

  {badge && (
    <div style="position:absolute;top:-8px;right:12px;z-index:10">
      <span style={`display:inline-block;font-family:'Archivo Black',sans-serif;font-size:.6rem;text-transform:uppercase;letter-spacing:.1em;padding:.2rem .6rem;border:2px solid;transform:rotate(-2deg);${
        badgeStyle === 'lime'  ? 'background:#CCFF00;color:#0A0A0A;border-color:#0A0A0A' :
        badgeStyle === 'red'   ? 'background:#FF3B3B;color:#fff;border-color:#fff' :
        badgeStyle === 'white' ? 'background:#F0F0F0;color:#0A0A0A;border-color:#0A0A0A' :
                                 'background:#0A0A0A;color:#CCFF00;border-color:#CCFF00'
      }`}>{badge}</span>
    </div>
  )}

  <!-- Product image -->
  <a href={url} rel="nofollow sponsored" target="_blank"
     style="display:block;background:#fff;overflow:hidden;border-bottom:2px solid rgba(255,255,255,.08)">
    {image ? (
      <img
        src={image}
        alt={name}
        loading="lazy"
        width="500" height="500"
        style="width:100%;aspect-ratio:1;object-fit:contain;padding:.75rem;transition:transform .25s,filter .25s;display:block"
        onmouseover="this.style.transform='scale(1.06)';this.style.filter='saturate(1.3) contrast(1.05)'"
        onmouseout="this.style.transform='';this.style.filter=''"
      />
    ) : (
      <div style="width:100%;aspect-ratio:1;background:#111;display:flex;align-items:center;justify-content:center">
        <span style="font-size:2.5rem">🐾</span>
      </div>
    )}
  </a>

  <div style="padding:1rem;flex:1;display:flex;flex-direction:column;gap:.5rem">
    <h3 style="font-family:'Archivo Black',sans-serif;font-size:.82rem;text-transform:uppercase;color:#F0F0F0;margin:0;line-height:1.2">{name}</h3>

    <div style="display:flex;align-items:center;justify-content:space-between;gap:.4rem">
      <div style="display:flex;align-items:center;gap:.25rem">
        <span style="color:#CCFF00;font-size:.78rem;letter-spacing:-.04em">{'★'.repeat(stars)}{'☆'.repeat(5-stars)}</span>
        <span style="font-family:'Space Mono',monospace;font-size:.58rem;color:#888">{rating.toFixed(1)}</span>
        {reviewCount && <span style="font-family:'Space Mono',monospace;font-size:.52rem;color:#666">({(reviewCount/1000).toFixed(0)}K)</span>}
      </div>
      {price && <span style="font-family:'Archivo Black',sans-serif;font-size:.92rem;color:#CCFF00">${price.toFixed(2)}</span>}
    </div>

    {features.length > 0 && (
      <ul style="margin:0;padding:0;list-style:none;flex:1;display:flex;flex-direction:column;gap:.22rem">
        {features.slice(0,3).map(f=>(
          <li style="font-family:'Barlow Condensed',sans-serif;font-size:.83rem;color:#aaa;display:flex;align-items:start;gap:.35rem">
            <span style="color:#CCFF00;flex-shrink:0;margin-top:1px;font-size:.7rem">→</span>{f}
          </li>
        ))}
      </ul>
    )}

    <a href={url} rel="nofollow sponsored" target="_blank"
       style="display:block;background:#CCFF00;color:#0A0A0A;font-family:'Archivo Black',sans-serif;font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;padding:.72rem;border:2px solid #0A0A0A;box-shadow:3px 3px 0 #0A0A0A;text-decoration:none;text-align:center;transition:transform .1s,box-shadow .1s;margin-top:auto"
       onmouseover="this.style.transform='translate(-2px,-2px)';this.style.boxShadow='5px 5px 0 #0A0A0A'"
       onmouseout="this.style.transform='';this.style.boxShadow='3px 3px 0 #0A0A0A'">
      CHECK PRICE ON AMAZON →
    </a>
  </div>
</div>
