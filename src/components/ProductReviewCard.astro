---
export interface Props {
  name:string; asin:string; price?:number; rating?:number; reviewCount?:number;
  ourScore?:number; verdict?:string; pros?:string[]; cons?:string[];
  badge?:string; features?:string[]; image?:string; tag?:string;
}
const {
  name,asin,price,rating=4.5,reviewCount,ourScore,verdict,
  pros=[],cons=[],badge,features=[],image,tag="aiexpertscorn-20"
} = Astro.props;
const url   = `https://www.amazon.com/dp/${asin}/?tag=${tag}`;
const stars = Math.round(rating);
const sc    = ourScore ? (ourScore>=9?'#CCFF00':ourScore>=7?'#FFD600':'#FF3B3B') : '#888';
const schema = JSON.stringify({
  "@context":"https://schema.org","@type":"Review",
  "itemReviewed":{"@type":"Product","name":name,"offers":price?{"@type":"Offer","price":price,"priceCurrency":"USD","url":url}:undefined},
  "reviewRating":{"@type":"Rating","ratingValue":ourScore||rating,"bestRating":10,"worstRating":1},
  "author":{"@type":"Organization","name":"Mr. Doggo Style"},"reviewBody":verdict
});
---
<div style="background:#222;border:2px solid rgba(255,255,255,.1);overflow:hidden;transition:border-color .15s"
     onmouseover="this.style.borderColor='#CCFF00'" onmouseout="this.style.borderColor='rgba(255,255,255,.1)'">
  <script type="application/ld+json" set:html={schema}/>
  {badge && <div style="background:#CCFF00;padding:.3rem 1rem;font-family:'Archivo Black',sans-serif;font-size:.62rem;text-transform:uppercase;letter-spacing:.1em;color:#0A0A0A">{badge}</div>}
  <div style="padding:1.1rem;display:flex;flex-direction:column;gap:.65rem">
    <div style="display:flex;align-items:flex-start;gap:.9rem">
      <a href={url} rel="nofollow sponsored" target="_blank"
         style="display:block;background:#fff;flex-shrink:0;width:72px;height:72px;overflow:hidden;border:1px solid rgba(255,255,255,.08)">
        {image ? (
          <img src={image} alt={name} loading="lazy" width="72" height="72"
               style="width:100%;height:100%;object-fit:contain;padding:.2rem;transition:transform .2s;display:block"
               onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform=''"/>
        ) : (
          <div style="width:100%;height:100%;background:#111;display:flex;align-items:center;justify-content:center">
            <span style="font-size:1.8rem">🐾</span>
          </div>
        )}
      </a>
      <div style="flex:1">
        <h3 style="font-family:'Archivo Black',sans-serif;font-size:.88rem;text-transform:uppercase;color:#F0F0F0;margin:0 0 .3rem;line-height:1.2">{name}</h3>
        <div style="display:flex;flex-wrap:wrap;align-items:center;gap:.4rem">
          <span style="color:#CCFF00;font-size:.78rem">{'★'.repeat(stars)}</span>
          <span style="font-family:'Space Mono',monospace;font-size:.58rem;color:#888">{rating.toFixed(1)}{reviewCount&&` (${reviewCount.toLocaleString()})`}</span>
          {price&&<span style="font-family:'Archivo Black',sans-serif;color:#CCFF00">${price.toFixed(2)}</span>}
        </div>
      </div>
      {ourScore&&(
        <div style="text-align:center;flex-shrink:0">
          <div style={`font-family:'Anton',sans-serif;font-size:1.6rem;color:${sc};line-height:1`}>{ourScore}<span style="font-size:.7rem;color:#666">/10</span></div>
          <div style="font-family:'Space Mono',monospace;font-size:.52rem;color:#666;text-transform:uppercase">SCORE</div>
        </div>
      )}
    </div>
    {verdict&&<p style="font-family:'Barlow Condensed',sans-serif;font-size:.92rem;color:#AAA;border-left:3px solid #CCFF00;padding:.25rem .65rem;margin:0;font-style:italic">"{verdict}"</p>}
    {features.length>0&&(
      <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:.2rem">
        {features.slice(0,3).map(f=>(
          <li style="font-family:'Barlow Condensed',sans-serif;font-size:.88rem;color:#AAA;display:flex;gap:.35rem">
            <span style="color:#CCFF00;flex-shrink:0;font-size:.7rem">→</span>{f}
          </li>
        ))}
      </ul>
    )}
    {(pros.length>0||cons.length>0)&&(
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.4rem">
        {pros.length>0&&<div style="background:rgba(204,255,0,.06);border:1px solid rgba(204,255,0,.2);padding:.5rem .65rem">
          <p style="font-family:'Archivo Black',sans-serif;font-size:.58rem;text-transform:uppercase;color:#CCFF00;margin:0 0 .3rem">✓ PROS</p>
          {pros.slice(0,3).map(p=><p style="font-family:'Barlow Condensed',sans-serif;font-size:.78rem;color:#AAA;margin:0 0 .12rem">{p}</p>)}
        </div>}
        {cons.length>0&&<div style="background:rgba(255,59,59,.06);border:1px solid rgba(255,59,59,.2);padding:.5rem .65rem">
          <p style="font-family:'Archivo Black',sans-serif;font-size:.58rem;text-transform:uppercase;color:#FF3B3B;margin:0 0 .3rem">✗ CONS</p>
          {cons.slice(0,3).map(c=><p style="font-family:'Barlow Condensed',sans-serif;font-size:.78rem;color:#AAA;margin:0 0 .12rem">{c}</p>)}
        </div>}
      </div>
    )}
    <a href={url} rel="nofollow sponsored" target="_blank"
       style="display:block;background:#CCFF00;color:#0A0A0A;font-family:'Archivo Black',sans-serif;font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;padding:.75rem;border:2px solid #0A0A0A;box-shadow:3px 3px 0 #0A0A0A;text-decoration:none;text-align:center;transition:all .1s"
       onmouseover="this.style.transform='translate(-2px,-2px)';this.style.boxShadow='5px 5px 0 #0A0A0A'"
       onmouseout="this.style.transform='';this.style.boxShadow='3px 3px 0 #0A0A0A'">
      CHECK PRICE ON AMAZON →
    </a>
  </div>
</div>
