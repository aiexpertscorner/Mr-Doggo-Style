---
import { getCollection } from 'astro:content';
export interface Props { currentTags?: string[]; currentSlug?: string; }
const { currentTags = [], currentSlug = '' } = Astro.props;
const all = await getCollection('blog');
const related = all
  .filter(p => `/blog/${p.slug}` !== currentSlug && (currentTags.some(t => (p.data.tags||[]).includes(t))))
  .slice(0, 3);
const posts = related.length >= 2 ? related : all.filter(p => `/blog/${p.slug}` !== currentSlug).slice(0, 3);
---
{posts.length > 0 && (
  <div class="related-posts">
    <h3 class="related-posts__heading">
      MORE DROPS <span class="related-posts__heading-accent">YOU'LL WANT</span>
    </h3>
    <div class="related-posts__grid">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="related-post-card">
          <div class="related-post-card__thumb">🐾</div>
          <div class="related-post-card__body">
            <span class="related-post-card__category">{post.data.category}</span>
            <h4 class="related-post-card__title">{post.data.title}</h4>
          </div>
        </a>
      ))}
    </div>
  </div>
)}

<style>
  .related-posts {
    margin-top: var(--space-12);
  }

  .related-posts__heading {
    font-family: var(--sw-font-display);
    font-size: var(--text-3xl);
    text-transform: uppercase;
    color: var(--sw-text);
    margin: 0 0 var(--space-5);
    letter-spacing: var(--tracking-snug);
  }

  .related-posts__heading-accent {
    color: var(--sw-accent);
  }

  /* min(220px, 100%) prevents column overflow on narrow viewports */
  .related-posts__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(220px, 100%), 1fr));
    gap: var(--space-4);
  }

  .related-post-card {
    display: block;
    background: var(--sw-bg);
    border: 2px solid var(--sw-border);
    text-decoration: none;
    overflow: hidden;
    transition:
      border-color var(--transition-base),
      transform var(--transition-base),
      box-shadow var(--transition-base);
  }

  .related-post-card:hover {
    border-color: var(--sw-accent);
    transform: translate(-2px, -2px);
    box-shadow: var(--sw-shadow-hard);
  }

  .related-post-card__thumb {
    background: var(--sw-bg-raised);
    height: var(--space-20);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-4xl);
    border-bottom: 1px solid var(--sw-chip-bg);
  }

  .related-post-card__body {
    padding: var(--space-3);
  }

  .related-post-card__category {
    font-family: var(--sw-font-mono);
    font-size: var(--sw-text-label);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--sw-accent);
  }

  .related-post-card__title {
    font-family: var(--sw-font-heading);
    font-size: var(--text-xs);
    text-transform: uppercase;
    color: var(--sw-text);
    margin: var(--space-1) 0 0;
    line-height: var(--leading-tight);
  }
</style>
