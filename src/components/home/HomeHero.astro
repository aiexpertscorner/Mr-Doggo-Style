---
/**
 * PupWiki homepage hero
 * Prop-driven and safe to wire up later through homepage-config/getHomepageData.
 */

export interface Cta {
  label: string;
  href: string;
}

export interface HeroStat {
  value: string;
  label: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  accent?: string;
  subtitle?: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  imageSrc?: string;
  imageAlt?: string;
  heroCardEyebrow?: string;
  heroCardText?: string;
  trustItems?: string[];
  stats?: HeroStat[];
}

const {
  id = 'home-hero',
  eyebrow = 'Trusted guidance for dog parents',
  title = 'Research breeds, plan costs, and care smarter.',
  accent = 'All in one place.',
  subtitle = 'PupWiki helps dog parents compare breeds and mixed breeds, understand health and care needs, explore training and lifestyle guidance, and make more confident ownership decisions.',
  primaryCta = { label: 'Explore Breeds', href: '/breeds' },
  secondaryCta = { label: 'Dog Names', href: '/dog-names' },
  imageSrc = 'https://images.unsplash.com/photo-1544568100-847a948585b9?w=1200&q=80&fit=crop',
  imageAlt = 'Happy dog owner with a golden retriever',
  heroCardEyebrow = 'Data-backed dog guidance',
  heroCardText = 'Breed profiles, mixed breeds, cost tools, care guidance, and practical next steps.',
  trustItems = ['277 breed guides', '75 mixed breeds', '5,000+ dog names', 'Cost and care tools'],
  stats = [],
} = Astro.props;

const hasStats = Array.isArray(stats) && stats.length > 0;
---

<section 
  id={id} 
  class="relative w-full overflow-hidden"
  style="background: var(--hero-bg);"
>
  <div class="mx-auto px-[var(--content-padding-mobile)] py-12 sm:px-[var(--content-padding)] sm:py-16 lg:px-[var(--content-padding-wide)] lg:py-[var(--section-padding)]" style="max-width: var(--max-width-wide);">
    <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16">
      
      {/* Content Kolom */}
      <div class="flex flex-col justify-center">
        {/* Eyebrow */}
        <div class="mb-6 flex">
          <span class="inline-flex items-center rounded-[var(--radius-full)] border border-[var(--color-border-accent)] bg-[var(--color-accent-subtle)] px-4 py-1.5 text-[var(--text-xs)] font-[var(--weight-bold)] uppercase tracking-[var(--tracking-label)] text-[var(--color-accent-active)]">
            {eyebrow}
          </span>
        </div>

        {/* Heading */}
        <h1 class="max-w-3xl text-[var(--text-h1)] font-[var(--weight-black)] leading-[var(--leading-tight)] tracking-[var(--tracking-tight)] text-[var(--hero-heading)]">
          {title}
          <span class="mt-1 block text-[var(--hero-heading-accent)]">{accent}</span>
        </h1>

        {/* Subtitle */}
        <p class="mt-6 max-w-[var(--max-width-prose)] text-[var(--text-lg)] font-[var(--weight-normal)] leading-[var(--leading-relaxed)] text-[var(--hero-body)]">
          {subtitle}
        </p>

        {/* CTAs */}
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a
            href={primaryCta.href}
            class="inline-flex items-center justify-center rounded-[var(--radius-xl)] bg-[var(--button-primary-bg)] px-6 py-3.5 text-[var(--text-md)] font-[var(--weight-semi)] text-[var(--button-primary-text)] shadow-[var(--shadow-cta)] transition-all hover:-translate-y-[2px] hover:bg-[var(--button-primary-bg-hover)] active:bg-[var(--button-primary-bg-active)]"
          >
            {primaryCta.label}
          </a>

          <a
            href={secondaryCta.href}
            class="inline-flex items-center justify-center rounded-[var(--radius-xl)] border border-[var(--button-outline-border)] bg-[var(--button-outline-bg)] px-6 py-3.5 text-[var(--text-md)] font-[var(--weight-semi)] text-[var(--button-outline-text)] transition-all hover:bg-[var(--button-outline-bg-hover)]"
          >
            {secondaryCta.label}
          </a>
        </div>

        {/* Trust Items */}
        {trustItems.length > 0 && (
          <div class="mt-10 flex flex-wrap gap-2.5">
            {trustItems.map((item) => (
              <span class="inline-flex items-center rounded-[var(--radius-full)] border border-[var(--color-border)] bg-[var(--color-surface)] px-3.5 py-1.5 text-[var(--text-sm)] font-[var(--weight-medium)] text-[var(--color-body-soft)]">
                <svg class="mr-1.5 h-4 w-4 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </span>
            ))}
          </div>
        )}

        {/* Stats */}
        {hasStats && (
          <div class="mt-10 grid gap-4 sm:grid-cols-3">
            {stats.map((stat) => (
              <div class="rounded-[var(--card-radius)] border border-[var(--card-border)] bg-[var(--card-bg)] p-5 shadow-[var(--card-shadow)] transition-shadow hover:shadow-[var(--card-shadow-hover)]">
                <p class="text-[var(--text-3xl)] font-[var(--weight-bold)] tracking-[var(--tracking-tight)] text-[var(--color-heading)]">{stat.value}</p>
                <p class="mt-1 text-[var(--text-sm)] font-[var(--weight-medium)] text-[var(--color-body-soft)]">{stat.label}</p>
              </div>
            ))}
          </div>
        )}
      </div>

      {/* Image Kolom */}
      <div class="relative w-full lg:ml-auto">
        {/* Main Image */}
        <div class="relative overflow-hidden rounded-[var(--radius-3xl)] border border-[var(--color-border-primary)] shadow-[var(--shadow-xl)]">
          <img
            src={imageSrc}
            alt={imageAlt}
            class="block h-[400px] w-full object-cover transition-transform duration-700 hover:scale-105 sm:h-[500px] lg:h-[600px]"
            loading="eager"
            decoding="async"
          />
          {/* Subtiele inner-shadow voor betere blending */}
          <div class="pointer-events-none absolute inset-0 rounded-[var(--radius-3xl)] ring-1 ring-inset ring-black/5"></div>
        </div>

        {/* Floating Hero Card */}
        <div class="relative mt-6 z-10 rounded-[var(--card-radius)] border border-[var(--color-border-warm)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-primary)] transition-transform hover:-translate-y-1 sm:absolute sm:-bottom-8 sm:-left-8 sm:mt-0 sm:max-w-[320px]">
          <div class="mb-3 flex items-center gap-2">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-accent-soft)] text-[var(--color-accent-active)]">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            </div>
            <p class="text-[var(--text-xs)] font-[var(--weight-bold)] uppercase tracking-[var(--tracking-label)] text-[var(--color-heading-soft)]">
              {heroCardEyebrow}
            </p>
          </div>
          <p class="text-[var(--text-sm)] font-[var(--weight-medium)] leading-[var(--leading-normal)] text-[var(--color-body)]">
            {heroCardText}
          </p>
        </div>
      </div>
      
    </div>
  </div>
</section>
