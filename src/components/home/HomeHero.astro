---
/**
 * PupWiki homepage hero
 * Token-driven, mobile-first, warm editorial design.
 * Uses global CSS variables from tokens.css.
 */

export interface Cta {
  label: string;
  href: string;
}

export interface HeroStat {
  value: string;
  label: string;
}

export interface HeroFeature {
  icon?: string;
  title: string;
  text: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  accent?: string;
  subtitle?: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  imageSrc?: string;
  imageAlt?: string;
  heroCardEyebrow?: string;
  heroCardText?: string;
  trustItems?: string[];
  features?: HeroFeature[];
  stats?: HeroStat[];
}

const {
  id = 'home-hero',
  eyebrow = 'Trusted guidance for dog parents',
  title = 'Research breeds, plan care, and raise a happier dog.',
  accent = 'All in one trusted place.',
  subtitle = 'PupWiki helps dog parents compare breeds and mixed breeds, understand care and health considerations, explore training guidance, and make smarter ownership decisions.',
  primaryCta = { label: 'Explore Dog Breeds', href: '/breeds' },
  secondaryCta = { label: 'Compare Breeds', href: '/breed-comparison' },
  imageSrc = 'https://images.unsplash.com/photo-1544568100-847a948585b9?w=1400&q=82&fit=crop',
  imageAlt = 'Happy golden retriever puppy outdoors',
  heroCardEyebrow = 'Data-backed dog guidance',
  heroCardText = 'Breed profiles, mixed breeds, cost tools, care guidance, and practical next steps for real dog owners.',
  trustItems = ['277 breed guides', '75 mixed breeds', '5,000+ dog names', 'Cost and care tools'],
  features = [
    {
      icon: '📖',
      title: 'Expert Advice',
      text: 'Practical dog guidance you can trust.',
    },
    {
      icon: '🐾',
      title: 'Breed Profiles',
      text: 'Research traits, care needs, and fit.',
    },
    {
      icon: '🧡',
      title: 'Happy Living',
      text: 'Training, care, lifestyle, and health basics.',
    },
    {
      icon: '🔎',
      title: 'Smart Tools',
      text: 'Compare, plan, and decide with confidence.',
    },
  ],
  stats = [],
} = Astro.props;

const hasStats = Array.isArray(stats) && stats.length > 0;
const hasTrustItems = Array.isArray(trustItems) && trustItems.length > 0;
const hasFeatures = Array.isArray(features) && features.length > 0;
---

<section id={id} class="pw-hero" aria-labelledby={`${id}-title`}>
  <div class="pw-hero__inner">
    <div class="pw-hero__grid">
      <div class="pw-hero__content">
        <p class="pw-hero__eyebrow">
          {eyebrow}
        </p>

        <h1 id={`${id}-title`} class="pw-hero__title">
          {title}
          <span>{accent}</span>
        </h1>

        <p class="pw-hero__subtitle">
          {subtitle}
        </p>

        <div class="pw-hero__actions" aria-label="Primary homepage actions">
          <a href={primaryCta.href} class="pw-hero__button pw-hero__button--primary">
            <span>{primaryCta.label}</span>
            <span class="pw-hero__button-icon" aria-hidden="true">→</span>
          </a>

          <a href={secondaryCta.href} class="pw-hero__button pw-hero__button--secondary">
            {secondaryCta.label}
          </a>
        </div>

        {hasTrustItems && (
          <ul class="pw-hero__trust" aria-label="PupWiki highlights">
            {trustItems.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}

        {hasStats && (
          <div class="pw-hero__stats" aria-label="PupWiki statistics">
            {stats.map((stat) => (
              <article class="pw-hero__stat">
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </article>
            ))}
          </div>
        )}
      </div>

      <div class="pw-hero__media-wrap">
        <div class="pw-hero__media">
          <img
            src={imageSrc}
            alt={imageAlt}
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />

          <div class="pw-hero__media-shade" aria-hidden="true"></div>

          <div class="pw-hero__floating-card">
            <p>{heroCardEyebrow}</p>
            <span>{heroCardText}</span>
          </div>
        </div>
      </div>
    </div>

    {hasFeatures && (
      <div class="pw-hero__features" aria-label="PupWiki sections">
        {features.map((feature) => (
          <article class="pw-hero__feature">
            <div class="pw-hero__feature-icon" aria-hidden="true">
              {feature.icon}
            </div>
            <div>
              <h2>{feature.title}</h2>
              <p>{feature.text}</p>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .pw-hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 88% 16%, rgba(255, 122, 0, 0.13), transparent 28rem),
      radial-gradient(circle at 8% 8%, rgba(21, 54, 95, 0.08), transparent 24rem),
      var(--hero-bg, linear-gradient(180deg, #fffaf3 0%, #ffffff 72%));
    color: var(--color-body);
  }

  .pw-hero::before {
    content: '';
    position: absolute;
    inset: auto -15% -34% -15%;
    height: 22rem;
    background: linear-gradient(
      90deg,
      rgba(255, 122, 0, 0.08),
      rgba(21, 54, 95, 0.06),
      rgba(255, 122, 0, 0.08)
    );
    filter: blur(48px);
    pointer-events: none;
  }

  .pw-hero__inner {
    position: relative;
    z-index: var(--z-base, 1);
    width: min(100%, var(--max-width, 1280px));
    margin-inline: auto;
    padding:
      clamp(var(--space-10, 2.5rem), 8vw, var(--space-24, 6rem))
      var(--content-padding-mobile, 1.25rem)
      clamp(var(--space-8, 2rem), 7vw, var(--space-18, 4.5rem));
  }

  .pw-hero__grid {
    display: grid;
    gap: clamp(var(--space-8, 2rem), 6vw, var(--space-14, 3.5rem));
    align-items: center;
  }

  .pw-hero__content {
    max-width: 46rem;
  }

  .pw-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    margin: 0;
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    background: var(--color-accent-subtle);
    padding: 0.55rem 0.9rem;
    color: var(--color-accent-hover);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-none);
    text-transform: uppercase;
  }

  .pw-hero__title {
    max-width: 13ch;
    margin: var(--space-5, 1.25rem) 0 0;
    color: var(--hero-heading, var(--color-heading));
    font-family: var(--font-serif);
    font-size: clamp(2.65rem, 13vw, 5.4rem);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: 0.98;
    text-wrap: balance;
  }

  .pw-hero__title span {
    display: block;
    color: var(--hero-heading-accent, var(--color-accent));
  }

  .pw-hero__subtitle {
    max-width: var(--max-width-prose, 72ch);
    margin: var(--space-5, 1.25rem) 0 0;
    color: var(--hero-body, var(--color-body-soft));
    font-family: var(--font-sans);
    font-size: clamp(var(--text-base), 2.4vw, var(--text-lg));
    line-height: var(--leading-relaxed);
  }

  .pw-hero__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 0.75rem);
    margin-top: var(--space-7, 1.75rem);
  }

  .pw-hero__button {
    display: inline-flex;
    min-height: 3.25rem;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    border-radius: var(--radius-xl);
    padding: 0.95rem 1.2rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    line-height: var(--leading-none);
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .pw-hero__button:focus-visible {
    outline: none;
    box-shadow: var(--ring-accent);
  }

  .pw-hero__button--primary {
    background: var(--button-primary-bg);
    color: var(--button-primary-text);
    box-shadow: var(--shadow-cta);
  }

  .pw-hero__button--primary:hover {
    transform: translateY(-2px);
    background: var(--button-primary-bg-hover);
  }

  .pw-hero__button--secondary {
    border: 1px solid var(--button-outline-border);
    background: var(--button-outline-bg);
    color: var(--button-outline-text);
    box-shadow: var(--shadow-xs);
  }

  .pw-hero__button--secondary:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-primary);
    background: var(--button-outline-bg-hover);
    color: var(--color-primary-hover);
  }

  .pw-hero__button-icon {
    display: grid;
    width: 1.65rem;
    height: 1.65rem;
    place-items: center;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.18);
    font-size: 1rem;
    line-height: 1;
  }

  .pw-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2, 0.5rem);
    margin: var(--space-6, 1.5rem) 0 0;
    padding: 0;
    list-style: none;
  }

  .pw-hero__trust li {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.74);
    padding: 0.55rem 0.75rem;
    color: var(--color-body);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semi);
    box-shadow: var(--shadow-xs);
    backdrop-filter: blur(12px);
  }

  .pw-hero__stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3, 0.75rem);
    margin-top: var(--space-6, 1.5rem);
  }

  .pw-hero__stat {
    border: 1px solid var(--card-border);
    border-radius: var(--card-radius);
    background: var(--card-bg);
    padding: var(--space-4, 1rem);
    box-shadow: var(--card-shadow);
  }

  .pw-hero__stat strong {
    display: block;
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    line-height: var(--leading-none);
  }

  .pw-hero__stat span {
    display: block;
    margin-top: var(--space-1, 0.25rem);
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  .pw-hero__media-wrap {
    position: relative;
  }

  .pw-hero__media {
    position: relative;
    overflow: hidden;
    min-height: 23rem;
    border: 1px solid var(--color-border-warm);
    border-radius: var(--radius-3xl);
    background: var(--color-bg-paper);
    box-shadow: var(--shadow-xl);
    isolation: isolate;
  }

  .pw-hero__media img {
    display: block;
    width: 100%;
    height: 23rem;
    object-fit: cover;
    object-position: center;
    transform: scale(1.01);
  }

  .pw-hero__media-shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, transparent 48%, rgba(11, 31, 54, 0.58) 100%),
      radial-gradient(circle at 12% 12%, rgba(255, 122, 0, 0.14), transparent 17rem);
    pointer-events: none;
  }

  .pw-hero__floating-card {
    position: absolute;
    right: var(--space-4, 1rem);
    bottom: var(--space-4, 1rem);
    left: var(--space-4, 1rem);
    z-index: 2;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: var(--radius-2xl);
    background: rgba(255, 253, 248, 0.92);
    padding: var(--space-4, 1rem);
    box-shadow: var(--shadow-lg);
    backdrop-filter: blur(14px);
  }

  .pw-hero__floating-card p {
    margin: 0;
    color: var(--color-accent-hover);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-none);
    text-transform: uppercase;
  }

  .pw-hero__floating-card span {
    display: block;
    margin-top: var(--space-2, 0.5rem);
    color: var(--color-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-normal);
  }

  .pw-hero__features {
    display: grid;
    gap: var(--space-3, 0.75rem);
    margin-top: clamp(var(--space-8, 2rem), 6vw, var(--space-14, 3.5rem));
  }

  .pw-hero__feature {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3, 0.75rem);
    align-items: center;
    border: 1px solid var(--card-border);
    border-radius: var(--radius-2xl);
    background: rgba(255, 255, 255, 0.76);
    padding: var(--space-4, 1rem);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(14px);
  }

  .pw-hero__feature-icon {
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border: 1px solid var(--color-border-warm);
    border-radius: var(--radius-full);
    background: var(--color-accent-subtle);
    font-size: 1.35rem;
    box-shadow: var(--shadow-xs);
  }

  .pw-hero__feature h2 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-snug);
    line-height: var(--leading-tight);
  }

  .pw-hero__feature p {
    margin: var(--space-1, 0.25rem) 0 0;
    color: var(--color-body-soft);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  @media (min-width: 520px) {
    .pw-hero__actions {
      flex-direction: row;
      align-items: center;
    }

    .pw-hero__button {
      width: auto;
      padding-inline: 1.35rem;
    }

    .pw-hero__features {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 768px) {
    .pw-hero__inner {
      padding-inline: var(--content-padding, 1.5rem);
    }

    .pw-hero__media,
    .pw-hero__media img {
      height: 30rem;
    }

    .pw-hero__media {
      min-height: 30rem;
    }

    .pw-hero__stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .pw-hero__inner {
      padding-inline: var(--content-padding-wide, 2rem);
    }

    .pw-hero__grid {
      grid-template-columns: minmax(0, 1.02fr) minmax(24rem, 0.98fr);
    }

    .pw-hero__content {
      padding-block: var(--space-6, 1.5rem);
    }

    .pw-hero__title {
      max-width: 12ch;
    }

    .pw-hero__media,
    .pw-hero__media img {
      height: 34rem;
    }

    .pw-hero__media {
      min-height: 34rem;
    }

    .pw-hero__media-wrap::before {
      content: '';
      position: absolute;
      inset: 7% auto auto -8%;
      width: 8.5rem;
      height: 8.5rem;
      border-radius: var(--radius-full);
      background: var(--color-accent-light);
      filter: blur(8px);
      opacity: 0.75;
      pointer-events: none;
    }

    .pw-hero__features {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .pw-hero__feature {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
      padding: var(--space-5, 1.25rem);
    }
  }

  @media (min-width: 1180px) {
    .pw-hero__media,
    .pw-hero__media img {
      height: 38rem;
    }

    .pw-hero__media {
      min-height: 38rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pw-hero__button,
    .pw-hero__button:hover {
      transform: none;
      transition: none;
    }
  }
</style>