---
/**
 * Legacy wrapper kept for backwards compatibility.
 * The canonical homepage hero implementation is HomeHeroClean.astro.
 */

import HomeHeroClean from './HomeHeroClean.astro';

export interface Cta { label: string; href: string }
export interface HeroStat { value: string; label: string }
export interface HeroFeature { icon?: string; title: string; text: string }
export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  accent?: string;
  subtitle?: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  imageSrc?: string;
  imageAlt?: string;
  heroCardEyebrow?: string;
  heroCardText?: string;
  trustItems?: string[];
  features?: HeroFeature[];
  stats?: HeroStat[];
}
---

<HomeHeroClean {...Astro.props} />
