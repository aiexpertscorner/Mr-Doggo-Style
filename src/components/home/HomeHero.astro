---
/**
 * HomeHero.astro — Legacy wrapper kept for backwards compatibility.
 *
 * Canonical implementation:
 * - HomeHeroClean.astro
 *
 * Purpose:
 * - Keeps older imports working, for example:
 *   import HomeHero from '@/components/home/HomeHero.astro';
 * - Passes all props through to the new canonical hero.
 * - Mirrors the public prop types from HomeHeroClean.astro.
 */

import HomeHeroClean from './HomeHeroClean.astro';

export interface Cta {
  label: string;
  href: string;
  ariaLabel?: string;
}

export interface HeroStat {
  value: string;
  label: string;
  detail?: string;
  icon?: string;
}

export interface HeroFeature {
  icon?: string;
  title: string;
  text: string;
  href?: string;
  cta?: string;
}

export interface QuickLink {
  label: string;
  href: string;
  icon?: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  accent?: string;
  subtitle?: string;

  primaryCta?: Cta;
  secondaryCta?: Cta;

  imageSrc?: string;
  imageAlt?: string;

  heroCardEyebrow?: string;
  heroCardText?: string;

  trustItems?: string[];
  quickLinks?: QuickLink[];
  features?: HeroFeature[];
  stats?: HeroStat[];
}

const props = Astro.props;
---

<HomeHeroClean {...props} />