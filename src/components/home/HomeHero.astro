---
/**
 * PupWiki homepage hero
 * Prop-driven and safe to wire up later through homepage-config/getHomepageData.
 */

export interface Cta {
  label: string;
  href: string;
}

export interface HeroStat {
  value: string;
  label: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  accent?: string;
  subtitle?: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  imageSrc?: string;
  imageAlt?: string;
  heroCardEyebrow?: string;
  heroCardText?: string;
  trustItems?: string[];
  stats?: HeroStat[];
}

const {
  id = 'home-hero',
  eyebrow = 'Trusted guidance for dog parents',
  title = 'Research breeds, plan costs, and care smarter.',
  accent = 'All in one place.',
  subtitle = 'PupWiki helps dog parents compare breeds and mixed breeds, understand health and care needs, explore training and lifestyle guidance, and make more confident ownership decisions.',
  primaryCta = { label: 'Explore Breeds', href: '/breeds' },
  secondaryCta = { label: 'Dog Names', href: '/dog-names' },
  imageSrc = 'https://images.unsplash.com/photo-1544568100-847a948585b9?w=1200&q=80&fit=crop',
  imageAlt = 'Happy dog owner with a golden retriever',
  heroCardEyebrow = 'Data-backed dog guidance',
  heroCardText = 'Breed profiles, mixed breeds, cost tools, care guidance, and practical next steps.',
  trustItems = ['277 breed guides', '75 mixed breeds', '5,000+ dog names', 'Cost and care tools'],
  stats = [],
} = Astro.props;

const hasStats = Array.isArray(stats) && stats.length > 0;
---

<section id={id} class="bg-gradient-to-b from-white to-slate-50">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-5 sm:py-16 lg:px-6 lg:py-20">
    <div class="grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-12">
      <div>
        <span class="inline-flex rounded-full bg-teal-50 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.14em] text-teal-800">
          {eyebrow}
        </span>

        <h1 class="mt-5 max-w-3xl text-4xl font-bold leading-tight tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
          {title}
          <span class="block text-teal-700">{accent}</span>
        </h1>

        <p class="mt-5 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">
          {subtitle}
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={primaryCta.href}
            class="inline-flex items-center justify-center rounded-xl bg-teal-600 px-5 py-3 text-sm font-bold text-white shadow-sm transition hover:-translate-y-[1px] hover:bg-teal-700"
          >
            {primaryCta.label}
          </a>

          <a
            href={secondaryCta.href}
            class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 hover:text-slate-900"
          >
            {secondaryCta.label}
          </a>
        </div>

        {trustItems.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-2">
            {trustItems.map((item) => (
              <span class="inline-flex rounded-full border border-stone-200 bg-white px-3 py-1 text-xs font-semibold text-slate-700">
                {item}
              </span>
            ))}
          </div>
        )}

        {hasStats && (
          <div class="mt-8 grid gap-3 sm:grid-cols-3">
            {stats.map((stat) => (
              <div class="rounded-2xl border border-stone-200 bg-white p-4">
                <p class="text-2xl font-bold tracking-tight text-slate-950">{stat.value}</p>
                <p class="mt-1 text-sm text-slate-600">{stat.label}</p>
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="relative">
        <div class="overflow-hidden rounded-3xl border border-stone-200 bg-white shadow-[0_30px_60px_-24px_rgba(15,23,42,0.2)]">
          <img
            src={imageSrc}
            alt={imageAlt}
            class="block h-[360px] w-full object-cover sm:h-[420px] lg:h-[520px]"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="mt-4 rounded-2xl border border-stone-200 bg-white p-4 shadow-sm sm:absolute sm:-bottom-5 sm:left-4 sm:right-auto sm:mt-0 sm:max-w-sm">
          <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-teal-700">
            {heroCardEyebrow}
          </p>
          <p class="mt-2 text-sm leading-6 text-slate-700">
            {heroCardText}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
