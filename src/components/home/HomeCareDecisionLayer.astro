---
/**
 * Care / decision-support layer cards.
 */

export interface CareCard {
  title: string;
  description: string;
  href: string;
  icon?: string;
  iconHtml?: string;
  eyebrow?: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  cards?: CareCard[];
}

const defaultCards: CareCard[] = [
  {
    title: 'Health & vet care',
    description: 'Understand breed-linked health patterns, care watch-outs, and practical guidance for everyday ownership.',
    href: '/categories/health',
    icon: '🩺',
    eyebrow: 'Care',
  },
  {
    title: 'Training & behavior',
    description: 'Explore trainability, routine-building, behavior patterns, and practical next steps for better day-to-day life.',
    href: '/categories/training',
    icon: '🦮',
    eyebrow: 'Behavior',
  },
  {
    title: 'Nutrition & feeding',
    description: 'Compare feeding approaches, food guidance, and practical nutrition considerations by breed and lifestyle.',
    href: '/categories/dog-food',
    icon: '🍖',
    eyebrow: 'Food',
  },
  {
    title: 'Lifestyle & gear',
    description: 'Browse practical product and lifestyle guidance for sleep, travel, safety, and daily routines.',
    href: '/categories/lifestyle',
    icon: '🎒',
    eyebrow: 'Lifestyle',
  },
];

const {
  id = 'home-care-decision-layer',
  eyebrow = 'Care smarter',
  title = 'The practical side of dog ownership',
  subtitle = 'Move from curiosity to confident decisions with care, training, health, and lifestyle guidance.',
  cards = defaultCards,
} = Astro.props;
---

<section id={id} class="py-12 sm:py-14 lg:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-5 lg:px-6">
    <div class="max-w-3xl">
      <p class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-primary)]">
        {eyebrow}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-heading)] sm:text-4xl">
        {title}
      </h2>
      <p class="mt-3 text-base leading-7 text-[var(--color-body-soft)]">
        {subtitle}
      </p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {cards.map((card) => (
        <a
          href={card.href}
          class="group flex h-full gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 shadow-sm transition hover:-translate-y-[2px] hover:border-[var(--color-border-strong)] hover:shadow-md"
        >
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[var(--color-bg-muted)] text-2xl text-[var(--color-body)]">
            {card.iconHtml ? <span set:html={card.iconHtml} /> : <span>{card.icon ?? '→'}</span>}
          </div>

          <div class="min-w-0">
            {card.eyebrow && (
              <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-[var(--color-muted)]">
                {card.eyebrow}
              </p>
            )}

            <h3 class="mt-1 text-lg font-bold text-[var(--color-heading)]">
              {card.title}
            </h3>

            <p class="mt-2 text-sm leading-6 text-[var(--color-body-soft)]">
              {card.description}
            </p>

            <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-primary)] transition group-hover:translate-x-[2px]">
              Explore
              <span aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
