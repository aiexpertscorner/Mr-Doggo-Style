---
/**
 * Lead capture / newsletter section.
 * This component avoids fake success behavior.
 * - If formAction exists, it renders a real form.
 * - If formAction is missing, it renders CTA links instead.
 */

export interface HiddenField {
  name: string;
  value: string;
}

export interface LinkItem {
  label: string;
  href: string;
}

export interface Props {
  id?: string;
  title?: string;
  description?: string;
  formAction?: string;
  method?: 'POST' | 'GET';
  emailPlaceholder?: string;
  buttonLabel?: string;
  hiddenFields?: HiddenField[];
  fallbackPrimary?: LinkItem;
  fallbackSecondary?: LinkItem;
  disclaimer?: string;
}

const {
  id = 'home-lead-capture',
  title = 'Stay in the loop',
  description = 'Use this section for your real newsletter or lead capture flow once your provider is connected.',
  formAction = '',
  method = 'POST',
  emailPlaceholder = 'Enter your email address',
  buttonLabel = 'Subscribe',
  hiddenFields = [],
  fallbackPrimary = { label: 'Explore Breeds', href: '/breeds' },
  fallbackSecondary = { label: 'Read the Blog', href: '/blog' },
  disclaimer = 'No spam. Only practical dog guidance, updates, and occasional curated recommendations.',
} = Astro.props;

const hasLiveForm = typeof formAction === 'string' && formAction.trim().length > 0;
---

<section id={id} class="py-12 sm:py-14 lg:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-5 lg:px-6">
    <div class="overflow-hidden rounded-3xl bg-[var(--color-surface-navy)] px-6 py-10 text-[var(--color-text-inverse)] sm:px-8 lg:px-10">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-accent)]">
          Email updates
        </p>

        <h2 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
          {title}
        </h2>

        <p class="mt-4 text-base leading-7 text-[var(--color-placeholder)]">
          {description}
        </p>

        {hasLiveForm ? (
          <form
            action={formAction}
            method={method}
            class="mx-auto mt-8 flex max-w-xl flex-col gap-3 sm:flex-row"
          >
            {hiddenFields.map((field) => (
              <input type="hidden" name={field.name} value={field.value} />
            ))}

            <input
              type="email"
              name="email"
              required
              placeholder={emailPlaceholder}
              class="w-full rounded-xl border border-white/10 bg-[var(--color-bg)] px-4 py-3 text-sm text-[var(--color-heading)] outline-none ring-0 placeholder:text-[var(--color-muted)]"
            />

            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-xl bg-[var(--color-accent)] px-5 py-3 text-sm font-bold text-[var(--color-text-inverse)] transition hover:bg-[var(--color-accent-hover)]"
            >
              {buttonLabel}
            </button>
          </form>
        ) : (
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href={fallbackPrimary.href}
              class="inline-flex items-center justify-center rounded-xl bg-[var(--color-accent)] px-5 py-3 text-sm font-bold text-[var(--color-text-inverse)] transition hover:bg-[var(--color-accent-hover)]"
            >
              {fallbackPrimary.label}
            </a>

            <a
              href={fallbackSecondary.href}
              class="inline-flex items-center justify-center rounded-xl border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-[var(--color-text-inverse)] transition hover:bg-white/10"
            >
              {fallbackSecondary.label}
            </a>
          </div>
        )}

        <p class="mt-4 text-xs leading-5 text-[var(--color-subtle)]">
          {disclaimer}
        </p>
      </div>
    </div>
  </div>
</section>
