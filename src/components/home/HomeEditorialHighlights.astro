---
/**
 * Editorial / featured content highlights.
 */

export interface EditorialCard {
  category?: string;
  title: string;
  description: string;
  href: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  viewAllHref?: string;
  viewAllLabel?: string;
  items?: EditorialCard[];
}

const {
  id = 'home-editorial-highlights',
  eyebrow = 'Editorial highlights',
  title = 'Guides, comparisons, and practical reads',
  subtitle = 'Use this section for curated editorial picks or later wire it to dynamic homepage content.',
  viewAllHref = '/blog',
  viewAllLabel = 'Read the blog',
  items = [],
} = Astro.props;
---

<section id={id} class="bg-[var(--color-bg-muted)] py-12 sm:py-14 lg:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-5 lg:px-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-primary)]">
          {eyebrow}
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-heading)] sm:text-4xl">
          {title}
        </h2>
        <p class="mt-3 text-base leading-7 text-[var(--color-body-soft)]">
          {subtitle}
        </p>
      </div>

      <a
        href={viewAllHref}
        class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-primary)] transition hover:text-[var(--color-primary-hover)]"
      >
        {viewAllLabel}
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="mt-8 grid gap-4 lg:grid-cols-3">
      {items.map((item) => (
        <a
          href={item.href}
          class="group flex h-full flex-col rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 shadow-sm transition hover:-translate-y-[2px] hover:border-[var(--color-border-strong)] hover:shadow-md"
        >
          {item.category && (
            <span class="inline-flex self-start rounded-full bg-[var(--color-bg-muted)] px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-[var(--color-body)]">
              {item.category}
            </span>
          )}

          <h3 class="mt-4 text-lg font-bold text-[var(--color-heading)]">
            {item.title}
          </h3>

          <p class="mt-3 flex-1 text-sm leading-6 text-[var(--color-body-soft)]">
            {item.description}
          </p>

          <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-primary)] transition group-hover:translate-x-[2px]">
            Read more
            <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
