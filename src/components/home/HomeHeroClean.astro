---
export interface Cta { label: string; href: string }
export interface HeroStat { value: string; label: string }
export interface HeroFeature { icon?: string; title: string; text: string }
export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  accent?: string;
  subtitle?: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  imageSrc?: string;
  imageAlt?: string;
  heroCardEyebrow?: string;
  heroCardText?: string;
  trustItems?: string[];
  features?: HeroFeature[];
  stats?: HeroStat[];
}
const {
  id = 'home-hero',
  eyebrow = 'Trusted guidance for dog parents',
  title = 'Research breeds, plan care, and raise a happier dog.',
  accent = 'All in one trusted place.',
  subtitle = 'PupWiki helps dog parents compare breeds and mixed breeds, understand care and health considerations, explore training guidance, and make smarter ownership decisions.',
  primaryCta = { label: 'Explore Dog Breeds', href: '/breeds' },
  secondaryCta = { label: 'Compare Breeds', href: '/breed-comparison' },
  imageSrc = 'https://images.unsplash.com/photo-1544568100-847a948585b9?w=1400&q=82&fit=crop',
  imageAlt = 'Happy dog outdoors',
  heroCardEyebrow = 'Data-backed dog guidance',
  heroCardText = 'Breed profiles, mixed breeds, cost tools, care guidance, and practical next steps for real dog owners.',
  trustItems = [],
  features = [],
  stats = [],
} = Astro.props;
---
<section id={id} class="pw-hero" aria-labelledby={`${id}-title`}>
  <div class="pw-hero__inner">
    <div class="pw-hero__grid">
      <div class="pw-hero__content pw-stack pw-stack--lg">
        <div class="pw-stack">
          <p class="pw-eyebrow pw-hero__eyebrow">{eyebrow}</p>
          <h1 id={`${id}-title`} class="pw-title-xl pw-hero__title">{title}<span>{accent}</span></h1>
          <p class="pw-lede pw-hero__subtitle">{subtitle}</p>
        </div>
        <div class="pw-hero__actions" aria-label="Primary homepage actions">
          <a href={primaryCta.href} class="pw-btn pw-btn--primary"><span>{primaryCta.label}</span><span class="pw-hero__button-icon" aria-hidden="true">→</span></a>
          <a href={secondaryCta.href} class="pw-btn pw-btn--outline">{secondaryCta.label}</a>
        </div>
        {trustItems.length > 0 && <ul class="pw-hero__trust" aria-label="PupWiki highlights">{trustItems.map((item) => <li>{item}</li>)}</ul>}
        {stats.length > 0 && <div class="pw-hero__stats" aria-label="PupWiki statistics">{stats.map((stat) => <article class="pw-stat-card"><strong>{stat.value}</strong><span>{stat.label}</span></article>)}</div>}
      </div>
      <div class="pw-hero__media-wrap">
        <figure class="pw-media-frame pw-hero__media">
          <img src={imageSrc} alt={imageAlt} loading="eager" decoding="async" />
          <div class="pw-media-shade" aria-hidden="true"></div>
          <figcaption class="pw-hero__floating-card"><p>{heroCardEyebrow}</p><span>{heroCardText}</span></figcaption>
        </figure>
      </div>
    </div>
    {features.length > 0 && <div class="pw-hero__features" aria-label="PupWiki sections">{features.map((feature) => <article class="pw-card pw-hero__feature"><div class="pw-hero__feature-icon" aria-hidden="true">{feature.icon ?? '•'}</div><div><h2>{feature.title}</h2><p>{feature.text}</p></div></article>)}</div>}
  </div>
</section>
