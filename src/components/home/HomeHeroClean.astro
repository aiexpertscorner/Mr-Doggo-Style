---
/**
 * HomeHeroClean.astro — PupWiki homepage hero v3
 *
 * Goals:
 * - Matches the supplied mockup direction: editorial, premium, warm, trusted.
 * - Mobile-first and desktop-polished.
 * - Uses existing PupWiki design tokens from tokens.css.
 * - No Tailwind dependency required inside this component; safe in Astro builds.
 * - Static hero, no rotator, no layout shift.
 */

import heroImageData from '../../data/home-hero-images.json';

export interface Cta {
  label: string;
  href: string;
  ariaLabel?: string;
}

export interface HeroStat {
  value: string;
  label: string;
  detail?: string;
  icon?: string;
}

export interface HeroFeature {
  icon?: string;
  title: string;
  text: string;
  href?: string;
  cta?: string;
}

export interface QuickLink {
  label: string;
  href: string;
  icon?: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  accent?: string;
  subtitle?: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  imageSrc?: string;
  imageAlt?: string;
  heroCardEyebrow?: string;
  heroCardText?: string;
  trustItems?: string[];
  quickLinks?: QuickLink[];
  features?: HeroFeature[];
  stats?: HeroStat[];
}

const {
  id = 'home-hero',
  eyebrow = 'Trusted guidance for dog parents',
  title = 'Research breeds, plan costs, and care smarter.',
  accent = 'All in one place.',
  subtitle = 'Expert-backed breed profiles, mixed-breed guides, care needs, and cost planning tools—so you can make confident, informed decisions for your dog.',
  primaryCta = { label: 'Explore Dog Breeds', href: '/breeds', ariaLabel: 'Explore PupWiki dog breed guides' },
  secondaryCta = { label: 'Plan Costs', href: '/cost-calculator', ariaLabel: 'Open the PupWiki dog cost planner' },
  imageSrc = 'https://images.pexels.com/photos/4587996/pexels-photo-4587996.jpeg?auto=compress&cs=tinysrgb&w=1200&h=900&fit=crop',
  imageAlt = 'Happy dog resting with owner outdoors',
  heroCardEyebrow = 'Decision support for dog parents',
  heroCardText = 'Breed profiles, mixed-breed guides, cost tools, care context and practical next steps for real households.',
  trustItems = ['Expert reviewed', 'Transparent & unbiased', 'Built for real dog parents'],
  quickLinks = [
    { label: 'Breed finder', href: '/breeds', icon: 'search' },
    { label: 'Puppy hub', href: '/categories/puppy', icon: 'puppy' },
    { label: 'Cost planner', href: '/cost-calculator', icon: 'cost' },
    { label: 'Senior dogs', href: '/categories/senior-dogs', icon: 'heart' },
  ],
  features = [
    {
      icon: 'book',
      title: 'Breed research',
      text: 'In-depth profiles, traits, and real-world insights to find the right dog for your life.',
      href: '/breeds',
      cta: 'Explore breeds',
    },
    {
      icon: 'cost',
      title: 'Cost planning',
      text: 'Upfront and ongoing cost breakdowns so you can plan realistically and avoid surprises.',
      href: '/cost-calculator',
      cta: 'Plan costs',
    },
    {
      icon: 'heart',
      title: 'Everyday care',
      text: 'Practical guides for training, nutrition, health, and life stages—backed by research.',
      href: '/categories/health',
      cta: 'Browse care guides',
    },
  ],
  stats = [
    { value: '350+', label: 'Breed guides', detail: 'Expert-backed profiles', icon: 'book' },
    { value: '12+', label: 'Cost tools', detail: 'Plan with confidence', icon: 'cost' },
    { value: '1,000+', label: 'Care guides', detail: 'For every life stage', icon: 'heart' },
  ],
} = Astro.props;

const enrichedImages = Array.isArray((heroImageData as any).images)
  ? (heroImageData as any).images
  : [];

const mainImage = enrichedImages.find((image: any) => image?.src) || {
  src: imageSrc,
  mobileSrc: imageSrc,
  alt: imageAlt,
};

const heroStats = stats.slice(0, 3);
const heroFeatures = features.slice(0, 3);
const heroQuickLinks = quickLinks.slice(0, 4);
const heroTrustItems = trustItems.slice(0, 3);

const iconMarkup: Record<string, string> = {
  search: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 21-4.35-4.35"/><circle cx="11" cy="11" r="7"/></svg>`,
  puppy: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8.8 7.6c.8-.9 1.9-1.4 3.2-1.4s2.4.5 3.2 1.4"/><path d="M7.5 9.2c-1.5-.5-2.7.2-3.1 1.5-.5 1.6.4 3.2 2 3.7"/><path d="M16.5 9.2c1.5-.5 2.7.2 3.1 1.5.5 1.6-.4 3.2-2 3.7"/><path d="M8 14.5c.8 2 2.1 3 4 3s3.2-1 4-3"/><path d="M10 11.2h.01M14 11.2h.01"/><path d="M11 14h2"/></svg>`,
  cost: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M15 9.2c-.7-.8-1.7-1.2-3-1.2-1.5 0-2.5.8-2.5 2s.9 1.7 2.7 2.1c1.9.4 2.8 1.1 2.8 2.4S13.8 17 12.1 17c-1.4 0-2.6-.5-3.4-1.4"/></svg>`,
  heart: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.8 8.6c0 5-8.8 10.1-8.8 10.1S3.2 13.6 3.2 8.6A4.6 4.6 0 0 1 12 6.7a4.6 4.6 0 0 1 8.8 1.9Z"/></svg>`,
  book: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.8 5.4c2.2-.8 4.8-.4 7.2 1.2v12c-2.4-1.6-5-2-7.2-1.2V5.4Z"/><path d="M19.2 5.4c-2.2-.8-4.8-.4-7.2 1.2v12c2.4-1.6 5-2 7.2-1.2V5.4Z"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s7-3.4 7-10V5.8L12 3 5 5.8V11c0 6.6 7 10 7 10Z"/><path d="m9.4 11.8 1.8 1.8 3.8-4"/></svg>`,
  check: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.4 12.2 2.3 2.3 4.9-5"/></svg>`,
  people: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 19v-1.2c0-1.8-1.5-3.3-3.3-3.3H8.3C6.5 14.5 5 16 5 17.8V19"/><circle cx="10.5" cy="8" r="3"/><path d="M19 19v-1c0-1.5-1-2.8-2.4-3.2"/><path d="M15.8 5.2a3 3 0 0 1 0 5.6"/></svg>`,
  trend: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 17 9.2 11.8l3.4 3.4L20 7.8"/><path d="M15 7.8h5v5"/></svg>`,
};

const renderIcon = (name = 'heart') => iconMarkup[name] || iconMarkup.heart;
---

<section id={id} class="pw-hero-v3" aria-labelledby={`${id}-title`}>
  <div class="pw-hero-v3__shell">
    <div class="pw-hero-v3__grid">
      <div class="pw-hero-v3__content">
        <p class="pw-hero-v3__eyebrow">{eyebrow}</p>

        <h1 id={`${id}-title`} class="pw-hero-v3__title">
          <span>{title}</span>
          <em>{accent}</em>
        </h1>

        <p class="pw-hero-v3__subtitle">{subtitle}</p>

        <div class="pw-hero-v3__actions" aria-label="Primary homepage actions">
          <a class="pw-hero-v3__btn pw-hero-v3__btn--primary" href={primaryCta.href} aria-label={primaryCta.ariaLabel || primaryCta.label}>
            <span>{primaryCta.label}</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>

          <a class="pw-hero-v3__btn pw-hero-v3__btn--secondary" href={secondaryCta.href} aria-label={secondaryCta.ariaLabel || secondaryCta.label}>
            <span>{secondaryCta.label}</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="6" y="4" width="12" height="16" rx="2"/><path d="M9 8h6M9 12h.01M12 12h.01M15 12h.01M9 16h.01M12 16h.01M15 16h.01" /></svg>
          </a>
        </div>

        {heroQuickLinks.length > 0 && (
          <nav class="pw-hero-v3__quick-links" aria-label="Popular PupWiki starting points">
            {heroQuickLinks.map((link) => (
              <a href={link.href} class="pw-hero-v3__quick-link">
                <span class="pw-hero-v3__quick-icon" set:html={renderIcon(link.icon)} />
                <span>{link.label}</span>
              </a>
            ))}
          </nav>
        )}

        {heroTrustItems.length > 0 && (
          <ul class="pw-hero-v3__trust" aria-label="PupWiki trust signals">
            {heroTrustItems.map((item, index) => (
              <li>
                <span set:html={renderIcon(index === 0 ? 'shield' : index === 1 ? 'check' : 'people')} />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="pw-hero-v3__visual">
        <figure class="pw-hero-v3__image-card">
          <picture>
            <source srcset={mainImage.mobileSrc || mainImage.src} media="(max-width: 640px)" />
            <img
              src={mainImage.src || imageSrc}
              alt={mainImage.alt || imageAlt}
              width="960"
              height="760"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </picture>

          <div class="pw-hero-v3__image-glow" aria-hidden="true"></div>

          <figcaption class="pw-hero-v3__insight-card">
            <span class="pw-hero-v3__insight-icon" set:html={renderIcon('trend')} />
            <span class="pw-hero-v3__insight-copy">
              <strong>{heroCardEyebrow}</strong>
              <span>{heroCardText}</span>
            </span>
          </figcaption>
        </figure>

        {heroStats.length > 0 && (
          <div class="pw-hero-v3__stats" aria-label="PupWiki highlights">
            {heroStats.map((stat) => (
              <article class="pw-hero-v3__stat">
                <span class="pw-hero-v3__stat-icon" set:html={renderIcon(stat.icon)} />
                <strong>{stat.value}</strong>
                <span class="pw-hero-v3__stat-label">{stat.label}</span>
                {stat.detail && <small>{stat.detail}</small>}
              </article>
            ))}
          </div>
        )}
      </div>
    </div>

    {heroFeatures.length > 0 && (
      <div class="pw-hero-v3__features" aria-label="PupWiki homepage sections">
        {heroFeatures.map((feature) => (
          <article class="pw-hero-v3__feature-card">
            <span class="pw-hero-v3__feature-icon" set:html={renderIcon(feature.icon)} />
            <div class="pw-hero-v3__feature-copy">
              <h2>{feature.title}</h2>
              <p>{feature.text}</p>
              {feature.href && (
                <a href={feature.href}>
                  <span>{feature.cta || 'Learn more'}</span>
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .pw-hero-v3,
  .pw-hero-v3 * {
    box-sizing: border-box;
  }

  .pw-hero-v3 {
    --hero-ink: var(--color-heading);
    --hero-ink-soft: var(--color-heading-soft);
    --hero-copy: var(--color-body-soft);
    --hero-accent: var(--color-accent);
    --hero-primary: var(--color-primary);
    --hero-primary-hover: var(--color-primary-hover);
    --hero-border: var(--color-border);
    --hero-border-strong: var(--color-border-primary);
    --hero-surface: var(--color-surface);
    --hero-surface-soft: var(--color-primary-soft);
    --hero-warm: var(--color-accent-subtle);

    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(circle at 74% 22%, rgba(21, 54, 95, 0.075), transparent 30rem),
      radial-gradient(circle at 18% 26%, rgba(255, 122, 0, 0.075), transparent 26rem),
      linear-gradient(180deg, var(--color-bg-soft) 0%, var(--color-bg) 82%);
    color: var(--hero-copy);
    padding: clamp(var(--space-10), 7vw, var(--space-20)) var(--content-padding-mobile) var(--space-10);
  }

  .pw-hero-v3::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.86), rgba(255, 255, 255, 0.42)),
      repeating-linear-gradient(
        90deg,
        rgba(21, 54, 95, 0.035) 0,
        rgba(21, 54, 95, 0.035) 1px,
        transparent 1px,
        transparent 7.5rem
      );
    opacity: 0.36;
  }

  .pw-hero-v3::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: -1;
    height: 34%;
    background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.92));
    pointer-events: none;
  }

  .pw-hero-v3__shell {
    width: min(100%, var(--max-width-wide));
    margin-inline: auto;
  }

  .pw-hero-v3__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  .pw-hero-v3__content {
    max-width: 43rem;
  }

  .pw-hero-v3__eyebrow {
    margin: 0 0 var(--space-3);
    color: var(--hero-primary);
    font-size: clamp(0.72rem, 1.5vw, var(--text-sm));
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: 1.2;
    text-transform: uppercase;
  }

  .pw-hero-v3__title {
    margin: 0;
    max-width: 11.5ch;
    color: var(--hero-ink);
    font-family: var(--font-serif);
    font-size: clamp(2.75rem, 10vw, 5.85rem);
    font-weight: var(--weight-bold);
    letter-spacing: -0.065em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .pw-hero-v3__title span,
  .pw-hero-v3__title em {
    display: block;
  }

  .pw-hero-v3__title em {
    margin-top: 0.08em;
    color: var(--hero-accent);
    font-style: normal;
    letter-spacing: -0.06em;
  }

  .pw-hero-v3__subtitle {
    max-width: 40rem;
    margin: var(--space-5) 0 0;
    color: var(--hero-copy);
    font-size: clamp(var(--text-base), 1.75vw, var(--text-lg));
    line-height: var(--leading-relaxed);
  }

  .pw-hero-v3__actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin-top: var(--space-7);
    max-width: 38rem;
  }

  .pw-hero-v3__btn {
    min-height: 3.65rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    border-radius: var(--radius-lg);
    font-size: var(--text-base);
    font-weight: var(--weight-black);
    line-height: 1;
    text-decoration: none;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base),
      background-color var(--transition-base),
      border-color var(--transition-base),
      color var(--transition-base);
  }

  .pw-hero-v3__btn svg,
  .pw-hero-v3__quick-icon svg,
  .pw-hero-v3__trust svg,
  .pw-hero-v3__insight-icon svg,
  .pw-hero-v3__stat-icon svg,
  .pw-hero-v3__feature-icon svg,
  .pw-hero-v3__feature-card a svg {
    width: 1.15em;
    height: 1.15em;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .pw-hero-v3__btn--primary {
    color: var(--color-text-inverse);
    background: linear-gradient(135deg, var(--hero-primary), var(--hero-primary-hover));
    border: 1px solid rgba(8, 26, 46, 0.18);
    box-shadow: var(--shadow-primary);
  }

  .pw-hero-v3__btn--primary:hover {
    color: var(--color-text-inverse);
    transform: translateY(-2px);
    box-shadow: 0 18px 34px rgba(21, 54, 95, 0.22);
  }

  .pw-hero-v3__btn--secondary {
    color: var(--hero-primary);
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(21, 54, 95, 0.46);
    box-shadow: var(--shadow-xs);
  }

  .pw-hero-v3__btn--secondary:hover {
    color: var(--hero-primary-hover);
    background: var(--color-primary-subtle);
    border-color: rgba(21, 54, 95, 0.68);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .pw-hero-v3__quick-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    max-width: 41rem;
    margin-top: var(--space-6);
  }

  .pw-hero-v3__quick-link {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: var(--space-2);
    min-height: 3rem;
    padding: var(--space-3) var(--space-4);
    color: var(--hero-ink-soft);
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(226, 232, 240, 0.94);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xs);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .pw-hero-v3__quick-link:hover {
    color: var(--hero-primary);
    border-color: rgba(21, 54, 95, 0.25);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .pw-hero-v3__quick-icon {
    display: inline-grid;
    place-items: center;
    flex: 0 0 auto;
    width: 1.55rem;
    height: 1.55rem;
    color: var(--hero-primary);
  }

  .pw-hero-v3__trust {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin: var(--space-6) 0 0;
    padding: 0;
    list-style: none;
  }

  .pw-hero-v3__trust li {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--hero-ink-soft);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    line-height: 1.25;
  }

  .pw-hero-v3__trust li > span:first-child {
    display: inline-grid;
    place-items: center;
    width: 1.25rem;
    height: 1.25rem;
    color: var(--hero-primary);
  }

  .pw-hero-v3__visual {
    position: relative;
    width: 100%;
    max-width: 42rem;
    margin-inline: auto;
  }

  .pw-hero-v3__image-card {
    position: relative;
    overflow: hidden;
    min-height: 21rem;
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-2xl);
    background: var(--color-surface);
    box-shadow: var(--shadow-xl);
  }

  .pw-hero-v3__image-card picture,
  .pw-hero-v3__image-card img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .pw-hero-v3__image-card img {
    min-height: 21rem;
    object-fit: cover;
    object-position: center;
    transform: scale(1.012);
  }

  .pw-hero-v3__image-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(11, 31, 54, 0.04) 0%, transparent 32%, rgba(11, 31, 54, 0.32) 100%),
      radial-gradient(circle at 26% 72%, rgba(255, 250, 243, 0.64), transparent 18rem);
  }

  .pw-hero-v3__insight-card {
    position: absolute;
    left: var(--space-4);
    right: var(--space-4);
    bottom: var(--space-4);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3);
    align-items: start;
    padding: var(--space-4);
    color: var(--hero-copy);
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
  }

  .pw-hero-v3__insight-icon {
    display: inline-grid;
    place-items: center;
    width: 2.65rem;
    height: 2.65rem;
    color: var(--color-text-inverse);
    background: linear-gradient(135deg, var(--hero-primary), var(--hero-primary-hover));
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-primary);
  }

  .pw-hero-v3__insight-copy {
    min-width: 0;
  }

  .pw-hero-v3__insight-copy strong,
  .pw-hero-v3__insight-copy span {
    display: block;
  }

  .pw-hero-v3__insight-copy strong {
    margin-bottom: var(--space-1);
    color: var(--hero-ink);
    font-size: var(--text-sm);
    font-weight: var(--weight-black);
    line-height: var(--leading-snug);
  }

  .pw-hero-v3__insight-copy span {
    color: var(--hero-copy);
    font-size: var(--text-xs);
    line-height: 1.55;
  }

  .pw-hero-v3__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    overflow: hidden;
    margin-top: -1px;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(226, 232, 240, 0.92);
    border-radius: 0 0 var(--radius-2xl) var(--radius-2xl);
    box-shadow: var(--shadow-lg);
  }

  .pw-hero-v3__stat {
    display: grid;
    justify-items: center;
    align-content: start;
    min-height: 7.8rem;
    padding: var(--space-4) var(--space-2);
    text-align: center;
    border-right: 1px solid rgba(226, 232, 240, 0.92);
  }

  .pw-hero-v3__stat:last-child {
    border-right: 0;
  }

  .pw-hero-v3__stat-icon {
    display: inline-grid;
    place-items: center;
    width: 1.65rem;
    height: 1.65rem;
    margin-bottom: var(--space-2);
    color: var(--hero-primary);
  }

  .pw-hero-v3__stat strong {
    display: block;
    color: var(--hero-ink-soft);
    font-family: var(--font-serif);
    font-size: clamp(1.55rem, 5vw, 2rem);
    font-weight: var(--weight-bold);
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .pw-hero-v3__stat-label {
    display: block;
    margin-top: var(--space-2);
