---
/**
 * Mixed breed discovery grid.
 * Current repo-safe defaults:
 * - hub: /breeds
 * - details: /breeds/[slug]
 */

export interface MixedBreedCard {
  slug: string;
  name: string;
  imageUrl?: string;
  img?: string;
  parent1?: string;
  parent2?: string;
  size?: string;
  energy?: string;
  trainability?: string;
  isPoodleMix?: boolean;
  href?: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  viewAllHref?: string;
  viewAllLabel?: string;
  detailRoutePrefix?: string;
  items?: MixedBreedCard[];
}

const {
  id = 'home-mixed-breed-discovery',
  eyebrow = 'Designer & mixed breeds',
  title = 'Popular mixed breed guides',
  subtitle = 'Explore mixed-breed profiles, likely trait blends, and practical care guidance based on parent-breed patterns.',
  viewAllHref = '/breeds',
  viewAllLabel = 'Browse mixed breeds',
  detailRoutePrefix = '/breeds',
  items = [],
} = Astro.props;
---

<section id={id} class="bg-violet-50/70 py-12 sm:py-14 lg:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-5 lg:px-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-violet-700">
          {eyebrow}
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">
          {title}
        </h2>
        <p class="mt-3 text-base leading-7 text-slate-600">
          {subtitle}
        </p>
      </div>

      <a
        href={viewAllHref}
        class="inline-flex items-center gap-2 text-sm font-semibold text-violet-700 transition hover:text-violet-800"
      >
        {viewAllLabel}
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {items.map((item) => {
        const href = item.href ?? `${detailRoutePrefix}/${item.slug}`;
        const image = item.imageUrl ?? item.img ?? '';
        return (
          <a
            href={href}
            class="group flex h-full flex-col overflow-hidden rounded-2xl border border-violet-100 bg-white shadow-sm transition hover:-translate-y-[2px] hover:border-violet-200 hover:shadow-md"
          >
            <div class="relative h-40 overflow-hidden bg-violet-100/60">
              {image ? (
                <img
                  src={image}
                  alt={item.name}
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-5xl">🐾</div>
              )}

              {item.isPoodleMix && (
                <span class="absolute left-3 top-3 inline-flex rounded-full bg-white/90 px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-violet-700">
                  Poodle mix
                </span>
              )}
            </div>

            <div class="flex flex-1 flex-col p-5">
              <h3 class="text-lg font-bold text-slate-950">
                {item.name}
              </h3>

              {(item.parent1 || item.parent2) && (
                <p class="mt-2 text-sm font-semibold text-violet-700">
                  {[item.parent1, item.parent2].filter(Boolean).join(' × ')}
                </p>
              )}

              <div class="mt-4 flex flex-wrap gap-2">
                {item.size && (
                  <span class="inline-flex rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold text-amber-800">
                    {item.size}
                  </span>
                )}
                {item.energy && (
                  <span class="inline-flex rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-800">
                    {item.energy} energy
                  </span>
                )}
                {item.trainability && (
                  <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
                    {item.trainability} training
                  </span>
                )}
              </div>

              <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-violet-700 transition group-hover:translate-x-[2px]">
                View mixed breed guide
                <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
