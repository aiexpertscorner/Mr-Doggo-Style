---
/**
 * HomeAwinSpotlight.astro
 * Homepage AWIN partner section — features top AWIN products.
 * Positioned after breed discovery to catch owners ready to shop.
 */
import awinProducts from '../../data/awin-products.json';
import affiliateProducts from '../../data/affiliate-products.json';

const liveProducts = Array.isArray(awinProducts) ? awinProducts : [];
const fallbackProducts = Array.isArray(affiliateProducts) ? affiliateProducts : [];
const products = liveProducts.length > 0 ? liveProducts : fallbackProducts;

const featured = [
  products.find((p: any) => p.id === 'chefpaw-1'),
  products.find((p: any) => p.id === 'rawwild-elk'),
  products.find((p: any) => p.id === 'jugbow-training-harness'),
].filter(Boolean) as any[];

const fallbackFeatured = products
  .filter((p: any) => p?.url)
  .sort((a: any, b: any) => Number(Boolean(b.image)) - Number(Boolean(a.image)))
  .slice(0, 3);

const spotlightProducts = featured.length >= 3 ? featured : fallbackFeatured;
---

{spotlightProducts.length > 0 && (
  <section class="py-12 sm:py-14 lg:py-16" style="background:var(--color-bg-soft)">
    <div class="mx-auto max-w-7xl px-4 sm:px-5 lg:px-6">

      <div class="max-w-3xl mb-8">
        <p class="text-xs font-bold uppercase tracking-[0.16em]" style="color:var(--color-accent)">
          Partner picks
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-heading)] sm:text-4xl">
          Products we actually recommend
        </h2>
        <p class="mt-3 text-base leading-7 text-[var(--color-body-soft)]">
          Tried-and-tested by dog owners. We earn a small commission if you buy — at no extra cost to you.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {spotlightProducts.map((product: any) => (
          <div class="flex flex-col rounded-2xl border bg-[var(--color-bg)] overflow-hidden shadow-sm" style="border-color:var(--color-border)">

            {/* Image area */}
            <div class="flex items-center justify-center p-6 min-h-[140px]" style="background:var(--color-bg-soft)">
              {product.image ? (
                <img
                  src={product.image}
                  alt={product.name}
                  width="120"
                  height="120"
                  loading="lazy"
                  class="object-contain max-h-28"
                  onerror="this.style.display='none'"
                />
              ) : (
                <span class="text-5xl">🐾</span>
              )}
            </div>

            {/* Details */}
            <div class="flex flex-col flex-1 p-5 gap-2">
              <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--color-accent)">
                {product.merchant}
              </p>
              <h3 class="text-sm font-bold leading-snug text-[var(--color-heading)]">
                {product.name}
              </h3>
              <p class="text-xs leading-relaxed text-[var(--color-muted)] flex-1">
                {product.description?.slice(0, 100)}{product.description?.length > 100 ? '…' : ''}
              </p>

              <div class="flex items-center justify-between pt-3 mt-auto" style="border-top:1px solid var(--color-border)">
                <span class="font-black text-lg text-[var(--color-heading)]">
                  {Number(product.price) > 0 ? `$${Number(product.price).toFixed(2)}` : 'Partner site'}
                </span>
                <a
                  href={product.url}
                  rel="nofollow sponsored"
                  target="_blank"
                  class="text-xs font-bold px-3 py-2 rounded-xl text-[var(--color-text-inverse)] transition hover:opacity-90"
                  style="background:linear-gradient(135deg,var(--color-accent),var(--color-accent-hover))"
                  data-affiliate-merchant={product.merchant}
                  data-affiliate-product={product.id}
                  data-affiliate-placement="homepage-spotlight"
                >
                  Shop now →
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="mt-4 text-xs text-center text-[var(--color-subtle)]">
        Reader-supported links - we may earn a commission at no extra cost to you.
        <a href="/disclosure" class="underline hover:text-[var(--color-body-soft)]">See disclosure →</a>
      </p>
    </div>
  </section>
)}
