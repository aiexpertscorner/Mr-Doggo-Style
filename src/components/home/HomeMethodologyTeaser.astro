---
/**
 * Methodology / trust teaser block.
 */

export interface LinkItem {
  label: string;
  href: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  description?: string;
  bullets?: string[];
  primaryLink?: LinkItem;
  secondaryLink?: LinkItem;
}

const {
  id = 'home-methodology-teaser',
  eyebrow = 'Why trust PupWiki',
  title = 'Clear, practical, and transparent guidance',
  description = 'PupWiki is built to help dog parents make better decisions with structured breed data, practical care guidance, and transparent editorial standards.',
  bullets = [
    'Breed and mixed-breed research grounded in structured data',
    'Reader-first recommendations, not paid rankings',
    'A growing platform for breed, cost, care, and decision support',
  ],
  primaryLink = { label: 'View methodology', href: '/methodology' },
  secondaryLink = { label: 'About PupWiki', href: '/about' },
} = Astro.props;
---

<section id={id} class="py-12 sm:py-14 lg:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-5 lg:px-6">
    <div class="overflow-hidden rounded-3xl border border-[var(--color-border)] bg-[var(--color-bg)] shadow-sm">
      <div class="grid gap-8 p-6 sm:p-8 lg:grid-cols-[1fr_0.9fr] lg:p-10">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-primary)]">
            {eyebrow}
          </p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-heading)] sm:text-4xl">
            {title}
          </h2>
          <p class="mt-4 max-w-2xl text-base leading-7 text-[var(--color-body-soft)]">
            {description}
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={primaryLink.href}
              class="inline-flex items-center justify-center rounded-xl bg-[var(--color-surface-navy)] px-5 py-3 text-sm font-bold text-[var(--color-text-inverse)] transition hover:bg-[var(--color-primary-active)]"
            >
              {primaryLink.label}
            </a>

            <a
              href={secondaryLink.href}
              class="inline-flex items-center justify-center rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] px-5 py-3 text-sm font-semibold text-[var(--color-body)] transition hover:bg-[var(--color-bg-muted)]"
            >
              {secondaryLink.label}
            </a>
          </div>
        </div>

        <div class="rounded-2xl border border-[var(--color-accent-light)] bg-[var(--color-accent-subtle)] p-5 sm:p-6">
          <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-[var(--color-primary)]">
            Editorial principles
          </p>

          <ul class="mt-4 space-y-3">
            {bullets.map((bullet) => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-xs font-bold text-[var(--color-text-inverse)]">
                  ✓
                </span>
                <span class="text-sm leading-6 text-[var(--color-body)]">
                  {bullet}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
