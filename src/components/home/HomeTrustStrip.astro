---
/**
 * Compact trust/stat strip.
 */

export interface TrustItem {
  value: string;
  label: string;
}

export interface Props {
  id?: string;
  items?: TrustItem[];
  note?: string;
}

const {
  id = 'home-trust-strip',
  items = [
    { value: '277', label: 'breed guides' },
    { value: '75', label: 'mixed breeds' },
    { value: '5,000+', label: 'dog names' },
    { value: 'Daily', label: 'care guidance' },
  ],
  note = 'Built to help dog parents compare breeds, plan costs, and care with more confidence.',
} = Astro.props;
---

<section id={id} class="border-y border-stone-200 bg-stone-50/70">
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-5 lg:px-6">
    <div class="grid gap-4 lg:grid-cols-[1fr_auto] lg:items-center">
      <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        {items.map((item) => (
          <div class="rounded-2xl border border-stone-200 bg-white px-4 py-4">
            <p class="text-2xl font-bold tracking-tight text-slate-950">{item.value}</p>
            <p class="mt-1 text-sm text-slate-600">{item.label}</p>
          </div>
        ))}
      </div>

      <p class="max-w-xl text-sm leading-6 text-slate-600 lg:pl-6">
        {note}
      </p>
    </div>
  </div>
</section>
