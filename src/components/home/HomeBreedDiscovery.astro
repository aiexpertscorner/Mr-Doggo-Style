---
/**
 * Breed discovery grid.
 */

export interface BreedCard {
  slug: string;
  name: string;
  imageUrl?: string;
  img?: string;
  subtitle?: string;
  tags?: string[];
  href?: string;
}

export interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  viewAllHref?: string;
  viewAllLabel?: string;
  routePrefix?: string;
  breeds?: BreedCard[];
}

const {
  id = 'home-breed-discovery',
  eyebrow = 'Breed discovery',
  title = 'Explore popular dog breeds',
  subtitle = 'Start with familiar favorites, then branch into breed guides that match your lifestyle, experience, and care expectations.',
  viewAllHref = '/breeds',
  viewAllLabel = 'View all breeds',
  routePrefix = '/breeds',
  breeds = [],
} = Astro.props;
---

<section id={id} class="py-12 sm:py-14 lg:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-5 lg:px-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-teal-700">
          {eyebrow}
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">
          {title}
        </h2>
        <p class="mt-3 text-base leading-7 text-slate-600">
          {subtitle}
        </p>
      </div>

      <a
        href={viewAllHref}
        class="inline-flex items-center gap-2 text-sm font-semibold text-teal-700 transition hover:text-teal-800"
      >
        {viewAllLabel}
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {breeds.map((breed) => {
        const href = breed.href ?? `${routePrefix}/${breed.slug}`;
        const image = breed.imageUrl ?? breed.img ?? '';
        return (
          <a
            href={href}
            class="group overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:-translate-y-[2px] hover:border-stone-300 hover:shadow-md"
          >
            <div class="relative h-44 overflow-hidden bg-slate-100">
              {image ? (
                <img
                  src={image}
                  alt={breed.name}
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-5xl">🐕</div>
              )}
            </div>

            <div class="p-5">
              <h3 class="text-lg font-bold text-slate-950">
                {breed.name}
              </h3>

              {breed.subtitle && (
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {breed.subtitle}
                </p>
              )}

              {breed.tags && breed.tags.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {breed.tags.slice(0, 3).map((tag) => (
                    <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-teal-700 transition group-hover:translate-x-[2px]">
                View breed guide
                <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
