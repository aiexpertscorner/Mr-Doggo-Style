---
import AwinProductSlot from '../affiliate/AwinProductSlot.astro';
import type { CategoryLink, CategoryMeta } from '../../lib/categories/categoryConfig';

export interface Props {
  meta: CategoryMeta;
  categorySlug: string;
  links: CategoryLink[];
  tags: string[];
}

const { meta, categorySlug, links, tags } = Astro.props;
---

<section id="owner-resources" class="category-hub__section category-hub__section--soft">
  <div class="category-hub__container">
    <div class="category-hub__section-header">
      <p class="category-hub__eyebrow">Owner resources</p>
      <h2>Plan smarter around {meta.title.toLowerCase()}</h2>
      <p>
        Use these internal resources to move from broad research to breed-specific decisions,
        care planning and high-intent next steps.
      </p>
    </div>

    {links.length > 0 && (
      <div class="category-hub__link-grid">
        {links.map((item) => (
          <a href={item.href} class="category-hub__link-card">
            <span aria-hidden="true">{item.icon}</span>
            <strong>{item.title}</strong>
            <p>{item.desc}</p>
          </a>
        ))}
      </div>
    )}

    <div class="category-hub__secondary-partner">
      <div>
        <p class="category-hub__eyebrow">Matched partner pick</p>
        <h3>More resources for {meta.title.toLowerCase()}</h3>
        <p>
          A second contextual slot helps surface a different partner resource when available,
          without relying on static Amazon product grids.
        </p>
      </div>

      <AwinProductSlot
        topicTags={tags}
        pageType="category"
        category={categorySlug}
        variant="compact"
        headline={`${meta.shortTitle} partner resource`}
      />
    </div>
  </div>
</section>
