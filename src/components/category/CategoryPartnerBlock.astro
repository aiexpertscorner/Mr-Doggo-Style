---
import AwinProductSlot from '../affiliate/AwinProductSlot.astro';
import type { CategoryMeta } from '../../lib/categories/categoryConfig';

export interface Props {
  meta: CategoryMeta;
  categorySlug: string;
  tags: string[];
}

const { meta, categorySlug, tags } = Astro.props;
---

<section id="partner-resource" class="category-hub__section category-hub__section--partner">
  <div class="category-hub__container">
    <div class="category-hub__partner-grid">
      <div class="category-hub__section-header">
        <p class="category-hub__eyebrow">Partner resource</p>
        <h2>Recommended {meta.title.toLowerCase()} resource</h2>
        <p>
          Pupwiki Recommended Partners.
        </p>
      </div>

      <AwinProductSlot
        topicTags={tags}
        pageType="category"
        category={categorySlug}
        headline={`Featured ${meta.shortTitle.toLowerCase()} resource`}
      />
    </div>

    <p class="category-hub__affiliate-note">
      Affiliate disclosure: PupWiki may earn a commission from qualifying partner links, at no extra cost to you.
      Editorial pages remain informational and should be used as a starting point for your own research.
    </p>
  </div>
</section>
