---
import imageLookup from '../data/image-lookup.json';

export interface Props {
  slug: string;
  name: string;
  group: string;
  temperament?: string;
  popularity?: number;
  size_category?: string;
  energy?: { category: string };
  shedding?: { category: string };
  dogCeoBreed?: string;
  compact?: boolean;
}
const {
  slug, name, group, temperament, popularity,
  size_category = 'medium', energy, shedding, dogCeoBreed, compact = false,
} = Astro.props;

const href = `/breeds/${slug}`;

const energyEmoji = {
  "Needs Lots of Activity": "🔥",
  "Energetic":              "⚡",
  "Regular Exercise":       "🚶",
  "Calm":                   "😌",
  "Couch Potato":           "🛋️",
}[energy?.category || ''] || "🐕";

const lookupUrl = (imageLookup as any).breeds?.[slug];
const hasImage  = lookupUrl && lookupUrl.startsWith('https://images.dog.ceo');
---
<a href={href} class:list={['breed-card', { 'breed-card--compact': compact }]}>

  <div class="breed-card__media">
    <!-- Placeholder sits at z-index 0; image covers it when loaded -->
    <div class="breed-card__placeholder" aria-hidden="true">
      <span class="breed-card__placeholder-emoji">🐕</span>
      {!hasImage && <span class="breed-card__placeholder-name">{name}</span>}
    </div>

    {hasImage && (
      <img
        src={lookupUrl}
        alt={`${name} dog`}
        loading="lazy"
        class="breed-card__img"
        data-slug={slug}
      />
    )}

    <div class="breed-card__overlay" aria-hidden="true"></div>

    {popularity && popularity <= 20 && (
      <div class="breed-card__badge">#{popularity}</div>
    )}
  </div>

  <div class="breed-card__body">
    <h3 class="breed-card__title">{name}</h3>
    {!compact && (
      <p class="breed-card__group">
        {group.replace(' Group','').replace(' Service','')}
      </p>
    )}
    {temperament && !compact && (
      <p class="breed-card__temperament">
        {temperament.split(',')[0].trim()}
      </p>
    )}
    <div class="breed-card__chips">
      <span class="breed-card__chip">{size_category}</span>
      <span class="breed-card__chip">{energyEmoji}</span>
    </div>
    <div class="breed-card__cta">VIEW GUIDE →</div>
  </div>
</a>

<style>
  .breed-card {
    display: flex;
    flex-direction: column;
    background: var(--sw-bg);
    border: 2px solid var(--sw-border);
    text-decoration: none;
    overflow: hidden;
    transition:
      border-color var(--transition-base),
      transform var(--transition-base),
      box-shadow var(--transition-base);
  }

  .breed-card:hover {
    border-color: var(--sw-accent);
    transform: translate(-2px, -2px);
    box-shadow: var(--sw-shadow-hard);
  }

  /* ── Media ──────────────────────────────────────────── */
  .breed-card__media {
    position: relative;
    background: var(--sw-bg-deep);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .breed-card--compact .breed-card__media {
    aspect-ratio: unset;
    height: clamp(100px, 25vw, 140px);
  }

  /* ── Placeholder ────────────────────────────────────── */
  .breed-card__placeholder {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: var(--space-1);
    background: linear-gradient(135deg, var(--sw-bg-deep), var(--sw-bg-raised));
  }

  .breed-card__placeholder-emoji {
    font-size: var(--text-4xl);
  }

  .breed-card__placeholder-name {
    font-family: var(--sw-font-mono);
    font-size: var(--sw-text-nano);
    color: var(--sw-text-faint);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
  }

  /* ── Image ──────────────────────────────────────────── */
  .breed-card__img {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s, filter 0.35s;
  }

  .breed-card:hover .breed-card__img {
    transform: scale(1.08);
  }

  /* ── Overlay & Badge ────────────────────────────────── */
  .breed-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(to top, var(--sw-overlay), transparent 50%);
    pointer-events: none;
  }

  .breed-card__badge {
    position: absolute;
    top: var(--space-2);
    left: var(--space-2);
    z-index: 3;
    background: var(--sw-accent);
    color: var(--sw-midnight);
    font-family: var(--sw-font-heading);
    font-size: var(--sw-text-label);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--sw-midnight);
  }

  /* ── Body ───────────────────────────────────────────── */
  .breed-card__body {
    padding: var(--space-3);
  }

  .breed-card__title {
    font-family: var(--sw-font-heading);
    font-size: var(--text-sm);
    text-transform: uppercase;
    color: var(--sw-text);
    margin: 0 0 var(--space-1);
    line-height: var(--leading-tight);
  }

  .breed-card__group {
    font-family: var(--sw-font-mono);
    font-size: var(--text-xs);
    color: var(--sw-text-dim);
    text-transform: uppercase;
    margin: 0 0 var(--space-1);
    letter-spacing: var(--tracking-wide);
  }

  .breed-card__temperament {
    font-family: var(--sw-font-body);
    font-size: var(--text-sm);
    color: var(--sw-accent);
    margin: 0 0 var(--space-1);
    text-transform: uppercase;
    letter-spacing: var(--tracking-snug);
  }

  .breed-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .breed-card__chip {
    background: var(--sw-chip-bg);
    font-family: var(--sw-font-heading);
    font-size: var(--sw-text-label);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-2);
    color: var(--sw-text-muted);
  }

  .breed-card__cta {
    font-family: var(--sw-font-heading);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--sw-accent);
    margin-top: var(--space-2);
  }
</style>

<script>
  document.querySelectorAll('img.breed-card__img').forEach(img => {
    img.addEventListener('error', function() {
      (this as HTMLImageElement).style.display = 'none';
    });
  });
</script>
