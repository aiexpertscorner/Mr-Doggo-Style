---
import AmazonProductSlot from './AmazonProductSlot.astro';
import type { AmazonPlacementContext } from '../../lib/amazon/amazonTypes';

export interface Props extends AmazonPlacementContext {
  headline?: string;
  placement?: string;
}

const {
  headline = 'Related Amazon picks',
  placement = 'amazon-rail',
  ...context
} = Astro.props;
---

<AmazonProductSlot
  {...context}
  headline={headline}
  eyebrow="Useful shopping shortcut"
  description="Related products available at Amazon.com"
  variant="compact"
  placement={placement}
  limit={context.limit ?? 3}
  columns={3}
/>
