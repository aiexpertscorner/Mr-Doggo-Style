---
import AmazonProductCard from './AmazonProductCard.astro';
import AmazonDisclosure from './AmazonDisclosure.astro';
import AmazonClickTracker from './AmazonClickTracker.astro';
import { ENABLE_AMAZON_BUTTONS } from '../../lib/amazon/amazonConfig';
import { matchAmazonProducts } from '../../lib/amazon/matchAmazonProducts';
import type {
  AmazonPlacementContext,
  AmazonProductRecord,
} from '../../lib/amazon/amazonTypes';

import '../../styles/components/amazon-affiliate.css';

let allProducts: AmazonProductRecord[] = [];
try {
  const imported = await import('../../data/amazon-products.json');
  allProducts = Array.isArray(imported.default) ? imported.default : [];
} catch {
  allProducts = [];
}

export interface Props extends AmazonPlacementContext {
  headline?: string;
  eyebrow?: string;
  description?: string;
  variant?: 'card' | 'compact';
  placement?: string;
  columns?: 2 | 3 | 4;
  showDisclosure?: boolean;
}

const {
  headline = 'Useful Amazon.com picks for dog parents',
  eyebrow = 'Amazon.com partner picks',
  description = 'Amazon.com recommended products.',
  variant = 'card',
  placement = 'amazon-slot',
  columns = 3,
  showDisclosure = true,
  pageType = 'category',
  pageSlug = Astro.url.pathname,
  category,
  topicTags = [],
  breedSize,
  breedEnergy,
  breedCoat,
  breedLifeStage,
  excludeProductIds = [],
  limit = 3,
  allowMediumRisk = false,
  allowHighRisk = false,
} = Astro.props;

const products = ENABLE_AMAZON_BUTTONS
  ? matchAmazonProducts(allProducts, {
      pageType,
      pageSlug,
      category,
      topicTags,
      breedSize,
      breedEnergy,
      breedCoat,
      breedLifeStage,
      excludeProductIds,
      limit,
      allowMediumRisk,
      allowHighRisk,
    })
  : [];
---

{products.length > 0 && (
  <section class="amazon-slot" aria-label={headline}>
    <div class="amazon-slot__shell">
      <div class="amazon-slot__header">
        <p class="amazon-slot__eyebrow">{eyebrow}</p>
        <h2 class="amazon-slot__title">{headline}</h2>
        <p class="amazon-slot__description">{description}</p>
      </div>

      <div
        class="amazon-slot__grid"
        style={`--amazon-cols:${columns}`}
      >
        {products.map((product) => (
          <AmazonProductCard
            product={product}
            variant={variant}
            placement={placement}
          />
        ))}
      </div>

      {showDisclosure && <AmazonDisclosure />}
    </div>

    <AmazonClickTracker />
  </section>
)}
