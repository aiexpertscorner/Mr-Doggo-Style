---
import { ENABLE_AMAZON_BUTTONS } from '../lib/site-config';

export interface Props {
  winner: string;
  winnerAsin: string;
  winnerNote: string;
  budgetPick?: string;
  budgetAsin?: string;
  budgetNote?: string;
  tag?: string;
}

const { winner, winnerAsin, winnerNote, budgetPick, budgetAsin, budgetNote, tag = 'aiexpertscorn-20' } = Astro.props;
const winnerUrl = `https://www.amazon.com/dp/${winnerAsin}/?tag=${tag}`;
const budgetUrl = budgetAsin ? `https://www.amazon.com/dp/${budgetAsin}/?tag=${tag}` : null;
---

<div style="border:2px solid var(--color-accent);border-radius:var(--radius-2xl);margin:2.5rem 0;overflow:hidden">
  <div style="background:var(--color-accent);padding:.6rem 1.25rem;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#fff">
    🏆 Our Verdict
  </div>
  <div style="background:var(--color-bg-soft);padding:1.5rem;display:flex;flex-direction:column;gap:1rem">

    <div style="display:flex;align-items:flex-start;gap:.9rem">
      <span style="font-size:1.5rem;flex-shrink:0">🥇</span>
      <div>
        <p style="font-size:.85rem;font-weight:700;text-transform:uppercase;color:var(--color-heading);margin:0 0 .2rem">Best Overall: {winner}</p>
        <p style="font-size:.95rem;color:var(--color-body-soft);margin:0 0 .9rem">{winnerNote}</p>
        {ENABLE_AMAZON_BUTTONS ? (
          <a href={winnerUrl} rel="nofollow sponsored" target="_blank" aria-label="Available at Amazon" style="display:inline-block;line-height:0">
            <img src="/images/amazon/available-at-amazon.png" alt="Available at Amazon" height="32" loading="lazy" style="height:32px;width:auto;display:block" />
          </a>
        ) : (
          <a href={winnerUrl} rel="nofollow sponsored" target="_blank"
            style="display:inline-flex;align-items:center;font-size:.8rem;font-weight:700;color:var(--color-accent);text-decoration:underline">
            Check price →
          </a>
        )}
      </div>
    </div>

    {budgetPick && (
      <div style="display:flex;align-items:flex-start;gap:.9rem;padding-top:1rem;border-top:1px solid var(--color-border)">
        <span style="font-size:1.5rem;flex-shrink:0">💰</span>
        <div>
          <p style="font-size:.85rem;font-weight:700;text-transform:uppercase;color:var(--color-heading);margin:0 0 .2rem">Best Value: {budgetPick}</p>
          <p style="font-size:.95rem;color:var(--color-body-soft);margin:0 0 .9rem">{budgetNote}</p>
          {budgetUrl && ENABLE_AMAZON_BUTTONS && (
            <a href={budgetUrl} rel="nofollow sponsored" target="_blank" aria-label="Available at Amazon" style="display:inline-block;line-height:0">
              <img src="/images/amazon/available-at-amazon.png" alt="Available at Amazon" height="32" loading="lazy" style="height:32px;width:auto;display:block" />
            </a>
          )}
          {budgetUrl && !ENABLE_AMAZON_BUTTONS && (
            <a href={budgetUrl} rel="nofollow sponsored" target="_blank"
              style="display:inline-flex;align-items:center;font-size:.8rem;font-weight:700;color:var(--color-accent);text-decoration:underline">
              Check price →
            </a>
          )}
        </div>
      </div>
    )}

  </div>
</div>
