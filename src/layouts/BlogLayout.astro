---
/**
 * BlogLayout.astro — global-styled article layout for PupWiki.
 * Styling lives in public/styles/pages/article.css.
 */

import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import PageBannerSlot from '../components/affiliate/PageBannerSlot.astro';
import AwinProductSlot from '../components/affiliate/AwinProductSlot.astro';

export interface Props {
  title: string;
  displayTitle?: string;
  description: string;
  canonicalUrl?: string;
  pubDate: string;
  updatedDate?: string;
  category: string;
  readTime?: number;
  heroImage?: string;
  heroImageAlt?: string;
  schema?: object;
  tags?: string[];
  postType?: string;
  breedSlug?: string;
  breedName?: string;
  breedSize?: string;
  breedEnergy?: string;
  breedCoat?: string;
  noIndex?: boolean;
  claimSensitivity?: string;
  medicalDisclaimer?: boolean;
}

const {
  title,
  displayTitle = title,
  description,
  canonicalUrl,
  pubDate,
  updatedDate,
  category,
  readTime = 5,
  heroImage,
  heroImageAlt = title,
  schema,
  tags = [],
  postType = 'general',
  breedSlug,
  breedName,
  breedSize,
  breedEnergy,
  breedCoat,
  noIndex = false,
  claimSensitivity,
  medicalDisclaimer = false,
} = Astro.props;

const showHealthDisclaimer = medicalDisclaimer || claimSensitivity === 'high' || ['Health', 'Supplements', 'Supplement'].includes(category);

function slugify(value: string) {
  return String(value || '').toLowerCase().trim().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

const categoryConfig: Record<string, { label: string; icon: string; className: string }> = {
  food: { label: 'Food & Nutrition', icon: '🍖', className: 'is-food' },
  'dog food': { label: 'Food & Nutrition', icon: '🍖', className: 'is-food' },
  toys: { label: 'Toys & Enrichment', icon: '🎾', className: 'is-toys' },
  health: { label: 'Health & Vet Care', icon: '🩺', className: 'is-health' },
  beds: { label: 'Sleep & Comfort', icon: '🛏️', className: 'is-beds' },
  grooming: { label: 'Grooming', icon: '✂️', className: 'is-grooming' },
  supplements: { label: 'Supplements', icon: '💊', className: 'is-supplements' },
  training: { label: 'Training', icon: '🦮', className: 'is-training' },
  gear: { label: 'Training & Gear', icon: '🦮', className: 'is-training' },
  'smart tech': { label: 'Smart Tech', icon: '📡', className: 'is-tech' },
  lifestyle: { label: 'Lifestyle', icon: '🎁', className: 'is-lifestyle' },
  'pupwiki partners': { label: 'Dog Brand Guides', icon: '🐾', className: 'is-lifestyle' },
};

const categoryKey = String(category || 'Guide').toLowerCase();
const categoryMeta = categoryConfig[categoryKey] || { label: category || 'Guide', icon: '🐾', className: 'is-default' };
const categoryPath = `/categories/${slugify(category)}`;
const displayDate = new Date(updatedDate ?? pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const publishedIso = new Date(pubDate).toISOString();
const updatedIso = updatedDate ? new Date(updatedDate).toISOString() : undefined;
const isHealthSensitive = ['health', 'supplements', 'food', 'dog food'].includes(categoryKey) || ['health', 'supplements', 'product-roundup'].includes(String(postType || '').toLowerCase());

const partnerTopicTags = [categoryKey, postType, breedSlug, breedName, breedSize, breedEnergy, breedCoat, ...tags]
  .filter(Boolean)
  .map((item) => String(item).toLowerCase());

const defaultArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: displayTitle,
  description,
  image: heroImage || undefined,
  datePublished: publishedIso,
  dateModified: updatedIso || publishedIso,
  author: { '@type': 'Organization', name: 'PupWiki' },
  publisher: { '@type': 'Organization', name: 'PupWiki' },
  mainEntityOfPage: canonicalUrl ? { '@type': 'WebPage', '@id': canonicalUrl } : undefined,
};

const resolvedSchema = schema || defaultArticleSchema;
const SITE = 'https://pupwiki.com';
const slugifiedCat = slugify(category);
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE}/blog` },
    { '@type': 'ListItem', position: 3, name: categoryMeta.label, item: `${SITE}/categories/${slugifiedCat}` },
    ...(canonicalUrl ? [{ '@type': 'ListItem', position: 4, name: displayTitle, item: canonicalUrl }] : []),
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  pageType="article"
  publishedTime={publishedIso}
  modifiedTime={updatedIso}
  noIndex={noIndex}
  ogImage={heroImage}
  ogImageAlt={heroImageAlt}
  bodyClass="article-page pw-page"
>
  <Fragment slot="head">
    {resolvedSchema && <script type="application/ld+json" set:html={JSON.stringify(resolvedSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <main class="article-page">
    <header class="article-hero">
      <div class="article-container">
        <Breadcrumb
          items={[
            { label: 'Home', href: '/' },
            { label: 'Guides', href: '/blog' },
            { label: categoryMeta.label, href: categoryPath },
            { label: displayTitle, current: true },
          ]}
        />

        <div class="article-meta-row">
          <span class:list={['article-category-pill', categoryMeta.className]}>{categoryMeta.icon} {categoryMeta.label}</span>
          <time datetime={updatedIso || publishedIso}>{displayDate}</time>
          <span aria-hidden="true">·</span>
          <span>{readTime} min read</span>
        </div>

        <h1>{displayTitle}</h1>
        <p class="article-hero__subtitle">{description}</p>

        <div class="article-trust-row" aria-label="Article trust notes">
          <span>Updated dog guide</span>
          <span>Reader-first recommendations</span>
          {isHealthSensitive && <span>General information, not veterinary advice</span>}
        </div>

        {heroImage && (
          <figure class="article-hero__image-wrap">
            <img src={heroImage} alt={heroImageAlt} width="1280" height="560" loading="eager" decoding="async" class="article-hero__image" />
          </figure>
        )}
      </div>
    </header>

    <section class="article-prelude">
      <div class="article-container">
        <div class="article-disclosure-card">
          <div>
            <strong>How PupWiki chooses resources</strong>
            <p>We prioritize dog relevance, practical fit, clear safety notes, and up-to-date product or service details. Always confirm current terms on the brand or retailer site before buying.</p>
          </div>
          <a href="/how-we-test">Research method →</a>
        </div>

        {isHealthSensitive && (
          <div class="article-health-note">
            <strong>Health note</strong>
            <p>This guide is for general informational and product-comparison purposes only. It is not veterinary advice. Diet, supplements, allergies, medical conditions, and weight-management decisions should be discussed with your veterinarian.</p>
          </div>
        )}
      </div>
    </section>

    <section class="article-main">
      <div class="article-container">
        <div class="article-layout">
          <article class="article-content prose" id="article-content">
            {showHealthDisclaimer && (
              <aside class="health-disclaimer not-prose">
                <strong>Health note:</strong> This guide is for general informational and product-comparison purposes only. It is not veterinary advice. Diet, health conditions, and supplement use should always be discussed with your veterinarian.
              </aside>
            )}

            <slot />

            <div class="article-tool-cta not-prose">
              <div class="article-tool-cta__icon" aria-hidden="true">🐾</div>
              <div class="article-tool-cta__content">
                <strong>Use PupWiki tools next</strong>
                <p>Compare breeds, estimate ownership costs, or find breed-specific dog name ideas.</p>
              </div>
              <div class="article-tool-cta__actions">
                <a href="/cost-calculator" class="article-button article-button--primary">Cost calculator</a>
                <a href="/breeds" class="article-button article-button--secondary">Explore breeds</a>
              </div>
            </div>

            <div class="article-correction-card not-prose">
              <div>
                <strong>Spotted outdated information?</strong>
                <p>Product availability, prices, formulas, and service details can change. Send us the page URL and the specific detail we should review.</p>
              </div>
              <a href="/contact">Suggest a correction →</a>
            </div>
          </article>

          <aside class="article-sidebar" aria-label="Article sidebar">
            <div class="article-sidebar__inner">
              <section class="article-sidebar-card">
                <h2>Article guide</h2>
                <dl>
                  <div><dt>Category</dt><dd>{categoryMeta.label}</dd></div>
                  <div><dt>Updated</dt><dd>{displayDate}</dd></div>
                  <div><dt>Read time</dt><dd>{readTime} min</dd></div>
                  {breedName && <div><dt>Breed</dt><dd>{breedName}</dd></div>}
                </dl>
              </section>

              <AwinProductSlot topicTags={partnerTopicTags} pageType="blog" category={categoryKey} breedSize={breedSize} breedEnergy={breedEnergy} headline="Helpful dog resources" variant="compact" />

              {!isHealthSensitive && <PageBannerSlot pageType="blog" placement="sidebar" topic={categoryKey} topicTags={partnerTopicTags} compact={true} />}

              <section class="article-sidebar-card">
                <h2>Explore next</h2>
                <nav class="article-sidebar-nav">
                  <a href="/breeds"><span>🐕</span><strong>Breed explorer</strong></a>
                  <a href="/cost-calculator"><span>💰</span><strong>Dog cost calculator</strong></a>
                  <a href="/dog-names"><span>✍️</span><strong>Dog name generator</strong></a>
                  <a href="/how-we-test"><span>🔍</span><strong>How we research guides</strong></a>
                </nav>
              </section>

              <section class="article-sidebar-card article-sidebar-card--warm">
                <h2>Transparency</h2>
                <p>PupWiki may earn from some product and brand links. Health-sensitive content is general information and should not replace veterinary advice.</p>
                <div class="article-sidebar-links">
                  <a href="/disclosure">Full disclosure →</a>
                  <a href="/privacy">Privacy policy →</a>
                  <a href="/contact">Contact →</a>
                </div>
              </section>

              <slot name="sidebar" />
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
