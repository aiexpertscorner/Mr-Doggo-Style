---
/**
 * BlogLayout.astro
 * Layout for all blog/review posts.
 * Wraps BaseLayout, adds article header + sidebar structure.
 */

import BaseLayout  from './BaseLayout.astro';
import Breadcrumb  from '../components/ui/Breadcrumb.astro';

export interface Props {
  title:         string;
  description:   string;
  canonicalUrl?: string;
  pubDate:       string;
  updatedDate?:  string;
  category:      string;
  readTime?:     number;
  heroImage?:    string;
  heroImageAlt?: string;
  schema?:       object;
}

const {
  title,
  description,
  canonicalUrl,
  pubDate,
  updatedDate,
  category,
  readTime = 5,
  heroImage,
  heroImageAlt = title,
  schema,
} = Astro.props;

const categoryColors: Record<string, string> = {
  food:     'food',
  toys:     'toys',
  health:   'health',
  training: 'training',
  grooming: 'grooming',
  beds:     'beds',
};

const categoryBadge = categoryColors[category.toLowerCase()] ?? 'primary';
const displayDate   = new Date(updatedDate ?? pubDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout {title} {description} {canonicalUrl}>
  <Fragment slot="head">
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </Fragment>

  <!-- Article hero -->
  <header class="article-hero">
    <div class="article-hero__inner">
      <Breadcrumb
        items={[
          { label: 'Home', href: '/' },
          { label: 'Blog', href: '/blog' },
          { label: category, href: `/categories/${category.toLowerCase()}` },
          { label: title, current: true },
        ]}
      />

      <div class="article-hero__meta">
        <span class={`badge badge--${categoryBadge}`}>{category}</span>
        <span class="rating__count">{displayDate}</span>
        <span class="rating__count">·</span>
        <span class="rating__count">{readTime} min read</span>
      </div>

      <h1 class="article-hero__title">{title}</h1>
      <p class="article-hero__subtitle">{description}</p>

      {heroImage && (
        <div class="article-hero__image-wrap">
          <img
            src={heroImage}
            alt={heroImageAlt}
            class="article-hero__image"
            width="1280"
            height="480"
            loading="eager"
            decoding="sync"
          />
        </div>
      )}
    </div>
  </header>

  <!-- Affiliate disclosure -->
  <div class="container" style="padding-top:2rem">
    <p class="affiliate-note">
      <strong>Disclosure:</strong> Mr. Doggo Style may earn a small commission from qualifying purchases via affiliate links at no extra cost to you. We never accept products in exchange for positive reviews.
      <a href="/disclosure" class="link">Full policy →</a>
    </p>
  </div>

  <!-- Article body + sidebar -->
  <main class="container section">
    <div class="layout-sidebar">
      <!-- Article content -->
      <article class="prose" id="article-content">
        <slot />
      </article>

      <!-- Sidebar (sticky) -->
      <aside>
        <slot name="sidebar" />
      </aside>
    </div>
  </main>
</BaseLayout>
