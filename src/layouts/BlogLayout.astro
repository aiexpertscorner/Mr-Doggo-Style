---
/**
 * BlogLayout.astro
 * Layout for all blog/review posts.
 * Wraps BaseLayout, adds article header + sidebar structure.
 */

import BaseLayout           from './BaseLayout.astro';
import Breadcrumb           from '../components/ui/Breadcrumb.astro';
import AffiliateProductCard from '../components/ui/AffiliateProductCard.astro';
import affiliateProducts    from '../data/affiliate-products.json';

export interface Props {
  title:         string;
  description:   string;
  canonicalUrl?: string;
  pubDate:       string;
  updatedDate?:  string;
  category:      string;
  readTime?:     number;
  heroImage?:    string;
  heroImageAlt?: string;
  schema?:       object;
}

const {
  title,
  description,
  canonicalUrl,
  pubDate,
  updatedDate,
  category,
  readTime = 5,
  heroImage,
  heroImageAlt = title,
  schema,
} = Astro.props;

const categoryColors: Record<string, string> = {
  food:     'food',
  toys:     'toys',
  health:   'health',
  training: 'training',
  grooming: 'grooming',
  beds:     'beds',
};

const categoryBadge = categoryColors[category.toLowerCase()] ?? 'primary';

// Pick an affiliate product for the sidebar based on article category
const catL = category.toLowerCase();
const sidebarProductId =
  ['training', 'behaviour'].includes(catL)            ? 'jugbow-training-harness' :
  ['food', 'dog food', 'health', 'supplements'].includes(catL) ? 'chefpaw-1'     :
  'crown-noble';
const sidebarProduct = (affiliateProducts as any[]).find((p: any) => p.id === sidebarProductId);
const displayDate   = new Date(updatedDate ?? pubDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout {title} {description} {canonicalUrl}>
  <Fragment slot="head">
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </Fragment>

  <!-- Article hero -->
  <header class="article-hero">
    <div class="article-hero__inner">
      <Breadcrumb
        items={[
          { label: 'Home', href: '/' },
          { label: 'Blog', href: '/blog' },
          { label: category, href: `/categories/${category.toLowerCase()}` },
          { label: title, current: true },
        ]}
      />

      <div class="article-hero__meta">
        <span class={`badge badge--${categoryBadge}`}>{category}</span>
        <span class="rating__count">{displayDate}</span>
        <span class="rating__count">·</span>
        <span class="rating__count">{readTime} min read</span>
      </div>

      <h1 class="article-hero__title">{title}</h1>
      <p class="article-hero__subtitle">{description}</p>

      {heroImage && (
        <div class="article-hero__image-wrap">
          <img
            src={heroImage}
            alt={heroImageAlt}
            class="article-hero__image"
            width="1280"
            height="480"
            loading="eager"
            decoding="sync"
          />
        </div>
      )}
    </div>
  </header>

  <!-- Affiliate disclosure -->
  <div class="container" style="padding-top:2rem">
    <p class="affiliate-note">
      <strong>Disclosure:</strong> PupWiki may earn a small commission from qualifying purchases via affiliate links at no extra cost to you. We never accept products in exchange for positive reviews.
      <a href="/disclosure" class="link">Full policy →</a>
    </p>
  </div>

  <!-- Article body + sidebar -->
  <main class="container section">
    <div class="layout-sidebar">
      <!-- Article content -->
      <article class="prose" id="article-content">
        <slot />

        <!-- Mid-article email capture -->
        <div class="email-capture-strip not-prose" id="article-email-capture">
          <div class="email-capture-strip__icon" aria-hidden="true">🐾</div>
          <div class="email-capture-strip__content">
            <strong>Get our weekly breed + product picks</strong>
            <p>3 products · 1 deal · 1 breed spotlight — every Tuesday, free</p>
          </div>
          <form class="email-capture-strip__form" id="article-newsletter" action="#" method="POST">
            <input
              type="email"
              name="email"
              class="form-input"
              placeholder="your@email.com"
              required
              aria-label="Email address"
            />
            <button type="submit" class="btn btn--primary">Subscribe</button>
          </form>
          <p class="email-capture-strip__success" id="article-newsletter-success">
            ✓ You're in!
          </p>
        </div>
      </article>

      <!-- Sidebar (sticky) -->
      <aside>
        <!-- Affiliate product card — shown on all blog posts -->
        {sidebarProduct && (
          <div style="margin-bottom: var(--space-6);">
            <AffiliateProductCard
              product={sidebarProduct}
              headline={
                ['training','behaviour'].includes(catL)             ? 'Training gear we recommend'     :
                ['food','dog food','health','supplements'].includes(catL) ? 'Make fresh food at home' :
                'Gift for dog lovers'
              }
              variant="card"
            />
          </div>
        )}
        <slot name="sidebar" />
      </aside>
    </div>
  </main>

  <script>
    const form = document.getElementById('article-newsletter') as HTMLFormElement | null;
    const wrap = document.getElementById('article-email-capture');
    if (form && wrap) {
      form.addEventListener('submit', (e) => {
        // Remove preventDefault once real action URL is set
        e.preventDefault();
        wrap.classList.add('is-subscribed');
      });
    }
  </script>
</BaseLayout>
