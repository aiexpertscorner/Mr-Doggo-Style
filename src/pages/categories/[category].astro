---
/**
 * src/pages/categories/[category].astro
 *
 * Clean category hub route.
 * Heavy config, helper logic and layout sections live outside this page.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

import CategoryHero from '../../components/category/CategoryHero.astro';
import CategoryQuickNav from '../../components/category/CategoryQuickNav.astro';
import CategoryPartnerBlock from '../../components/category/CategoryPartnerBlock.astro';
import CategoryBreedGuides from '../../components/category/CategoryBreedGuides.astro';
import CategoryOwnerResources from '../../components/category/CategoryOwnerResources.astro';
import CategoryArticleGrid from '../../components/category/CategoryArticleGrid.astro';
import CategoryRelatedTopics from '../../components/category/CategoryRelatedTopics.astro';
import CategoryEmptyState from '../../components/category/CategoryEmptyState.astro';

import masterBreeds from '../../data/master-breeds.json';
import masterCrossbreeds from '../../data/master-crossbreeds.json';
import breedLinkMap from '../../data/breed-link-map.json';
import contentStatus from '../../data/content-status.json';

import {
  buildBreadcrumbLd,
  buildCollectionPageLd,
  buildItemListLd,
  getAwinTags,
  getCategoryBreedGuides,
  getCategoryLinks,
  getCategoryMeta,
  getCategoryPosts,
  getRelatedCategoryCards,
  isCategorySlug,
} from '../../lib/categories/categoryHelpers';

import '../../styles/pages/category-hub.css';

const SITE = 'https://pupwiki.com';

/**
 * Keep the slugs inside getStaticPaths.
 * This avoids Astro/Cloudflare scope issues where imported or outer constants
 * can fail during route-cache generation for dynamic pages.
 */
export function getStaticPaths() {
  return [
    'dog-food',
    'toys',
    'health',
    'training',
    'grooming',
    'beds',
    'supplements',
    'smart-tech',
    'travel',
    'lifestyle',
  ].map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const categorySlug = String(category || '');

if (!isCategorySlug(categorySlug)) return Astro.redirect('/categories');

const meta = getCategoryMeta(categorySlug)!;
const allPosts = await getCollection('blog');
const catPosts = getCategoryPosts(allPosts as any, categorySlug, meta);
const featuredPosts = catPosts.slice(0, 6);
const supportingPosts = catPosts.slice(6, 12);

const allBreedRecords = [...(masterBreeds as any[]), ...(masterCrossbreeds as any[])];

const breedGuides = getCategoryBreedGuides({
  categorySlug,
  allBreeds: allBreedRecords,
  breedLinkMap: breedLinkMap as any,
  contentStatus: contentStatus as any,
  limit: 10,
});

const featuredBreedGuides = breedGuides.slice(0, 6);
const breedChips = breedGuides.slice(0, 10);
const categoryLinks = getCategoryLinks(categorySlug);
const relatedCards = getRelatedCategoryCards(categorySlug);
const awinTags = getAwinTags(categorySlug, meta);

const breadcrumbLd = buildBreadcrumbLd(meta, categorySlug);
const collectionPageLd = buildCollectionPageLd(meta, categorySlug);
const itemListLd = buildItemListLd({
  meta,
  breedGuides: featuredBreedGuides,
  posts: featuredPosts as any,
});
---

<BaseLayout
  title={meta.seoTitle}
  description={meta.seoDescription}
  canonicalUrl={`${SITE}/categories/${categorySlug}`}
>
  <script type="application/ld+json" set:html={breadcrumbLd} />
  <script type="application/ld+json" set:html={collectionPageLd} />
  {itemListLd && <script type="application/ld+json" set:html={itemListLd} />}

  <main class:list={['category-hub', `category-hub--${meta.theme}`]}>
    <CategoryHero meta={meta} />

    <CategoryQuickNav
      hasPosts={featuredPosts.length > 0}
      hasBreedGuides={featuredBreedGuides.length > 0}
    />

    <CategoryPartnerBlock
      meta={meta}
      categorySlug={categorySlug}
      tags={awinTags.primary}
    />

    {breedChips.length >= 3 && (
      <section class="category-hub__strip" aria-label={`${meta.title} breed shortcuts`}>
        <div class="category-hub__container">
          <div class="category-hub__strip-header">
            <p>{meta.title} by breed</p>
            <a href="/breeds">All breeds →</a>
          </div>

          <div class="category-hub__chip-row">
            {breedChips.map((breed) => (
              <a href={breed.href}>{breed.name}</a>
            ))}
          </div>
        </div>
      </section>
    )}

    <CategoryBreedGuides
      meta={meta}
      guides={featuredBreedGuides}
    />

    <CategoryOwnerResources
      meta={meta}
      categorySlug={categorySlug}
      links={categoryLinks}
      tags={awinTags.secondary}
    />

    {featuredPosts.length > 0 && (
      <CategoryArticleGrid
        meta={meta}
        posts={featuredPosts}
        supportingPosts={supportingPosts}
        totalCount={catPosts.length}
      />
    )}

    <CategoryRelatedTopics
      meta={meta}
      cards={relatedCards}
    />

    {featuredPosts.length === 0 && featuredBreedGuides.length === 0 && (
      <CategoryEmptyState meta={meta} />
    )}
  </main>
</BaseLayout>
