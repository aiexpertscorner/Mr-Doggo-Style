---
/**
 * pages/categories/[category].astro
 */
import BaseLayout   from '../../layouts/BaseLayout.astro';
import BlogCard     from '../../components/content/BlogCard.astro';
import ProductCard  from '../../components/content/ProductCard.astro';
import Breadcrumb   from '../../components/ui/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import productsData from '../../data/products.json';

const CATEGORIES: Record<string, {
  title: string; desc: string; emoji: string;
  theme: string; reviewCount: number;
}> = {
  'dog-food': { title: 'Dog Food',     desc: 'Dry, wet, grain-free and breed-specific formulas independently tested for nutrition, quality and value.',      emoji: '🍖', theme: 'food',     reviewCount: 11 },
  'toys':     { title: 'Toys & Gear',  desc: 'Durable chew toys, interactive puzzles, harnesses, GPS trackers and more — ranked by real-world durability.', emoji: '🎾', theme: 'toys',     reviewCount: 12 },
  'health':   { title: 'Dog Health',   desc: 'Supplements, DNA tests, dental care and flea control reviewed for safety and efficacy by our expert panel.',   emoji: '🩺', theme: 'health',   reviewCount: 7  },
  'training': { title: 'Training',     desc: 'Harnesses, GPS collars, training treats and tools tested on dogs of all sizes and temperaments.',              emoji: '🦮', theme: 'training', reviewCount: 9  },
  'grooming': { title: 'Grooming',     desc: 'Brushes, shampoos, nail trimmers and professional-grade grooming tools reviewed by coat type.',               emoji: '✂️', theme: 'grooming', reviewCount: 6  },
  'beds':     { title: 'Beds & Sleep', desc: 'Orthopedic, elevated and crate beds tested for support, durability and ease of cleaning.',                    emoji: '🛏️', theme: 'beds',     reviewCount: 6  },
};

export function getStaticPaths() {
  return Object.keys(CATEGORIES).map(slug => ({ params: { category: slug } }));
}

const { category } = Astro.params;
const meta         = CATEGORIES[category];
const allPosts     = await getCollection('blog');

const catPosts = allPosts.filter(
  p => (p.data.category ?? '').toLowerCase().replace(/\s+/g, '-') === category
);

type ProductEntry = { name: string; asin: string; price?: number; rating?: number; image?: string; features?: string[] };
const products: ProductEntry[] = (productsData as Record<string, ProductEntry[]>)[category] ?? [];
---

<BaseLayout
  title={`${meta.title} Reviews 2026 — Expert Picks | Mr. Doggo Style`}
  description={meta.desc}
  canonicalUrl={`https://mrdoggostyle.com/categories/${category}`}
>

  <div class="page-hero">
    <div class="container page-hero__inner">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Categories', href: '/categories' },
        { label: meta.title, current: true },
      ]} />

      <h1 class="page-hero__title">
        <span aria-hidden="true">{meta.emoji}</span> {meta.title} <em>Reviews</em>
      </h1>
      <p class="page-hero__desc">{meta.desc}</p>

      <div class="flex gap-3" style="margin-top: var(--space-6)">
        <span class="badge badge--primary">{meta.reviewCount} products reviewed</span>
        <span class="badge badge--muted">Updated March 2026</span>
        <span class="badge badge--success">Expert verified</span>
      </div>
    </div>
  </div>

  <main class="section">
    <div class="container">

      <!-- Top products -->
      {products.length > 0 && (
        <section aria-labelledby="products-heading" style="margin-bottom: var(--space-16)">
          <div class="section-header">
            <div>
              <span class="section-eyebrow">Our picks</span>
              <h2 class="section-title" id="products-heading">Top Ranked {meta.title}</h2>
            </div>
          </div>
          <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(240px, 1fr))">
            {products.slice(0, 6).map((p, i) => (
              <ProductCard
                name={p.name}
                asin={p.asin}
                price={p.price}
                rating={p.rating}
                image={p.image}
                features={p.features}
                badge={i === 0 ? "Editor's Pick" : i === 1 ? 'Best Seller' : undefined}
                badgeTheme={i === 0 ? 'accent' : 'success'}
              />
            ))}
          </div>
        </section>
      )}

      <!-- Category posts -->
      {catPosts.length > 0 && (
        <section aria-labelledby="guides-heading">
          <div class="section-header">
            <div>
              <span class="section-eyebrow">In-depth guides</span>
              <h2 class="section-title" id="guides-heading">{meta.title} Guides</h2>
            </div>
            <span style="color: var(--color-muted); font-size: var(--text-sm)">{catPosts.length} articles</span>
          </div>
          <div class="grid grid-3">
            {catPosts.map(post => (
              <BlogCard
                title={post.data.title}
                excerpt={post.data.description ?? ''}
                category={post.data.category ?? meta.title}
                href={`/blog/${post.slug}`}
                pubDate={post.data.pubDate}
                image={post.data.heroImage}
              />
            ))}
          </div>
        </section>
      )}

    </div>
  </main>

</BaseLayout>
