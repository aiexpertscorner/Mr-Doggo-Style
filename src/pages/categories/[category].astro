export function getStaticPaths() {
  return Object.keys(CATEGORIES).map((slug) => ({ params: { category: slug } }));
}

const { category } = Astro.params;
const categorySlug = String(category || '');
const meta = CATEGORIES[categorySlug];

if (!meta) return Astro.redirect('/categories');

const normalize = (value?: unknown) =>
  String(value ?? '')
    .trim()
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');

const toDateValue = (value: unknown) => {
  if (!value) return 0;
  const date = value instanceof Date ? value : new Date(String(value));
  const time = date.getTime();
  return Number.isFinite(time) ? time : 0;
};

const toIsoString = (value: unknown) => {
  if (!value) return undefined;
  const date = value instanceof Date ? value : new Date(String(value));
  return Number.isFinite(date.getTime()) ? date.toISOString() : undefined;
};

const allPosts = await getCollection('blog');

const catPosts = allPosts
  .filter((post) => {
    const postCategory = normalize(post.data.category);
    const tags = Array.isArray(post.data.tags) ? post.data.tags.map(normalize) : [];

    return postCategory === categorySlug || tags.includes(categorySlug) || tags.includes(meta.theme);
  })
  .sort((a, b) => toDateValue(b.data.pubDate) - toDateValue(a.data.pubDate));

const featuredPosts = catPosts.slice(0, 6);
const supportingPosts = catPosts.slice(6, 12);

const CAT_TO_LINK_KEY: Record<string, string | null> = {
