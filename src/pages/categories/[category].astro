const RELATED_CATEGORIES: Record<string, string[]> = {
  'dog-food': ['supplements', 'health', 'cost-calculator', 'training'],
  toys: ['training', 'smart-tech', 'travel', 'lifestyle'],
  health: ['supplements', 'dog-food', 'cost-calculator', 'grooming'],
  training: ['toys', 'smart-tech', 'travel', 'dog-food'],
  grooming: ['health', 'supplements', 'beds', 'dog-food'],
  beds: ['health', 'lifestyle', 'travel', 'grooming'],
  supplements: ['health', 'dog-food', 'cost-calculator', 'grooming'],
  'smart-tech': ['training', 'travel', 'toys', 'health'],
  travel: ['training', 'smart-tech', 'beds', 'lifestyle'],
  lifestyle: ['beds', 'travel', 'toys', 'dog-food'],
};

const SPECIAL_LINKS: Record<string, { title: string; desc: string; href: string; icon: string }> = {
  'cost-calculator': {
    title: 'Cost Calculator',
    desc: 'Estimate breed-specific food, vet, grooming and lifetime costs.',
    href: '/cost-calculator',
    icon: '💰',
  },
};

const categoryLinks = CATEGORY_LINK_BLOCKS[categorySlug] ?? [];

const relatedCategoryCards = (RELATED_CATEGORIES[categorySlug] ?? [])
  .map((slug) => {
    if (SPECIAL_LINKS[slug]) return SPECIAL_LINKS[slug];

    const related = CATEGORIES[slug];
    if (!related) return null;

    return {
      title: related.title,
      desc: related.desc,
      href: `/categories/${slug}`,
      icon: related.emoji,
    };
  })
  .filter(Boolean) as { title: string; desc: string; href: string; icon: string }[];

const linkKey = CAT_TO_LINK_KEY[categorySlug];
const allBreedRecords = [...(masterBreeds as any[]), ...(masterCrossbreeds as any[])];

const preferredBreedSlugs = [
  'bulldog',
  'french-bulldog',
  'golden-retriever',
  'labrador-retriever',
  'german-shepherd',
  'beagle',
  'poodle-standard',
  'dachshund',
  'boxer',
  'border-collie',
  'cavalier-king-charles-spaniel',
  'goldendoodle',
];

const sortedBreeds = [...allBreedRecords].sort((a, b) => {
  const aIndex = preferredBreedSlugs.indexOf(a.slug);
  const bIndex = preferredBreedSlugs.indexOf(b.slug);

  if (aIndex !== -1 || bIndex !== -1) {
    return (aIndex === -1 ? 999 : aIndex) - (bIndex === -1 ? 999 : bIndex);
  }

  return String(a.name || '').localeCompare(String(b.name || ''));
});

const breedGuides = linkKey
  ? sortedBreeds
      .filter((breed) => breed?.slug && (contentStatus as any)[breed.slug]?.[linkKey] === true)
      .slice(0, 10)
      .map((breed) => ({
        name: breed.name,
        slug: breed.slug,
        size: breed.size_category,
        energy: breed.energy_level,
        href: (breedLinkMap as any)[breed.slug]?.[linkKey] ?? `/breeds/${breed.slug}`,
      }))
  : sortedBreeds
      .filter((breed) => breed?.slug && breed?.name)
      .slice(0, 10)
      .map((breed) => ({
        name: breed.name,
        slug: breed.slug,
        size: breed.size_category,
        energy: breed.energy_level,
        href: `/breeds/${breed.slug}`,
      }));

const featuredBreedGuides = breedGuides.slice(0, 6);
const breedChips = breedGuides.slice(0, 10);

const collectionPageLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${meta.title} Guides`,
  description: meta.seoDescription,
  url: `${SITE}/categories/${categorySlug}`,
  isPartOf: {
    '@type': 'WebSite',
    name: 'PupWiki',
    url: SITE,
  },
});

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: meta.title, item: `${SITE}/categories/${categorySlug}` },
  ],
});

const itemListEntries = [
  ...featuredBreedGuides.map((guide, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: `${guide.name} ${meta.shortTitle} Guide`,
    url: `${SITE}${guide.href}`,
  })),
  ...featuredPosts.slice(0, 6).map((post, index) => ({
    '@type': 'ListItem',
    position: featuredBreedGuides.length + index + 1,
    name: post.data.title,
    url: `${SITE}/blog/${post.slug}`,
  })),
];

const itemListLd = itemListEntries.length
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      itemListElement: itemListEntries,
    })
  : null;
---

<BaseLayout
  title={meta.seoTitle}
  description={meta.seoDescription}
  canonicalUrl={`${SITE}/categories/${categorySlug}`}
>
  <script type="application/ld+json" set:html={breadcrumbLd} />
  <script type="application/ld+json" set:html={collectionPageLd} />
  {itemListLd && <script type="application/ld+json" set:html={itemListLd} />}

  <main class:list={['category-page', `category-page--${meta.theme}`]}>
    <section class="category-hero" aria-labelledby="category-title">
      <div class="category-container">
        <Breadcrumb items={[
          { label: 'Home', href: '/' },
          { label: meta.title, current: true },
        ]} />

        <div class="category-hero__grid">
          <div class="category-hero__content">
            <p class="category-eyebrow">
              <span aria-hidden="true">{meta.emoji}</span>
              {meta.heroLabel}
            </p>

            <h1 id="category-title">
              {meta.title}
              <em>guides for dog owners</em>
            </h1>

            <p class="category-hero__desc">{meta.desc}</p>

            <div class="category-hero__actions">
              <a href={meta.primaryCta.href} class="category-button category-button--primary">
                {meta.primaryCta.label}
                <span aria-hidden="true">→</span>
              </a>
              <a href={meta.secondaryCta.href} class="category-button category-button--secondary">
                {meta.secondaryCta.label}
              </a>
            </div>

            <ul class="category-badges" aria-label={`${meta.title} page highlights`}>
              <li>{meta.updatedLabel}</li>
              <li>Breed-specific resources</li>
              <li>Affiliate-supported picks</li>
            </ul>
          </div>

          <aside class="category-hero-card" aria-label={`${meta.title} quick overview`}>
            <span class="category-hero-card__emoji" aria-hidden="true">{meta.emoji}</span>
            <p>Owner resource hub</p>
            <strong>{meta.shortTitle}</strong>
            <span>
              Browse breed-specific pages, related guides, and partner resources matched to this topic.
            </span>
          </aside>
        </div>
      </div>
    </section>

    <nav class="category-quick-nav" aria-label="Category quick links">
      <div class="category-container category-quick-nav__inner">
        <a href="#partner-resource">Partner resource</a>
        <a href="#breed-guides">Breed guides</a>
        <a href="#owner-resources">Owner resources</a>
        {featuredPosts.length > 0 && <a href="#latest-guides">Latest guides</a>}
        <a href="#related-topics">Related topics</a>
      </div>
    </nav>

    <section id="partner-resource" class="category-section category-section--partner">
      <div class="category-container">
        <div class="category-partner-grid">
          <div class="category-section-header">
