---
/**
 * pages/categories/[category].astro
 */
import BaseLayout  from '../../layouts/BaseLayout.astro';
import BlogCard    from '../../components/content/BlogCard.astro';
import ProductCard from '../../components/content/ProductCard.astro';
import Breadcrumb  from '../../components/ui/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import productsData from '../../data/products.json';

// ── CATEGORIES must be defined at module scope so both
//    getStaticPaths AND the component body can access it ──────
const CATEGORIES: Record<string, {
  title: string; desc: string; emoji: string;
  theme: string; reviewCount: number;
}> = {
  'dog-food':   { title: 'Dog Food',       desc: 'Dry, wet, grain-free and breed-specific formulas independently tested for nutrition, quality and value.',        emoji: '🍖', theme: 'food',      reviewCount: 24 },
  'toys':       { title: 'Toys & Gear',    desc: 'Durable chew toys, interactive puzzles, harnesses, GPS trackers and more — ranked by real-world durability.',   emoji: '🎾', theme: 'toys',      reviewCount: 20 },
  'health':     { title: 'Dog Health',     desc: 'DNA tests, flea control, dental care and wound care reviewed for safety and efficacy by our expert panel.',      emoji: '🩺', theme: 'health',    reviewCount: 15 },
  'training':   { title: 'Training',       desc: 'Harnesses, GPS collars, training leads and tools tested on dogs of all sizes and temperaments.',                 emoji: '🦮', theme: 'training',  reviewCount: 9  },
  'grooming':   { title: 'Grooming',       desc: 'Brushes, shampoos, nail trimmers and professional-grade grooming tools reviewed by coat type.',                  emoji: '✂️', theme: 'grooming',  reviewCount: 12 },
  'beds':       { title: 'Beds & Sleep',   desc: 'Orthopedic, elevated, calming and travel beds tested for support, durability and ease of cleaning.',             emoji: '🛏️', theme: 'beds',      reviewCount: 13 },
  'supplements':{ title: 'Supplements',    desc: 'Joint, probiotic, omega-3 and calming supplements reviewed for quality, efficacy and value.',                    emoji: '💊', theme: 'health',    reviewCount: 10 },
  'smart-tech': { title: 'Smart Tech',     desc: 'AI health collars, GPS trackers, pet cameras and smart feeders — the best connected gear for 2026.',             emoji: '📡', theme: 'health',    reviewCount: 10 },
  'travel':     { title: 'Travel',         desc: 'Carriers, car seat covers, travel bowls and crash-tested crates for dogs on the go.',                           emoji: '✈️', theme: 'training',  reviewCount: 5  },
  'lifestyle':  { title: 'Lifestyle',      desc: 'Aesthetic harnesses, premium bowls, leashes and accessories designed for the modern dog-friendly home.',         emoji: '🎨', theme: 'training',  reviewCount: 7  },
};

// getStaticPaths can now access CATEGORIES (module-level const)
export function getStaticPaths() {
  const CATS = {
    'dog-food': true, 'toys': true, 'health': true, 'training': true,
    'grooming': true, 'beds': true, 'supplements': true, 'smart-tech': true,
    'travel': true, 'lifestyle': true,
  };
  return Object.keys(CATS).map(slug => ({ params: { category: slug } }));
}

const { category } = Astro.params;
const meta         = CATEGORIES[category];
const allPosts     = await getCollection('blog');

const catPosts = allPosts.filter(
  p => (p.data.category ?? '').toLowerCase().replace(/\s+/g, '-') === category
);

type ProductEntry = {
  name: string; asin: string; price?: number; rating?: number;
  image?: string; features?: string[];
};
const products: ProductEntry[] = (productsData as Record<string, ProductEntry[]>)[category] ?? [];
---

<BaseLayout
  title={`${meta.title} Reviews 2026 — Expert Picks | Mr. Doggo Style`}
  description={meta.desc}
  canonicalUrl={`https://mrdoggostyle.com/categories/${category}`}
>

  <div class="page-hero">
    <div class="container page-hero__inner">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Categories', href: '/' },
        { label: meta.title, current: true },
      ]} />
      <h1 class="page-hero__title">
        <span aria-hidden="true">{meta.emoji}</span> {meta.title} <em>Reviews</em>
      </h1>
      <p class="page-hero__desc">{meta.desc}</p>
      <div class="flex gap-3" style="margin-top: var(--space-6); flex-wrap: wrap">
        <span class="badge badge--primary">{meta.reviewCount} products reviewed</span>
        <span class="badge badge--muted">Updated March 2026</span>
        <span class="badge badge--success">Expert verified</span>
      </div>
    </div>
  </div>

  <main class="section">
    <div class="container">

      {products.length > 0 && (
        <section aria-labelledby="products-heading" style="margin-bottom: var(--space-16)">
          <div class="section-header">
            <div>
              <span class="section-eyebrow">Our picks</span>
              <h2 class="section-title" id="products-heading">Top Ranked {meta.title}</h2>
            </div>
          </div>
          <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: var(--space-6)">
            {products.slice(0, 6).map((p, i) => (
              <ProductCard
                name={p.name}
                asin={p.asin}
                price={p.price}
                rating={p.rating}
                image={p.image}
                features={p.features}
                badge={i === 0 ? "Editor's Pick" : i === 1 ? 'Best Seller' : undefined}
                badgeTheme={i === 0 ? 'accent' : 'success'}
              />
            ))}
          </div>
        </section>
      )}

      {catPosts.length > 0 && (
        <section aria-labelledby="guides-heading">
          <div class="section-header">
            <div>
              <span class="section-eyebrow">In-depth guides</span>
              <h2 class="section-title" id="guides-heading">{meta.title} Guides</h2>
            </div>
            <span style="color: var(--color-muted); font-size: var(--text-sm)">{catPosts.length} articles</span>
          </div>
          <div class="grid grid-3">
            {catPosts.map(post => (
              <BlogCard
                title={post.data.title}
                excerpt={post.data.description ?? ''}
                category={post.data.category ?? meta.title}
                href={`/blog/${post.slug}`}
                pubDate={post.data.pubDate}
                image={post.data.heroImage}
              />
            ))}
          </div>
        </section>
      )}

      {products.length === 0 && catPosts.length === 0 && (
        <div style="text-align: center; padding: var(--space-20) 0; color: var(--color-muted)">
          <p style="font-size: var(--text-lg)">Content voor {meta.title} komt binnenkort.</p>
          <a href="/" class="btn btn--outline" style="margin-top: var(--space-6)">← Terug naar home</a>
        </div>
      )}

    </div>
  </main>

</BaseLayout>
