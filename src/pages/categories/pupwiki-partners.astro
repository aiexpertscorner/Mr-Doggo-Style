---
import BaseLayout from '../../layouts/BaseLayout.astro';

import awinData from '../../data/awin-programs.json';
import products from '../../data/awin-products.json';
import bannerRegistry from '../../data/affiliate-banners.json';
import partnerSummary from '../../data/pupwiki-partners-summary.json';

const SITE = 'https://pupwiki.com';
const activePrograms = ((awinData as any).programs || []).filter((program: any) => program.relationship === 'joined' && program.isActive !== false);
const allProducts = Array.isArray(products) ? products : [];
const banners = Array.isArray(bannerRegistry) ? bannerRegistry : ((bannerRegistry as any).banners || []);
const summaryPartners = ((partnerSummary as any).partners || []) as any[];

function titleCase(value: string) {
  return String(value || '').replace(/[-_]+/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
}
function resourceStatus(program: any) {
  const hasProducts = productCount(program) > 0;
  const hasCreative = creativeCount(program) > 0;
  if (hasProducts && hasCreative) return 'Product details and brand imagery available';
  if (hasProducts) return 'Product details available';
  if (hasCreative || program.logoUrl) return 'Brand profile available';
  return 'Brand site review recommended';
}
function clusterFor(program: any) {
  const blob = [program.name, program.primarySector, ...(program.topicTags || [])].join(' ').toLowerCase();
  if (/food|nutrition|broth|fresh|raw|feeding/.test(blob)) return { label: 'Food & nutrition', href: '/categories/dog-food', icon: '🍖' };
  if (/training|leash|harness|collar|fence|obedience|gear/.test(blob)) return { label: 'Training & gear', href: '/categories/training', icon: '🦮' };
  if (/gift|portrait|memorial|license|lifestyle|apparel|accessor/.test(blob)) return { label: 'Lifestyle & gifts', href: '/categories/lifestyle', icon: '🎁' };
  if (/bed|sleep|comfort|home/.test(blob)) return { label: 'Beds & comfort', href: '/categories/beds', icon: '🛏️' };
  if (/health|insurance|vet|wellness|supplement/.test(blob)) return { label: 'Health & wellness', href: '/categories/health', icon: '🩺' };
  return { label: 'Dog owner resources', href: '/categories/pupwiki-partners', icon: '🐾' };
}
function productCount(program: any) {
  return allProducts.filter((product: any) => String(product.advertiserId || '') === String(program.advertiserId || '') || String(product.programId || '') === String(program.key || '')).length;
}
function creativeCount(program: any) {
  return banners.filter((banner: any) => String(banner.advertiserId || '') === String(program.advertiserId || '') || String(banner.programKey || '') === String(program.key || '')).length;
}
function profileHref(program: any) {
  const match = summaryPartners.find((item) => item.key === program.key);
  return match?.href || `/blog/partner-${program.key}`;
}

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'PupWiki Dog Brand Guides',
    description: 'Dog-focused brand and product guides for owners comparing food, training gear, comfort products, lifestyle gifts, and care resources.',
    url: `${SITE}/categories/pupwiki-partners`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'PupWiki dog brand resources',
    itemListElement: activePrograms.map((program: any, index: number) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: program.name,
      url: `${SITE}${profileHref(program)}`,
    })),
  },
];
---

<BaseLayout
  title="Dog Brand Guides — PupWiki Product & Service Resources"
  description="Explore PupWiki dog brand guides: food, training gear, comfort, lifestyle gifts, and care resources with practical fit notes for dog owners."
  canonicalUrl={`${SITE}/categories/pupwiki-partners`}
  pageType="collection"
  bodyClass="pw-page"
  structuredData={structuredData}
>
  <main class="pw-page">
    <section class="pw-section pw-section--soft">
      <div class="pw-container pw-stack pw-stack--lg">
        <nav class="pw-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a><span aria-hidden="true">›</span><span>Dog Brand Guides</span>
        </nav>

        <div class="pw-page-header pw-stack">
          <p class="pw-eyebrow">🐾 Dog owner resources</p>
          <h1 class="pw-title-xl">Dog Brand Guides</h1>
          <p class="pw-lede">
            Compare dog-focused brands and resources by product type, owner use case, safety notes, and practical buying questions.
            Each guide is written for dog owners first: what the brand offers, when it may fit, and what to check before you buy.
          </p>
        </div>

        <div class="pw-grid pw-grid--3">
          <article class="pw-stat-card"><strong>{activePrograms.length}</strong><span>Brand guides</span></article>
          <article class="pw-stat-card"><strong>{allProducts.length}</strong><span>Products to review</span></article>
          <article class="pw-stat-card"><strong>{banners.length}</strong><span>Brand resources</span></article>
        </div>
      </div>
    </section>

    <section class="pw-section">
      <div class="pw-container pw-stack pw-stack--lg">
        <div class="pw-section-head">
          <p class="pw-eyebrow">Featured resources</p>
          <h2 class="pw-title-md">Dog brands and products worth comparing</h2>
          <p>Use these pages as a starting point. Confirm current product details, ingredients, sizing, shipping, subscriptions, returns, and suitability for your dog on the brand site before buying.</p>
        </div>

        <div class="pw-grid pw-grid--3">
          {activePrograms.map((program: any) => {
            const cluster = clusterFor(program);
            return (
              <article class="pw-card pw-card--interactive pw-stack partner-card">
                <div class="pw-cluster partner-card__top">
                  {program.logoUrl ? <img class="partner-card__logo" src={program.logoUrl} alt={`${program.name} logo`} width="64" height="64" loading="lazy" decoding="async" /> : <span class="pw-chip pw-chip--accent">🐾</span>}
                  <a class="pw-chip pw-chip--primary" href={cluster.href}>{cluster.icon} {cluster.label}</a>
                </div>

                <div>
                  <h3 class="partner-card__title">{program.name}</h3>
                  <p class="partner-card__meta">
                    {program.primarySector || 'Dog resource'} · {resourceStatus(program)}
                  </p>
                </div>

                <div class="pw-cluster">
                  {(program.topicTags || []).slice(0, 4).map((tag: string) => <span class="pw-chip">{titleCase(tag)}</span>)}
                </div>

                <dl class="pw-grid pw-grid--2 partner-card__stats">
                  <div class="pw-note partner-card__stat"><strong>{productCount(program)}</strong><br />Products</div>
                  <div class="pw-note partner-card__stat"><strong>{cluster.label}</strong><br />Main fit</div>
                </dl>

                <div class="pw-cluster partner-card__actions">
                  <a class="pw-btn pw-btn--primary" href={profileHref(program)}>Read guide</a>
                  <a class="pw-btn pw-btn--outline" href={program.deeplink || program.clickThroughUrl} target="_blank" rel="sponsored noopener">Visit brand site</a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="pw-section pw-section--muted pw-section--bordered">
      <div class="pw-container pw-stack pw-stack--lg">
        <div class="pw-section-head">
          <p class="pw-eyebrow">How to compare</p>
          <h2 class="pw-title-md">What to check before choosing a dog brand</h2>
          <p>Good dog-owner decisions are practical: match the product to your dog’s size, age, health context, training routine, home setup, and budget.</p>
        </div>

        <div class="pw-grid pw-grid--3">
          <article class="pw-card pw-stack partner-rule-card"><span class="pw-chip pw-chip--accent">1</span><h3>Match the dog</h3><p>Start with age, size, chewing style, coat type, activity level, sensitivities, and daily routine.</p></article>
          <article class="pw-card pw-stack partner-rule-card"><span class="pw-chip pw-chip--accent">2</span><h3>Check current details</h3><p>Review ingredients, materials, sizing, shipping, subscriptions, returns, and availability before buying.</p></article>
          <article class="pw-card pw-stack partner-rule-card"><span class="pw-chip pw-chip--accent">3</span><h3>Stay cautious with health</h3><p>For food, supplements, insurance, or vet-adjacent choices, use brand pages as research and ask a professional when needed.</p></article>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
