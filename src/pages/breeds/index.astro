---
/**
 * breeds/index.astro — Breed directory
 * Filter by size, energy, coat. Search by name.
 */
import BaseLayout  from '../../layouts/BaseLayout.astro';
import Breadcrumb  from '../../components/ui/Breadcrumb.astro';
import masterBreeds from '../../data/master-breeds.json';

const breeds = masterBreeds as any[];
const COAT_ICONS: Record<string,string> = {
  double:'🌀', long:'💫', short:'✨', wiry:'🔧', curly:'🔄',
  silky:'🌟', corded:'🪢', hairless:'⭕', wavy:'〰️', medium:'🐾',
};
const SIZE_EMOJI: Record<string,string> = { small:'🐕', medium:'🐕‍🦺', large:'🐕‍🦺', giant:'🦮' };
---

<BaseLayout
  title="Dog Breed Directory 2026 — 277 Breeds with Expert Care Guides"
  description="Browse all 277 dog breeds. Filter by size, energy and coat type. Each breed has expert product picks, care guides and health info."
  canonicalUrl="https://mrdoggostyle.com/breeds"
>

  <div class="page-hero">
    <div class="container page-hero__inner">
      <Breadcrumb items={[{ label:'Home', href:'/' }, { label:'All Breeds', current:true }]} />
      <h1 class="page-hero__title">Dog Breed Directory</h1>
      <p class="page-hero__desc">{breeds.length} breeds — each with expert product picks, care guides and health info.</p>
      <div style="display:flex;flex-wrap:wrap;gap:var(--space-2);margin-top:var(--space-4)">
        <span class="badge badge--primary">{breeds.length} breeds</span>
        <span class="badge badge--muted">Expert picks per breed</span>
        <span class="badge badge--muted">Updated 2026</span>
      </div>
    </div>
  </div>

  <main class="section">
    <div class="container">

      <!-- Filters -->
      <div style="margin-bottom:var(--space-6);display:flex;flex-direction:column;gap:var(--space-3)">

        <div>
          <p style="font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--color-muted);margin-bottom:var(--space-2)">Size</p>
          <div class="breed-filters">
            <button class="breed-filter-btn active" data-filter="size" data-value="all">All</button>
            <button class="breed-filter-btn" data-filter="size" data-value="small">🐕 Small</button>
            <button class="breed-filter-btn" data-filter="size" data-value="medium">🐕‍🦺 Medium</button>
            <button class="breed-filter-btn" data-filter="size" data-value="large">🐕‍🦺 Large</button>
            <button class="breed-filter-btn" data-filter="size" data-value="giant">🦮 Giant</button>
          </div>
        </div>

        <div>
          <p style="font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--color-muted);margin-bottom:var(--space-2)">Energy</p>
          <div class="breed-filters">
            <button class="breed-filter-btn active" data-filter="energy" data-value="all">All</button>
            <button class="breed-filter-btn" data-filter="energy" data-value="active">⚡ Active</button>
            <button class="breed-filter-btn" data-filter="energy" data-value="regular">🚶 Regular</button>
            <button class="breed-filter-btn" data-filter="energy" data-value="calm">😴 Calm</button>
          </div>
        </div>

        <div>
          <p style="font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--color-muted);margin-bottom:var(--space-2)">Trainability</p>
          <div class="breed-filters">
            <button class="breed-filter-btn active" data-filter="training" data-value="all">All</button>
            <button class="breed-filter-btn" data-filter="training" data-value="easy">🟢 Easy</button>
            <button class="breed-filter-btn" data-filter="training" data-value="moderate">🟡 Moderate</button>
            <button class="breed-filter-btn" data-filter="training" data-value="difficult">🔴 Independent</button>
          </div>
        </div>

        <div style="display:flex;align-items:center;gap:var(--space-4)">
          <input
            type="search"
            id="breed-search"
            placeholder="Search breeds…"
            style="flex:1;max-width:320px;padding:var(--space-2) var(--space-4);border:1px solid var(--color-border);border-radius:var(--radius-lg);font-size:var(--text-sm);background:var(--color-bg);color:var(--color-body);outline:none"
            aria-label="Search breeds"
          />
          <span id="breed-count" style="font-size:var(--text-sm);color:var(--color-muted)">{breeds.length} breeds</span>
          <button id="clear-btn" style="font-size:var(--text-xs);color:var(--color-primary);background:none;border:none;cursor:pointer;text-decoration:underline;display:none">Clear filters</button>
        </div>
      </div>

      <!-- Grid -->
      <div id="breed-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:var(--space-4)">
        {breeds.map(b => (
          <a
            href={`/breeds/${b.slug}`}
            class="breed-card"
            data-size={b.size_category}
            data-energy={b.energy_level}
            data-training={b.training_level}
            data-name={b.name.toLowerCase()}
          >
            <div class="breed-card__image-placeholder" style="height:130px;font-size:2.5rem">
              {SIZE_EMOJI[b.size_category]||'🐕'}
            </div>
            <div class="breed-card__body">
              <h3 class="breed-card__name">{b.name}</h3>
              {b.akc_group && <p class="breed-card__group">{b.akc_group.replace(' Group','')}</p>}
              <div class="breed-card__badges">
                <span style="font-size:10px;padding:2px 7px;background:var(--color-bg-muted);border-radius:99px;color:var(--color-muted)">{b.size_category}</span>
                <span style="font-size:10px;padding:2px 7px;background:var(--color-bg-muted);border-radius:99px;color:var(--color-muted)">{b.energy_level}</span>
                <span style="font-size:10px;padding:2px 7px;background:var(--color-bg-muted);border-radius:99px;color:var(--color-muted)" title={b.coat_type}>{COAT_ICONS[b.coat_type]||'🐾'}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div id="no-results" style="display:none;text-align:center;padding:var(--space-16) 0;color:var(--color-muted)">
        <p style="font-size:var(--text-lg);margin-bottom:var(--space-4)">No breeds match your filters.</p>
        <button id="clear-btn-2" style="color:var(--color-primary);background:none;border:none;cursor:pointer;font-size:var(--text-base);text-decoration:underline">Clear all filters</button>
      </div>

    </div>
  </main>

</BaseLayout>

<script>
  let activeFilters: Record<string,string> = { size:'all', energy:'all', training:'all' };
  let searchQ = '';

  function applyFilters() {
    const cards = document.querySelectorAll<HTMLElement>('#breed-grid .breed-card');
    let n = 0;
    cards.forEach(card => {
      const show =
        (activeFilters.size     === 'all' || card.dataset.size     === activeFilters.size) &&
        (activeFilters.energy   === 'all' || card.dataset.energy   === activeFilters.energy) &&
        (activeFilters.training === 'all' || card.dataset.training === activeFilters.training) &&
        (!searchQ || (card.dataset.name||'').includes(searchQ));
      card.style.display = show ? '' : 'none';
      if (show) n++;
    });
    (document.getElementById('breed-count') as any).textContent = `${n} breeds`;
    (document.getElementById('no-results') as any).style.display = n === 0 ? '' : 'none';
    const hasFilter = Object.values(activeFilters).some(v => v !== 'all') || !!searchQ;
    (document.getElementById('clear-btn') as any).style.display = hasFilter ? '' : 'none';
  }

  document.querySelectorAll('[data-filter]').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter!;
      const value  = (btn as HTMLElement).dataset.value!;
      document.querySelectorAll(`[data-filter="${filter}"]`).forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilters[filter] = value;
      applyFilters();
    });
  });

  (document.getElementById('breed-search') as HTMLInputElement)?.addEventListener('input', e => {
    searchQ = (e.target as HTMLInputElement).value.toLowerCase().trim();
    applyFilters();
  });

  function clearAll() {
    activeFilters = { size:'all', energy:'all', training:'all' };
    searchQ = '';
    (document.getElementById('breed-search') as HTMLInputElement).value = '';
    document.querySelectorAll('.breed-filter-btn').forEach(b => {
      b.classList.toggle('active', (b as HTMLElement).dataset.value === 'all');
    });
    applyFilters();
  }

  document.getElementById('clear-btn')?.addEventListener('click', clearAll);
  document.getElementById('clear-btn-2')?.addEventListener('click', clearAll);
</script>
