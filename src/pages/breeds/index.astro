---
/**
 * src/pages/breeds/index.astro — PupWiki Breed Finder / Directory
 *
 * Enhanced rebuild:
 * - Uses normalized breed data from src/lib/breeds/*.
 * - Includes master breeds + crossbreeds.
 * - Mobile-first search, quick filters, advanced filters and active chips.
 * - URL-state ready: /breeds/?size=small&energy=calm&q=bulldog
 * - Robust image fallbacks and guide availability chips.
 * - No inline utility-heavy layout; page styles live in src/styles/pages/breed-directory.css.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import masterBreeds from '../../data/master-breeds.json';
import masterCrossbreeds from '../../data/master-crossbreeds.json';
import breedLinkMap from '../../data/breed-link-map.json';
import contentStatus from '../../data/content-status.json';
import '../../styles/pages/breed-directory.css';

import {
  normalizeBreedList,
  serializeBreedForClient,
  type NormalizedBreed,
} from '../../lib/breeds/normalizeBreed';

import {
  createBreedFilterOptions,
  filterBreedRecords,
  getCollectionLinks,
  QUICK_BREED_FILTERS,
} from '../../lib/breeds/filterBreeds';

const SITE = 'https://pupwiki.com';

const rawBreeds = [
  ...(masterBreeds as any[]),
  ...(masterCrossbreeds as any[]),
];

const breeds = normalizeBreedList(rawBreeds, {
  breedLinkMap: breedLinkMap as any,
  contentStatus: contentStatus as any,
});

const filterOptions = createBreedFilterOptions(breeds);
const recommendedBreeds = filterBreedRecords(breeds, { sort: 'recommended' });
const popularBreeds = filterBreedRecords(breeds, { sort: 'popular' }).slice(0, 12);
const collectionLinks = getCollectionLinks();

const topOrigins = filterOptions.origins.slice(0, 10);
const topGroups = filterOptions.groups.slice(0, 9);
const purebredCount = breeds.filter((breed) => breed.type === 'purebred').length;
const mixedBreedCount = breeds.filter((breed) => breed.type === 'mixed').length;
const foodGuideCount = breeds.filter((breed) => breed.guideAvailability.food).length;
const healthGuideCount = breeds.filter((breed) => breed.guideAvailability.health).length;
const costCalculatorCount = breeds.filter((breed) => breed.guideAvailability.cost).length;

const clientBreeds = breeds.map(serializeBreedForClient);
const breedsJson = JSON.stringify(clientBreeds);
const defaultVisibleCount = 48;

const itemListLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Dog Breed Directory — ${breeds.length} Breeds`,
  description: 'PupWiki dog breed finder with filters for size, energy, shedding, coat, trainability, lifespan and owner resources.',
  numberOfItems: breeds.length,
  itemListElement: recommendedBreeds.slice(0, 30).map((breed, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: breed.name,
    url: `${SITE}/breeds/${breed.slug}`,
  })),
});

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Dog Breed Directory', item: `${SITE}/breeds` },
  ],
});

const collectionPageLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Dog Breed Directory',
  description: `Browse ${breeds.length} dog breeds by size, energy, coat, shedding, trainability, lifespan and owner fit.`,
  url: `${SITE}/breeds`,
  isPartOf: {
    '@type': 'WebSite',
    name: 'PupWiki',
    url: SITE,
  },
});

function guideByKey(breed: NormalizedBreed, key: string) {
  return breed.guideLinks.find((link) => link.key === key && link.available);
}

function cardGuideChips(breed: NormalizedBreed) {
  return ['cost', 'food', 'health', 'training']
    .map((key) => guideByKey(breed, key))
    .filter(Boolean)
    .slice(0, 3);
}
---

<BaseLayout
  title={`Dog Breed Directory 2026 — Find and Compare ${breeds.length} Breeds | PupWiki`}
  description={`Browse ${breeds.length} dog breeds by size, energy, shedding, trainability, coat type, lifespan and owner fit. Includes breed profiles, cost calculators and care resources.`}
  canonicalUrl={`${SITE}/breeds`}
  bodyClass="breed-directory-page"
>
  <script type="application/ld+json" set:html={itemListLd} />
  <script type="application/ld+json" set:html={breadcrumbLd} />
  <script type="application/ld+json" set:html={collectionPageLd} />

  <main class="breed-directory" data-breed-directory>
    <section class="breed-directory-hero" aria-labelledby="breed-directory-title">
      <div class="breed-directory-container">
        <nav class="breed-directory-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">All Breeds</span>
        </nav>

        <div class="breed-directory-hero__grid">
          <div class="breed-directory-hero__content">
            <p class="breed-directory-eyebrow">
              <span aria-hidden="true">🐾</span>
              Breed finder
            </p>

            <h1 id="breed-directory-title">
              Dog Breed Directory
              <em>Find your fit faster.</em>
            </h1>

            <p class="breed-directory-hero__desc">
              Search and filter {breeds.length} breed profiles by size, energy, coat, shedding,
              trainability, lifespan and owner resources. Every breed links into PupWiki’s care,
              cost and category ecosystem.
            </p>

            <div class="breed-directory-hero__actions">
              <a href="#breed-finder" class="breed-directory-button breed-directory-button--primary">
                Start filtering
                <span aria-hidden="true">→</span>
              </a>
              <a href="/breed-quiz" class="breed-directory-button breed-directory-button--secondary">
                Take breed quiz
              </a>
              <a href="/cost-calculator" class="breed-directory-button breed-directory-button--ghost">
                Compare costs
              </a>
            </div>
          </div>

          <aside class="breed-directory-hero-card" aria-label="Breed directory summary">
            <div class="breed-directory-hero-card__icon" aria-hidden="true">🐕</div>
            <p>Directory coverage</p>
            <strong>{breeds.length} breeds</strong>
            <dl>
              <div>
                <dt>Purebreds</dt>
                <dd>{purebredCount}</dd>
              </div>
              <div>
                <dt>Mixed breeds</dt>
                <dd>{mixedBreedCount}</dd>
              </div>
              <div>
                <dt>Cost tools</dt>
                <dd>{costCalculatorCount}</dd>
              </div>
            </dl>
          </aside>
        </div>
      </div>
    </section>

    <section class="breed-directory-stats" aria-label="Directory highlights">
      <div class="breed-directory-container breed-directory-stats__grid">
        <article>
          <strong>{breeds.length}</strong>
          <span>Total breed profiles</span>
        </article>
        <article>
          <strong>{foodGuideCount}</strong>
          <span>Food guide links</span>
        </article>
        <article>
          <strong>{healthGuideCount}</strong>
          <span>Health guide links</span>
        </article>
        <article>
          <strong>{filterOptions.origins.length}</strong>
          <span>Origin countries</span>
        </article>
      </div>
    </section>

    <section id="breed-finder" class="breed-finder" aria-labelledby="breed-finder-title">
      <div class="breed-directory-container">
        <div class="breed-finder__header">
          <div>
            <p class="breed-directory-eyebrow">Search & filter</p>
            <h2 id="breed-finder-title">Find breeds by lifestyle, care needs and owner intent</h2>
            <p>
              Start with search or tap a quick filter. Advanced filters stay available without overwhelming mobile users.
            </p>
          </div>
        </div>

        <div class="breed-search-panel">
          <div class="breed-search-panel__top">
            <div class="breed-search-field" role="search">
              <label for="breed-search">Search breeds</label>
              <div class="breed-search-field__control">
                <span aria-hidden="true">🔍</span>
                <input
                  id="breed-search"
                  type="search"
                  name="q"
                  placeholder="Search e.g. bulldog, low shedding, Germany, retriever…"
                  autocomplete="off"
                  spellcheck="false"
                  data-breed-search
                />
                <button type="button" class="breed-search-clear" data-clear-search hidden aria-label="Clear search">
                  ×
                </button>
              </div>
            </div>

            <div class="breed-sort-field">
              <label for="breed-sort">Sort</label>
              <select id="breed-sort" data-breed-sort>
                <option value="recommended">Recommended</option>
                <option value="popular">Most popular</option>
                <option value="az">A → Z</option>
                <option value="za">Z → A</option>
                <option value="smallest">Smallest first</option>
                <option value="largest">Largest first</option>
                <option value="lifespan-desc">Longest lived</option>
                <option value="lifespan-asc">Shortest lived</option>
                <option value="low-shedding">Lowest shedding</option>
                <option value="easy-training">Easiest to train</option>
              </select>
            </div>
          </div>

          <div class="breed-quick-filters" aria-label="Quick breed filters">
            {QUICK_BREED_FILTERS.map((item) => (
              <button
                type="button"
                class="breed-quick-filter"
                data-quick-filter={JSON.stringify(item.state)}
              >
                <span aria-hidden="true">{item.emoji}</span>
                <strong>{item.label}</strong>
                <em>{item.description}</em>
              </button>
            ))}
          </div>

          <div class="breed-active-row">
            <p id="breed-result-count" class="breed-result-count" aria-live="polite" aria-atomic="true">
              Showing {breeds.length} breeds
            </p>
            <div id="breed-active-chips" class="breed-active-chips" aria-label="Active filters"></div>
            <button type="button" id="breed-clear-filters" class="breed-clear-filters" hidden>
              Clear all
            </button>
          </div>

          <button
            type="button"
            class="breed-filter-toggle"
            data-filter-toggle
            aria-expanded="false"
            aria-controls="breed-filter-panel"
          >
            <span>Advanced filters</span>
            <em aria-hidden="true">▾</em>
          </button>

          <div id="breed-filter-panel" class="breed-filter-panel" data-filter-panel>
            <div class="breed-filter-panel__grid">
              <fieldset class="breed-filter-group">
                <legend>Breed type</legend>
                <div class="breed-filter-buttons">
                  <button type="button" data-filter="type" data-value="all" class="breed-filter-button is-active">All</button>
                  {filterOptions.types.map((option) => (
                    <button type="button" data-filter="type" data-value={option.value} class="breed-filter-button">
                      {option.emoji && <span aria-hidden="true">{option.emoji}</span>}
                      {option.label}
                      <span class="breed-count-badge" data-count-filter="type" data-count-value={option.value}>{option.count}</span>
                    </button>
                  ))}
                </div>
              </fieldset>

              <fieldset class="breed-filter-group">
                <legend>Size</legend>
                <div class="breed-filter-buttons">
                  <button type="button" data-filter="size" data-value="all" class="breed-filter-button is-active">All</button>
                  {filterOptions.sizes.map((option) => (
                    <button type="button" data-filter="size" data-value={option.value} class="breed-filter-button">
                      {option.emoji && <span aria-hidden="true">{option.emoji}</span>}
                      {option.label}
                      <span class="breed-count-badge" data-count-filter="size" data-count-value={option.value}>{option.count}</span>
                    </button>
                  ))}
                </div>
              </fieldset>

              <fieldset class="breed-filter-group">
                <legend>Energy</legend>
                <div class="breed-filter-buttons">
                  <button type="button" data-filter="energy" data-value="all" class="breed-filter-button is-active">All</button>
                  {filterOptions.energy.map((option) => (
                    <button type="button" data-filter="energy" data-value={option.value} class="breed-filter-button">
                      {option.emoji && <span aria-hidden="true">{option.emoji}</span>}
                      {option.label}
                      <span class="breed-count-badge" data-count-filter="energy" data-count-value={option.value}>{option.count}</span>
                    </button>
                  ))}
                </div>
              </fieldset>

              <fieldset class="breed-filter-group">
                <legend>Shedding</legend>
                <div class="breed-filter-buttons">
                  <button type="button" data-filter="shedding" data-value="all" class="breed-filter-button is-active">All</button>
                  {filterOptions.shedding.map((option) => (
                    <button type="button" data-filter="shedding" data-value={option.value} class="breed-filter-button">
                      {option.emoji && <span aria-hidden="true">{option.emoji}</span>}
                      {option.label}
                      <span class="breed-count-badge" data-count-filter="shedding" data-count-value={option.value}>{option.count}</span>
                    </button>
                  ))}
                </div>
              </fieldset>

              <fieldset class="breed-filter-group">
                <legend>Trainability</legend>
                <div class="breed-filter-buttons">
                  <button type="button" data-filter="training" data-value="all" class="breed-filter-button is-active">All</button>
                  {filterOptions.training.map((option) => (
                    <button type="button" data-filter="training" data-value={option.value} class="breed-filter-button">
                      {option.emoji && <span aria-hidden="true">{option.emoji}</span>}
                      {option.label}
                      <span class="breed-count-badge" data-count-filter="training" data-count-value={option.value}>{option.count}</span>
                    </button>
                  ))}
                </div>
              </fieldset>

              <fieldset class="breed-filter-group">
                <legend>Coat type</legend>
                <div class="breed-filter-buttons">
                  <button type="button" data-filter="coat" data-value="all" class="breed-filter-button is-active">All</button>
                  {filterOptions.coats.map((option) => (
                    <button type="button" data-filter="coat" data-value={option.value} class="breed-filter-button">
                      {option.label}
                      <span class="breed-count-badge" data-count-filter="coat" data-count-value={option.value}>{option.count}</span>
                    </button>
                  ))}
                </div>
              </fieldset>

              <fieldset class="breed-filter-group">
                <legend>Group</legend>
                <div class="breed-filter-buttons">
                  <button type="button" data-filter="group" data-value="all" class="breed-filter-button is-active">All</button>
                  {topGroups.map((option) => (
                    <button type="button" data-filter="group" data-value={option.value} class="breed-filter-button">
                      {option.emoji && <span aria-hidden="true">{option.emoji}</span>}
                      {option.label}
                      <span class="breed-count-badge" data-count-filter="group" data-count-value={option.value}>{option.count}</span>
                    </button>
                  ))}
                </div>
              </fieldset>

              <fieldset class="breed-filter-group">
                <legend>Origin</legend>
                <div class="breed-filter-buttons">
                  <button type="button" data-filter="origin" data-value="all" class="breed-filter-button is-active">All</button>
                  {topOrigins.map((option) => (
                    <button type="button" data-filter="origin" data-value={option.value} class="breed-filter-button">
                      {option.emoji && <span aria-hidden="true">{option.emoji}</span>}
                      {option.label}
                      <span class="breed-count-badge" data-count-filter="origin" data-count-value={option.value}>{option.count}</span>
                    </button>
                  ))}
                </div>
              </fieldset>

              <fieldset class="breed-filter-group">
                <legend>Lifespan</legend>
                <div class="breed-filter-buttons">
                  <button type="button" data-filter="lifespan" data-value="all" class="breed-filter-button is-active">All</button>
                  {filterOptions.lifespan.map((option) => (
                    <button type="button" data-filter="lifespan" data-value={option.value} class="breed-filter-button">
                      {option.label}
                      <span class="breed-count-badge" data-count-filter="lifespan" data-count-value={option.value}>{option.count}</span>
                    </button>
                  ))}
                </div>
              </fieldset>

              <fieldset class="breed-filter-group">
                <legend>Available guides</legend>
                <div class="breed-filter-buttons">
                  <button type="button" data-filter="guide" data-value="all" class="breed-filter-button is-active">All</button>
                  {filterOptions.guides.map((option) => (
                    <button type="button" data-filter="guide" data-value={option.value} class="breed-filter-button">
                      {option.label}
                      <span class="breed-count-badge" data-count-filter="guide" data-count-value={option.value}>{option.count}</span>
                    </button>
                  ))}
                </div>
              </fieldset>
            </div>
          </div>
        </div>

        {popularBreeds.length > 0 && (
          <section class="breed-popular-strip" aria-label="Popular breed shortcuts">
            <div class="breed-popular-strip__header">
              <p>Popular breeds</p>
              <a href="/breeds/?sort=popular">View popular →</a>
            </div>
            <div class="breed-chip-row">
              {popularBreeds.map((breed) => (
                <a href={`/breeds/${breed.slug}`}>{breed.name}</a>
              ))}
            </div>
          </section>
        )}

        <section class="breed-grid-section" aria-labelledby="breed-grid-title">
          <div class="breed-grid-section__header">
            <div>
              <p class="breed-directory-eyebrow">Directory</p>
              <h2 id="breed-grid-title">Browse breed profiles</h2>
            </div>
            <button type="button" class="breed-load-more" data-show-all>
              Show all breeds
            </button>
          </div>

          <div id="breed-grid" class="breed-grid" role="list" aria-label="Dog breed cards">
            {recommendedBreeds.map((breed, index) => {
              const guideChips = cardGuideChips(breed);
              const visibleByDefault = index < defaultVisibleCount;

              return (
                <article
                  class:list={['breed-directory-card', !visibleByDefault && 'is-extra']}
                  data-breed-card
                  data-slug={breed.slug}
                  data-default-visible={visibleByDefault ? 'true' : 'false'}
                  role="listitem"
                >
                  <a href={`/breeds/${breed.slug}`} class="breed-directory-card__image" aria-label={`View ${breed.name} breed profile`}>
                    {breed.primaryImage ? (
                      <img
                        src={breed.primaryImage}
                        alt={breed.imageAlt}
                        width="360"
                        height="240"
                        loading={index < 12 ? 'eager' : 'lazy'}
                        fetchpriority={index === 0 ? 'high' : 'auto'}
                        decoding="async"
                        data-card-image
                      />
                    ) : null}
                    <span class:list={['breed-directory-card__fallback', breed.primaryImage && 'is-hidden']} data-card-fallback aria-hidden="true">
                      {breed.fallbackEmoji}
                    </span>
                    <span class="breed-directory-card__type">{breed.type === 'mixed' ? 'Mixed' : 'Purebred'}</span>
                  </a>

                  <div class="breed-directory-card__body">
                    <div class="breed-directory-card__title-row">
                      <div>
                        <h3><a href={`/breeds/${breed.slug}`}>{breed.name}</a></h3>
                        <p>{breed.group.label}{breed.origin.key !== 'unknown' ? ` · ${breed.origin.label}` : ''}</p>
                      </div>
                      {breed.popularityRank < 9999 && (
                        <span class="breed-directory-card__rank">#{breed.popularityRank}</span>
                      )}
                    </div>

                    <div class="breed-directory-card__facts" aria-label={`${breed.name} quick facts`}>
                      <span>{breed.size.label}</span>
                      <span>{breed.energy.label} energy</span>
                      {breed.lifespan.label && <span>{breed.lifespan.label}</span>}
                      {breed.weight.label && <span>{breed.weight.label}</span>}
                    </div>

                    <div class="breed-directory-card__traits">
                      <span class:list={['is-shedding', breed.flags.isLowShedding && 'is-positive']}>
                        {breed.shedding.label} shedding
                      </span>
                      <span class:list={['is-training', breed.flags.isEasyToTrain && 'is-positive', breed.flags.isHardToTrain && 'is-warning']}>
                        {breed.training.label} training
                      </span>
                      {breed.coat.key !== 'unknown' && <span>{breed.coat.label} coat</span>}
                    </div>

                    {guideChips.length > 0 && (
                      <div class="breed-directory-card__guides" aria-label={`${breed.name} available guides`}>
                        {guideChips.map((guide) => (
                          <a href={guide?.href}>{guide?.label}</a>
                        ))}
                      </div>
                    )}
                  </div>
                </article>
              );
            })}
          </div>

          <div id="breed-no-results" class="breed-no-results" hidden>
            <span aria-hidden="true">🔍</span>
            <h2>No breeds match those filters</h2>
            <p>Try removing one filter, clearing the search term, or starting with a broader quick filter.</p>
            <div>
              <button type="button" data-clear-all-empty>Clear all filters</button>
              <a href="/breed-quiz">Take breed quiz</a>
            </div>
          </div>
        </section>
      </div>
    </section>

    <section class="breed-collections" aria-labelledby="breed-collections-title">
      <div class="breed-directory-container">
        <div class="breed-section-header">
          <p class="breed-directory-eyebrow">Explore collections</p>
          <h2 id="breed-collections-title">Popular ways to browse breeds</h2>
          <p>
            These crawlable collection links open the directory with useful filters already applied.
          </p>
        </div>

        <div class="breed-collection-grid">
          {collectionLinks.map((item) => (
            <a href={item.href} class="breed-collection-card">
              <span aria-hidden="true">{item.icon}</span>
              <strong>{item.label}</strong>
              <p>{item.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="breed-owner-links" aria-labelledby="breed-owner-links-title">
      <div class="breed-directory-container">
        <div class="breed-section-header">
          <p class="breed-directory-eyebrow">Owner resources</p>
          <h2 id="breed-owner-links-title">Move from breed research to real planning</h2>
          <p>
            Use PupWiki’s connected pages to compare care, cost, food, health and training decisions by breed.
          </p>
        </div>

        <div class="breed-owner-link-grid">
          <a href="/cost-calculator">
            <span aria-hidden="true">💰</span>
            <strong>Breed cost calculator</strong>
            <p>Estimate food, vet, grooming, insurance and lifetime costs.</p>
          </a>
          <a href="/categories/dog-food">
            <span aria-hidden="true">🍖</span>
            <strong>Dog food guides</strong>
            <p>Connect breed size, age and care needs with feeding research.</p>
          </a>
          <a href="/categories/health">
            <span aria-hidden="true">🩺</span>
            <strong>Health resources</strong>
            <p>Review general breed health context and planning resources.</p>
          </a>
          <a href="/categories/training">
            <span aria-hidden="true">🦮</span>
            <strong>Training guides</strong>
            <p>Match training expectations to breed energy and difficulty.</p>
          </a>
        </div>
      </div>
    </section>

    <div class="sr-only" aria-live="assertive" id="breed-sr-announce"></div>
  </main>

  <script define:vars={{ breedsJson, defaultVisibleCount }}>
    const BREEDS = JSON.parse(breedsJson);

    const DEFAULT_STATE = {
      q: '',
      type: 'all',
      size: 'all',
      energy: 'all',
      shedding: 'all',
      training: 'all',
      coat: 'all',
      group: 'all',
      origin: 'all',
      lifespan: 'all',
      guide: 'all',
      sort: 'recommended',
    };

    const FILTER_KEYS = ['type', 'size', 'energy', 'shedding', 'training', 'coat', 'group', 'origin', 'lifespan', 'guide'];
    const ALL_STATE_KEYS = ['q', ...FILTER_KEYS, 'sort'];

    const grid = document.getElementById('breed-grid');
    const searchInput = document.querySelector('[data-breed-search]');
    const clearSearch = document.querySelector('[data-clear-search]');
    const sortSelect = document.querySelector('[data-breed-sort]');
    const resultCount = document.getElementById('breed-result-count');
    const activeChips = document.getElementById('breed-active-chips');
    const clearFilters = document.getElementById('breed-clear-filters');
    const noResults = document.getElementById('breed-no-results');
    const srAnnounce = document.getElementById('breed-sr-announce');
    const filterPanel = document.querySelector('[data-filter-panel]');
    const filterToggle = document.querySelector('[data-filter-toggle]');
    const showAllButton = document.querySelector('[data-show-all]');
    const cards = Array.from(document.querySelectorAll('[data-breed-card]'));

    let showAll = false;
    let state = { ...DEFAULT_STATE };

    const bySlug = new Map(BREEDS.map((breed) => [breed.slug, breed]));
    const cardBySlug = new Map(cards.map((card) => [card.dataset.slug, card]));

    function normalizeQuery(value) {
      return String(value || '')
        .normalize('NFKD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .replace(/&/g, ' and ')
        .replace(/[^a-z0-9]+/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function readStateFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const next = { ...DEFAULT_STATE };

      for (const key of ALL_STATE_KEYS) {
        const value = params.get(key);
        if (value) next[key] = value;
      }

      return next;
    }

    function writeStateToUrl() {
      const params = new URLSearchParams();

      for (const key of ALL_STATE_KEYS) {
        if (!state[key] || state[key] === DEFAULT_STATE[key]) continue;
        params.set(key, state[key]);
      }

      const query = params.toString();
      const nextUrl = `${window.location.pathname}${query ? `?${query}` : ''}`;
      window.history.replaceState({}, '', nextUrl);
    }

    function isDefaultState() {
      return ALL_STATE_KEYS.every((key) => state[key] === DEFAULT_STATE[key]);
    }

    function searchMatches(breed) {
      const q = normalizeQuery(state.q);
      if (!q) return true;
      const tokens = q.split(' ').filter(Boolean);
      return tokens.every((token) => breed.searchText.includes(token));
    }

    function lifespanMatches(value) {
      if (state.lifespan === 'all') return true;
      if (typeof value !== 'number') return false;
      if (state.lifespan === 'lt10') return value < 10;
      if (state.lifespan === '10-12') return value >= 10 && value <= 12;
      if (state.lifespan === '12-14') return value > 12 && value <= 14;
      if (state.lifespan === 'gt14') return value > 14;
      return true;
    }

    function guideMatches(breed) {
      if (state.guide === 'all') return true;
      return Boolean(breed.guideAvailability?.[state.guide] || (state.guide === 'cost' && breed.flags?.hasCostCalculator));
    }

    function matches(breed, override = {}) {
      const current = { ...state, ...override };
      const previous = state;
      state = current;

      const result =
        searchMatches(breed) &&
        (state.type === 'all' || breed.type === state.type) &&
        (state.size === 'all' || breed.size === state.size) &&
        (state.energy === 'all' || breed.energy === state.energy) &&
        (state.shedding === 'all' || breed.shedding === state.shedding) &&
        (state.training === 'all' || breed.training === state.training) &&
        (state.coat === 'all' || breed.coat === state.coat) &&
        (state.group === 'all' || breed.group === state.group) &&
        (state.origin === 'all' || breed.origin === state.origin) &&
        lifespanMatches(breed.lifespan) &&
        guideMatches(breed);

      state = previous;
      return result;
    }

    function recommendedScore(breed) {
      let score = 0;
      if (breed.popularityRank && breed.popularityRank < 9999) score += Math.max(0, 220 - breed.popularityRank);
      if (breed.flags?.hasFoodGuide) score += 12;
      if (breed.flags?.hasHealthGuide) score += 12;
      if (breed.flags?.hasTrainingGuide) score += 10;
      if (breed.flags?.hasMonetizableGuides) score += 10;
      if (breed.origin !== 'unknown') score += 4;
      if (breed.lifespan) score += 4;
      return score;
    }

    const sizeOrder = { small: 1, medium: 2, large: 3, giant: 4, unknown: 99 };
    const sheddingOrder = { minimal: 1, low: 2, seasonal: 3, heavy: 4, unknown: 99 };
    const trainingOrder = { easy: 1, moderate: 2, difficult: 3, unknown: 99 };

    function sortBreeds(items) {
      return [...items].sort((a, b) => {
        if (state.sort === 'recommended') return recommendedScore(b) - recommendedScore(a) || a.name.localeCompare(b.name);
        if (state.sort === 'popular') return (a.popularityRank || 9999) - (b.popularityRank || 9999) || a.name.localeCompare(b.name);
        if (state.sort === 'az') return a.name.localeCompare(b.name);
        if (state.sort === 'za') return b.name.localeCompare(a.name);
        if (state.sort === 'smallest') return (sizeOrder[a.size] || 99) - (sizeOrder[b.size] || 99) || a.name.localeCompare(b.name);
        if (state.sort === 'largest') return (sizeOrder[b.size] || 99) - (sizeOrder[a.size] || 99) || a.name.localeCompare(b.name);
        if (state.sort === 'lifespan-desc') return (b.lifespan || -1) - (a.lifespan || -1) || a.name.localeCompare(b.name);
        if (state.sort === 'lifespan-asc') return (a.lifespan || 999) - (b.lifespan || 999) || a.name.localeCompare(b.name);
        if (state.sort === 'low-shedding') return (sheddingOrder[a.shedding] || 99) - (sheddingOrder[b.shedding] || 99) || a.name.localeCompare(b.name);
        if (state.sort === 'easy-training') return (trainingOrder[a.training] || 99) - (trainingOrder[b.training] || 99) || a.name.localeCompare(b.name);
        return 0;
      });
    }

    function getFilteredBreeds() {
      return sortBreeds(BREEDS.filter((breed) => matches(breed)));
    }

    function updateControls() {
      if (searchInput) searchInput.value = state.q;
      if (clearSearch) clearSearch.hidden = !state.q;
      if (sortSelect) sortSelect.value = state.sort;

      document.querySelectorAll('[data-filter]').forEach((button) => {
        const key = button.dataset.filter;
        const value = button.dataset.value;
        const active = state[key] === value;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', String(active));
      });
    }

    function updateActiveChips() {
      if (!activeChips) return;
      activeChips.innerHTML = '';

      const labels = {
        q: state.q ? `Search: ${state.q}` : '',
        type: state.type,
        size: state.size,
        energy: state.energy,
        shedding: state.shedding,
        training: state.training,
        coat: state.coat,
        group: state.group,
        origin: state.origin,
        lifespan: state.lifespan,
        guide: state.guide,
      };

      for (const key of ['q', ...FILTER_KEYS]) {
        if (state[key] === DEFAULT_STATE[key]) continue;

        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = 'breed-active-chip';
        chip.dataset.clearKey = key;
        chip.textContent = `${String(labels[key]).replace(/-/g, ' ')} ×`;
        activeChips.appendChild(chip);
      }

      if (clearFilters) clearFilters.hidden = isDefaultState();
    }

    function updateDynamicCounts() {
      document.querySelectorAll('[data-count-filter][data-count-value]').forEach((badge) => {
        const key = badge.dataset.countFilter;
        const value = badge.dataset.countValue;
        const count = BREEDS.filter((breed) => matches(breed, { [key]: value })).length;
        badge.textContent = String(count);

        const button = badge.closest('[data-filter]');
        if (button) {
          const isActive = state[key] === value;
          button.disabled = count === 0 && !isActive;
        }
      });
    }

    function applyFilters({ updateUrl = true, announce = true } = {}) {
      const filtered = getFilteredBreeds();
      const visibleSlugs = new Set(filtered.map((breed) => breed.slug));
      const shouldLimit = !showAll && isDefaultState();
      const visibleLimited = shouldLimit ? filtered.slice(0, defaultVisibleCount) : filtered;
      const limitedSlugs = new Set(visibleLimited.map((breed) => breed.slug));

      for (const breed of filtered) {
        const card = cardBySlug.get(breed.slug);
        if (card && grid) grid.appendChild(card);
      }

      cards.forEach((card) => {
        const slug = card.dataset.slug;
        const isVisible = visibleSlugs.has(slug) && limitedSlugs.has(slug);
        card.hidden = !isVisible;
      });

      if (noResults) noResults.hidden = filtered.length !== 0;
      if (resultCount) {
        const limitedCopy = shouldLimit && filtered.length > defaultVisibleCount ? ` · showing first ${defaultVisibleCount}` : '';
        resultCount.textContent = `Showing ${filtered.length} breed${filtered.length === 1 ? '' : 's'}${limitedCopy}`;
      }

      if (showAllButton) {
        showAllButton.hidden = !(isDefaultState() && !showAll && filtered.length > defaultVisibleCount);
      }

      updateControls();
      updateActiveChips();
      updateDynamicCounts();
      if (updateUrl) writeStateToUrl();
      if (announce && srAnnounce) srAnnounce.textContent = `${filtered.length} breeds shown`;
    }

    function resetState() {
      state = { ...DEFAULT_STATE };
      showAll = false;
      applyFilters();
    }

    searchInput?.addEventListener('input', () => {
      state.q = searchInput.value;
      showAll = true;
      applyFilters();
    });

    clearSearch?.addEventListener('click', () => {
      state.q = '';
      searchInput?.focus();
      applyFilters();
    });

    sortSelect?.addEventListener('change', () => {
      state.sort = sortSelect.value;
      applyFilters();
    });

    document.querySelectorAll('[data-filter]').forEach((button) => {
      button.addEventListener('click', () => {
        const key = button.dataset.filter;
        const value = button.dataset.value;
        state[key] = value;
        showAll = true;
        applyFilters();
      });
    });

    document.querySelectorAll('[data-quick-filter]').forEach((button) => {
      button.addEventListener('click', () => {
        try {
          const quickState = JSON.parse(button.dataset.quickFilter || '{}');
          state = { ...state, ...quickState };
          showAll = true;
          applyFilters();
          document.getElementById('breed-grid-title')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch {
          // Ignore malformed quick filter payloads.
        }
      });
    });

    activeChips?.addEventListener('click', (event) => {
      const target = event.target.closest('[data-clear-key]');
      if (!target) return;
      const key = target.dataset.clearKey;
      state[key] = DEFAULT_STATE[key];
      applyFilters();
    });

    clearFilters?.addEventListener('click', resetState);
    document.querySelector('[data-clear-all-empty]')?.addEventListener('click', resetState);

    showAllButton?.addEventListener('click', () => {
      showAll = true;
      applyFilters({ updateUrl: false });
    });

    filterToggle?.addEventListener('click', () => {
      const isOpen = filterPanel?.classList.toggle('is-open');
      filterToggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
    });

    document.querySelectorAll('[data-card-image]').forEach((image) => {
      image.addEventListener('error', () => {
        image.hidden = true;
        const fallback = image.closest('.breed-directory-card__image')?.querySelector('[data-card-fallback]');
        fallback?.classList.remove('is-hidden');
      });
    });

    window.addEventListener('popstate', () => {
      state = readStateFromUrl();
      showAll = true;
      applyFilters({ updateUrl: false });
    });

    state = readStateFromUrl();
    showAll = !isDefaultState();
    applyFilters({ updateUrl: false, announce: false });
  </script>
</BaseLayout>
