---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BreedCard from '../../components/BreedCard.astro';
import breedsData from '../../data/breeds.json';

const groups = [...new Set(breedsData.map(b => b.group).filter(Boolean))].sort();
const energyCats = ["Needs Lots of Activity","Energetic","Regular Exercise","Calm","Couch Potato"];
const sizeCats = ["small","medium","large"];

const jsonLd = JSON.stringify({
  "@context":"https://schema.org",
  "@type":"CollectionPage",
  "name":"Dog Breed Product Guides — Mr. Doggo Style",
  "description":`Complete product guides for ${breedsData.length} dog breeds. Best food, toys, beds, and grooming tools for every breed.`,
  "url":"https://mrdoggostyle.com/breeds",
  "numberOfItems": breedsData.length,
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Dog Breed Guides (All {breedsData.length} Breeds) | MR. DOGGO STYLE</title>
  <meta name="description" content={`Complete product guides for all ${breedsData.length} AKC-recognized dog breeds. Best food, toys, beds, and grooming tools matched to every breed's needs.`}/>
  <link rel="canonical" href="https://mrdoggostyle.com/breeds"/>
  <script type="application/ld+json" set:html={jsonLd}/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo+Black&family=Barlow+Condensed:wght@400;600;700&family=Space+Mono:wght@400&display=swap" rel="stylesheet"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    :root{--midnight:#0A0A0A;--concrete:#222;--cl:#2E2E2E;--lime:#CCFF00;--ash:#888;--smoke:#AAA;--white:#F0F0F0}
    *{box-sizing:border-box} html{background:var(--midnight)} body{font-family:'Barlow Condensed',sans-serif;background:var(--midnight);color:var(--white);margin:0;overflow-x:hidden}
    body::before{content:'';position:fixed;inset:0;opacity:.4;pointer-events:none;z-index:998;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E")}
    .btn-lime{display:inline-block;background:var(--lime);color:var(--midnight);font-family:'Archivo Black',sans-serif;font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;padding:.55rem 1.25rem;border:2px solid var(--midnight);box-shadow:3px 3px 0 var(--midnight);text-decoration:none;transition:all .1s}
    .btn-lime:hover{transform:translate(-2px,-2px);box-shadow:5px 5px 0 var(--midnight)}
    .filter-btn{font-family:'Archivo Black',sans-serif;font-size:.62rem;text-transform:uppercase;letter-spacing:.08em;padding:.35rem .8rem;border:2px solid rgba(255,255,255,.12);background:transparent;color:var(--smoke);cursor:pointer;transition:all .12s}
    .filter-btn:hover,.filter-btn.active{background:var(--lime);color:var(--midnight);border-color:var(--midnight)}
    input[type=text]{font-family:'Barlow Condensed',sans-serif;border:2px solid rgba(255,255,255,.15);background:var(--concrete);color:var(--white);padding:.65rem 1rem;font-size:.95rem;outline:none;width:100%}
    input[type=text]:focus{border-color:var(--lime)}
    ::selection{background:var(--lime);color:var(--midnight)}
    ::-webkit-scrollbar{width:4px} ::-webkit-scrollbar-track{background:var(--midnight)} ::-webkit-scrollbar-thumb{background:var(--cl)} ::-webkit-scrollbar-thumb:hover{background:var(--lime)}
    .hidden-card{display:none!important}
  </style>
</head>
<body>
<Header/>

<!-- Hero -->
<div style="background:var(--concrete);border-bottom:2px solid rgba(255,255,255,.07)">
  <div style="max-width:1400px;margin:0 auto;padding:4rem 1.5rem">
    <span style="font-family:'Space Mono',monospace;font-size:.58rem;text-transform:uppercase;letter-spacing:.12em;color:var(--lime)">{breedsData.length} BREED GUIDES</span>
    <h1 style="font-family:'Anton',sans-serif;font-size:clamp(3rem,8vw,6rem);text-transform:uppercase;color:var(--white);margin:.2rem 0 1rem;letter-spacing:-.02em;line-height:.9">
      EVERY BREED.<br/><span style="color:var(--lime)">EVERY GUIDE.</span>
    </h1>
    <p style="font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;color:var(--smoke);max-width:540px;margin:0 0 1.5rem;line-height:1.5">
      Expert food, toy, bed, and grooming picks matched to every breed's exact size, energy, coat, and health profile. Powered by AKC breed registry data.
    </p>
    <!-- Search -->
    <div style="max-width:520px;position:relative">
      <input type="text" id="breed-search" placeholder="Search by breed (e.g. Labrador, Poodle, Husky...)" style="padding-left:2.5rem"/>
      <span style="position:absolute;left:.75rem;top:50%;transform:translateY(-50%);font-size:1rem;pointer-events:none">🔍</span>
    </div>
  </div>
</div>

<!-- Stats strip -->
<div style="background:#0d0d0d;border-bottom:1px solid rgba(255,255,255,.05)">
  <div style="max-width:1400px;margin:0 auto;padding:.65rem 1.5rem;display:flex;flex-wrap:wrap;gap:1.5rem;justify-content:center">
    {[
      [`${breedsData.length}`,"BREEDS COVERED"],
      [`${breedsData.filter(b=>b.size_category==='large').length}`,"LARGE BREEDS"],
      [`${breedsData.filter(b=>b.energy?.category==='Needs Lots of Activity').length}`,"HIGH ENERGY BREEDS"],
      [`${breedsData.filter(b=>b.popularity&&b.popularity<=50).length}`,"TOP-50 POPULAR"],
    ].map(([n,l])=>(
      <div style="text-align:center">
        <div style="font-family:'Anton',sans-serif;font-size:1.5rem;color:var(--lime);line-height:1">{n}</div>
        <div style="font-family:'Space Mono',monospace;font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ash)">{l}</div>
      </div>
    ))}
  </div>
</div>

<!-- Filters + Grid -->
<div style="max-width:1400px;margin:0 auto;padding:2rem 1.5rem">

  <!-- Filter rows -->
  <div style="margin-bottom:1.5rem;display:flex;flex-direction:column;gap:.6rem">
    <div style="display:flex;flex-wrap:wrap;gap:.4rem;align-items:center">
      <span style="font-family:'Space Mono',monospace;font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ash);width:50px;flex-shrink:0">GROUP</span>
      <button class="filter-btn active" data-filter="group" data-value="">ALL</button>
      {groups.filter(g=>!g.includes('Foundation')&&!g.includes('Misc')).map(g=>(
        <button class="filter-btn" data-filter="group" data-value={g}>{g.replace(' Group','').replace(' Service','').toUpperCase()}</button>
      ))}
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:.4rem;align-items:center">
      <span style="font-family:'Space Mono',monospace;font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ash);width:50px;flex-shrink:0">SIZE</span>
      <button class="filter-btn active" data-filter="size" data-value="">ALL</button>
      {sizeCats.map(s=><button class="filter-btn" data-filter="size" data-value={s}>{s.toUpperCase()}</button>)}
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:.4rem;align-items:center">
      <span style="font-family:'Space Mono',monospace;font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ash);width:50px;flex-shrink:0">ENERGY</span>
      <button class="filter-btn active" data-filter="energy" data-value="">ALL</button>
      {energyCats.map(e=><button class="filter-btn" data-filter="energy" data-value={e}>{e.toUpperCase()}</button>)}
    </div>
  </div>

  <!-- Count -->
  <p style="font-family:'Space Mono',monospace;font-size:.58rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ash);margin:0 0 1.25rem">
    SHOWING <strong id="shown-count" style="color:var(--lime)">{breedsData.length}</strong> OF {breedsData.length} BREEDS
  </p>

  <!-- Breed grid with real photos -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem" id="breed-grid">
    {breedsData.map(b => (
      <div class="breed-item"
           data-name={b.name.toLowerCase()}
           data-group={b.group}
           data-size={b.size_category}
           data-energy={b.energy?.category}>
        <BreedCard
          slug={b.slug}
          name={b.name}
          group={b.group}
          temperament={b.temperament}
          popularity={b.popularity}
          size_category={b.size_category}
          energy={b.energy}
          shedding={b.shedding}
          dogCeoBreed={b.dogCeoBreed}
        />
      </div>
    ))}
  </div>

  <!-- No results -->
  <div id="no-results" style="display:none;text-align:center;padding:4rem 1rem">
    <div style="font-size:4rem;margin-bottom:1rem">🐕</div>
    <p style="font-family:'Archivo Black',sans-serif;font-size:1rem;text-transform:uppercase;color:var(--smoke)">NO BREEDS MATCH YOUR FILTERS.</p>
    <button onclick="resetFilters()" class="btn-lime" style="margin-top:1rem">RESET FILTERS →</button>
  </div>
</div>

<Footer/>

<script>
  const items = document.querySelectorAll('.breed-item');
  const btns  = document.querySelectorAll('.filter-btn');
  const shownCount = document.getElementById('shown-count');
  const noRes = document.getElementById('no-results');
  const searchInput = document.getElementById('breed-search');

  let activeFilters = {group:'', size:'', energy:''};
  let searchTerm = '';

  function applyFilters() {
    let count = 0;
    items.forEach(item => {
      const name   = item.dataset.name;
      const group  = item.dataset.group;
      const size   = item.dataset.size;
      const energy = item.dataset.energy;
      const show   =
        (!searchTerm || name.includes(searchTerm)) &&
        (!activeFilters.group  || group  === activeFilters.group) &&
        (!activeFilters.size   || size   === activeFilters.size) &&
        (!activeFilters.energy || energy === activeFilters.energy);
      item.style.display = show ? '' : 'none';
      if (show) count++;
    });
    if (shownCount) shownCount.textContent = count;
    if (noRes) noRes.style.display = count === 0 ? 'block' : 'none';
  }

  searchInput?.addEventListener('input', e => {
    searchTerm = e.target.value.toLowerCase().trim();
    applyFilters();
  });

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const f = btn.dataset.filter, v = btn.dataset.value;
      activeFilters[f] = v;
      document.querySelectorAll(`.filter-btn[data-filter="${f}"]`).forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
  });

  window.resetFilters = () => {
    activeFilters = {group:'', size:'', energy:''};
    searchTerm = '';
    if(searchInput) searchInput.value = '';
    btns.forEach(b => { b.classList.remove('active'); if(b.dataset.value==='') b.classList.add('active'); });
    applyFilters();
  };
</script>
</body>
</html>
