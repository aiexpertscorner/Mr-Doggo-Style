        <aside class="breed-sidebar" aria-label={`${b.name} sidebar`}>
          <div class="breed-sidebar__inner">
            <section class="breed-sidebar-card">
              <h2>Quick Facts</h2>

              <dl>
                {[
                  ['Size', titleCase(b.size_category)],
                  ['Energy', titleCase(b.energy_level)],
                  ['Shedding', titleCase(b.shedding_level)],
                  ['Training', titleCase(b.training_level)],
                  ['Coat', COAT_LABEL[b.coat_type] || titleCase(b.coat_type)],
                  ['Grooming', b.grooming_freq],
                  wt.min_lbs ? ['Weight', `${wt.min_lbs}–${wt.max_lbs} lbs`] : null,
                  life.min ? ['Lifespan', `${life.min}–${life.max} years`] : null,
                  b.akc_group ? ['AKC Group', b.akc_group.replace(' Group', '')] : null,
                  b.origin_country ? ['Origin', b.origin_country] : null,
                  profile.intelligence_tier ? ['Intelligence', titleCase(profile.intelligence_tier as string)] : null,
                  ['Owner difficulty', `${profile.owner_difficulty}/10`],
                ].filter(Boolean).map((row: any) => (
                  <div>
                    <dt>{row[0]}</dt>
                    <dd>{row[1]}</dd>
                  </div>
                ))}
              </dl>
            </section>

            <AwinProductSlot
              topicTags={[...awinBaseTags, 'dog-owner', 'care', 'lifestyle']}
              pageType="breed"
              breedSize={b.size_category}
              breedEnergy={b.energy_level}
              breedTraining={b.training_level}
              headline={`For ${b.name} owners`}
              variant="compact"
            />

            <PageBannerSlot
              pageType="breed"
              placement="after-summary"
              topic="care"
              topicTags={[...awinBaseTags, 'care']}
              compact={true}
            />

            <section class="breed-sidebar-card">
              <h2>{b.name} Guides</h2>

              <nav class="breed-sidebar-nav">
                <a href={COST_CALC_HREF} class="is-featured">
                  <span>💰</span>
                  <strong>Cost calculator</strong>
