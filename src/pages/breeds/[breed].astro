                {CLUSTER_LINKS.filter((item) => status[item.key] && item.href).map((item) => (
                  <a href={item.href}>
                    <span>{item.emoji}</span>
                    <strong>{item.label}</strong>
                  </a>
                ))}
              </nav>
            </section>
          </div>
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>

