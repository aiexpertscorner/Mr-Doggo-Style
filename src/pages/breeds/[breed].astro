---
/**
 * src/pages/breeds/[breed].astro — Breed hub page v3
 *
 * Cleaned layout:
 * - Uses BreedImage gallery/fallback pipeline
 * - Removes Amazon/productIndex blocks
 * - Uses AWIN affiliate pipeline via AwinProductSlot + PageBannerSlot
 * - Safer wording: no unsupported "Expert Picks"
 * - Mobile-first, token-driven styling
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import masterBreeds from '../../data/master-breeds.json';
import masterCrossbreeds from '../../data/master-crossbreeds.json';
import breedLinkMap from '../../data/breed-link-map.json';
import contentStatus from '../../data/content-status.json';
import healthProfiles from '../../data/breed-health-profiles.json';

import BreedImage from '../../components/breed/BreedImage.astro';
import PageBannerSlot from '../../components/affiliate/PageBannerSlot.astro';
import AwinProductSlot from '../../components/affiliate/AwinProductSlot.astro';
import BreedCareProfile from '../../components/enrichment/BreedCareProfile.astro';

import { deriveProfile } from '../../../scripts/lib/breed-profile.mjs';
import { existsSync } from 'fs';
import { join } from 'path';

const SITE = 'https://pupwiki.com';

const ALL_BREEDS = [...(masterBreeds as any[]), ...(masterCrossbreeds as any[])];

export function getStaticPaths() {
  const allBreeds = [...(masterBreeds as any[]), ...(masterCrossbreeds as any[])];

  return allBreeds
    .filter((breed) => breed?.slug)
    .map((breed) => ({
      params: { breed: breed.slug },
    }));
}

const { breed: slug } = Astro.params;
const b = ALL_BREEDS.find((item) => item.slug === slug);

if (!b) return Astro.redirect('/breeds');

const isCrossbreed = Array.isArray(b.parent_breeds) && b.parent_breeds.length > 0;
const profile = deriveProfile(b);

const links = (breedLinkMap as any)[slug] || {};
const status = (contentStatus as any)[slug] || {};
const rank = b.ranking_data || {};
const life = b.life_expectancy || {};
const wt = b.weight || {};
const ht = b.height || {};

const healthProfileList = Array.isArray((healthProfiles as any).profiles)
  ? (healthProfiles as any).profiles
  : [];

const healthProfile = healthProfileList.find((p: any) => p.breed_slug === slug) ?? null;

const imageUrls = [
  ...(Array.isArray(b.image_urls) ? b.image_urls : []),
  ...(Array.isArray(b.image_gallery) ? b.image_gallery.map((item: any) => item.url || item.image_url) : []),
  b.image_url,
].filter(Boolean);

const primaryImage = imageUrls[0] || b.image_url || '';

const COAT_LABEL: Record<string, string> = {
  double: 'Double coat',
  long: 'Long coat',
  short: 'Short coat',
  wiry: 'Wire coat',
  curly: 'Curly coat',
  silky: 'Silky coat',
  corded: 'Corded',
  hairless: 'Hairless',
  wavy: 'Wavy coat',
};

const SEVERITY_STYLES: Record<string, { className: string; label: string }> = {
  Low: { className: 'is-low', label: 'Low' },
  Medium: { className: 'is-medium', label: 'Medium' },
  'Medium-High': { className: 'is-medium-high', label: 'Medium-High' },
  High: { className: 'is-high', label: 'High' },
  Critical: { className: 'is-critical', label: 'Critical' },
};

function titleCase(value?: string | null) {
  if (!value) return '';
  return String(value)
    .replace(/[-_]+/g, ' ')
    .replace(/\b\w/g, (char) => char.toUpperCase());
}

function pctBar(value: number) {
  return Math.round((value || 0) * 100);
}

function truncate(value?: string, max = 280) {
  if (!value) return '';
  return value.length > max ? `${value.slice(0, max).trim()}…` : value;
}

const CLUSTER_LINKS = [
  { key: 'food_post', href: links.food_post, emoji: '🍖', label: `${b.name} food & nutrition guide` },
  { key: 'toy_post', href: links.toy_post, emoji: '🎾', label: `${b.name} toy & enrichment ideas` },
  { key: 'names_page', href: links.names_page, emoji: '✍️', label: `${b.name} names` },
  { key: 'bed_post', href: links.bed_post, emoji: '🛏️', label: `${b.name} bed & sleep guide` },
  { key: 'grooming_post', href: links.grooming_post, emoji: '✂️', label: `${b.name} grooming guide` },
  { key: 'health_post', href: links.health_post, emoji: '🩺', label: `${b.name} health concerns` },
  { key: 'supplement_post', href: links.supplement_post, emoji: '💊', label: `${b.name} supplement considerations` },
  { key: 'training_post', href: links.training_post, emoji: '🦮', label: `${b.name} training guide` },
];

const COST_CALC_HREF = `/cost-calculator/${slug}`;

const enrichmentPath = join(process.cwd(), 'src/data/enrichment/breeds', `${slug}.json`);
let enrichmentData: any = null;
if (existsSync(enrichmentPath)) {
  const { readFileSync } = await import('fs');
  enrichmentData = JSON.parse(readFileSync(enrichmentPath, 'utf8'));
}

const suitabilityBullets: string[] = [];
{
  const difficulty = Number(profile.owner_difficulty || 5);
  const traits: string[] = (profile.dominant_traits as string[]) || [];
  const firstTrait = traits[0] || 'adaptable';

  if (difficulty <= 3) {
    suitabilityBullets.push(`Suitable for first-time owners — rates ${difficulty}/10 on the owner difficulty scale.`);
  } else if (difficulty <= 6) {
    suitabilityBullets.push(`Best suited to owners with some dog experience — difficulty rated ${difficulty}/10.`);
  } else {
    suitabilityBullets.push(`Recommended for experienced owners — higher owner difficulty rating of ${difficulty}/10.`);
  }

  if (profile.is_urban_friendly) {
    suitabilityBullets.push('Urban-friendly: adapts well to apartment or townhouse living when daily exercise is consistent.');
  } else {
    suitabilityBullets.push(`Better suited to homes with outdoor space — this ${b.size_category || 'dog'} needs room to move.`);
  }

  const traitSentence = traits.length >= 2
    ? `Naturally ${traits.slice(0, 2).join(' and ')}, this breed fits best with early socialization and clear routines.`
    : `A ${firstTrait} temperament can make this breed a reliable companion for the right household.`;

  suitabilityBullets.push(traitSentence);

  if (profile.is_working_heritage) {
    suitabilityBullets.push('Working heritage means structured activity matters — under-stimulation can lead to problem behaviors.');
  }
}

const TRAITS = [
  { label: 'Energy', val: b.traits?.energy_value || 0, className: 'is-energy' },
  { label: 'Shedding', val: b.traits?.shedding_value || 0, className: 'is-shedding' },
  { label: 'Trainability', val: b.traits?.trainability_value || 0, className: 'is-training' },
  { label: 'Grooming', val: b.traits?.grooming_value || 0, className: 'is-grooming' },
  { label: 'Friendliness', val: b.traits?.demeanor_value || 0, className: 'is-friendly' },
];

const awinBaseTags = [
  b.size_category,
  b.energy_level,
  b.training_level,
  b.coat_type,
  b.akc_group,
  isCrossbreed ? 'mixed-breed' : 'purebred',
  profile.is_working_heritage ? 'working-dog' : null,
  profile.is_urban_friendly ? 'apartment' : 'outdoor-space',
  'breed',
  'dog-owners',
].filter(Boolean) as string[];

const relatedGuides = [
  {
    href: '/blog/best-dog-food-maker-chefpaw-review-2026',
    emoji: '🍳',
    label: 'Fresh dog food tools: what to compare',
    desc: 'A practical look at fresh-food prep, cost, and owner fit.',
    tag: 'Food',
  },
  {
    href: '/blog/best-training-tools-stubborn-dogs-2026',
    emoji: '🦮',
    label: 'Training gear for dogs that need structure',
    desc: 'Harnesses, long lines, and reward routines for better walks.',
    tag: 'Training',
  },
  {
    href: '/blog/best-gifts-for-dog-lovers-2026',
    emoji: '🎁',
    label: 'Dog lover gifts that feel personal',
    desc: 'Custom portraits and practical dog-parent gift ideas.',
    tag: 'Lifestyle',
  },
];

const pageTitle = b.seo?.title || `${b.name} Dog Breed Guide — Traits, Care, Costs & Owner Fit`;
const pageDescription =
  b.seo?.description ||
  `Complete ${b.name} guide: temperament, size, grooming, training, health context, ownership costs, and practical next steps.`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDescription,
  image: primaryImage || undefined,
  author: { '@type': 'Organization', name: 'PupWiki' },
  publisher: { '@type': 'Organization', name: 'PupWiki' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE}/breeds/${slug}` },
});

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Breeds', item: `${SITE}/breeds` },
    { '@type': 'ListItem', position: 3, name: b.name, item: `${SITE}/breeds/${slug}` },
  ],
});

const faqItems: { q: string; a: string }[] = [
  {
    q: `Is the ${b.name} a good family dog?`,
    a: b.temperament
      ? `${b.name}s are known for being ${b.temperament.slice(0, 100).toLowerCase()}. They are generally considered ${b.good_with_kids === true ? 'good' : b.good_with_kids === false ? 'better suited to adult households' : 'adaptable'} with children. As with all breeds, supervised interaction with young children is recommended.`
      : `${b.name}s have a ${(b.energy_level || 'moderate').toLowerCase()} energy level. Individual temperament varies, so early socialisation and consistent training are important for family integration.`,
  },
  {
    q: `How much exercise does a ${b.name} need daily?`,
    a: b.exercise_needs_text
      ? b.exercise_needs_text
      : b.energy_level === 'active'
        ? `${b.name}s are an active breed and need at least 1–2 hours of vigorous exercise daily, plus mental enrichment to prevent boredom.`
        : b.energy_level === 'calm'
          ? `${b.name}s have moderate energy and typically do well with 30–45 minutes of daily exercise, though they enjoy outdoor time.`
          : `${b.name}s need regular daily exercise — typically 45–60 minutes — to stay healthy and well-behaved.`,
  },
  ...(healthProfile?.common_issues?.length > 0
    ? [{
        q: `What health issues are common in ${b.name}s?`,
        a: `${b.name}s may be prone to ${(healthProfile.common_issues as any[]).slice(0, 3).map((i: any) => i.name || i).join(', ')}. Regular veterinary check-ups and breed-specific health screening are recommended. This is general information — consult your vet for guidance specific to your dog.`,
      }]
    : []),
];

const faqLd = faqItems.length > 0 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}) : null;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={`${SITE}/breeds/${slug}`}
  pageType="profile"
  ogImage={primaryImage || undefined}
  ogImageAlt={`${b.name} dog breed guide`}
>
  <script type="application/ld+json" set:html={jsonLd} />
  <script type="application/ld+json" set:html={breadcrumbLd} />
  {faqLd && <script type="application/ld+json" set:html={faqLd} />}

  <main class="breed-page">
    <section class="breed-hero" aria-labelledby="breed-title">
      <div class="breed-container">
        <nav class="breed-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/breeds">Breeds</a>
          <span aria-hidden="true">›</span>
          <span>{b.name}</span>
        </nav>

        <div class="breed-hero__grid">
          <BreedImage
            breed={b}
            width={640}
            height={640}
            priority={true}
            showGallery={true}
            variant="hero"
            class="breed-hero__image"
          />

          <div class="breed-hero__content">
            <div class="breed-pills" aria-label={`${b.name} quick labels`}>
              {isCrossbreed ? (
                <span class="breed-pill breed-pill--purple">Designer / Mixed Breed</span>
              ) : (
                <span class="breed-pill breed-pill--accent">{titleCase(b.size_category)} breed</span>
              )}

              {b.energy_level && <span class="breed-pill breed-pill--warm">{titleCase(b.energy_level)} energy</span>}
              {b.coat_type && <span class="breed-pill">{COAT_LABEL[b.coat_type] || titleCase(b.coat_type)}</span>}
              {b.akc_group && <span class="breed-pill breed-pill--purple">{b.akc_group}</span>}

              {!isCrossbreed && b.origin_country && (
                <a href={`/breeds?origin=${encodeURIComponent(b.origin_country)}`} class="breed-pill breed-pill--success">
                  🌍 {b.origin_country}
                </a>
              )}

              {b.akc_popularity && b.akc_popularity <= 20 && (
                <span class="breed-pill breed-pill--gold">🏆 #{b.akc_popularity} most popular</span>
              )}

              {isCrossbreed && b.is_poodle_mix && (
                <span class="breed-pill breed-pill--success">🐩 Poodle mix</span>
              )}
            </div>

            <h1 id="breed-title">{b.name}</h1>

            {b.temperament && (
              <p class="breed-hero__temperament">{b.temperament}</p>
            )}

            {b.description && (
              <p class="breed-hero__description">
                {truncate(b.description)}
              </p>
            )}

            <div class="breed-quick-facts" aria-label={`${b.name} key facts`}>
              {wt.min_lbs && wt.max_lbs && <span>⚖️ {wt.min_lbs}–{wt.max_lbs} lbs</span>}
              {ht.min_in && ht.max_in && <span>📏 {ht.min_in}–{ht.max_in}"</span>}
              {life.min && life.max && <span>🎂 {life.min}–{life.max} years</span>}
              {rank.intelligence_rank && (
                <span>🧠 Intelligence #{rank.intelligence_rank}{profile.intelligence_tier ? ` — ${profile.intelligence_tier}` : ''}</span>
              )}
            </div>

            {isCrossbreed && b.parent_breeds?.length > 0 && (
              <div class="breed-parent-row" aria-label={`${b.name} parent breeds`}>
                <span>Mix of:</span>
                {(b.parent_breeds as any[]).map((parent) => (
                  <a href={`/breeds/${parent.slug}`}>🐕 {parent.name}</a>
                ))}
              </div>
            )}

            <div class="breed-hero__actions">
              <a href={COST_CALC_HREF} class="breed-button breed-button--primary">
                Estimate {b.name} costs
                <span aria-hidden="true">→</span>
              </a>

              {links.names_page && (
                <a href={links.names_page} class="breed-button breed-button--secondary">
                  Find {b.name} names
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="breed-container breed-main">
      <div class="breed-layout">
        <div class="breed-content">
          <section class="breed-section" aria-labelledby="characteristics-title">
            <div class="breed-section__header">
              <p class="breed-eyebrow">Traits</p>
              <h2 id="characteristics-title">{b.name} Characteristics</h2>
            </div>

            <div class="breed-traits-grid">
              {TRAITS.map((trait) => (
                <article class="breed-trait-card">
                  <p>{trait.label}</p>
                  <div class="breed-meter" aria-hidden="true">
                    <span class={trait.className} style={`width:${pctBar(trait.val)}%`}></span>
                  </div>
                  <strong>{pctBar(trait.val)}%</strong>
                </article>
              ))}

              {b.coat_type && (
                <article class="breed-trait-card">
                  <p>Coat Type</p>
                  <strong>{COAT_LABEL[b.coat_type] || titleCase(b.coat_type)}</strong>
                  {b.grooming_freq && <span class="breed-trait-card__muted">{b.grooming_freq}</span>}
                </article>
              )}
            </div>
          </section>

          {rank && (rank.intelligence_rank || rank.longevity_years || rank.lifetime_cost_usd || rank.annual_food_cost) && (
            <section class="breed-section breed-section--warm" aria-labelledby="breed-data-title">
              <div class="breed-section__header">
                <p class="breed-eyebrow">Breed data</p>
                <h2 id="breed-data-title">Data Snapshot</h2>
              </div>

              <div class="breed-data-grid">
                {rank.intelligence_rank && (
                  <article>
                    <span>🧠</span>
                    <strong>#{rank.intelligence_rank}</strong>
                    <p>Intelligence</p>
                  </article>
                )}

                {rank.longevity_years && (
                  <article>
                    <span>🎂</span>
                    <strong>{rank.longevity_years}yr</strong>
                    <p>Average lifespan</p>
                  </article>
                )}

                {rank.lifetime_cost_usd && (
                  <article>
                    <span>💰</span>
                    <strong>${(rank.lifetime_cost_usd / 1000).toFixed(0)}K</strong>
                    <p>Lifetime cost</p>
                  </article>
                )}

                {rank.annual_food_cost && (
                  <article>
                    <span>🍖</span>
                    <strong>${rank.annual_food_cost}/yr</strong>
                    <p>Annual food estimate</p>
                  </article>
                )}

                {rank.children_score !== undefined && (
                  <article>
                    <span>👨‍👩‍👧</span>
                    <strong>{rank.children_score >= 0.8 ? 'Great' : rank.children_score >= 0.5 ? 'Good' : 'Careful'}</strong>
                    <p>With kids</p>
                  </article>
                )}

                {rank.genetic_ailments !== undefined && (
                  <article>
                    <span>🩺</span>
                    <strong>{rank.genetic_ailments}</strong>
                    <p>Known conditions</p>
                  </article>
                )}
              </div>

              {rank.genetic_ailment_names && rank.genetic_ailment_names !== 'none' && (
                <p class="breed-muted">
                  Known genetic concerns: <strong>{rank.genetic_ailment_names}</strong>
                </p>
              )}
            </section>
          )}

          {healthProfile && (
            <section class="breed-section" aria-labelledby="health-title">
              <div class="breed-section__header">
                <p class="breed-eyebrow breed-eyebrow--danger">Health watch</p>
                <h2 id="health-title">{b.name} Health Context</h2>
              </div>

              <div class="breed-health-note">
                <strong>Veterinary note</strong>
                <p>
                  This section is general breed information, not veterinary advice. If your dog has symptoms,
                  pain, breathing issues, sudden behavior changes, or urgent concerns, contact a veterinarian.
                </p>
              </div>

              <div class="breed-health-list">
                {(healthProfile.common_issues as any[]).map((issue) => {
                  const severity = SEVERITY_STYLES[issue.severity] ?? SEVERITY_STYLES.Medium;

                  return (
                    <article class:list={['breed-health-card', severity.className]}>
                      <div>
                        <span>{severity.label}</span>
                      </div>

                      <div>
                        <h3>{issue.name}</h3>
                        {issue.prevalence && <em>{issue.prevalence} prevalence</em>}
                        {issue.early_warning && (
                          <p><strong>Early signs:</strong> {issue.early_warning}</p>
                        )}
                      </div>
                    </article>
                  );
                })}
              </div>

              {healthProfile.care_tips && (
                <div class="breed-callout breed-callout--info">
                  <span aria-hidden="true">💡</span>
                  <p>{healthProfile.care_tips}</p>
                </div>
              )}
            </section>
          )}

          {healthProfile && (
            <a href={COST_CALC_HREF} class="breed-cost-link">
              <div>
                <strong>{healthProfile.common_issues?.[0]?.name ?? 'Health considerations'}</strong>
                <p>Breed health context can affect lifetime costs. Estimate food, care, and planning costs for a {b.name}.</p>
              </div>
              <span aria-hidden="true">💰</span>
            </a>
          )}

          <section class="breed-section breed-section--awin" aria-labelledby="owner-picks-title">
            <div class="breed-section__header">
              <p class="breed-eyebrow">Owner resources</p>
              <h2 id="owner-picks-title">Matched Resources for {b.name} Owners</h2>
              <p>
                Contextual partner picks from the PupWiki affiliate pipeline. These are matched by breed size,
                energy, training needs, lifestyle, and ownership intent.
              </p>
            </div>

            <div class="breed-awin-grid">
              <AwinProductSlot
                topicTags={[...awinBaseTags, 'food', 'nutrition', 'fresh-food', 'meal-prep']}
                pageType="breed"
                category="food"
                breedSize={b.size_category}
                breedEnergy={b.energy_level}
                breedTraining={b.training_level}
                headline={`${b.name} food & nutrition tools`}
              />

              <AwinProductSlot
                topicTags={[...awinBaseTags, 'training', 'walking', 'harness', 'obedience']}
                pageType="breed"
                category="training"
                breedSize={b.size_category}
                breedEnergy={b.energy_level}
                breedTraining={b.training_level}
                headline={`${b.name} training & walking gear`}
              />

              <AwinProductSlot
                topicTags={[...awinBaseTags, 'gift', 'lifestyle', 'custom-pet', 'dog-owner']}
                pageType="breed"
                category="gifts"
                breedSize={b.size_category}
                breedEnergy={b.energy_level}
                breedTraining={b.training_level}
                headline={`For ${b.name} owners`}
              />
            </div>

            <p class="breed-affiliate-note">
              Affiliate disclosure: PupWiki may earn a commission from qualifying partner links,
              at no extra cost to you. Availability and pricing can change.
            </p>
          </section>

          {b.care_tips?.length > 0 && (
            <section class="breed-section" aria-labelledby="care-title">
              <div class="breed-section__header">
                <p class="breed-eyebrow">Care basics</p>
                <h2 id="care-title">{b.name} Care Tips</h2>
              </div>

              <div class="breed-tip-list">
                {b.care_tips.map((tip: string) => (
                  <article>
                    <span aria-hidden="true">✓</span>
                    <p>{tip}</p>
                  </article>
                ))}
              </div>
            </section>
          )}

          <section class="breed-section breed-section--success" aria-labelledby="fit-title">
            <div class="breed-section__header">
              <p class="breed-eyebrow">Owner fit</p>
              <h2 id="fit-title">Who the {b.name} Suits</h2>
            </div>

            <ul class="breed-fit-list">
              {suitabilityBullets.map((bullet) => (
                <li>
                  <span aria-hidden="true">✓</span>
                  <p>{bullet}</p>
                </li>
              ))}
            </ul>

            {profile.coat_care_label && (
              <p class="breed-section__footer-note">
                <strong>Grooming commitment:</strong> {profile.coat_care_label as string}
              </p>
            )}
          </section>

          <section class="breed-section breed-section--decision" aria-labelledby="decision-title">
            <div class="breed-section__header">
              <p class="breed-eyebrow">Before you choose</p>
              <h2 id="decision-title">Make an Informed {b.name} Decision</h2>
            </div>

            <div class="breed-decision-grid">
              <a href="/breed-quiz">
                <span>🐾</span>
                <strong>Is this breed right for me?</strong>
                <p>Compare your lifestyle, home, experience level, and activity needs.</p>
              </a>

              <a href={COST_CALC_HREF}>
                <span>💰</span>
                <strong>What does a {b.name} cost?</strong>
                <p>Estimate puppy, annual, food, care, and lifetime ownership costs.</p>
              </a>

              <a href="/guides/first-dog">
