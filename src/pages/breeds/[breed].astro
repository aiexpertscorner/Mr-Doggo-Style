---
/**
 * breeds/[breed].astro — Breed hub page v2
 * - Real Dog CEO images via breed.image_url
 * - Full master-breeds.json data: ranking, FCI, traits, products
 * - Cluster links to all 10 content types
 * - Tailwind CSS (matching existing site design)
 */
import BaseLayout          from '../../layouts/BaseLayout.astro';
import masterBreeds        from '../../data/master-breeds.json';
import masterCrossbreeds   from '../../data/master-crossbreeds.json';
import productIndex        from '../../data/product-index.json';
import breedLinkMap        from '../../data/breed-link-map.json';
import contentStatus       from '../../data/content-status.json';
import affiliateProducts    from '../../data/affiliate-products.json';
import AffiliateProductCard  from '../../components/ui/AffiliateProductCard.astro';
import PageBannerSlot        from '../../components/affiliate/PageBannerSlot.astro';
import AwinProductSlot       from '../../components/affiliate/AwinProductSlot.astro';
import healthProfiles        from '../../data/breed-health-profiles.json';
import { deriveProfile } from '../../../scripts/lib/breed-profile.mjs';

const AFFILIATE_TAG = 'aiexpertscorn-20';
const SITE          = 'https://pupwiki.com';

const ALL_BREEDS = [...(masterBreeds as any[]), ...(masterCrossbreeds as any[])];

export function getStaticPaths() {
  const allBreeds = [...(masterBreeds as any[]), ...(masterCrossbreeds as any[])];
  return allBreeds.map(b => ({ params: { breed: b.slug } }));
}

const { breed: slug } = Astro.params;
const b = ALL_BREEDS.find(x => x.slug === slug);
if (!b) return Astro.redirect('/breeds');

const isCrossbreed = !!(b.parent_breeds?.length);

const profile = deriveProfile(b);

const links  = (breedLinkMap as any)[slug]     || {};
const status = (contentStatus as any)[slug]    || {};
const picks  = b.product_picks                 || {};
const rank   = b.ranking_data                  || {};
const life   = b.life_expectancy               || {};
const wt     = b.weight                        || {};
const ht     = b.height                        || {};

// Get matched products
const topProds = Object.entries(picks)
  .map(([cat, id]) => { const p = (productIndex as any)[id as string]; return p ? {...p, _cat: cat} : null; })
  .filter(Boolean).slice(0, 6);

const foodProd = picks['dog-food'] ? (productIndex as any)[picks['dog-food']] : null;
const toyProd  = picks['toys']     ? (productIndex as any)[picks['toys']]     : null;

const healthProfile = (healthProfiles as any).profiles.find((p: any) => p.breed_slug === slug) ?? null;
const SEVERITY_STYLES: Record<string, { bg: string; color: string }> = {
  Low:          { bg: 'var(--color-success-light)', color: '#16a34a' },
  Medium:       { bg: '#fefce8', color: '#ca8a04' },
  'Medium-High':{ bg: '#fff7ed', color: '#ea580c' },
  High:         { bg: '#fef2f2', color: '#dc2626' },
  Critical:     { bg: '#fdf2f8', color: '#9333ea' },
};

const SIZE_EMOJI: Record<string,string> = { small:'🐕', medium:'🐕‍🦺', large:'🐕‍🦺', giant:'🦮' };
const COAT_LABEL: Record<string,string> = {
  double:'Double coat', long:'Long coat', short:'Short coat', wiry:'Wire coat',
  curly:'Curly coat', silky:'Silky coat', corded:'Corded', hairless:'Hairless', wavy:'Wavy coat',
};
const ENERGY_COLOR: Record<string,string> = { active:'#16a34a', regular:'var(--color-warning)', calm:'#6366f1' };
const TRAIN_COLOR:  Record<string,string> = { easy:'#16a34a', moderate:'var(--color-warning)', difficult:'#ef4444' };

function amzUrl(asin: string) { return `https://www.amazon.com/dp/${asin}/?tag=${AFFILIATE_TAG}`; }
function pctBar(val: number) { return Math.round((val || 0) * 100); }

const CLUSTER_LINKS = [
  { key:'food_post',       href: links.food_post,       emoji:'🍖', label:`Best food for ${b.name}s`       },
  { key:'toy_post',        href: links.toy_post,        emoji:'🎾', label:`Best toys for ${b.name}s`        },
  { key:'names_page',      href: links.names_page,      emoji:'✍️', label:`${b.name} names`                 },
  { key:'bed_post',        href: links.bed_post,        emoji:'🛏️', label:`Best beds for ${b.name}s`        },
  { key:'grooming_post',   href: links.grooming_post,   emoji:'✂️', label:`Grooming guide`                  },
  { key:'health_post',     href: links.health_post,     emoji:'🩺', label:`Health problems`                 },
  { key:'supplement_post', href: links.supplement_post, emoji:'💊', label:`Best supplements`                },
  { key:'training_post',   href: links.training_post,   emoji:'🦮', label:`Training guide`                  },
];

const COST_CALC_HREF = `/cost-calculator/${slug}`;

// ── "Who this breed suits" — 2–4 data-driven bullets ────────────
const suitabilityBullets: string[] = [];
{
  const d = profile.owner_difficulty as number;
  const traits: string[] = (profile.dominant_traits as string[]) || [];
  const firstTrait = traits[0] || 'adaptable';
  const energyLabel: Record<string,string> = { active:'very active', regular:'moderately active', calm:'relaxed' };

  if (d <= 3) {
    suitabilityBullets.push(`Suitable for first-time owners — rates ${d}/10 on the owner difficulty scale.`);
  } else if (d <= 6) {
    suitabilityBullets.push(`Best suited to owners with some dog experience — difficulty rated ${d}/10.`);
  } else {
    suitabilityBullets.push(`Recommended for experienced owners — high owner difficulty rating of ${d}/10.`);
  }

  if (profile.is_urban_friendly) {
    suitabilityBullets.push(`Urban-friendly: adapts well to flat or townhouse living provided daily exercise is consistent.`);
  } else {
    suitabilityBullets.push(`Better suited to homes with outdoor space — this ${b.size_category} breed needs room to move.`);
  }

  const traitSentence = traits.length >= 2
    ? `Naturally ${traits.slice(0, 2).join(' and ')}, it integrates well into family life when socialised early.`
    : `A ${firstTrait} temperament makes it a reliable companion for the right household.`;
  suitabilityBullets.push(traitSentence);

  if (profile.is_working_heritage) {
    suitabilityBullets.push(`Working heritage means it needs a job or structured activity — under-stimulation leads to problem behaviours.`);
  }
}

const TRAITS = [
  { label:'Energy',       val: b.traits?.energy_value       || 0, color:'#16a34a' },
  { label:'Shedding',     val: b.traits?.shedding_value     || 0, color:'#f59e0b' },
  { label:'Trainability', val: b.traits?.trainability_value || 0, color:'#3b82f6' },
  { label:'Grooming',     val: b.traits?.grooming_value     || 0, color:'#8b5cf6' },
  { label:'Friendliness', val: b.traits?.demeanor_value     || 0, color:'#ec4899' },
];

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": b.seo?.title || `${b.name} Dog Breed Guide`,
  "description": b.seo?.description,
  "image": b.image_url || "",
  "author": { "@type": "Organization", "name": "PupWiki" },
  "publisher": { "@type": "Organization", "name": "PupWiki" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `${SITE}/breeds/${slug}` },
});

const breadcrumbLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",   "item": `${SITE}/` },
    { "@type": "ListItem", "position": 2, "name": "Breeds", "item": `${SITE}/breeds` },
    { "@type": "ListItem", "position": 3, "name": b.name,   "item": `${SITE}/breeds/${slug}` },
  ]
});
---

<BaseLayout
  title={b.seo?.title || `${b.name} Dog — Expert Care Guide & Products 2026`}
  description={b.seo?.description || `Complete ${b.name} guide: best food, toys, beds and grooming matched to this breed's size, energy and coat type.`}
  canonicalUrl={`${SITE}/breeds/${slug}`}
>
  <script type="application/ld+json" set:html={jsonLd} />
  <script type="application/ld+json" set:html={breadcrumbLd} />

  <!-- ── Breed Hero ── -->
  <div style="background:linear-gradient(to bottom,var(--color-surface-warm),var(--color-bg-soft));border-bottom:1px solid var(--color-border-warm)">
    <div class="max-w-7xl mx-auto px-4 py-10 sm:py-14">

      <!-- Breadcrumb -->
      <nav class="font-sans text-sm mb-4 flex flex-wrap items-center gap-1" style="color:var(--color-accent)">
        <a href="/" class="hover:underline" style="color:var(--color-accent)">Home</a>
        <span style="color:#d4a574">›</span>
        <a href="/breeds" class="hover:underline" style="color:var(--color-accent)">Breeds</a>
        <span style="color:#d4a574">›</span>
        <span style="color:var(--color-accent-active)">{b.name}</span>
      </nav>

      <div class="flex flex-col md:flex-row md:items-start gap-8">

        <!-- Image -->
        <div class="flex-shrink-0">
          {b.image_url ? (
            <img
              src={b.image_url}
              alt={`${b.name} dog`}
              width="240"
              height="240"
              loading="eager"
              decoding="async"
              class="w-48 h-48 md:w-60 md:h-60 object-cover rounded-2xl shadow-lg border-4"
              style="border-color:var(--color-border-warm)"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
            />
            <div class="w-48 h-48 md:w-60 md:h-60 rounded-2xl hidden items-center justify-content-center text-7xl" style="background:var(--color-surface-warm);display:none">
              {SIZE_EMOJI[b.size_category]||'🐕'}
            </div>
          ) : (
            <div class="w-48 h-48 md:w-60 md:h-60 rounded-2xl flex items-center justify-center text-7xl" style="background:var(--color-surface-warm)">
              {SIZE_EMOJI[b.size_category]||'🐕'}
            </div>
          )}
        </div>

        <!-- Info -->
        <div class="flex-1 min-w-0">
          <!-- Badges -->
          <div class="flex flex-wrap gap-2 mb-3">
            {isCrossbreed ? (
              <span class="font-sans text-xs font-bold px-3 py-1 rounded-full" style="background:#7c3aed;color:white">
                Designer / Mixed Breed
              </span>
            ) : (
              <span class="font-sans text-xs font-bold px-3 py-1 rounded-full" style="background:var(--color-accent);color:white">
                {b.size_category.charAt(0).toUpperCase()+b.size_category.slice(1)} breed
              </span>
            )}
            <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style="background:var(--color-warning-light);color:var(--color-accent-active)">
              {b.energy_level} energy
            </span>
            <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style="background:#f3f4f6;color:#374151">
              {COAT_LABEL[b.coat_type]||b.coat_type}
            </span>
            {b.akc_group && (
              <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style="background:#ede9fe;color:#5b21b6">
                {b.akc_group}
              </span>
            )}
            {!isCrossbreed && b.origin_country && (
              <a
                href={`/breeds?origin=${encodeURIComponent(b.origin_country)}`}
                class="font-sans text-xs font-semibold px-3 py-1 rounded-full hover:opacity-80 transition-opacity"
                style="background:var(--color-success-light);color:var(--color-success);text-decoration:none"
              >
                🌍 {b.origin_country} →
              </a>
            )}
            {b.akc_popularity && b.akc_popularity <= 20 && (
              <span class="font-sans text-xs font-bold px-3 py-1 rounded-full" style="background:#fef9c3;color:#854d0e">
                🏆 #{b.akc_popularity} most popular
              </span>
            )}
            {isCrossbreed && b.is_poodle_mix && (
              <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style="background:var(--color-success-light);color:var(--color-success)">
                🐩 Poodle mix
              </span>
            )}
          </div>

          <h1 class="font-display text-4xl md:text-5xl font-bold mb-2" style="font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)">
            {b.name}
          </h1>

          {b.temperament && (
            <p class="font-body text-lg italic mb-3" style="color:var(--color-muted);font-family:'Source Serif 4',Georgia,serif">
              {b.temperament}
            </p>
          )}

          <p class="font-sans text-base leading-relaxed mb-4 max-w-2xl" style="color:var(--color-body-soft)">
            {b.description?.slice(0,280)}{b.description?.length > 280 ? '…' : ''}
          </p>

          <!-- Quick facts row -->
          <div class="flex flex-wrap gap-5 font-sans text-sm" style="color:var(--color-muted)">
            {wt.min_lbs && wt.max_lbs && <span>⚖️ {wt.min_lbs}–{wt.max_lbs} lbs ({wt.min_kg}–{wt.max_kg} kg)</span>}
            {ht.min_in  && ht.max_in  && <span>📏 {ht.min_in}–{ht.max_in}"</span>}
            {life.min   && life.max   && <span>🎂 {life.min}–{life.max} yr lifespan</span>}
            {rank.intelligence_rank   && <span>🧠 Intelligence #{rank.intelligence_rank}{profile.intelligence_tier ? ` — ${profile.intelligence_tier}` : ''}</span>}
          </div>

          <!-- Parent breeds (crossbreeds only) -->
          {isCrossbreed && b.parent_breeds?.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2 items-center font-sans text-sm">
              <span style="color:var(--color-muted);font-weight:600">Mix of:</span>
              {(b.parent_breeds as any[]).map((p: any) => (
                <a
                  href={`/breeds/${p.slug}`}
                  class="inline-flex items-center gap-1 px-3 py-1 rounded-full font-sans text-xs font-semibold transition-colors"
                  style="background:#ede9fe;color:#5b21b6;text-decoration:none;border:1px solid #ddd6fe"
                  onmouseover="this.style.background='#ddd6fe'"
                  onmouseout="this.style.background='#ede9fe'"
                >
                  🐕 {p.name}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- ── Main Content ── -->
  <div class="max-w-7xl mx-auto px-4 py-10">
    <div class="lg:grid lg:grid-cols-[1fr_300px] lg:gap-10">

      <!-- Left column -->
      <div class="space-y-10 min-w-0">

        <!-- Trait bars -->
        <section>
          <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)">
            {b.name} Characteristics
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            {TRAITS.map(t => (
              <div class="rounded-xl p-4" style="background:var(--color-bg-soft);border:1px solid var(--color-border-warm)">
                <p class="font-sans text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-subtle)">{t.label}</p>
                <div class="h-2 rounded-full mb-2" style="background:var(--color-border-warm);overflow:hidden">
                  <div class="h-full rounded-full" style={`width:${pctBar(t.val)}%;background:${t.color}`}></div>
                </div>
                <p class="font-sans text-sm font-semibold" style="color:var(--color-heading)">{pctBar(t.val)}%</p>
              </div>
            ))}
            <div class="rounded-xl p-4" style="background:var(--color-bg-soft);border:1px solid var(--color-border-warm)">
              <p class="font-sans text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-subtle)">Coat Type</p>
              <p class="font-sans text-sm font-semibold" style="color:var(--color-heading)">{COAT_LABEL[b.coat_type]||b.coat_type}</p>
              <p class="font-sans text-xs mt-1" style="color:var(--color-muted)">{b.grooming_freq}</p>
            </div>
          </div>
        </section>

        <!-- Ranking data panel -->
        {rank && rank.intelligence_rank && (
          <section class="rounded-2xl p-6" style="background:linear-gradient(135deg,var(--color-bg-soft),var(--color-warning-light));border:1px solid #fbbf24">
            <p class="font-sans text-xs font-bold uppercase tracking-wider mb-4" style="color:var(--color-accent-active)">Breed Data</p>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {rank.intelligence_rank && (
                <div class="rounded-xl p-3 text-center" style="background:white;border:1px solid var(--color-warning-light)">
                  <div class="text-2xl mb-1">🧠</div>
                  <div class="font-sans font-black text-xl" style="color:var(--color-heading)">#{rank.intelligence_rank}</div>
                  <div class="font-sans text-xs" style="color:var(--color-muted)">Intelligence</div>
                </div>
              )}
              {rank.longevity_years && (
                <div class="rounded-xl p-3 text-center" style="background:white;border:1px solid var(--color-warning-light)">
                  <div class="text-2xl mb-1">🎂</div>
                  <div class="font-sans font-black text-xl" style="color:var(--color-heading)">{rank.longevity_years}yr</div>
                  <div class="font-sans text-xs" style="color:var(--color-muted)">Avg lifespan</div>
                </div>
              )}
              {rank.lifetime_cost_usd && (
                <div class="rounded-xl p-3 text-center" style="background:white;border:1px solid var(--color-warning-light)">
                  <div class="text-2xl mb-1">💰</div>
                  <div class="font-sans font-black text-xl" style="color:var(--color-heading)">${(rank.lifetime_cost_usd/1000).toFixed(0)}K</div>
                  <div class="font-sans text-xs" style="color:var(--color-muted)">Lifetime cost</div>
                </div>
              )}
              {rank.annual_food_cost && (
                <div class="rounded-xl p-3 text-center" style="background:white;border:1px solid var(--color-warning-light)">
                  <div class="text-2xl mb-1">🍖</div>
                  <div class="font-sans font-black text-xl" style="color:var(--color-heading)">${rank.annual_food_cost}/yr</div>
                  <div class="font-sans text-xs" style="color:var(--color-muted)">Annual food</div>
                </div>
              )}
              {rank.children_score !== undefined && (
                <div class="rounded-xl p-3 text-center" style="background:white;border:1px solid var(--color-warning-light)">
                  <div class="text-2xl mb-1">👨‍👩‍👧</div>
                  <div class="font-sans font-black text-xl" style="color:var(--color-heading)">
                    {rank.children_score >= 0.8 ? 'Great' : rank.children_score >= 0.5 ? 'Good' : 'Careful'}
                  </div>
                  <div class="font-sans text-xs" style="color:var(--color-muted)">With kids</div>
                </div>
              )}
              {rank.genetic_ailments !== undefined && (
                <div class="rounded-xl p-3 text-center" style="background:white;border:1px solid var(--color-warning-light)">
                  <div class="text-2xl mb-1">🩺</div>
                  <div class="font-sans font-black text-xl" style="color:var(--color-heading)">{rank.genetic_ailments}</div>
                  <div class="font-sans text-xs" style="color:var(--color-muted)">Known conditions</div>
                </div>
              )}
            </div>
            {rank.genetic_ailment_names && rank.genetic_ailment_names !== 'none' && (
              <p class="font-sans text-xs mt-3" style="color:var(--color-muted)">
                Known genetic concerns: <strong style="color:var(--color-accent-active)">{rank.genetic_ailment_names}</strong>
              </p>
            )}
          </section>
        )}

        <!-- Health profile section -->
        {healthProfile && (
          <section>
            <div class="flex items-center gap-2 mb-1">
              <span class="font-sans text-xs font-bold uppercase tracking-widest" style="color:var(--color-danger)">Health Watch</span>
            </div>
            <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)">
              {b.name} Health Conditions
            </h2>
            <div class="space-y-3">
              {(healthProfile.common_issues as any[]).map((issue: any) => {
                const sty = SEVERITY_STYLES[issue.severity] ?? SEVERITY_STYLES.Medium;
                return (
                  <div class="rounded-xl p-4 flex gap-4" style={`background:${sty.bg};border:1px solid ${sty.color}30`}>
                    <div class="flex-shrink-0 mt-0.5">
                      <span class="inline-block font-sans text-xs font-bold px-2 py-0.5 rounded-full" style={`background:${sty.color}20;color:${sty.color}`}>
                        {issue.severity}
                      </span>
                    </div>
                    <div class="min-w-0">
                      <div class="flex flex-wrap items-center gap-2 mb-1">
                        <p class="font-sans font-bold text-sm" style="color:var(--color-heading)">{issue.name}</p>
                        <span class="font-sans text-xs px-2 py-0.5 rounded-full" style="background:#f1f5f9;color:var(--color-muted)">
                          {issue.prevalence} prevalence
                        </span>
                      </div>
                      {issue.early_warning && (
                        <p class="font-sans text-xs leading-relaxed" style="color:var(--color-body-soft)">
                          <strong style="color:var(--color-muted)">Early signs:</strong> {issue.early_warning}
                        </p>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
            {healthProfile.care_tips && (
              <div class="mt-4 rounded-xl p-4 flex gap-3" style="background:#f0f9ff;border:1px solid #bae6fd">
                <span style="font-size:1.25rem;flex-shrink:0">💡</span>
                <p class="font-sans text-sm leading-relaxed" style="color:#0c4a6e">{healthProfile.care_tips}</p>
              </div>
            )}
          </section>
        )}
        <!-- Health → cost cross-link -->
        {healthProfile && (
          <a href={COST_CALC_HREF}
            class="flex items-center justify-between gap-3 rounded-xl px-4 py-3 hover:opacity-90 transition-opacity"
            style="background:var(--color-warning-light);border:1px solid var(--color-border-warm);text-decoration:none">
            <p class="font-sans text-sm" style="color:var(--color-heading)">
              <strong>{healthProfile.common_issues?.[0]?.name ?? 'Health conditions'}</strong> can significantly affect lifetime vet costs —
              <span style="color:var(--color-accent)"> see the {b.name} cost calculator →</span>
            </p>
            <span style="font-size:1.25rem;flex-shrink:0">💰</span>
          </a>
        )}

        <!-- Top matched products -->
        {topProds.length > 0 && (
          <section>
            <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)">
              Expert Picks for {b.name}s
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {topProds.map((p: any, i: number) => (
                <div class="rounded-2xl overflow-hidden flex flex-col" style="border:1px solid var(--color-border-warm);background:white">
                  <div class="flex items-center justify-center p-4" style="background:var(--color-bg-soft);height:140px;position:relative">
                    {i === 0 && (
                      <span class="absolute top-2 left-2 font-sans text-xs font-bold px-2 py-1 rounded-full" style="background:var(--color-accent);color:white">
                        ⭐ Top Pick
                      </span>
                    )}
                    {p.image?.includes('media-amazon') ? (
                      <img
                        src={p.image}
                        alt={p.name}
                        width="120"
                        height="120"
                        loading="lazy"
                        class="object-contain max-h-28"
                        onerror="this.parentElement.innerHTML='<span style=font-size:2.5rem>🐾</span>'"
                      />
                    ) : (
                      <span style="font-size:2.5rem">🐾</span>
                    )}
                  </div>
                  <div class="p-4 flex flex-col flex-1 gap-2">
                    <p class="font-sans text-xs font-bold uppercase tracking-wider" style="color:var(--color-accent)">
                      {(p._cat||p.category_key||'').replace(/-/g,' ')}
                    </p>
                    <h3 class="font-sans text-sm font-bold leading-tight" style="color:var(--color-heading)">{p.name}</h3>
                    <div class="flex items-center gap-1">
                      <span style="color:var(--color-warning);font-size:0.75rem">{'★'.repeat(Math.round(p.rating||4.5))}</span>
                      <span class="font-sans text-xs" style="color:var(--color-muted)">{parseFloat(p.rating||4.5).toFixed(1)}</span>
                    </div>
                    {p.verdict && <p class="font-sans text-xs italic" style="color:var(--color-muted)">{p.verdict.slice(0,70)}…</p>}
                    <div class="mt-auto flex items-center justify-between pt-2" style="border-top:1px solid var(--color-surface-warm)">
                      <span class="font-sans font-black text-base" style="color:var(--color-heading)">
                        {p.price ? `$${parseFloat(p.price).toFixed(2)}` : '—'}
                      </span>
                      {p.asin && p.asin !== 'SUBSCRIPTION' ? (
                        <a
                          href={amzUrl(p.asin)}
                          rel="nofollow sponsored"
                          target="_blank"
                          class="font-sans text-xs font-bold px-3 py-1.5 rounded-lg btn-amazon text-white"
                          style="background:linear-gradient(135deg,#FF9900,#e88700)"
                        >
                          Check price →
                        </a>
                      ) : p.asin === 'SUBSCRIPTION' ? (
                        <span class="font-sans text-xs" style="color:var(--color-muted)">Subscription</span>
                      ) : null}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Care tips -->
        {b.care_tips?.length > 0 && (
          <section>
            <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)">
              {b.name} Care Tips
            </h2>
            <div class="space-y-3">
              {b.care_tips.map((tip: string) => (
                <div class="flex gap-3 items-start rounded-xl p-4" style="background:var(--color-success-light);border:1px solid var(--color-success-light)">
                  <span style="color:#16a34a;font-weight:bold;flex-shrink:0;margin-top:1px">✓</span>
                  <p class="font-sans text-sm leading-relaxed" style="color:var(--color-heading)">{tip}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Who this breed suits -->
        <section class="rounded-2xl p-6" style="background:linear-gradient(135deg,var(--color-success-light),#dcfce7);border:1px solid #86efac">
          <h2 class="font-display text-2xl font-bold mb-4" style="font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)">
            Who the {b.name} Suits
          </h2>
          <ul class="space-y-3">
            {suitabilityBullets.map((bullet: string) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-0.5 w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold text-white" style="background:#16a34a">✓</span>
                <p class="font-sans text-sm leading-relaxed" style="color:var(--color-heading)">{bullet}</p>
              </li>
            ))}
          </ul>
          {(profile.coat_care_label as string) && (
            <div class="mt-4 pt-4 font-sans text-sm" style="border-top:1px solid var(--color-success-light);color:var(--color-muted)">
              <strong style="color:var(--color-heading)">Grooming commitment:</strong> {profile.coat_care_label as string}
            </div>
          )}
        </section>

        <!-- Pre-dog decision CTA -->
        <section style="background:var(--color-bg-cool);border:1px solid var(--color-primary-light);border-radius:var(--radius-2xl);padding:var(--space-6)">
          <p class="font-sans text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--color-primary)">Thinking about getting a {b.name}?</p>
          <h2 class="font-display text-xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)">
            Make an informed decision
          </h2>
          <div class="grid gap-3 sm:grid-cols-3">
            <a href="/breed-quiz" style="background:white;border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--space-4);text-decoration:none;display:block" class="hover:shadow-md transition-shadow">
              <span style="font-size:1.5rem;display:block;margin-bottom:var(--space-2)">🐾</span>
              <p class="font-sans font-bold text-sm mb-1" style="color:var(--color-heading)">Is this breed right for me?</p>
              <p class="font-sans text-xs" style="color:var(--color-muted)">Take the breed match quiz to compare your lifestyle</p>
            </a>
            <a href={COST_CALC_HREF} style="background:white;border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--space-4);text-decoration:none;display:block" class="hover:shadow-md transition-shadow">
              <span style="font-size:1.5rem;display:block;margin-bottom:var(--space-2)">💰</span>
              <p class="font-sans font-bold text-sm mb-1" style="color:var(--color-heading)">What does a {b.name} cost?</p>
              <p class="font-sans text-xs" style="color:var(--color-muted)">Full cost breakdown — puppy, annual, and lifetime</p>
            </a>
            <a href="/guides/first-dog" style="background:white;border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--space-4);text-decoration:none;display:block" class="hover:shadow-md transition-shadow">
              <span style="font-size:1.5rem;display:block;margin-bottom:var(--space-2)">📋</span>
              <p class="font-sans font-bold text-sm mb-1" style="color:var(--color-heading)">New to dog ownership?</p>
              <p class="font-sans text-xs" style="color:var(--color-muted)">First dog guide — what to prepare before you bring one home</p>
            </a>
          </div>
        </section>

        <!-- Content cluster links -->
        <section>
          <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)">
            All {b.name} Guides
          </h2>

          <!-- Cost calculator — always available for all breeds -->
          <a
            href={COST_CALC_HREF}
            class="flex items-center gap-4 rounded-xl p-4 mb-4 transition-all"
            style="border:2px solid var(--color-warning);background:linear-gradient(135deg,var(--color-accent-subtle),var(--color-warning-light));text-decoration:none"
            onmouseover="this.style.borderColor='var(--color-warning)';this.style.background='linear-gradient(135deg,var(--color-warning-light),var(--color-warning-light))'"
            onmouseout="this.style.borderColor='var(--color-warning)';this.style.background='linear-gradient(135deg,var(--color-accent-subtle),var(--color-warning-light))'"
          >
            <span style="font-size:1.5rem">💰</span>
            <div>
              <p class="font-sans font-bold text-sm" style="color:var(--color-heading)">{b.name} Cost Calculator</p>
              <p class="font-sans text-xs" style="color:#78350f">Puppy price, annual costs &amp; lifetime estimate →</p>
            </div>
            <span class="ml-auto font-sans text-sm font-bold" style="color:var(--color-warning)">→</span>
          </a>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {CLUSTER_LINKS.map(c => {
              const done = status[c.key];
              return done && c.href ? (
                <a
                  href={c.href}
                  class="flex items-center gap-3 rounded-xl p-4 transition-all"
                  style="border:1px solid var(--color-border-warm);background:white;text-decoration:none;color:var(--color-heading)"
                  onmouseover="this.style.borderColor='var(--color-accent)';this.style.background='var(--color-bg-soft)'"
                  onmouseout="this.style.borderColor='var(--color-border-warm)';this.style.background='white'"
                >
                  <span style="font-size:1.25rem">{c.emoji}</span>
                  <span class="font-sans text-sm font-semibold">{c.label}</span>
                  <span class="ml-auto font-sans text-xs" style="color:var(--color-accent)">→</span>
                </a>
              ) : (
                <div
                  class="flex items-center gap-3 rounded-xl p-4"
                  style="border:1px solid #f0e4d0;background:#fafaf9;opacity:0.5"
                >
                  <span style="font-size:1.25rem">{c.emoji}</span>
                  <span class="font-sans text-sm" style="color:var(--color-subtle)">{c.label}</span>
                </div>
              );
            })}
          </div>
        </section>

        <!-- FCI classification -->
        {b.fci_group && (
          <section class="rounded-2xl p-6" style="background:var(--color-bg-soft);border:1px solid var(--color-border-warm)">
            <h2 class="font-display text-xl font-bold mb-4" style="font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)">
              FCI Classification
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 font-sans text-sm">
              <div>
                <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color:var(--color-subtle)">FCI Group</p>
                <p class="font-semibold" style="color:var(--color-heading)">Group {b.fci_group} — {b.fci_group_name}</p>
              </div>
              {b.fci_section && (
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color:var(--color-subtle)">Section</p>
                  <p class="font-semibold" style="color:var(--color-heading)">{b.fci_section}</p>
                </div>
              )}
              <div>
                <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color:var(--color-subtle)">Status</p>
                <p class="font-semibold capitalize" style="color:var(--color-heading)">{b.fci_status?.replace('-',' ')}</p>
              </div>
            </div>
          </section>
        )}

      <!-- ── Related editorial guides ─────────────────────────────── -->
      {(() => {
        const isFood     = ['food','health'].includes(b.energy_level) || b.size_category !== '';
        const isTraining = ['active'].includes(b.energy_level) || (b.traits?.trainability_value || 0) >= 0.6;
        const guides = [
          {
            href: '/blog/best-dog-food-maker-chefpaw-review-2026',
            emoji: '🍳',
            label: 'ChefPaw Dog Food Maker: Honest Review',
            desc: 'Is the $640 fresh-food appliance worth it for your breed?',
            tag: 'Food',
          },
          {
            href: '/blog/best-training-tools-stubborn-dogs-2026',
            emoji: '🦮',
            label: 'Training Gear for Dogs That Don\'t Listen',
            desc: 'No-pull harnesses, long lines, and treat strategy that works.',
            tag: 'Training',
          },
          {
            href: '/blog/best-gifts-for-dog-lovers-2026',
            emoji: '🎁',
            label: 'Gifts for Dog Lovers That Actually Land',
            desc: 'Custom portraits and personalised gifts for the specific dog.',
            tag: 'Lifestyle',
          },
        ];
        return (
          <section class="mt-2">
            <p class="font-sans text-xs font-bold uppercase tracking-widest mb-4" style="color:var(--color-muted)">Related guides</p>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              {guides.map(g => (
                <a href={g.href}
                  class="flex gap-3 p-4 rounded-2xl transition-all hover:shadow-sm"
                  style="border:1px solid var(--color-border-warm);background:white;text-decoration:none"
                  onmouseover="this.style.borderColor='var(--color-accent)';this.style.background='var(--color-bg-soft)'"
                  onmouseout="this.style.borderColor='var(--color-border-warm)';this.style.background='white'">
                  <span style="font-size:1.5rem;flex-shrink:0;line-height:1">{g.emoji}</span>
                  <div>
                    <span class="font-sans text-xs font-bold px-2 py-0.5 rounded-full mb-1 inline-block" style="background:var(--color-bg-soft);color:var(--color-accent)">{g.tag}</span>
                    <p class="font-sans font-bold text-sm leading-snug mb-1" style="color:var(--color-heading)">{g.label}</p>
                    <p class="font-sans text-xs leading-relaxed" style="color:var(--color-muted)">{g.desc}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        );
      })()}

      </div>

      <!-- ── Sidebar ── -->
      <aside class="hidden lg:block">
        <div class="sticky space-y-5" style="top:80px">

          <!-- Quick facts -->
          <div class="rounded-2xl overflow-hidden" style="border:1px solid var(--color-border-warm);background:white">
            <div class="px-4 py-3 font-sans text-xs font-bold uppercase tracking-wider" style="background:var(--color-surface-warm);color:var(--color-accent-active);border-bottom:1px solid var(--color-border-warm)">
              Quick Facts
            </div>
            <div class="p-4 space-y-3 font-sans text-sm">
              {[
                ['Size',      b.size_category.charAt(0).toUpperCase()+b.size_category.slice(1)],
                ['Energy',    b.energy_level.charAt(0).toUpperCase()+b.energy_level.slice(1)],
                ['Shedding',  (b.shedding_level||'').charAt(0).toUpperCase()+(b.shedding_level||'').slice(1)],
                ['Training',  (b.training_level||'').charAt(0).toUpperCase()+(b.training_level||'').slice(1)],
                ['Coat',      COAT_LABEL[b.coat_type]||b.coat_type],
                ['Grooming',  b.grooming_freq],
                wt.min_lbs ? ['Weight',  `${wt.min_lbs}–${wt.max_lbs} lbs`]  : null,
                life.min   ? ['Lifespan',`${life.min}–${life.max} years`]     : null,
                b.akc_group     ? ['AKC Group', b.akc_group.replace(' Group','')] : null,
                b.origin_country? ['Origin',    b.origin_country]              : null,
                profile.intelligence_tier ? ['Intelligence', (profile.intelligence_tier as string).charAt(0).toUpperCase()+(profile.intelligence_tier as string).slice(1)] : null,
                ['Owner difficulty', `${profile.owner_difficulty}/10`],
              ].filter(Boolean).map((row: any) => (
                <div class="flex justify-between gap-2 pb-2" style="border-bottom:1px solid var(--color-surface-warm)">
                  <span style="color:var(--color-muted)">{row[0]}</span>
                  <span class="font-semibold text-right" style="color:var(--color-heading);max-width:160px">{row[1]}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Top food product -->
          {foodProd && foodProd.asin && foodProd.asin !== 'SUBSCRIPTION' && (
            <div class="rounded-2xl overflow-hidden" style="border:2px solid var(--color-accent);background:white">
              <div class="px-4 py-2 font-sans text-xs font-bold uppercase tracking-wider text-white" style="background:var(--color-accent)">
                Top food for {b.name}s
              </div>
              <div class="p-4 flex items-center justify-center" style="background:var(--color-bg-soft);height:120px">
                {foodProd.image?.includes('media-amazon') ? (
                  <img src={foodProd.image} alt={foodProd.name} width="100" height="100" loading="lazy" class="object-contain max-h-24"
                    onerror="this.parentElement.innerHTML='<span style=font-size:2rem>🍖</span>'" />
                ) : <span style="font-size:2rem">🍖</span>}
              </div>
              <div class="p-4">
                <p class="font-sans text-sm font-bold mb-1" style="color:var(--color-heading)">{foodProd.name}</p>
                <div class="flex items-center gap-1 mb-2">
                  <span style="color:var(--color-warning);font-size:0.7rem">{'★'.repeat(Math.round(foodProd.rating||4.5))}</span>
                  <span class="font-sans text-xs" style="color:var(--color-muted)">{parseFloat(foodProd.rating||4.5).toFixed(1)}/5</span>
                </div>
                <p class="font-sans font-black text-lg mb-3" style="color:var(--color-heading)">${parseFloat(foodProd.price||0).toFixed(2)}</p>
                <a href={amzUrl(foodProd.asin)} rel="nofollow sponsored" target="_blank"
                  class="flex justify-center" aria-label="Available at Amazon">
                  <img src="/images/amazon/available-at-amazon.png" alt="Available at Amazon" height="36" loading="lazy" style="height:36px;width:auto" />
                </a>
              </div>
            </div>
          )}

          <!-- Smart AWIN product slot — matched to breed context -->
          <AwinProductSlot
            topicTags={[b.energy_level, b.training_level, b.size_category, 'gift', 'lifestyle'].filter(Boolean)}
            pageType="breed"
            breedSize={b.size_category}
            breedEnergy={b.energy_level}
            breedTraining={b.training_level}
            headline={`For ${b.name} owners`}
          />

          <!-- AWIN partner banner — breed context -->
          <PageBannerSlot
            pageType="breed"
            placement="after-summary"
            topic="care"
            topicTags={[b.energy_level, b.training_level, 'care'].filter(Boolean)}
            compact={true}
          />

          <!-- Guide links sidebar -->
          <div class="rounded-2xl p-4" style="border:1px solid var(--color-border-warm);background:white">
            <p class="font-sans text-xs font-bold uppercase tracking-wider mb-3" style="color:var(--color-subtle)">
              {b.name} Guides
            </p>
            <div class="space-y-1">
              <!-- Cost calculator always shown -->
              <a href={COST_CALC_HREF} class="flex items-center gap-2 px-2 py-2 rounded-lg font-sans text-sm font-semibold transition-colors"
                style="color:var(--color-accent-active);text-decoration:none;background:var(--color-accent-subtle)"
                onmouseover="this.style.background='var(--color-warning-light)'"
                onmouseout="this.style.background='var(--color-accent-subtle)'">
                <span>💰</span>
                <span>Cost calculator →</span>
              </a>
              {CLUSTER_LINKS.filter(c => status[c.key] && c.href).map(c => (
                <a href={c.href} class="flex items-center gap-2 px-2 py-2 rounded-lg font-sans text-sm transition-colors"
                  style="color:var(--color-heading);text-decoration:none"
                  onmouseover="this.style.background='var(--color-bg-soft)';this.style.color='var(--color-accent)'"
                  onmouseout="this.style.background='transparent';this.style.color='var(--color-heading)'">
                  <span>{c.emoji}</span>
                  <span>{c.label} →</span>
                </a>
              ))}
            </div>
          </div>

        </div>
      </aside>

    </div>
  </div>

</BaseLayout>
