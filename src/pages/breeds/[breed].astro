---
/**
 * breeds/[breed].astro — Breed hub page
 * Single source of truth: master-breeds.json
 */
import BaseLayout   from '../../layouts/BaseLayout.astro';
import Breadcrumb   from '../../components/ui/Breadcrumb.astro';
import BreedStats   from '../../components/breed/BreedStats.astro';
import RankingData  from '../../components/breed/RankingData.astro';
import ClusterLinks from '../../components/breed/ClusterLinks.astro';
import ProductGrid  from '../../components/content/ProductGrid.astro';

import masterBreeds  from '../../data/master-breeds.json';
import productIndex  from '../../data/product-index.json';
import breedLinkMap  from '../../data/breed-link-map.json';
import contentStatus from '../../data/content-status.json';

export function getStaticPaths() {
  return (masterBreeds as any[]).map(b => ({ params: { breed: b.slug } }));
}

const { breed: slug } = Astro.params;
const b = (masterBreeds as any[]).find(x => x.slug === slug);
if (!b) return Astro.redirect('/breeds');

const links  = (breedLinkMap as any)[slug] || {};
const status = (contentStatus as any)[slug] || {};
const picks  = b.product_picks || {};

const topProds = Object.entries(picks)
  .map(([, id]) => (productIndex as any)[id as string])
  .filter(Boolean).slice(0, 6);

const foodProd = picks['dog-food'] ? (productIndex as any)[picks['dog-food']] : null;

const wt = b.weight || {};
const ht = b.height || {};
const le = b.life_expectancy || {};

const SIZE_EMOJI: Record<string,string> = { small:'🐕', medium:'🐕‍🦺', large:'🐕‍🦺', giant:'🦮' };
const COAT_LABELS: Record<string,string> = {
  double:'Double coat', long:'Long coat', short:'Short coat', wiry:'Wire coat',
  curly:'Curly coat', silky:'Silky coat', corded:'Corded coat', hairless:'Hairless', wavy:'Wavy coat',
};

const sidebar_links = [
  ['🍖','Best food',     links.food_post,      status.food_post],
  ['🎾','Best toys',     links.toy_post,       status.toy_post],
  ['🛏️','Best beds',     links.bed_post,       status.bed_post],
  ['✂️','Grooming',      links.grooming_post,  status.grooming_post],
  ['🩺','Health',        links.health_post,    status.health_post],
  ['💊','Supplements',   links.supplement_post,status.supplement_post],
  ['✍️','Names',         links.names_page,     status.names_page],
].filter((r: any) => r[2] && r[3]);
---

<BaseLayout
  title={b.seo?.title || `${b.name} Dog — Expert Care Guide, Products & Facts 2026`}
  description={b.seo?.description || `Complete ${b.name} guide: best food, toys, beds and grooming matched to this breed's size, energy and coat type.`}
  canonicalUrl={`https://mrdoggostyle.com/breeds/${slug}`}
>

  <!-- ── Hero ── -->
  <div class="breed-hero">
    <div class="container">
      <Breadcrumb items={[
        { label:'Home', href:'/' },
        { label:'Breeds', href:'/breeds' },
        { label: b.name, current: true },
      ]} />
      <div class="breed-hero__inner">
        <div>
          <div class="breed-hero__badges">
            <span class="badge badge--primary">{b.size_category.charAt(0).toUpperCase()+b.size_category.slice(1)} breed</span>
            <span class="badge badge--muted">{b.energy_level} energy</span>
            <span class="badge badge--muted">{COAT_LABELS[b.coat_type] || b.coat_type}</span>
            {b.akc_group   && <span class="badge badge--muted">{b.akc_group}</span>}
            {b.origin_country && <span class="badge badge--muted">🌍 {b.origin_country}</span>}
            {b.akc_popularity && b.akc_popularity <= 20 && (
              <span class="badge badge--accent">🏆 #{b.akc_popularity} most popular</span>
            )}
          </div>
          <h1 class="breed-hero__title">{b.name}</h1>
          {b.temperament && <p class="breed-hero__subtitle">{b.temperament}</p>}
          <p style="color:var(--color-body);font-size:var(--text-base);max-width:600px;line-height:1.7;margin-bottom:var(--space-4)">
            {b.description?.slice(0,280)}{b.description?.length > 280 ? '…' : ''}
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:var(--space-4);font-size:var(--text-sm);color:var(--color-muted)">
            {wt.min_lbs && wt.max_lbs && <span>⚖️ {wt.min_lbs}–{wt.max_lbs} lbs ({wt.min_kg}–{wt.max_kg} kg)</span>}
            {ht.min_in  && ht.max_in  && <span>📏 {ht.min_in}–{ht.max_in}"</span>}
            {le.min && le.max && <span>🎂 {le.min}–{le.max} yr lifespan</span>}
          </div>
        </div>
        <div class="breed-hero__image-placeholder" aria-hidden="true">{SIZE_EMOJI[b.size_category]||'🐕'}</div>
      </div>
    </div>
  </div>

  <!-- ── Main ── -->
  <main class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 300px;gap:var(--space-10);align-items:start">

        <!-- Left column -->
        <div style="min-width:0;display:flex;flex-direction:column;gap:var(--space-10)">

          <!-- Traits -->
          <section>
            <div class="section-header">
              <div>
                <span class="section-eyebrow">Breed profile</span>
                <h2 class="section-title">{b.name} Characteristics</h2>
              </div>
            </div>
            {b.traits && (
              <BreedStats
                traits={b.traits}
                energy_level={b.energy_level}
                shedding_level={b.shedding_level}
                training_level={b.training_level}
                coat_type={b.coat_type}
                grooming_freq={b.grooming_freq}
              />
            )}
          </section>

          <!-- Ranking data -->
          {b.ranking_data && Object.keys(b.ranking_data).length > 0 && (
            <RankingData ranking_data={b.ranking_data} breed_name={b.name} />
          )}

          <!-- Top products -->
          {topProds.length > 0 && (
            <ProductGrid
              products={topProds}
              eyebrow="Expert picks"
              heading={`Top Products for ${b.name}s`}
            />
          )}

          <!-- Care tips -->
          {b.care_tips?.length > 0 && (
            <section>
              <div class="section-header">
                <div>
                  <span class="section-eyebrow">Owner guide</span>
                  <h2 class="section-title">{b.name} Care Tips</h2>
                </div>
              </div>
              <div class="care-tips">
                {b.care_tips.map((tip: string) => <div class="care-tip">{tip}</div>)}
              </div>
            </section>
          )}

          <!-- All cluster content -->
          <section>
            <div class="section-header">
              <div>
                <span class="section-eyebrow">Complete guides</span>
                <h2 class="section-title">All {b.name} Content</h2>
              </div>
            </div>
            <ClusterLinks slug={slug} breed_name={b.name} content={status} link_map={links} />
          </section>

          <!-- FCI classification -->
          {b.fci_group && (
            <section style="background:var(--color-bg-soft);border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--space-6)">
              <h2 class="section-title" style="margin-bottom:var(--space-4)">FCI Classification</h2>
              <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:var(--space-3);font-size:var(--text-sm)">
                <div>
                  <span style="color:var(--color-muted);font-size:var(--text-xs);display:block;margin-bottom:2px">FCI Group</span>
                  <strong>Group {b.fci_group} — {b.fci_group_name}</strong>
                </div>
                {b.fci_section && (
                  <div>
                    <span style="color:var(--color-muted);font-size:var(--text-xs);display:block;margin-bottom:2px">Section</span>
                    <strong>{b.fci_section}</strong>
                  </div>
                )}
                <div>
                  <span style="color:var(--color-muted);font-size:var(--text-xs);display:block;margin-bottom:2px">Status</span>
                  <strong style="text-transform:capitalize">{b.fci_status?.replace('-',' ')}</strong>
                </div>
              </div>
            </section>
          )}

        </div>

        <!-- ── Sidebar ── -->
        <aside style="position:sticky;top:var(--space-8);display:flex;flex-direction:column;gap:var(--space-5)">

          <!-- Quick facts -->
          <div style="border:1px solid var(--color-border);border-radius:var(--radius-xl);overflow:hidden;background:var(--color-bg)">
            <div style="padding:var(--space-3) var(--space-4);background:var(--color-bg-soft);border-bottom:1px solid var(--color-border);font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--color-muted)">
              Quick Facts
            </div>
            <div style="padding:var(--space-4);display:flex;flex-direction:column;gap:var(--space-3);font-size:var(--text-sm)">
              {[
                ['Size',     b.size_category.charAt(0).toUpperCase()+b.size_category.slice(1)],
                ['Energy',   b.energy_level.charAt(0).toUpperCase()+b.energy_level.slice(1)],
                ['Shedding', b.shedding_level?.charAt(0).toUpperCase()+(b.shedding_level?.slice(1)||'')],
                ['Training', b.training_level?.charAt(0).toUpperCase()+(b.training_level?.slice(1)||'')],
                ['Coat',     COAT_LABELS[b.coat_type]||b.coat_type],
                ['Grooming', b.grooming_freq],
                wt.min_lbs     ? ['Weight',   `${wt.min_lbs}–${wt.max_lbs} lbs`]     : null,
                le.min         ? ['Lifespan', `${le.min}–${le.max} years`]            : null,
                b.akc_group    ? ['AKC',      b.akc_group.replace(' Group','')]        : null,
                b.origin_country? ['Origin',  b.origin_country]                       : null,
                b.fci_group    ? ['FCI',      `Group ${b.fci_group}`]                 : null,
              ].filter(Boolean).map((row: any) => (
                <div style="display:flex;justify-content:space-between;gap:var(--space-2);border-bottom:1px solid var(--color-border);padding-bottom:var(--space-2)">
                  <span style="color:var(--color-muted)">{row[0]}</span>
                  <span style="font-weight:600;color:var(--color-heading);text-align:right;max-width:160px">{row[1]}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Food product sidebar -->
          {foodProd && (
            <div class="sidebar-product">
              <div class="sidebar-product__header">Top food for {b.name}s</div>
              <div class="sidebar-product__image-wrap">
                {foodProd.image?.includes('media-amazon')
                  ? <img src={foodProd.image} alt={foodProd.name} class="sidebar-product__image" loading="lazy" width="140" height="140" />
                  : <span style="font-size:3rem">🍖</span>
                }
              </div>
              <div class="sidebar-product__body">
                <p class="sidebar-product__name">{foodProd.name}</p>
                <div class="sidebar-product__rating">
                  <span class="sidebar-product__stars">{'★'.repeat(Math.round(foodProd.rating||4.5))}</span>
                  <span class="sidebar-product__rating-val">{parseFloat(foodProd.rating||4.5).toFixed(1)}/5</span>
                </div>
                {foodProd.verdict && <p style="font-size:var(--text-xs);color:var(--color-muted);font-style:italic;margin-bottom:var(--space-2)">{foodProd.verdict.slice(0,80)}…</p>}
                <p class="sidebar-product__price">${parseFloat(foodProd.price||0).toFixed(2)}</p>
                {foodProd.asin && foodProd.asin !== 'SUBSCRIPTION' && (
                  <a href={`https://www.amazon.com/dp/${foodProd.asin}/?tag=aiexpertscorn-20`} rel="nofollow sponsored" target="_blank" class="sidebar-product__cta">
                    Check price on Amazon →
                  </a>
                )}
              </div>
            </div>
          )}

          <!-- Guide links -->
          {sidebar_links.length > 0 && (
            <div style="border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--space-4)">
              <p style="font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--color-muted);margin-bottom:var(--space-3)">{b.name} guides</p>
              <div style="display:flex;flex-direction:column;gap:var(--space-1)">
                {sidebar_links.map((r: any) => (
                  <a href={r[2]} style="display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--color-body);text-decoration:none;padding:6px var(--space-2);border-radius:var(--radius-md);transition:background .15s" onmouseover="this.style.background='var(--color-bg-soft)'" onmouseout="this.style.background=''">
                    <span>{r[0]}</span><span>{r[1]} for {b.name}s →</span>
                  </a>
                ))}
              </div>
            </div>
          )}

        </aside>
      </div>
    </div>
  </main>

</BaseLayout>
