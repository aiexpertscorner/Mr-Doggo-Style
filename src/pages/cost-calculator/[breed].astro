              <h2 id="lifetime-title">{n} lifetime cost projection</h2>

              <div class="cost-table-wrap">
                <table class="cost-detail-table">
                  <thead>
                    <tr>
                      <th>Year</th>
                      <th>Annual cost</th>
                      <th>Cumulative</th>
                    </tr>
                  </thead>
                  <tbody>
                    {Array.from({ length: Math.min(Math.ceil(lifespan), 15) }, (_, i) => {
                      const yr = i + 1;
                      const cost = yr === 1 ? annual_total + one_time_total + puppy_price_low : annual_total;
                      const cumul = yr === 1 ? cost : annual_total * yr + one_time_total + puppy_price_low;

                      return (
                        <tr>
                          <td>
                            Year {yr}
                            {yr === 1 ? ' (puppy)' : yr >= Math.ceil(lifespan - 2) ? ' (senior)' : ''}
                          </td>
                          <td>{usd(cost)}</td>
                          <td>{usd(cumul)}</td>
                        </tr>
                      );
                    })}
