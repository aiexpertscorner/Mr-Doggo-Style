            )}

            <section class="cost-detail-section" aria-labelledby="first-year-title">
              <p class="cost-detail-eyebrow">First year</p>
              <h2 id="first-year-title">First year cost for a {n}</h2>

              <div class="cost-table-card">
                <div class="cost-row-list">
                  {firstYearRows.map((row) => (
                    <div class="cost-row">
                      <div>
                        <strong>{row.label}</strong>
                        <span>{row.note}</span>
                      </div>
                      <p>{usd(row.low)}–{usd(row.high)}</p>
                    </div>
                  ))}
                </div>

                <div class="cost-total-row">
                  <span>First year total estimate</span>
                  <strong>{usd(firstYearLow)}–{usd(firstYearHigh)}</strong>
                </div>
              </div>
            </section>

            <section class="cost-detail-section" aria-labelledby="lifetime-title">
