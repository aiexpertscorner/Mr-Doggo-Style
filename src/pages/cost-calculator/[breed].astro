---
/**
 * cost-calculator/[breed].astro
 * Breed-specific lifetime cost of ownership calculator.
 * Mobile-first, token-driven, and resilient against dataset field-name variants.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import masterBreeds from '../../data/master-breeds.json';
import masterCrossbreeds from '../../data/master-crossbreeds.json';
import breedLinkMap from '../../data/breed-link-map.json';
import AwinProductSlot from '../../components/affiliate/AwinProductSlot.astro';
import PageBannerSlot from '../../components/affiliate/PageBannerSlot.astro';
import actuarialRates from '../../data/actuarial-breed-rates.json';
import actuarialAgeFactors from '../../data/actuarial-age-factors.json';
import statesIndex from '../../data/us-states-insurance-index.json';
import StateAgeSelector from '../../components/StateAgeSelector.astro';
import healthProfiles from '../../data/breed-health-profiles.json';

const SITE = 'https://pupwiki.com';

const getAllCostBreeds = () => [
  ...(masterBreeds as any[]),
  ...(masterCrossbreeds as any[]),
];

export function getStaticPaths() {
  const allCostBreeds = [
    ...(masterBreeds as any[]),
    ...(masterCrossbreeds as any[]),
  ];

  return allCostBreeds
    .filter((breed) => breed?.slug)
    .map((breed) => ({
      params: { breed: breed.slug },
    }));
}

const { breed: slug } = Astro.params;
const ALL_COST_BREEDS = getAllCostBreeds();
const b = ALL_COST_BREEDS.find((item) => item.slug === slug);

if (!b) return Astro.redirect('/breeds');

const links = (breedLinkMap as any)[slug] || {};
const rank = b.ranking_data || {};
const life = b.life_expectancy || {};
const wt = b.weight || {};
const n = b.name;

const toNumber = (value: unknown, fallback = 0) => {
  const number = Number(value);
  return Number.isFinite(number) ? number : fallback;
};

const titleCase = (value?: string | null) => {
  if (!value) return '';
  return String(value)
    .replace(/[-_]+/g, ' ')
    .replace(/\b\w/g, (char) => char.toUpperCase());
};

const normalizeKey = (value?: unknown) =>
  String(value ?? '')
    .trim()
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/_/g, '-');

const normalizeSizeCategory = (value?: unknown) => {
  const key = normalizeKey(value);

  if (key.includes('giant') || key.includes('xlarge') || key.includes('extra-large')) return 'giant';
  if (key.includes('large')) return 'large';
  if (key.includes('small') || key.includes('toy')) return 'small';
  if (key.includes('medium')) return 'medium';

  return 'medium';
};

const sizeCategory = normalizeSizeCategory(b.size_category || b.size || b.sizeCategory);
const energyLevel = normalizeKey(b.energy_level || b.energy || b.activity_level || 'regular') || 'regular';
const coatType = normalizeKey(b.coat_type || b.coat || b.coatType || 'medium') || 'medium';

const breedWeightMin = toNumber(wt.min_lbs ?? wt.min ?? wt.min_weight_lbs ?? wt.minimum_lbs, 0);
const breedWeightMax = toNumber(wt.max_lbs ?? wt.max ?? wt.max_weight_lbs ?? wt.maximum_lbs, 0);

const breedWeight =
  breedWeightMin && breedWeightMax
    ? `${breedWeightMin}–${breedWeightMax} lb`
    : breedWeightMin
      ? `${breedWeightMin}+ lb`
      : breedWeightMax
        ? `up to ${breedWeightMax} lb`
        : null;

const lifeMin = toNumber(life.min ?? life.min_years ?? life.minimum_years, 0);
const lifeMax = toNumber(life.max ?? life.max_years ?? life.maximum_years, 0);
const rankLongevity = toNumber(rank.longevity_years, 0);

const lifespan = rankLongevity || (lifeMin && lifeMax ? (lifeMin + lifeMax) / 2 : 12);

function getImageUrl(item: any) {
  if (!item) return '';
  if (typeof item === 'string') return item;
  return item.url || item.image_url || item.src || '';
}

function uniqueValidUrls(urls: unknown[]) {
  const seen = new Set<string>();

  return urls
    .map(getImageUrl)
    .filter((url): url is string => typeof url === 'string' && /^https?:\/\//.test(url))
    .filter((url) => {
      if (seen.has(url)) return false;
      seen.add(url);
      return true;
    });
}

const breedImageUrls = uniqueValidUrls([
  b.image_url,
  ...(Array.isArray(b.image_urls) ? b.image_urls : []),
  ...(Array.isArray(b.image_gallery) ? b.image_gallery : []),
  ...(Array.isArray(b.image_url_candidates) ? b.image_url_candidates : []),
  b.image_url_parent_1,
  b.image_url_parent_2,
]);

const primaryImage = breedImageUrls[0] || '';

const healthProfileList = Array.isArray((healthProfiles as any).profiles)
  ? (healthProfiles as any).profiles
  : Array.isArray(healthProfiles)
    ? (healthProfiles as any)
    : [];

const healthProfile =
  healthProfileList.find((profile: any) => profile.breed_slug === slug || profile.slug === slug) ?? null;

const topHealthIssues = Array.isArray(healthProfile?.common_issues)
  ? healthProfile.common_issues.slice(0, 3)
  : [];

const getIssueName = (issue: any) =>
  typeof issue === 'string'
    ? issue
    : issue?.name || issue?.condition || issue?.title || 'Health consideration';

const getIssueSeverity = (issue: any) =>
  typeof issue === 'string'
    ? 'Medium'
    : issue?.severity || issue?.risk || 'Medium';

const getIssueEarlyWarning = (issue: any) =>
  typeof issue === 'string'
    ? ''
    : issue?.early_warning || issue?.warning_signs || issue?.symptoms || '';

const SIZE_COSTS: Record<
  string,
  {
    food_annual: number;
    vet_annual: number;
    grooming_annual: number;
    supplies_one_time: number;
    spay_neuter: number;
  }
> = {
  small: { food_annual: 600, vet_annual: 600, grooming_annual: 400, supplies_one_time: 400, spay_neuter: 300 },
  medium: { food_annual: 900, vet_annual: 800, grooming_annual: 500, supplies_one_time: 500, spay_neuter: 400 },
  large: { food_annual: 1400, vet_annual: 1000, grooming_annual: 700, supplies_one_time: 700, spay_neuter: 500 },
  giant: { food_annual: 2000, vet_annual: 1400, grooming_annual: 900, supplies_one_time: 900, spay_neuter: 700 },
};

const COAT_GROOMING_MULT: Record<string, number> = {
  double: 1.4,
  long: 1.6,
  silky: 1.5,
  wiry: 1.5,
  curly: 1.7,
  corded: 2.0,
  short: 0.8,
  smooth: 0.8,
  wavy: 1.2,
  medium: 1.0,
};

const ENERGY_HEALTH_MULT: Record<string, number> = {
  active: 1.3,
  high: 1.25,
  'very-active': 1.35,
  energetic: 1.25,
  regular: 1.0,
  moderate: 1.0,
  medium: 1.0,
  calm: 0.9,
  low: 0.9,
};

const base = SIZE_COSTS[sizeCategory] || SIZE_COSTS.medium;
const gmult = COAT_GROOMING_MULT[coatType] || 1.0;
const hmult = ENERGY_HEALTH_MULT[energyLevel] || 1.0;

const annual_food = toNumber(rank.annual_food_cost, 0) || base.food_annual;
const annual_vet = Math.round(base.vet_annual * hmult);
const annual_groom = Math.round(base.grooming_annual * gmult);
const annual_toys = energyLevel === 'active' || energyLevel === 'high' || energyLevel === 'very-active' ? 400 : energyLevel === 'calm' || energyLevel === 'low' ? 150 : 250;
const annual_other = 200;
const annual_total = annual_food + annual_vet + annual_groom + annual_toys + annual_other;

const one_time_puppy = base.supplies_one_time;
const one_time_spay = base.spay_neuter;
const one_time_total = one_time_puppy + one_time_spay + 200;

const rankLifetimeCost = toNumber(rank.lifetime_cost_usd, 0);
const lifetime_est = rankLifetimeCost || Math.round(one_time_total + annual_total * lifespan);

const puppy_price_low =
  sizeCategory === 'small'
    ? 500
    : sizeCategory === 'large' || sizeCategory === 'giant'
      ? 1200
      : 800;

const puppy_price_high = puppy_price_low * 2.5;

const INS_DEFAULT_AGE = 3;
const INS_DEFAULT_STATE = 'CA';

const SIZE_FALLBACK: Record<string, number> = {
  small: 35,
  medium: 50,
  large: 70,
  giant: 95,
};

const breedRate = (actuarialRates as any).breed_rates.find((rate: any) => rate.breed_slug === slug);
const insBasePremium = breedRate?.base_premium ?? SIZE_FALLBACK[sizeCategory] ?? 50;
const insRiskCategory = breedRate?.risk_category ?? 'Standard';
const insIsEstimated = !breedRate;

const insAgeFactor =
  (actuarialAgeFactors as any).age_factors.find(
    (factor: any) => INS_DEFAULT_AGE >= factor.min_age_years && INS_DEFAULT_AGE < factor.max_age_years
  )?.premium_factor ?? 1.09;

const insState = (statesIndex as any).states.find((state: any) => state.code === INS_DEFAULT_STATE);
const insStateMultiplier = insState?.cost_multiplier ?? 1.34;
const insStateName = insState?.name ?? 'California';

const insMonthlyEst = Math.round(insBasePremium * insAgeFactor * insStateMultiplier * 100) / 100;
const insAnnualEst = Math.round(insMonthlyEst * 12);

const riskClass = `is-risk-${String(insRiskCategory).toLowerCase().replace(/\s+/g, '-')}`;

const COST_ITEMS = [
  {
    label: 'Dog food',
    annual: annual_food,
    icon: '🍖',
    note: `Based on ${titleCase(sizeCategory)} breed feeding requirements`,
  },
  {
    label: 'Veterinary care',
    annual: annual_vet,
    icon: '🩺',
    note: `${titleCase(energyLevel)} energy breeds have ${hmult > 1 ? 'higher' : 'typical'} baseline vet costs`,
  },
  {
    label: 'Grooming',
    annual: annual_groom,
    icon: '✂️',
    note: `${titleCase(coatType || 'standard')} coat requires ${gmult > 1.3 ? 'frequent' : 'regular'} grooming`,
  },
  {
    label: 'Toys & enrichment',
    annual: annual_toys,
    icon: '🎾',
    note: energyLevel === 'active' || energyLevel === 'high' || energyLevel === 'very-active'
      ? 'Active breeds need more mental stimulation'
      : 'Standard toy rotation',
  },
  {
    label: 'Other costs',
    annual: annual_other,
    icon: '💰',
    note: 'Training, boarding, supplies, insurance contributions, and miscellaneous care',
  },
];

const firstYearRows = [
  {
    label: 'Puppy / adoption fee',
    low: puppy_price_low,
    high: puppy_price_high,
    note: 'Reputable breeder or rescue',
  },
  {
    label: 'Initial vet visit',
    low: 150,
    high: 300,
    note: 'Health check, vaccines, and microchip',
  },
  {
    label: 'Spay / neuter',
    low: Math.max(base.spay_neuter - 100, 150),
    high: base.spay_neuter + 200,
    note: 'Often recommended around 6–12 months',
  },
  {
    label: 'Supplies',
    low: base.supplies_one_time,
    high: Math.round(base.supplies_one_time * 1.5),
    note: 'Crate, bed, bowls, leash, collar, and toys',
  },
  {
    label: 'Food',
    low: annual_food,
    high: Math.round(annual_food * 1.2),
    note: 'Puppy food and growth-stage nutrition',
  },
  {
    label: 'Training classes',
    low: 150,
    high: 400,
    note: 'Puppy classes and basic obedience',
  },
];

const firstYearLow =
  puppy_price_low + 150 + Math.max(base.spay_neuter - 100, 150) + base.supplies_one_time + annual_food + 150;

const firstYearHigh =
  puppy_price_high +
  300 +
  (base.spay_neuter + 200) +
  Math.round(base.supplies_one_time * 1.5) +
  Math.round(annual_food * 1.2) +
  400;

const savingTips = [
  {
    icon: '🍖',
    tip: 'Buy food strategically',
    save: '$100–300/yr',
    detail: 'Bulk buying and auto-ship discounts can reduce repeat food costs.',
  },
  {
    icon: '🩺',
    tip: 'Budget for preventive care',
    save: '$200–800/yr',
    detail: 'Dental care, healthy weight, exercise, and routine checkups can reduce avoidable vet bills.',
  },
  {
    icon: '🛡️',
    tip: 'Compare insurance early',
    save: 'Potentially thousands',
    detail: 'Premiums are often lower when a dog is young and healthy.',
  },
  {
    icon: '✂️',
    tip: 'Learn basic grooming',
    save: '$200–600/yr',
    detail: 'Brushing, nail trims, and coat maintenance between appointments can cut grooming costs.',
  },
  {
    icon: '🎾',
    tip: 'Rotate toys',
    save: '$100–200/yr',
    detail: 'A small rotating set keeps novelty high without constant buying.',
  },
  {
    icon: '🐾',
    tip: 'Consider adoption',
    save: '$1,000+ upfront',
    detail: 'Rescue and rehoming fees are often far lower than breeder purchase prices.',
  },
];

const severityClass = (severity: string) =>
  `is-severity-${String(severity || 'medium').toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;

const usd = (value: number) => `$${Math.round(value).toLocaleString()}`;
const monthly = (value: number) => `$${Number(value).toFixed(2)}`;

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Breeds', item: `${SITE}/breeds` },
    { '@type': 'ListItem', position: 3, name: n, item: `${SITE}/breeds/${slug}` },
    { '@type': 'ListItem', position: 4, name: 'Cost Calculator', item: `${SITE}/cost-calculator/${slug}` },
  ],
});

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `How much does a ${n} cost per year?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `A ${n} costs approximately ${usd(annual_total)} per year in ongoing expenses, including food (${usd(
          annual_food
        )}), veterinary care (${usd(annual_vet)}), grooming (${usd(annual_groom)}), and toys (${usd(annual_toys)}).`,
      },
    },
    {
      '@type': 'Question',
      name: `What is the lifetime cost of a ${n}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `The estimated lifetime cost of owning a ${n} is ${usd(
          lifetime_est
        )}, based on an average lifespan of ${lifespan} years and annual expenses of ${usd(annual_total)}.`,
      },
    },
    {
      '@type': 'Question',
      name: `How much does a ${n} puppy cost?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${n} puppies from reputable breeders typically cost ${usd(puppy_price_low)}–${usd(
          puppy_price_high
        )}. Rescue or rehoming fees are usually lower, depending on the organization.`,
      },
    },
  ],
});
---

<BaseLayout
  title={`How Much Does a ${n} Cost? 2026 Complete Cost Breakdown`}
  description={`Full ${n} cost of ownership: puppy price ${usd(puppy_price_low)}–${usd(
    puppy_price_high
  )}, annual costs ${usd(annual_total)}/yr, lifetime estimate ${usd(
    lifetime_est
  )}. Includes food, vet, grooming, insurance, and first-year costs.`}
  canonicalUrl={`${SITE}/cost-calculator/${slug}`}
  bodyClass="cost-detail-page bg-white text-slate-900"
>
  <script type="application/ld+json" set:html={breadcrumbLd} />
  <script type="application/ld+json" set:html={jsonLd} />

  <main class="cost-detail">
    <section class="cost-detail-hero" aria-labelledby="cost-detail-title">
      <div class="cost-detail-container">
        <nav class="cost-detail-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/breeds">Breeds</a>
          <span aria-hidden="true">›</span>
          <a href={`/breeds/${slug}`}>{n}</a>
          <span aria-hidden="true">›</span>
          <span>Cost Calculator</span>
        </nav>

        <div class="cost-detail-hero__grid">
          <div class="cost-detail-hero__content">
            <p class="cost-detail-eyebrow">Breed cost calculator</p>

            <h1 id="cost-detail-title" class="cost-detail-hero__title">
              How much does a
              <span>{n}</span>
              cost?
            </h1>

            <p class="cost-detail-hero__subtitle">
              Complete 2026 cost breakdown for {n} ownership, including puppy price, annual expenses,
              lifetime estimate, first-year setup costs, and state-adjusted insurance estimates.
            </p>

            <div class="cost-detail-hero__actions">
              <a href="#annual-breakdown" class="cost-detail-button cost-detail-button--primary">
                View breakdown
                <span aria-hidden="true">→</span>
              </a>
              <a href="/cost-calculator" class="cost-detail-button cost-detail-button--secondary">
                Compare all breeds
              </a>
            </div>

            <ul class="cost-detail-hero__badges" aria-label={`${n} profile summary`}>
              <li>{titleCase(sizeCategory)} size</li>
              <li>{titleCase(energyLevel)} energy</li>
              {coatType && <li>{titleCase(coatType)} coat</li>}
              {breedWeight && <li>{breedWeight}</li>}
            </ul>
          </div>

          <aside class="cost-detail-hero__media" aria-label={`${n} cost summary`}>
            {primaryImage ? (
              <>
                <img
                  src={primaryImage}
                  alt={`${n} dog`}
                  width="520"
                  height="420"
                  loading="eager"
                  decoding="async"
                  data-cost-detail-image
                />
                <div class="cost-detail-hero__fallback" hidden data-cost-detail-fallback aria-hidden="true">🐕</div>
              </>
            ) : (
              <div class="cost-detail-hero__fallback" aria-hidden="true">🐕</div>
            )}

            <div class="cost-detail-hero__summary">
              <p>Estimated lifetime cost</p>
              <strong>{usd(lifetime_est)}</strong>
              <span>Based on ~{lifespan} years and {usd(annual_total)}/yr ongoing costs.</span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="cost-detail-main">
      <div class="cost-detail-container">
        <div class="cost-detail-layout">
          <div class="cost-detail-content">
            <section class="cost-summary-grid" aria-label={`${n} cost summary cards`}>
              <article class="cost-summary-card cost-summary-card--dark">
                <p>Puppy price</p>
                <strong>{usd(puppy_price_low)}–{usd(puppy_price_high)}</strong>
                <span>From reputable breeder</span>
              </article>

              <article class="cost-summary-card cost-summary-card--accent">
                <p>Annual cost</p>
                <strong>{usd(annual_total)}</strong>
                <span>Per year ongoing</span>
              </article>

              <article class="cost-summary-card cost-summary-card--warm">
                <p>Lifetime total</p>
                <strong>{usd(lifetime_est)}</strong>
                <span>Over ~{lifespan} years</span>
              </article>
            </section>

            <section class="cost-insurance-panel" aria-labelledby="insurance-estimate-title">
              <div class="cost-insurance-panel__header">
                <div class="cost-insurance-panel__icon" aria-hidden="true">🛡️</div>

                <div>
                  <p class="cost-detail-eyebrow">Pet insurance estimate</p>
                  <h2 id="insurance-estimate-title">
                    {n} insurance estimate
                  </h2>
                  <span>
                    <span id="ins-header-age">Age {INS_DEFAULT_AGE}</span>
                    ·
                    <span id="ins-header-state">{insStateName}</span>
                    {insIsEstimated && ' · size-based estimate'}
                  </span>
                </div>

                <div class="cost-insurance-panel__price">
                  <strong><span id="ins-monthly">{monthly(insMonthlyEst)}</span>/mo</strong>
                  <span><span id="ins-annual">{usd(insAnnualEst)}</span>/year</span>
                </div>
              </div>

              <div class="cost-insurance-panel__body">
                <StateAgeSelector defaultState="CA" defaultAge="3" compact={true} id={`insurance-${slug}`} />

                <div class="cost-insurance-metrics">
                  <article>
                    <p>Base premium</p>
                    <strong>{monthly(insBasePremium)}/mo</strong>
                    <span>{insIsEstimated ? `${titleCase(sizeCategory)} size estimate` : 'Breed-specific rate'}</span>
                  </article>

                  <article>
                    <p>Age factor</p>
                    <strong id="ins-age-factor">×{insAgeFactor.toFixed(2)}</strong>
                    <span id="ins-age-display">Age {INS_DEFAULT_AGE}</span>
                  </article>

                  <article>
                    <p>State multiplier</p>
                    <strong id="ins-state-mult">×{insStateMultiplier.toFixed(2)}</strong>
                    <span id="ins-state-name">{insStateName} ({INS_DEFAULT_STATE})</span>
                  </article>
                </div>

                <div class="cost-insurance-panel__note">
                  <span class:list={['cost-risk-pill', riskClass]}>
                    {insRiskCategory} risk
                  </span>
                  <p id="ins-formula">
                    Formula: {monthly(insBasePremium)} × {insAgeFactor.toFixed(2)} × {insStateMultiplier.toFixed(2)}
                    = {monthly(insMonthlyEst)}/mo
                  </p>
                </div>

                <p class="cost-detail-disclaimer">
                  Insurance estimates are indicative. Actual premiums vary by provider, coverage level, deductible,
                  reimbursement rate, age, location, and individual health history.
                </p>
              </div>
            </section>

            <section id="annual-breakdown" class="cost-detail-section" aria-labelledby="annual-breakdown-title">
              <p class="cost-detail-eyebrow">Annual breakdown</p>
              <h2 id="annual-breakdown-title">{n} annual cost breakdown</h2>

              <div class="cost-breakdown-list">
                {COST_ITEMS.map((item) => {
                  const pct = Math.round((item.annual / annual_total) * 100);

                  return (
                    <article class="cost-breakdown-item">
                      <div class="cost-breakdown-item__icon" aria-hidden="true">
                        {item.icon}
                      </div>

                      <div class="cost-breakdown-item__body">
                        <div class="cost-breakdown-item__top">
                          <h3>{item.label}</h3>
                          <strong>{usd(item.annual)}/yr</strong>
                        </div>

                        <div class="cost-progress" aria-label={`${item.label} is ${pct}% of annual cost`}>
                          <span style={`width:${pct}%`}></span>
                        </div>

                        <p>{item.note}</p>
                      </div>
                    </article>
                  );
                })}

                <div class="cost-breakdown-total">
                  <span>Total annual cost</span>
                  <strong>{usd(annual_total)}</strong>
                </div>
              </div>

              <p class="cost-detail-footnote">
                Estimates are based on the {n} profile: {titleCase(sizeCategory)} size, {titleCase(energyLevel)} energy,
                and {titleCase(coatType || 'standard')} coat. Actual costs vary by location, lifestyle, product choices,
                and individual health.
              </p>
            </section>

            {healthProfile && topHealthIssues.length > 0 && (
              <section class="cost-detail-section" aria-labelledby="health-cost-title">
                <p class="cost-detail-eyebrow">Health considerations</p>
                <h2 id="health-cost-title">Common health costs for {n}s</h2>

                <p class="cost-detail-section__intro">
                  These breed-specific health considerations can affect real-world vet costs. Use this as a budgeting
                  prompt, not medical advice.
                </p>

                <div class="health-issue-list">
                  {topHealthIssues.map((issue: any) => (
                    <article class="health-issue-card">
                      <div>
                        <h3>{getIssueName(issue)}</h3>
                        {getIssueEarlyWarning(issue) && (
                          <p>
                            <strong>Watch for:</strong> {getIssueEarlyWarning(issue)}
                          </p>
                        )}
                      </div>

                      <span class:list={['health-severity-pill', severityClass(getIssueSeverity(issue))]}>
                        {getIssueSeverity(issue)}
                      </span>
                    </article>
                  ))}

                  {links.health_post && (
