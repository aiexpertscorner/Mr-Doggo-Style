              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <script define:vars={{ insBasePremium, insAgeFactor, insStateMultiplier, insMonthlyEst, insAnnualEst }}>
    let currentAgeFactor = insAgeFactor;
    let currentStateMultiplier = insStateMultiplier;

    const formatMonthly = (value) => `$${Number(value).toFixed(2)}`;
    const formatAnnual = (value) => `$${Math.round(value).toLocaleString()}`;

    function updateInsuranceDisplay() {
      const monthly = Math.round(insBasePremium * currentAgeFactor * currentStateMultiplier * 100) / 100;
      const annual = Math.round(monthly * 12);

      const monthlyEl = document.getElementById('ins-monthly');
      const annualEl = document.getElementById('ins-annual');
      const ageFactorEl = document.getElementById('ins-age-factor');
      const stateMultEl = document.getElementById('ins-state-mult');
      const formulaEl = document.getElementById('ins-formula');

      if (monthlyEl) monthlyEl.textContent = formatMonthly(monthly);
      if (annualEl) annualEl.textContent = formatAnnual(annual);
      if (ageFactorEl) ageFactorEl.textContent = `×${currentAgeFactor.toFixed(2)}`;
      if (stateMultEl) stateMultEl.textContent = `×${currentStateMultiplier.toFixed(2)}`;

      if (formulaEl) {
        formulaEl.textContent = `Formula: ${formatMonthly(insBasePremium)} × ${currentAgeFactor.toFixed(
          2
        )} × ${currentStateMultiplier.toFixed(2)} = ${formatMonthly(monthly)}/mo`;
      }
    }

    document.addEventListener('stateChange', (event) => {
      currentStateMultiplier = event.detail.multiplier;

      const headerState = document.getElementById('ins-header-state');
      const stateName = document.getElementById('ins-state-name');

      if (headerState) headerState.textContent = event.detail.name;
      if (stateName) stateName.textContent = `${event.detail.name} (${event.detail.code})`;

      updateInsuranceDisplay();
    });

    document.addEventListener('ageChange', (event) => {
      currentAgeFactor = event.detail.factor;

      const headerAge = document.getElementById('ins-header-age');
      const ageDisplay = document.getElementById('ins-age-display');

      if (headerAge) headerAge.textContent = event.detail.displayAge;
      if (ageDisplay) ageDisplay.textContent = event.detail.displayAge;

      updateInsuranceDisplay();
    });

    document.querySelectorAll('[data-cost-detail-image]').forEach((image) => {
      image.addEventListener('error', () => {
        image.hidden = true;

        const fallback = image.parentElement?.querySelector('[data-cost-detail-fallback]');
        if (fallback) fallback.hidden = false;
      });
    });
  </script>
</BaseLayout>

