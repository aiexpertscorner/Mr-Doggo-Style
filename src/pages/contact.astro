---
import BaseLayout from '../layouts/BaseLayout.astro';

const CONTACT_EMAIL = 'hello@pupwiki.com';

const contactTopics = [
  {
    icon: '🔍',
    title: 'Corrections',
    desc: 'Found an error, outdated information, or a broken link? Send the page URL and the detail we should review.',
  },
  {
    icon: '💡',
    title: 'Product tips',
    desc: 'Know a product we should consider? Tell us the product name, category, and why it may be useful for dog owners.',
  },
  {
    icon: '🤝',
    title: 'Partnerships',
    desc: 'For brand, affiliate, or press enquiries, include your company name, website, and proposal summary.',
  },
  {
    icon: '🐾',
    title: 'Breed questions',
    desc: 'Missing breed information or mixed-breed data? Let us know which page or breed needs attention.',
  },
];

const helpfulDetails = [
  'The page URL you are referring to',
  'The specific correction, question, or suggestion',
  'Any relevant source or product link',
  'Whether this is urgent or safety-related',
];

const relatedLinks = [
  ['/about', 'About PupWiki'],
  ['/how-we-test', 'How we test products'],
  ['/disclosure', 'Affiliate disclosure'],
  ['/privacy', 'Privacy policy'],
];

const SITE = 'https://pupwiki.com';
const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',    item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: `${SITE}/contact` },
  ],
});
---

<BaseLayout
  title="Contact Us — PupWiki"
  description="Contact PupWiki for corrections, questions, product suggestions, partnership enquiries, and editorial feedback."
  canonicalUrl="https://pupwiki.com/contact"
  pageType="website"
>
<script type="application/ld+json" set:html={breadcrumbLd} />
  <main class="contact-page">
    <section class="contact-hero" aria-labelledby="contact-title">
      <div class="contact-container">
        <nav class="contact-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span>Contact</span>
        </nav>

        <p class="contact-eyebrow">Contact PupWiki</p>

        <h1 id="contact-title" class="contact-hero__title">
          Get in touch.
        </h1>

        <p class="contact-hero__subtitle">
          We read every serious message. Send corrections, questions, product suggestions,
          partnership enquiries, or feedback about PupWiki content.
        </p>

        <div class="contact-hero__meta">
          <span>Typical response: 1–2 business days</span>
          <span>Corrections welcome</span>
          <span>Gmail address stays private</span>
        </div>
      </div>
    </section>

    <section class="contact-main">
      <div class="contact-container">
        <div class="contact-layout">
          <section class="contact-card contact-card--primary" aria-labelledby="email-contact-title">
            <p class="contact-eyebrow">Best way to contact us</p>

            <h2 id="email-contact-title">
              Email PupWiki directly
            </h2>

            <p>
              The public contact address is <strong>{CONTACT_EMAIL}</strong>. Messages sent here
              are routed privately to the PupWiki inbox. Please include enough detail so we can
              review your request quickly.
            </p>

            <div class="contact-email-box">
              <div>
                <span>Email address</span>
                <strong>{CONTACT_EMAIL}</strong>
              </div>

              <button
                type="button"
                class="contact-copy-button"
                data-copy-email={CONTACT_EMAIL}
                aria-label={`Copy ${CONTACT_EMAIL}`}
              >
                Copy
              </button>
            </div>

            <div class="contact-actions">
              <a
                href={`mailto:${CONTACT_EMAIL}?subject=PupWiki%20contact%20request`}
                class="contact-button contact-button--primary"
              >
                Email us
                <span aria-hidden="true">→</span>
              </a>

              <a href="/disclosure" class="contact-button contact-button--secondary">
                Affiliate disclosure
              </a>
            </div>

            <p class="contact-note" data-copy-status aria-live="polite">
              Use this address for editorial corrections, partnership enquiries, and general questions.
            </p>
          </section>

          <aside class="contact-sidebar" aria-label="Contact information">
            <section class="contact-side-card">
              <h2>Common enquiries</h2>

              <div class="contact-topic-list">
                {contactTopics.map((item) => (
                  <article>
                    <span aria-hidden="true">{item.icon}</span>
                    <div>
                      <h3>{item.title}</h3>
                      <p>{item.desc}</p>
                    </div>
                  </article>
                ))}
              </div>
            </section>

            <section class="contact-side-card contact-side-card--warm">
              <h2>Helpful details to include</h2>

              <ul class="contact-check-list">
                {helpfulDetails.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </section>

            <section class="contact-side-card">
              <h2>Related pages</h2>

              <nav class="contact-related-nav" aria-label="Related policy and trust pages">
                {relatedLinks.map(([href, label]) => (
                  <a href={href}>{label} →</a>
                ))}
              </nav>
            </section>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <script>
    document.querySelectorAll('[data-copy-email]').forEach((button) => {
      button.addEventListener('click', async () => {
        const email = button.getAttribute('data-copy-email') || '';
        const status = document.querySelector('[data-copy-status]');

        try {
          await navigator.clipboard.writeText(email);
          button.textContent = 'Copied';
          if (status) status.textContent = 'Email address copied to clipboard.';

          window.setTimeout(() => {
            button.textContent = 'Copy';
          }, 1800);
        } catch {
          if (status) {
            status.textContent = `Copy failed. Email us at ${email}.`;
          }
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .contact-page {
    background:
      radial-gradient(circle at 88% 4%, rgba(255, 122, 0, 0.1), transparent 24rem),
      radial-gradient(circle at 8% 2%, rgba(21, 54, 95, 0.08), transparent 22rem),
      var(--color-bg);
    color: var(--color-body);
  }

  .contact-container {
    width: min(100%, var(--max-width));
    margin-inline: auto;
    padding-inline: var(--content-padding-mobile);
  }

  .contact-hero {
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(255, 250, 243, 0.98) 0%, #ffffff 78%);
  }

  .contact-hero .contact-container {
    padding-block: clamp(2.5rem, 7vw, 5.75rem);
  }

  .contact-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin-bottom: var(--space-5);
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .contact-breadcrumb a {
    color: var(--color-primary);
    font-weight: var(--weight-semi);
    text-decoration: none;
  }

  .contact-breadcrumb a:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact-eyebrow {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    margin: 0;
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    background: var(--color-accent-subtle);
    padding: 0.54rem 0.85rem;
    color: var(--color-accent-hover);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-none);
    text-transform: uppercase;
  }

  .contact-hero__title {
    max-width: 11ch;
    margin: var(--space-5) 0 0;
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 12vw, 5.65rem);
    font-weight: var(--weight-bold);
    letter-spacing: -0.055em;
    line-height: 0.96;
    text-wrap: balance;
  }

  .contact-hero__subtitle {
    max-width: 46rem;
    margin: var(--space-5) 0 0;
    color: var(--color-body-soft);
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2.2vw, var(--text-lg));
    line-height: var(--leading-relaxed);
    text-wrap: pretty;
  }

  .contact-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }

  .contact-hero__meta span {
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.78);
    padding: 0.5rem 0.72rem;
    color: var(--color-body-soft);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    line-height: 1;
    box-shadow: var(--shadow-xs);
  }

  .contact-main {
    padding-block: clamp(var(--space-8), 6vw, var(--space-14));
  }

  .contact-layout {
    display: grid;
    gap: var(--space-8);
    align-items: start;
  }

  .contact-card,
  .contact-side-card {
    border: 1px solid var(--card-border);
    border-radius: var(--radius-3xl);
    background: rgba(255, 255, 255, 0.92);
    padding: var(--space-5);
    box-shadow: var(--shadow-card);
  }

  .contact-card--primary {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 94% 8%, rgba(255, 122, 0, 0.12), transparent 18rem),
      rgba(255, 255, 255, 0.94);
  }

  .contact-card h2,
  .contact-side-card h2 {
    margin: var(--space-3) 0 var(--space-4);
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }

  .contact-side-card h2 {
    font-size: var(--text-2xl);
  }

  .contact-card p,
  .contact-side-card p,
  .contact-side-card li {
    color: var(--color-body-soft);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .contact-card p {
    margin: 0;
  }

  .contact-card strong {
    color: var(--color-heading);
  }

  .contact-email-box {
    display: grid;
    gap: var(--space-3);
    margin-block: var(--space-6);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-2xl);
    background: var(--color-accent-subtle);
    padding: var(--space-4);
  }

  .contact-email-box span {
    display: block;
    margin-bottom: var(--space-1);
    color: var(--color-accent-hover);
    font-size: var(--text-xs);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-none);
    text-transform: uppercase;
  }

  .contact-email-box strong {
    display: block;
    overflow-wrap: anywhere;
    color: var(--color-heading);
    font-family: var(--font-sans);
    font-size: clamp(var(--text-lg), 4vw, var(--text-2xl));
    line-height: var(--leading-tight);
  }

  .contact-copy-button {
    display: inline-flex;
    width: fit-content;
    min-height: 2.45rem;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    background: #ffffff;
    color: var(--color-accent-hover);
    padding: 0.62rem 0.95rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-black);
    cursor: pointer;
    box-shadow: var(--shadow-xs);
    transition: var(--transition-smooth);
  }

  .contact-copy-button:hover {
    transform: translateY(-1px);
  }

  .contact-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact-button {
    display: inline-flex;
    min-height: 3.1rem;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: var(--radius-xl);
    padding: 0.9rem 1.1rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    line-height: 1;
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .contact-button--primary {
    background: var(--button-primary-bg);
    color: var(--button-primary-text);
    box-shadow: var(--shadow-cta);
  }

  .contact-button--primary:hover {
    background: var(--button-primary-bg-hover);
    transform: translateY(-2px);
  }

  .contact-button--secondary {
    border: 1px solid var(--button-outline-border);
    background: var(--button-outline-bg);
    color: var(--button-outline-text);
    box-shadow: var(--shadow-xs);
  }

  .contact-button--secondary:hover {
    border-color: var(--color-border-primary);
    background: var(--button-outline-bg-hover);
    color: var(--color-primary-hover);
    transform: translateY(-2px);
  }

  .contact-note {
    margin-top: var(--space-4) !important;
    color: var(--color-muted) !important;
    font-size: var(--text-sm) !important;
  }

  .contact-sidebar {
    display: grid;
    gap: var(--space-5);
  }

  .contact-side-card--warm {
    border-color: var(--color-border-accent);
    background: var(--color-accent-subtle);
  }

  .contact-topic-list {
    display: grid;
    gap: var(--space-4);
  }

  .contact-topic-list article {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-4);
  }

  .contact-topic-list article:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .contact-topic-list span {
    font-size: 1.25rem;
    line-height: 1;
  }

  .contact-topic-list h3 {
    margin: 0;
    color: var(--color-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-black);
    line-height: var(--leading-tight);
  }

  .contact-topic-list p {
    margin: var(--space-1) 0 0;
    color: var(--color-body-soft);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .contact-check-list {
    display: grid;
    gap: var(--space-2);
    margin: 0;
    padding-left: 0;
    list-style: none;
  }

  .contact-check-list li {
    position: relative;
    border: 1px solid rgba(4, 120, 87, 0.18);
    border-radius: var(--radius-xl);
    background: var(--color-success-light);
    padding: 0.75rem 0.85rem 0.75rem 2.25rem;
    color: var(--color-body);
    font-size: var(--text-sm);
  }

  .contact-check-list li::before {
    content: '✓';
    position: absolute;
    left: 0.85rem;
    top: 0.75rem;
    color: var(--color-success);
    font-weight: var(--weight-black);
  }

  .contact-related-nav {
    display: grid;
    gap: var(--space-2);
  }

  .contact-related-nav a {
    border-radius: var(--radius-lg);
    padding: 0.62rem 0.7rem;
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    text-decoration: none;
    transition: var(--transition-base);
  }

  .contact-related-nav a:hover {
    background: var(--color-bg-soft);
    color: var(--color-accent-hover);
  }

  @media (min-width: 520px) {
    .contact-email-box {
      grid-template-columns: 1fr auto;
      align-items: center;
    }

    .contact-actions {
      flex-direction: row;
      align-items: center;
    }

    .contact-button {
      width: auto;
    }
  }

  @media (min-width: 768px) {
    .contact-container {
      padding-inline: var(--content-padding);
    }

    .contact-card,
    .contact-side-card {
      padding: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .contact-container {
      padding-inline: var(--content-padding-wide);
    }

    .contact-layout {
      grid-template-columns: minmax(0, 1fr) 22rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-copy-button,
    .contact-button,
    .contact-related-nav a {
      transition: none;
      transform: none !important;
    }
  }
</style>