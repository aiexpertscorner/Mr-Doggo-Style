---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us — Mr. Doggo Style"
  description="Get in touch with the Mr. Doggo Style team. Questions, corrections, product suggestions, or partnership enquiries."
  canonicalURL="https://mrdoggostyle.com/contact"
>

  <div style="background:linear-gradient(to bottom,#f5e8d0,#fdf8f0);border-bottom:1px solid #e8ccaa">
    <div class="max-w-3xl mx-auto px-4 py-14 sm:py-18">
      <nav class="font-sans text-sm mb-6 flex items-center gap-1.5" style="color:#94a3b8">
        <a href="/" class="hover:underline" style="color:#a0621c">Home</a>
        <span>›</span>
        <span style="color:#475569">Contact</span>
      </nav>
      <h1 class="font-display text-4xl sm:text-5xl font-bold mb-4" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
        Get in Touch
      </h1>
      <p class="font-sans text-lg leading-relaxed" style="color:#64748b">
        We read every message. Whether it's a correction, a question, or just a photo of your dog — we'd love to hear from you.
      </p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-14">
    <div class="grid md:grid-cols-[1fr_340px] gap-10 items-start">

      <!-- Contact form -->
      <div class="rounded-3xl p-8" style="background:white;border:1px solid #e8ccaa">
        <h2 class="font-display text-2xl font-bold mb-6" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          Send us a message
        </h2>

        <form
          id="contact-form"
          class="space-y-5"
          novalidate
        >
          <div>
            <label for="name" class="block font-sans text-sm font-semibold mb-1.5" style="color:#1e293b">
              Your name <span style="color:#dc2626">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Jane Smith"
              class="w-full font-sans text-sm px-4 py-3 rounded-xl border focus:outline-none focus:ring-2"
              style="border-color:#e8ccaa;background:#fdf8f0;color:#1e293b;--tw-ring-color:#fbbf24"
            />
          </div>

          <div>
            <label for="email" class="block font-sans text-sm font-semibold mb-1.5" style="color:#1e293b">
              Email address <span style="color:#dc2626">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="jane@example.com"
              class="w-full font-sans text-sm px-4 py-3 rounded-xl border focus:outline-none focus:ring-2"
              style="border-color:#e8ccaa;background:#fdf8f0;color:#1e293b;--tw-ring-color:#fbbf24"
            />
          </div>

          <div>
            <label for="subject" class="block font-sans text-sm font-semibold mb-1.5" style="color:#1e293b">
              Subject <span style="color:#dc2626">*</span>
            </label>
            <select
              id="subject"
              name="subject"
              required
              class="w-full font-sans text-sm px-4 py-3 rounded-xl border focus:outline-none focus:ring-2"
              style="border-color:#e8ccaa;background:#fdf8f0;color:#1e293b;--tw-ring-color:#fbbf24"
            >
              <option value="" disabled selected>Select a topic…</option>
              <option value="correction">I found an error or outdated info</option>
              <option value="product">Product suggestion or recommendation</option>
              <option value="breed">Question about a specific breed</option>
              <option value="partnership">Brand / partnership enquiry</option>
              <option value="press">Press enquiry</option>
              <option value="other">Something else</option>
            </select>
          </div>

          <div>
            <label for="message" class="block font-sans text-sm font-semibold mb-1.5" style="color:#1e293b">
              Message <span style="color:#dc2626">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Tell us what's on your mind…"
              class="w-full font-sans text-sm px-4 py-3 rounded-xl border focus:outline-none focus:ring-2 resize-none"
              style="border-color:#e8ccaa;background:#fdf8f0;color:#1e293b;--tw-ring-color:#fbbf24"
            ></textarea>
          </div>

          <!-- Honeypot -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

          <button
            type="submit"
            id="submit-btn"
            class="w-full font-sans font-bold text-sm py-4 rounded-xl text-white transition-all"
            style="background:linear-gradient(135deg,#a0621c,#7d4a10)"
          >
            Send message →
          </button>

          <!-- Success / error messages -->
          <div id="form-success" class="hidden rounded-xl p-4 text-center font-sans text-sm font-semibold" style="background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d">
            ✓ Message sent! We'll get back to you within 2 business days.
          </div>
          <div id="form-error" class="hidden rounded-xl p-4 text-center font-sans text-sm" style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626">
            Something went wrong. Please email us directly at hello@mrdoggostyle.com
          </div>
        </form>
      </div>

      <!-- Sidebar info -->
      <aside class="space-y-5">

        <div class="rounded-2xl p-5" style="background:white;border:1px solid #e8ccaa">
          <h3 class="font-sans font-bold text-sm mb-4" style="color:#1e293b">Common enquiries</h3>
          <div class="space-y-3">
            {[
              ['🔍', 'Corrections', 'Found an error or outdated review? We take corrections seriously and update quickly.'],
              ['💡', 'Product tips', 'Know a product we should review? Tell us the name and why you think it belongs.'],
              ['🤝', 'Partnerships', 'Brand partnerships or press enquiries. We respond to all serious enquiries.'],
              ['🐾', 'Breed questions', 'Can\'t find info about your breed? Let us know.'],
            ].map(([icon, title, desc]) => (
              <div class="flex gap-3 items-start pb-3" style="border-bottom:1px solid #f5e8d0">
                <span style="font-size:1.1rem;flex-shrink:0;margin-top:1px">{icon}</span>
                <div>
                  <p class="font-sans text-sm font-bold" style="color:#1e293b">{title}</p>
                  <p class="font-sans text-xs mt-0.5 leading-relaxed" style="color:#64748b">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl p-5" style="background:#fdf8f0;border:1px solid #e8ccaa">
          <h3 class="font-sans font-bold text-sm mb-3" style="color:#1e293b">Response time</h3>
          <p class="font-sans text-sm leading-relaxed" style="color:#64748b">
            We typically respond within <strong style="color:#1e293b">1–2 business days</strong>. For urgent matters, include "Urgent" in your subject line.
          </p>
        </div>

        <div class="rounded-2xl p-5" style="background:#fdf8f0;border:1px solid #e8ccaa">
          <h3 class="font-sans font-bold text-sm mb-3" style="color:#1e293b">Other pages</h3>
          <div class="space-y-1.5">
            {[
              ['/about', 'About Mr. Doggo Style'],
              ['/how-we-test', 'How we test products'],
              ['/disclosure', 'Affiliate disclosure'],
              ['/privacy', 'Privacy policy'],
            ].map(([href, label]) => (
              <a href={href} class="block font-sans text-sm hover:underline" style="color:#a0621c">{label} →</a>
            ))}
          </div>
        </div>

      </aside>
    </div>
  </div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const ok   = document.getElementById('form-success')!;
  const err  = document.getElementById('form-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Basic validation
    const name    = (form.querySelector('#name') as HTMLInputElement).value.trim();
    const email   = (form.querySelector('#email') as HTMLInputElement).value.trim();
    const subject = (form.querySelector('#subject') as HTMLSelectElement).value;
    const message = (form.querySelector('#message') as HTMLTextAreaElement).value.trim();
    const honey   = (form.querySelector('[name="_gotcha"]') as HTMLInputElement).value;

    if (honey) return; // bot trap
    if (!name || !email || !subject || !message) return;

    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      // Using Formspree — replace YOUR_FORM_ID with your Formspree form ID
      // Sign up free at formspree.io
      const res = await fetch('https://formspree.io/f/YOUR_FORM_ID', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body:    JSON.stringify({ name, email, subject, message }),
      });

      if (res.ok) {
        form.style.display = 'none';
        ok.classList.remove('hidden');
      } else {
        throw new Error('Server error');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Send message →';
      err.classList.remove('hidden');
    }
  });
</script>

</BaseLayout>
