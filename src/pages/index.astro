---
/**
 * src/pages/index.astro — PupWiki homepage
 * Sprint 1: global design foundation + clean component composition.
 */

import BaseLayout from '../layouts/BaseLayout.astro';

import HomeHero from '../components/home/HomeHeroClean.astro';
import HomePrimaryJourneys from '../components/home/HomePrimaryJourneys.astro';
import HomeTrustStrip from '../components/home/HomeTrustStrip.astro';
import HomeBreedDiscovery from '../components/home/HomeBreedDiscovery.astro';
import HomeMixedBreedDiscovery from '../components/home/HomeMixedBreedDiscovery.astro';
import HomeCareDecisionLayer from '../components/home/HomeCareDecisionLayer.astro';
import HomeEditorialHighlights from '../components/home/HomeEditorialHighlights.astro';
import HomeMethodologyTeaser from '../components/home/HomeMethodologyTeaser.astro';
import HomeLeadCapture from '../components/home/HomeLeadCapture.astro';
import HomeAwinSpotlight from '../components/home/HomeAwinSpotlight.astro';

import getHomepageData from '../lib/homepage/getHomepageData';

const homepage = await getHomepageData();

const {
  seo,
  featureFlags,
  hero,
  primaryJourneys,
  trustStrip,
  breedDiscovery,
  mixedBreedDiscovery,
  careDecisionLayer,
  editorialHighlights,
  methodologyTeaser,
  leadCapture,
} = homepage;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: seo.title,
    description: seo.description,
    url: seo.canonicalUrl,
    about: [
      { '@type': 'Thing', name: 'Dog Breeds' },
      { '@type': 'Thing', name: 'Mixed Breeds' },
      { '@type': 'Thing', name: 'Dog Care' },
      { '@type': 'Thing', name: 'Dog Costs' },
      { '@type': 'Thing', name: 'Dog Training' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'PupWiki homepage journeys',
    itemListElement: primaryJourneys.items.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.title,
      url: new URL(item.href, seo.canonicalUrl).toString(),
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Featured breed discovery',
    itemListElement: breedDiscovery.breeds.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      url: new URL(item.href, seo.canonicalUrl).toString(),
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Featured mixed breed discovery',
    itemListElement: mixedBreedDiscovery.items.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      url: new URL(item.href, seo.canonicalUrl).toString(),
    })),
  },
];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonicalUrl={seo.canonicalUrl}
  ogImage={seo.ogImage}
  ogImageAlt={seo.ogImageAlt}
  pageType="website"
  bodyClass="homepage pw-page"
  structuredData={structuredData}
>
  <div class="overflow-x-clip">
    {featureFlags.showHero && <HomeHero {...hero} />}

    {featureFlags.showPrimaryJourneys && <HomePrimaryJourneys {...primaryJourneys} />}

    {featureFlags.showTrustStrip && <HomeTrustStrip {...trustStrip} />}

    {featureFlags.showBreedDiscovery && (
      <HomeBreedDiscovery
        id="home-breed-discovery"
        eyebrow={breedDiscovery.eyebrow}
        title={breedDiscovery.title}
        subtitle={breedDiscovery.subtitle}
        viewAllHref={breedDiscovery.viewAllHref}
        viewAllLabel={breedDiscovery.viewAllLabel}
        routePrefix={breedDiscovery.routePrefix}
        breeds={breedDiscovery.breeds}
      />
    )}

    {featureFlags.showMixedBreedDiscovery && (
      <HomeMixedBreedDiscovery
        id="home-mixed-breed-discovery"
        eyebrow={mixedBreedDiscovery.eyebrow}
        title={mixedBreedDiscovery.title}
        subtitle={mixedBreedDiscovery.subtitle}
        viewAllHref={mixedBreedDiscovery.viewAllHref}
        viewAllLabel={mixedBreedDiscovery.viewAllLabel}
        detailRoutePrefix={mixedBreedDiscovery.detailRoutePrefix}
        items={mixedBreedDiscovery.items}
      />
    )}

    {featureFlags.showCareDecisionLayer && <HomeCareDecisionLayer {...careDecisionLayer} />}

    {(featureFlags as any).showAwinSpotlight && <HomeAwinSpotlight />}

    {featureFlags.showEditorialHighlights && (
      <HomeEditorialHighlights
        id="home-editorial-highlights"
        eyebrow={editorialHighlights.eyebrow}
        title={editorialHighlights.title}
        subtitle={editorialHighlights.subtitle}
        viewAllHref={editorialHighlights.viewAllHref}
        viewAllLabel={editorialHighlights.viewAllLabel}
        items={editorialHighlights.items}
      />
    )}

    {featureFlags.showMethodologyTeaser && <HomeMethodologyTeaser {...methodologyTeaser} />}

    {featureFlags.showLeadCapture && <HomeLeadCapture {...leadCapture} />}
  </div>
</BaseLayout>
