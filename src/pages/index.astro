---
/**
 * pages/index.astro — Homepage
 */
import BaseLayout    from '../layouts/BaseLayout.astro';
import CategoryCard  from '../components/content/CategoryCard.astro';
import BlogCard      from '../components/content/BlogCard.astro';
import QuickCard     from '../components/content/QuickCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const latest = posts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const categories = [
  { slug: 'dog-food',   theme: 'food'     as const, emoji: '🍖', title: 'Dog Food',      desc: 'Dry, wet, grain-free and breed-specific formulas — all independently tested.',       reviewCount: 11, href: '/categories/dog-food',   linkText: 'Explore food reviews' },
  { slug: 'toys',       theme: 'toys'     as const, emoji: '🎾', title: 'Toys & Gear',   desc: 'Durable chew toys, interactive puzzles, harnesses, GPS trackers and beds.',          reviewCount: 21, href: '/categories/toys',       linkText: 'Find the best gear'   },
  { slug: 'health',     theme: 'health'   as const, emoji: '🩺', title: 'Dog Health',    desc: 'Supplements, flea control, dental care, DNA tests and expert health advice.',        reviewCount: 14, href: '/categories/health',     linkText: 'Boost their health'   },
  { slug: 'training',   theme: 'training' as const, emoji: '🦮', title: 'Training',      desc: 'Harnesses, GPS collars, training treats, long lines and professional techniques.',   reviewCount: 9,  href: '/categories/training',   linkText: 'Train smarter'        },
  { slug: 'grooming',   theme: 'grooming' as const, emoji: '✂️', title: 'Grooming',      desc: 'Brushes, shampoos, nail trimmers and professional grooming guides by coat type.',    reviewCount: 6,  href: '/categories/grooming',   linkText: 'Grooming guides'      },
  { slug: 'beds',       theme: 'beds'     as const, emoji: '🛏️', title: 'Beds & Sleep',  desc: 'Orthopedic, elevated and crate beds — matched to size, age and sleeping style.',    reviewCount: 6,  href: '/categories/beds',       linkText: 'Find the right bed'   },
];

const quickLinks = [
  { label: 'Best Dog Food',      value: 'French Bulldog',      href: '/blog/best-food-for-french-bulldogs'     },
  { label: 'Durable Toys',       value: 'Heavy Chewers',       href: '/blog/best-toys-for-aggressive-chewers'  },
  { label: 'Orthopedic Beds',    value: 'Senior Dogs',         href: '/blog/best-orthopedic-dog-bed-senior'    },
  { label: 'Top Harness',        value: 'Active Retrievers',   href: '/blog/best-harness-for-active-breeds'    },
  { label: 'Smartest Breeds',    value: 'Intelligence Ranked', href: '/blog/smartest-dog-breeds'               },
  { label: 'DNA Test',           value: 'Embark vs Wisdom',    href: '/blog/embark-vs-wisdom-panel'            },
  { label: 'Budget Food',        value: 'Under $50/month',     href: '/blog/best-dog-food-under-50'            },
  { label: 'Dog Names',          value: '7,000+ Curated',      href: '/dog-names'                              },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Mr. Doggo Style — Expert Dog Product Reviews',
  description: 'Independent, data-driven dog product reviews, breed guides and safety-verified insights for conscientious dog owners.',
  url: 'https://mrdoggostyle.com',
};
---

<BaseLayout
  title="Mr. Doggo Style | Verified Dog Product Reviews & Breed Guides 2026"
  description="Expert, data-driven dog product reviews, breed-specific guides and safety-verified insights. 51 products tested. 277 breed guides. Zero paid placements."
  canonicalUrl="https://mrdoggostyle.com"
>

  <!-- ── HERO ──────────────────────────────────────────────────── -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero__inner">

      <span class="hero__eyebrow">
        <span class="hero__eyebrow-dot"></span>
        Verified Dog Product Research · Est. 2023
        <span class="hero__eyebrow-dot"></span>
      </span>

      <h1 class="hero__title" id="hero-title">
        Your Trusted Guide to the<br>
        <em>Best Dog Products</em>
      </h1>

      <p class="hero__subtitle">
        "Expert reviews, data-driven comparisons, and safety-verified insights
        to make the best decisions for your canine family member."
      </p>

      <div class="hero__actions">
        <a href="/blog" class="btn btn--primary btn--lg">
          Explore Trending Now
        </a>
        <a href="/about" class="btn btn--outline btn--lg">
          How We Test Products
        </a>
      </div>

      <div class="hero__trust-bar">
        <span class="hero__trust-item">
          <span class="hero__trust-icon">✓</span> 51 products tested
        </span>
        <span class="hero__trust-item">
          <span class="hero__trust-icon">✓</span> 277 breed guides
        </span>
        <span class="hero__trust-item">
          <span class="hero__trust-icon">✓</span> Zero paid placements
        </span>
        <span class="hero__trust-item">
          <span class="hero__trust-icon">✓</span> Updated March 2026
        </span>
      </div>

    </div>
  </section>

  <!-- ── CATEGORIES ────────────────────────────────────────────── -->
  <section class="section" aria-labelledby="categories-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Browse by category</span>
          <h2 class="section-title" id="categories-heading">
            Explore Product Categories
          </h2>
        </div>
        <a href="/categories" class="btn btn--ghost btn--sm">
          View all →
        </a>
      </div>

      <div class="grid grid-3" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr))">
        {categories.map(cat => (
          <CategoryCard {...cat} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── QUICK LINKS ────────────────────────────────────────────── -->
  <section class="section section--soft" aria-labelledby="quicklinks-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Jump straight in</span>
          <h2 class="section-title" id="quicklinks-heading">
            Verified Top Choices, Instantly
          </h2>
        </div>
      </div>

      <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-4)">
        {quickLinks.map(q => (
          <QuickCard {...q} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── LATEST POSTS ───────────────────────────────────────────── -->
  <section class="section" aria-labelledby="blog-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">From the experts</span>
          <h2 class="section-title" id="blog-heading">
            Latest Expert Insights
          </h2>
        </div>
        <a href="/blog" class="btn btn--ghost btn--sm">
          All posts →
        </a>
      </div>

      <div class="grid grid-3">
        {latest.length > 0
          ? latest.map(post => (
              <BlogCard
                title={post.data.title}
                excerpt={post.data.description ?? ''}
                category={post.data.category ?? 'Review'}
                href={`/blog/${post.slug}`}
                pubDate={post.data.pubDate}
                readTime={post.data.readTime}
                image={post.data.heroImage}
              />
            ))
          : [
              { title: 'Best Harnesses for Active Breeds', cat: 'Gear',   emoji: '🦮', excerpt: 'We tested 10 harnesses on active Retrievers and Pointers. This is the definitive winner.',     href: '/blog/best-harness-active-breeds'   },
              { title: '5 Critical Signs of Aging',        cat: 'Health', emoji: '🩺', excerpt: 'How to spot joint pain, cognitive decline, and other senior health issues early.',               href: '/blog/signs-of-dog-aging'           },
              { title: 'Top Indestructible Chew Toys',     cat: 'Toys',   emoji: '🎾', excerpt: 'Verified reviews from heavy chewers — Bulldogs and Great Danes included.',                      href: '/blog/best-indestructible-chew-toys' },
            ].map(p => (
              <BlogCard title={p.title} excerpt={p.excerpt} category={p.cat} href={p.href} emoji={p.emoji} />
            ))
        }
      </div>
    </div>
  </section>

  <!-- ── NEWSLETTER ────────────────────────────────────────────── -->
  <section class="section section--soft" aria-labelledby="newsletter-heading">
    <div class="container" style="max-width: var(--max-width-prose); text-align: center">
      <span class="section-eyebrow">Weekly gear drops</span>
      <h2 class="section-title" id="newsletter-heading" style="margin-bottom: var(--space-4)">
        The Dog Gear Drop
      </h2>
      <p class="section-subtitle" style="margin-inline: auto; margin-bottom: var(--space-8)">
        3 product picks, 1 deal, 1 breed spotlight. Every Tuesday. Zero spam.
      </p>
      <form class="newsletter-form" style="margin-inline: auto" action="#" method="POST">
        <input
          type="email"
          name="email"
          class="form-input"
          placeholder="your@email.com"
          required
          aria-label="Email address"
        />
        <button type="submit" class="btn btn--primary">
          Subscribe
        </button>
      </form>
      <p style="font-size: var(--text-xs); color: var(--color-subtle); margin-top: var(--space-3)">
        No spam. Unsubscribe anytime. 
      </p>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

</BaseLayout>
