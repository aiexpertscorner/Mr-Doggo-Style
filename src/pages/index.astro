---
/**
 * pages/index.astro — Homepage
 */
import BaseLayout    from '../layouts/BaseLayout.astro';
import CategoryCard  from '../components/content/CategoryCard.astro';
import BlogCard      from '../components/content/BlogCard.astro';
import QuickCard     from '../components/content/QuickCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const latest = posts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const categories = [
  { slug: 'dog-food',   theme: 'food'     as const, emoji: '🍖', title: 'Dog Food',      desc: 'Dry, wet, grain-free and breed-specific formulas — all independently tested.',       reviewCount: 11, href: '/categories/dog-food',   linkText: 'Explore food reviews' },
  { slug: 'toys',       theme: 'toys'     as const, emoji: '🎾', title: 'Toys & Gear',   desc: 'Durable chew toys, interactive puzzles, harnesses, GPS trackers and beds.',          reviewCount: 21, href: '/categories/toys',       linkText: 'Find the best gear'   },
  { slug: 'health',     theme: 'health'   as const, emoji: '🩺', title: 'Dog Health',    desc: 'Supplements, flea control, dental care, DNA tests and expert health advice.',        reviewCount: 14, href: '/categories/health',     linkText: 'Boost their health'   },
  { slug: 'training',   theme: 'training' as const, emoji: '🦮', title: 'Training',      desc: 'Harnesses, GPS collars, training treats, long lines and professional techniques.',   reviewCount: 9,  href: '/categories/training',   linkText: 'Train smarter'        },
  { slug: 'grooming',   theme: 'grooming' as const, emoji: '✂️', title: 'Grooming',      desc: 'Brushes, shampoos, nail trimmers and professional grooming guides by coat type.',    reviewCount: 6,  href: '/categories/grooming',   linkText: 'Grooming guides'      },
  { slug: 'beds',       theme: 'beds'     as const, emoji: '🛏️', title: 'Beds & Sleep',  desc: 'Orthopedic, elevated and crate beds — matched to size, age and sleeping style.',    reviewCount: 6,  href: '/categories/beds',       linkText: 'Find the right bed'   },
];

const quickLinks = [
  { label: 'Best Dog Food',      value: 'French Bulldog',      href: '/blog/best-food-for-french-bulldogs'     },
  { label: 'Durable Toys',       value: 'Heavy Chewers',       href: '/blog/best-toys-for-aggressive-chewers'  },
  { label: 'Orthopedic Beds',    value: 'Senior Dogs',         href: '/blog/best-orthopedic-dog-bed-senior'    },
  { label: 'Top Harness',        value: 'Active Retrievers',   href: '/blog/best-harness-for-active-breeds'    },
  { label: 'Smartest Breeds',    value: 'Intelligence Ranked', href: '/blog/smartest-dog-breeds'               },
  { label: 'DNA Test',           value: 'Embark vs Wisdom',    href: '/blog/embark-vs-wisdom-panel'            },
  { label: 'Budget Food',        value: 'Under $50/month',     href: '/blog/best-dog-food-under-50'            },
  { label: 'Dog Names',          value: '7,000+ Curated',      href: '/dog-names'                              },
];

const popularBreeds = [
  { slug: 'labrador-retriever',  name: 'Labrador Retriever',  emoji: '🐕'   },
  { slug: 'french-bulldog',      name: 'French Bulldog',      emoji: '🐾'   },
  { slug: 'golden-retriever',    name: 'Golden Retriever',    emoji: '🦮'   },
  { slug: 'german-shepherd',     name: 'German Shepherd',     emoji: '🐕‍🦺' },
  { slug: 'bulldog',             name: 'Bulldog',             emoji: '🐶'   },
  { slug: 'poodle',              name: 'Poodle',              emoji: '🐩'   },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How do you choose which products to review?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We select products based on popularity, safety record, and relevance to specific breed needs. Every product is scored using our 8-point methodology covering ingredients, durability, safety, value, and breed suitability — never on affiliate commission rates.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you recommend products per dog breed?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Our breed-specific system matches every product review to the relevant breed\'s size, energy level, coat type, and common health concerns. We cover 277 breeds with tailored food, toy, bed, and health recommendations.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are your reviews paid for by brands?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. We never accept payment or free products in exchange for reviews. We earn small affiliate commissions when you buy through our links, but our editorial scores and recommendations are determined entirely by our testing methodology.',
      },
    },
  ],
};
---

<BaseLayout
  title="Mr. Doggo Style | Verified Dog Product Reviews & Breed Guides 2026"
  description="Expert, data-driven dog product reviews, breed-specific guides and safety-verified insights. 125+ products reviewed. 277 breed guides. Zero paid placements."
  canonicalUrl="https://mrdoggostyle.com"
>

  <!-- ── HERO ──────────────────────────────────────────────────── -->
  <section class="hero hero--split" aria-labelledby="hero-title">
    <div class="hero__inner hero__inner--split">
      <div class="hero__content">
        <span class="hero__eyebrow">
          <span class="hero__eyebrow-dot"></span>
          Verified Dog Product Research · Est. 2023
          <span class="hero__eyebrow-dot"></span>
        </span>

        <h1 class="hero__title" id="hero-title">
          Your Trusted Guide to
          <br />
          <em>Better Dog Products</em>
        </h1>

        <p class="hero__subtitle">
          Breed-specific reviews, data-driven comparisons, and safety-first
          insights — so you can choose confidently for your dog.
        </p>

        <div class="hero__actions">
          <a href="/blog/top-picks-2026" class="btn btn--white btn--lg">
            See Top Picks for 2026
          </a>
          <a href="/how-we-test" class="btn btn--outline-white btn--lg">
            How We Review
          </a>
        </div>

        <div class="hero__trust-bar">
          <span class="hero__trust-item">
            <span class="hero__trust-icon">✓</span> 125+ products reviewed
          </span>
          <span class="hero__trust-item">
            <span class="hero__trust-icon">✓</span> 277 breed guides
          </span>
          <span class="hero__trust-item">
            <span class="hero__trust-icon">✓</span> Zero paid placements
          </span>
          <span class="hero__trust-item">
            <span class="hero__trust-icon">✓</span> Updated 2026
          </span>
        </div>
      </div>

      <div class="hero__media" aria-hidden="true">
        <div class="hero__media-shape">
          <img
            src="/hero/dog-owner-hero.jpg"
            alt=""
            class="hero__image"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="hero__card hero__card--top">
          <span class="hero__card-label">Trusted Picks</span>
          <strong>Breed-smart reviews</strong>
          <p>Independent advice for modern dog owners.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── STATS STRIP ───────────────────────────────────────────── -->
  <div class="stats-strip" role="region" aria-label="Site statistics">
    <div class="stats-strip__inner">
      <div class="stats-strip__item">
        <span class="stats-strip__number">277</span>
        <span class="stats-strip__label">Breed Guides</span>
      </div>
      <div class="stats-strip__item">
        <span class="stats-strip__number">125+</span>
        <span class="stats-strip__label">Products Reviewed</span>
      </div>
      <div class="stats-strip__item">
        <span class="stats-strip__number">442+</span>
        <span class="stats-strip__label">Expert Articles</span>
      </div>
      <div class="stats-strip__item">
        <span class="stats-strip__number">0</span>
        <span class="stats-strip__label">Paid Placements</span>
      </div>
    </div>
  </div>

  <!-- ── CATEGORIES ────────────────────────────────────────────── -->
  <section class="section" aria-labelledby="categories-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Browse by category</span>
          <h2 class="section-title" id="categories-heading">
            Explore Product Categories
          </h2>
        </div>
        <a href="/categories" class="btn btn--ghost btn--sm">
          View all →
        </a>
      </div>

      <div class="grid grid-3" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr))">
        {categories.map(cat => (
          <CategoryCard {...cat} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── BREED SPOTLIGHT ───────────────────────────────────────── -->
  <section class="section section--soft" aria-labelledby="breeds-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Breed-matched advice</span>
          <h2 class="section-title" id="breeds-heading">
            Find Guides for Your Breed
          </h2>
        </div>
        <a href="/breeds" class="btn btn--ghost btn--sm">
          All 277 breeds →
        </a>
      </div>

      <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: var(--space-4)">
        {popularBreeds.map(breed => (
          <a href={`/breeds/${breed.slug}`} class="breed-pill">
            <span class="breed-pill__emoji">{breed.emoji}</span>
            <span class="breed-pill__name">{breed.name}</span>
            <span class="breed-pill__cta">Food · Toys · Care →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── QUICK LINKS ────────────────────────────────────────────── -->
  <section class="section" aria-labelledby="quicklinks-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Jump straight in</span>
          <h2 class="section-title" id="quicklinks-heading">
            Top-Rated Guides, Instantly
          </h2>
        </div>
      </div>

      <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-4)">
        {quickLinks.map(q => (
          <QuickCard {...q} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── LATEST POSTS ───────────────────────────────────────────── -->
  <section class="section section--soft" aria-labelledby="blog-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">From the experts</span>
          <h2 class="section-title" id="blog-heading">
            Latest Expert Reviews
          </h2>
        </div>
        <a href="/blog" class="btn btn--ghost btn--sm">
          All articles →
        </a>
      </div>

      <div class="grid grid-3">
        {latest.length > 0
          ? latest.map(post => (
              <BlogCard
                title={post.data.title}
                excerpt={post.data.description ?? ''}
                category={post.data.category ?? 'Review'}
                href={`/blog/${post.slug}`}
                pubDate={post.data.pubDate}
                readTime={post.data.readTime}
                image={post.data.heroImage}
              />
            ))
          : [
              { title: 'Best Harnesses for Active Breeds', cat: 'Gear',   emoji: '🦮', excerpt: 'We tested 10 harnesses on active Retrievers and Pointers. This is the definitive winner.',     href: '/blog/best-harness-active-breeds'    },
              { title: '5 Critical Signs of Aging',        cat: 'Health', emoji: '🩺', excerpt: 'How to spot joint pain, cognitive decline, and other senior health issues early.',               href: '/blog/signs-of-dog-aging'            },
              { title: 'Top Indestructible Chew Toys',     cat: 'Toys',   emoji: '🎾', excerpt: 'Verified reviews from heavy chewers — Bulldogs and Great Danes included.',                      href: '/blog/best-indestructible-chew-toys' },
            ].map(p => (
              <BlogCard title={p.title} excerpt={p.excerpt} category={p.cat} href={p.href} emoji={p.emoji} />
            ))
        }
      </div>
    </div>
  </section>

  <!-- ── HOW WE REVIEW (Trust strip) ──────────────────────────── -->
  <section class="section" aria-labelledby="trust-heading">
    <div class="container" style="max-width: var(--max-width-prose)">
      <div style="text-align:center; margin-bottom: var(--space-10)">
        <span class="section-eyebrow">Our methodology</span>
        <h2 class="section-title" id="trust-heading">Why You Can Trust Our Reviews</h2>
        <p class="section-subtitle" style="margin-inline:auto">
          Every recommendation follows the same 8-point scoring process — before we ever consider affiliate rates.
        </p>
      </div>
      <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--space-6)">
        {[
          { icon: '🔬', title: 'Ingredient Analysis',  body: 'We scrutinise every formula for quality protein, fillers, and flagged additives.' },
          { icon: '🐾', title: 'Breed Matching',       body: 'Recommendations are filtered by size, energy, coat type and health predispositions.' },
          { icon: '📊', title: 'Data-Driven Scores',   body: 'Our 1–10 score combines lab data, owner reviews, vet guidance, and safety history.' },
          { icon: '🚫', title: 'No Paid Placements',   body: 'Brands cannot pay to feature or improve their score. Ever.' },
        ].map(item => (
          <div style="display:flex;flex-direction:column;gap:var(--space-3)">
            <span style="font-size:2rem">{item.icon}</span>
            <strong style="font-size:var(--text-base);font-weight:var(--weight-bold);color:var(--color-heading)">{item.title}</strong>
            <p style="font-size:var(--text-sm);color:var(--color-body);line-height:var(--leading-relaxed);margin:0">{item.body}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:var(--space-10)">
        <a href="/how-we-test" class="btn btn--outline">Read our full methodology →</a>
      </div>
    </div>
  </section>

  <!-- ── NEWSLETTER ────────────────────────────────────────────── -->
  <section class="section section--soft" aria-labelledby="newsletter-heading">
    <div class="container" style="max-width: var(--max-width-prose); text-align: center">
      <span class="section-eyebrow">Free weekly picks</span>
      <h2 class="section-title" id="newsletter-heading" style="margin-bottom: var(--space-3)">
        The Dog Gear Drop
      </h2>
      <p class="section-subtitle" style="margin-inline: auto; margin-bottom: var(--space-2)">
        3 product picks · 1 deal · 1 breed spotlight — every Tuesday.
      </p>
      <p style="font-size: var(--text-sm); color: var(--color-muted); margin-bottom: var(--space-8)">
        Join 5,000+ dog owners who get unfiltered picks before they go mainstream.
      </p>
      <form
        class="newsletter-form"
        style="margin-inline: auto"
        id="homepage-newsletter"
        action="#"
        method="POST"
      >
        <input
          type="email"
          name="email"
          class="form-input"
          placeholder="your@email.com"
          required
          aria-label="Email address"
        />
        <button type="submit" class="btn btn--primary">
          Subscribe free
        </button>
      </form>
      <p id="newsletter-success" style="display:none;font-size:var(--text-sm);color:var(--color-success);font-weight:var(--weight-semi);margin-top:var(--space-4)">
        ✓ You're in! Check your inbox for a confirmation.
      </p>
      <p style="font-size: var(--text-xs); color: var(--color-subtle); margin-top: var(--space-3)">
        No spam. Unsubscribe anytime.
      </p>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script>
    // Newsletter success state (replace form action with real email service URL)
    const form = document.getElementById('homepage-newsletter');
    const success = document.getElementById('newsletter-success');
    if (form && success) {
      form.addEventListener('submit', (e) => {
        // Remove this preventDefault once a real action URL is set
        e.preventDefault();
        form.style.display = 'none';
        success.style.display = 'block';
      });
    }
  </script>

</BaseLayout>
