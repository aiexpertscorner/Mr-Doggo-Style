---
/**
 * src/pages/blog/[slug].astro — cleaned PupWiki blog article route
 *
 * Changes:
 * - Removes Amazon/productIndex sidebar logic
 * - Removes legacy inline brown styling
 * - Uses cleaned BlogLayout props
 * - Adds safe Article + Breadcrumb schema
 * - Adds breed-aware context card using BreedImage
 * - Adds safer support links to breed hub / tools
 * - Keeps AWIN/PageBanner pipeline available without hardcoded Amazon products
 */

import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

import masterBreeds from '../../data/master-breeds.json';
import masterCrossbreeds from '../../data/master-crossbreeds.json';
import breedLinkMap from '../../data/breed-link-map.json';
import contentStatus from '../../data/content-status.json';

import BreedImage from '../../components/breed/BreedImage.astro';
import PageBannerSlot from '../../components/affiliate/PageBannerSlot.astro';
import AwinProductSlot from '../../components/affiliate/AwinProductSlot.astro';
import AmazonProductSlot from '../../components/amazon/AmazonProductSlot.astro';

const SITE = 'https://pupwiki.com';

const ALL_BREEDS = [...(masterBreeds as any[]), ...(masterCrossbreeds as any[])];

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const fm = post.data;

const category = fm.category || 'Guide';
const tags = Array.isArray(fm.tags) ? fm.tags : [];
const pageTitle = fm.seoTitle || fm.title;
const displayTitle = fm.displayTitle || fm.title;

function normalize(value: unknown) {
  return String(value || '').toLowerCase();
}

function slugify(value: string) {
  return String(value || '')
    .toLowerCase()
    .trim()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

function titleCase(value?: string | null) {
  if (!value) return '';
  return String(value)
    .replace(/[-_]+/g, ' ')
    .replace(/\b\w/g, (char) => char.toUpperCase());
}

function getWordCount(value?: string) {
  return String(value || '')
    .split(/\s+/)
    .filter(Boolean).length;
}

const bodyWordCount = getWordCount(post.body);
const readTime = fm.readTime || Math.max(4, Math.ceil(bodyWordCount / 220));

const breedSlug =
  fm.breedSlug ||
  fm.breed_slug ||
  null;

const breed =
  breedSlug
    ? ALL_BREEDS.find((item) => item.slug === breedSlug)
    : null;

const breedName = fm.breedName || fm.breed_name || breed?.name || '';
const links = breedSlug ? (breedLinkMap as any)[breedSlug] || {} : {};
const status = breedSlug ? (contentStatus as any)[breedSlug] || {} : {};

const isBreedSupportPost = Boolean(breedSlug || breedName || breed);

const isHealthSensitive =
  ['health', 'supplements', 'food', 'dog food'].includes(normalize(category)) ||
  tags.some((tag: string) =>
    ['health', 'supplements', 'nutrition', 'medical-warning', 'vet-critical', 'emergency-vet'].includes(normalize(tag))
  );

const isGeneratedSupport =
  Boolean(fm.generated) ||
  Boolean(fm.breedSlug) ||
  Boolean(fm.breedName) ||
  ['product-roundup', 'breed-support', 'generated-support'].includes(normalize(fm.postType));

const canonicalUrl = fm.canonicalUrl || `${SITE}/blog/${post.slug}`;

const heroImage =
  fm.heroImage ||
  fm.image ||
  breed?.image_url ||
  (Array.isArray(breed?.image_urls) ? breed.image_urls[0] : null) ||
  '';

const breedAltLabel = breedName?.endsWith(' Dog') ? breedName : `${breedName} dog`;
const heroImageAlt =
  fm.heroImageAlt ||
  fm.imageAlt ||
  (breedName ? `${breedAltLabel} guide` : displayTitle);

const awinTopicTags = [
  normalize(category),
  normalize(fm.postType),
  breedSlug,
  breedName,
  breed?.size_category,
  breed?.energy_level,
  breed?.training_level,
  breed?.coat_type,
  ...tags,
]
  .filter(Boolean)
  .map((item) => String(item).toLowerCase());

const clusterLinks = breedSlug
  ? [
      {
        key: 'hub',
        href: links.hub || `/breeds/${breedSlug}`,
        emoji: '🐾',
        label: `${breedName || 'Breed'} hub`,
      },
      {
        key: 'food_post',
        href: links.food_post,
        emoji: '🍖',
        label: 'Food & nutrition',
      },
      {
        key: 'toy_post',
        href: links.toy_post,
        emoji: '🎾',
        label: 'Toys & enrichment',
      },
      {
        key: 'bed_post',
        href: links.bed_post,
        emoji: '🛏️',
        label: 'Beds & sleep',
      },
      {
        key: 'grooming_post',
        href: links.grooming_post,
        emoji: '✂️',
        label: 'Grooming guide',
      },
      {
        key: 'health_post',
        href: links.health_post,
        emoji: '🩺',
        label: 'Health context',
      },
      {
        key: 'supplement_post',
        href: links.supplement_post,
        emoji: '💊',
        label: 'Supplement considerations',
      },
      {
        key: 'training_post',
        href: links.training_post,
        emoji: '🦮',
        label: 'Training guide',
      },
      {
        key: 'names_page',
        href: links.names_page,
        emoji: '✍️',
        label: 'Name ideas',
      },
      {
        key: 'cost_calculator',
        href: `/cost-calculator/${breedSlug}`,
        emoji: '💰',
        label: 'Cost calculator',
      },
    ].filter((item) => item.href && item.href !== Astro.url.pathname)
  : [];

const showCommercialMidContent =
  !isHealthSensitive &&
  !tags.some((tag: string) =>
    ['medical-warning', 'vet-critical', 'emergency-vet', 'diagnosis', 'treatment'].includes(normalize(tag))
  );

const showProductRoundupCommerce =
  normalize(fm.postType) === 'product-roundup' &&
  !tags.some((tag: string) =>
    ['medical-warning', 'vet-critical', 'emergency-vet', 'diagnosis', 'treatment'].includes(normalize(tag))
  );

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: displayTitle,
  description: fm.description,
  image: heroImage || undefined,
  datePublished: new Date(fm.pubDate).toISOString(),
  dateModified: fm.updatedDate
    ? new Date(fm.updatedDate).toISOString()
    : new Date(fm.pubDate).toISOString(),
  author: {
    '@type': 'Organization',
    name: 'PupWiki',
    url: SITE,
  },
  publisher: {
    '@type': 'Organization',
    name: 'PupWiki',
    url: SITE,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${SITE}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Guides',
      item: `${SITE}/blog`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: category,
      item: `${SITE}/categories/${slugify(category)}`,
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: displayTitle,
      item: canonicalUrl,
    },
  ],
};

const schema = [articleSchema, breadcrumbSchema];

const relatedToolLinks = [
  {
    href: '/breeds',
    icon: '🐕',
    title: 'Explore dog breeds',
    text: 'Compare breed traits, size, grooming, training, and owner fit.',
  },
  {
    href: '/cost-calculator',
    icon: '💰',
    title: 'Estimate dog ownership costs',
    text: 'Plan puppy, annual, and lifetime costs by breed.',
  },
  {
    href: '/dog-names',
    icon: '✍️',
    title: 'Find dog name ideas',
    text: 'Generate, favorite, export, and share name ideas locally.',
  },
];
---

<BlogLayout
  title={pageTitle}
  displayTitle={displayTitle}
  description={fm.description}
  canonicalUrl={canonicalUrl}
  pubDate={fm.pubDate}
  updatedDate={fm.updatedDate}
  category={category}
  readTime={readTime}
  heroImage={heroImage}
  heroImageAlt={heroImageAlt}
  schema={schema}
  tags={tags}
  postType={fm.postType || 'general'}
  breedSlug={breedSlug}
  breedName={breedName}
  breedSize={breed?.size_category}
  breedEnergy={breed?.energy_level}
  breedCoat={breed?.coat_type}
  noIndex={fm.noIndex || false}
>
  {isGeneratedSupport && (
    <aside class="article-support-note not-prose" aria-label="Support content note">
      <div>
        <strong>Breed-support guide</strong>
        <p>
          This article supports PupWiki’s breed research pages. For the complete ownership profile,
          costs, traits, health context, and related tools, start from the breed hub.
        </p>
      </div>

      {breedSlug && (
        <a href={links.hub || `/breeds/${breedSlug}`}>
          View {breedName || 'breed'} hub →
        </a>
      )}
    </aside>
  )}

  {breed && (
    <aside class="article-breed-card not-prose" aria-label={`${breedName} breed context`}>
      <BreedImage
        breed={breed}
        width={220}
        height={220}
        variant="card"
        class="article-breed-card__image"
      />

      <div class="article-breed-card__body">
        <p class="article-breed-card__eyebrow">Breed context</p>

        <h2>
          {breedName}
        </h2>

        <p>
          Use the main breed hub for traits, owner fit, costs, health context, grooming, training,
          and related PupWiki tools.
        </p>

        <div class="article-breed-card__pills">
          {breed.size_category && <span>{titleCase(breed.size_category)} size</span>}
          {breed.energy_level && <span>{titleCase(breed.energy_level)} energy</span>}
          {breed.coat_type && <span>{titleCase(breed.coat_type)} coat</span>}
        </div>

        <a href={links.hub || `/breeds/${breedSlug}`} class="article-breed-card__link">
          Open full {breedName} guide →
        </a>
      </div>
    </aside>
  )}

  <Content />

  {showProductRoundupCommerce && (
    <section class="article-commerce-suite not-prose" aria-label="Relevant shopping resources">
      <div class="article-commerce-suite__header">
        <p>Shopping resources</p>
        <h2>Current partner and Amazon.com options</h2>
        <span>
          These modules are matched from the active affiliate feeds. Always confirm formula, size,
          availability, and seller details before purchase.
        </span>
      </div>

      <div class="article-commerce-suite__grid">
        <AwinProductSlot
          topicTags={awinTopicTags}
          pageType="blog"
          category={normalize(category)}
          breedSize={breed?.size_category || fm.breedSize}
          breedEnergy={breed?.energy_level || fm.breedEnergy}
          breedTraining={breed?.training_level}
          headline="AWIN partner match"
          monetizationIntent="high"
        />

        <AmazonProductSlot
          topicTags={awinTopicTags}
          pageType="blog"
          pageSlug={`/blog/${post.slug}`}
          category={normalize(category)}
          breedSize={breed?.size_category || fm.breedSize}
          breedEnergy={breed?.energy_level || fm.breedEnergy}
          breedCoat={breed?.coat_type || fm.breedCoat}
          headline="Amazon.com matches"
          limit={3}
        />
      </div>
    </section>
  )}

  {showCommercialMidContent && (
    <div class="article-partner-strip not-prose">
      <AwinProductSlot
        topicTags={awinTopicTags}
        pageType="blog"
        category={normalize(category)}
        breedSize={breed?.size_category}
        breedEnergy={breed?.energy_level}
        breedTraining={breed?.training_level}
        headline="Relevant partner resources"
      />
    </div>
  )}

  {showCommercialMidContent && (
    <PageBannerSlot
      pageType="blog"
      placement="mid-content"
      topic={normalize(category)}
      topicTags={awinTopicTags}
      compact={false}
    />
  )}

  {clusterLinks.length > 0 && (
    <section class="article-related-breed not-prose" aria-labelledby="related-breed-guides-title">
      <div class="article-related-breed__header">
        <p>More breed guidance</p>
        <h2 id="related-breed-guides-title">
          More {breedName} guides
        </h2>
      </div>

      <div class="article-related-grid">
        {clusterLinks.slice(0, 10).map((item) => (
          <a href={item.href}>
            <span aria-hidden="true">{item.emoji}</span>
            <strong>{item.label}</strong>
            <em aria-hidden="true">→</em>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="article-next-tools not-prose" aria-labelledby="article-next-tools-title">
    <div class="article-next-tools__header">
      <p>Explore next</p>
      <h2 id="article-next-tools-title">
        Continue with PupWiki tools
      </h2>
    </div>

    <div class="article-next-tools__grid">
      {relatedToolLinks.map((item) => (
        <a href={item.href}>
          <span aria-hidden="true">{item.icon}</span>
          <strong>{item.title}</strong>
          <p>{item.text}</p>
        </a>
      ))}
    </div>
  </section>

  <Fragment slot="sidebar">
    {clusterLinks.length > 0 && (
      <section class="article-custom-sidebar-card">
        <h2>{breedName} links</h2>

        <nav>
          {clusterLinks.slice(0, 8).map((item) => (
            <a href={item.href}>
              <span>{item.emoji}</span>
              <strong>{item.label}</strong>
            </a>
          ))}
        </nav>
      </section>
    )}
  </Fragment>
</BlogLayout>

<style>
  .article-support-note {
    display: grid;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-2xl);
    background: var(--color-accent-subtle);
    padding: var(--space-4);
  }

  .article-support-note strong {
    display: block;
    color: var(--color-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-black);
  }

  .article-support-note p {
    margin: var(--space-2) 0 0;
    color: var(--color-body-soft);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .article-support-note a {
    align-self: center;
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    text-decoration: none;
  }

  .article-support-note a:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-breed-card {
    display: grid;
    gap: var(--space-4);
    margin-bottom: var(--space-7);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-3xl);
    background:
      radial-gradient(circle at 94% 8%, rgba(255, 122, 0, 0.1), transparent 18rem),
      rgba(255, 255, 255, 0.94);
    padding: var(--space-4);
    box-shadow: var(--shadow-card);
  }

  .article-breed-card__image {
    width: min(100%, 12rem);
  }

  .article-breed-card__body {
    min-width: 0;
  }

  .article-breed-card__eyebrow,
  .article-related-breed__header p,
  .article-next-tools__header p {
    display: inline-flex;
    width: fit-content;
    margin: 0;
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    background: var(--color-accent-subtle);
    padding: 0.44rem 0.7rem;
    color: var(--color-accent-hover);
    font-size: 0.68rem;
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: 1;
    text-transform: uppercase;
  }

  .article-breed-card h2,
  .article-related-breed__header h2,
  .article-next-tools__header h2 {
    margin: var(--space-3) 0 0;
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }

  .article-breed-card p:not(.article-breed-card__eyebrow) {
    margin: var(--space-3) 0 0;
    color: var(--color-body-soft);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .article-breed-card__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .article-breed-card__pills span {
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: #ffffff;
    padding: 0.42rem 0.6rem;
    color: var(--color-body-soft);
    font-size: var(--text-xs);
    font-weight: var(--weight-black);
    line-height: 1;
    box-shadow: var(--shadow-xs);
  }

  .article-breed-card__link {
    display: inline-flex;
    margin-top: var(--space-4);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    text-decoration: none;
  }

  .article-breed-card__link:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-partner-strip {
    margin-top: var(--space-8);
  }

  .article-related-breed,
  .article-next-tools,
  .article-commerce-suite {
    margin-top: var(--space-10);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-8);
  }

  .article-related-breed__header,
  .article-next-tools__header,
  .article-commerce-suite__header {
    margin-bottom: var(--space-5);
  }

  .article-commerce-suite__header p {
    display: inline-flex;
    width: fit-content;
    margin: 0;
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    background: var(--color-accent-subtle);
    padding: 0.44rem 0.7rem;
    color: var(--color-accent-hover);
    font-size: 0.68rem;
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: 1;
    text-transform: uppercase;
  }

  .article-commerce-suite__header h2 {
    margin: var(--space-3) 0 0;
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    letter-spacing: 0;
    line-height: var(--leading-tight);
  }

  .article-commerce-suite__header span {
    display: block;
    max-width: 48rem;
    margin-top: var(--space-3);
    color: var(--color-body-soft);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .article-commerce-suite__grid {
    display: grid;
    gap: var(--space-4);
  }

  .article-related-grid,
  .article-next-tools__grid {
    display: grid;
    gap: var(--space-3);
  }

  .article-related-grid a,
  .article-next-tools__grid a {
    display: grid;
    gap: var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: #ffffff;
    padding: var(--space-4);
    color: var(--color-heading);
    text-decoration: none;
    box-shadow: var(--shadow-xs);
    transition: var(--transition-smooth);
  }

  .article-related-grid a {
    grid-template-columns: auto 1fr auto;
    align-items: center;
  }

  .article-related-grid a:hover,
  .article-next-tools__grid a:hover {
    border-color: var(--color-border-accent);
    background: var(--color-bg-soft);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .article-related-grid span,
  .article-next-tools__grid span {
    font-size: 1.35rem;
    line-height: 1;
  }

  .article-related-grid strong,
  .article-next-tools__grid strong {
    color: var(--color-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-black);
    line-height: var(--leading-tight);
  }

  .article-related-grid em {
    color: var(--color-accent-hover);
    font-style: normal;
    font-weight: var(--weight-black);
  }

  .article-next-tools__grid p {
    margin: 0;
    color: var(--color-body-soft);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .article-custom-sidebar-card {
    border: 1px solid var(--card-border);
    border-radius: var(--radius-3xl);
    background: rgba(255, 255, 255, 0.92);
    padding: var(--space-5);
    box-shadow: var(--shadow-card);
  }

  .article-custom-sidebar-card h2 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .article-custom-sidebar-card nav {
    display: grid;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .article-custom-sidebar-card a {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2);
    align-items: center;
    border-radius: var(--radius-lg);
    padding: 0.65rem 0.7rem;
    color: var(--color-heading);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: var(--transition-base);
  }

  .article-custom-sidebar-card a:hover {
    background: var(--color-bg-soft);
    color: var(--color-accent-hover);
  }

  .article-custom-sidebar-card strong {
    font-weight: var(--weight-semi);
  }

  @media (min-width: 640px) {
    .article-support-note {
      grid-template-columns: 1fr auto;
      align-items: center;
    }

    .article-breed-card {
      grid-template-columns: auto 1fr;
      align-items: center;
    }

    .article-related-grid,
    .article-next-tools__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 900px) {
    .article-commerce-suite__grid {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.35fr);
      align-items: start;
    }

    .article-related-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .article-next-tools__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-related-grid a,
    .article-next-tools__grid a,
    .article-custom-sidebar-card a {
      transition: none;
      transform: none !important;
    }
  }
</style>
