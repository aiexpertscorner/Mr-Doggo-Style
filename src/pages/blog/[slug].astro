---
/**
 * blog/[slug].astro v2
 * - Breed-aware: shows cluster sidebar for breed posts
 * - Real product images in sidebar widget
 * - All postTypes rendered correctly
 * - Compatible with existing BlogLayout
 */
import { getCollection }  from 'astro:content';
import BlogLayout          from '../../layouts/BlogLayout.astro';
import masterBreeds        from '../../data/master-breeds.json';
import productIndex        from '../../data/product-index.json';
import breedLinkMap        from '../../data/breed-link-map.json';
import contentStatus       from '../../data/content-status.json';

const AFFILIATE_TAG = 'aiexpertscorn-20';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const fm = post.data;

// Resolve breed data if this is a breed cluster post
const breed     = fm.breedSlug ? (masterBreeds as any[]).find(b => b.slug === fm.breedSlug) : null;
const links     = fm.breedSlug ? (breedLinkMap as any)[fm.breedSlug]    || {} : {};
const status    = fm.breedSlug ? (contentStatus as any)[fm.breedSlug]   || {} : {};
const breedN    = fm.breedName || breed?.name || '';

// Resolve top product for sidebar
const topProd = (() => {
  if (!fm.topProduct?.asin) return null;
  // Try to find in product index by asin
  const found = Object.values(productIndex as any).find((p: any) => p.asin === fm.topProduct!.asin) as any;
  if (found) return found;
  // Fallback to frontmatter data
  return fm.topProduct;
})();

// Breed image for header (breed posts only)
const breedImageUrl = breed?.image_url || null;

// Related cluster links for sidebar
const CLUSTER_LINKS = breedSlug => [
  { key:'food_post',       href: links.food_post,       emoji:'🍖', label:'Best food'       },
  { key:'toy_post',        href: links.toy_post,        emoji:'🎾', label:'Best toys'        },
  { key:'bed_post',        href: links.bed_post,        emoji:'🛏️', label:'Best beds'        },
  { key:'grooming_post',   href: links.grooming_post,   emoji:'✂️', label:'Grooming guide'  },
  { key:'health_post',     href: links.health_post,     emoji:'🩺', label:'Health guide'    },
  { key:'supplement_post', href: links.supplement_post, emoji:'💊', label:'Supplements'     },
  { key:'training_post',   href: links.training_post,   emoji:'🦮', label:'Training guide'  },
  { key:'names_page',      href: links.names_page,      emoji:'✍️', label:'Names'           },
  { key:'hub',             href: links.hub,             emoji:'🐾', label:`${breedN} hub`  },
].filter(c => c.href && c.href !== Astro.url.pathname);

const clusterLinks = fm.breedSlug ? CLUSTER_LINKS(fm.breedSlug) : [];

// Reading time estimate
const readTime = fm.readTime || Math.max(5, Math.ceil(post.body?.split(' ').length / 200));

// Build featured product for BlogLayout sidebar
const featuredProduct = topProd ? {
  name:   topProd.name,
  asin:   topProd.asin,
  price:  topProd.price,
  rating: topProd.rating,
  image:  topProd.image,
} : undefined;
---

<BlogLayout
  title={fm.title}
  description={fm.description}
  pubDate={fm.pubDate}
  updatedDate={fm.updatedDate}
  category={fm.category || 'Reviews'}
  tags={fm.tags || []}
  author={fm.author || 'The PupWiki Team'}
  readingTime={readTime}
  featuredProduct={featuredProduct}
>

  <!-- Breed header band (only for breed cluster posts) -->
  {breed && breedImageUrl && (
    <div class="flex items-center gap-4 p-4 rounded-2xl mb-6 font-sans" style="background:#fdf8f0;border:1px solid #e8ccaa">
      <img
        src={breedImageUrl}
        alt={breedN}
        width="64"
        height="64"
        loading="lazy"
        class="w-16 h-16 object-cover rounded-xl"
        style="border:2px solid #e8ccaa"
        onerror="this.style.display='none'"
      />
      <div>
        <p class="text-xs font-bold uppercase tracking-wider mb-0.5" style="color:#94a3b8">Breed guide</p>
        <a href={links.hub || `/breeds/${fm.breedSlug}`} class="font-bold text-base hover:underline" style="color:#a0621c">
          {breedN} — View complete breed guide →
        </a>
        <div class="flex gap-2 mt-1">
          {breed.size_category && <span class="text-xs px-2 py-0.5 rounded-full" style="background:#f5e8d0;color:#7d4a10">{breed.size_category}</span>}
          {breed.energy_level  && <span class="text-xs px-2 py-0.5 rounded-full" style="background:#f5e8d0;color:#7d4a10">{breed.energy_level} energy</span>}
          {breed.coat_type     && <span class="text-xs px-2 py-0.5 rounded-full" style="background:#f5e8d0;color:#7d4a10">{breed.coat_type} coat</span>}
        </div>
      </div>
    </div>
  )}

  <!-- Main content -->
  <Content />

  <!-- Breed cluster links (end of article) -->
  {clusterLinks.length > 0 && (
    <div class="mt-10 pt-8" style="border-top:2px solid #f5e8d0">
      <h3 class="font-display font-bold text-xl mb-4" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
        More {breedN} guides
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {clusterLinks.slice(0, 9).map((c: any) => (
          <a
            href={c.href}
            class="flex items-center gap-2 p-3 rounded-xl font-sans text-sm font-semibold transition-all"
            style="border:1px solid #e8ccaa;background:white;text-decoration:none;color:#1e293b"
            onmouseover="this.style.borderColor='#a0621c';this.style.background='#fdf8f0';this.style.color='#a0621c'"
            onmouseout="this.style.borderColor='#e8ccaa';this.style.background='white';this.style.color='#1e293b'"
          >
            <span>{c.emoji}</span>
            <span class="leading-tight">{c.label} →</span>
          </a>
        ))}
      </div>
    </div>
  )}

</BlogLayout>
