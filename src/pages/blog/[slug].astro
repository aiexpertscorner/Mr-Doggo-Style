---
/**
 * blog/[slug].astro — Blog post renderer
 * Handles all postTypes with sidebar product widget + cluster links
 */
import BaseLayout  from '../../layouts/BaseLayout.astro';
import Breadcrumb  from '../../components/ui/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import productIndex from '../../data/product-index.json';
import breedLinkMap from '../../data/breed-link-map.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const fm = post.data;

const links  = fm.breedSlug ? (breedLinkMap as any)[fm.breedSlug] || {} : {};
const breedN = fm.breedName || '';

const POST_META: Record<string, { emoji: string; label: string }> = {
  'product-roundup': { emoji: '⭐', label: 'Expert Review'  },
  'comparison':      { emoji: '⚖️', label: 'Comparison'     },
  'health':          { emoji: '🩺', label: 'Health Guide'   },
  'how-to':          { emoji: '🦮', label: 'Training Guide' },
  'general':         { emoji: '📖', label: 'Guide'          },
};
const meta = POST_META[fm.postType || 'general'] || POST_META.general;
const top  = fm.topProduct;

const RELATED_LINKS = fm.breedSlug ? [
  { emoji: '🍖', label: 'Best food',    href: links.food_post },
  { emoji: '🎾', label: 'Best toys',    href: links.toy_post },
  { emoji: '🛏️', label: 'Best beds',    href: links.bed_post },
  { emoji: '✂️', label: 'Grooming',     href: links.grooming_post },
  { emoji: '🩺', label: 'Health',       href: links.health_post },
  { emoji: '💊', label: 'Supplements',  href: links.supplement_post },
  { emoji: '✍️', label: 'Names',        href: links.names_page },
  { emoji: '🐾', label: 'Breed hub',    href: links.hub },
].filter(r => r.href && r.href !== Astro.url.pathname) : [];
---

<BaseLayout
  title={`${fm.title} | Mr. Doggo Style`}
  description={fm.description}
  canonicalUrl={`https://mrdoggostyle.com/blog/${post.slug}`}
>

  <div class="post-hero">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: fm.category || 'Reviews', href: `/categories/${(fm.category||'reviews').toLowerCase().replace(/\s+/g,'-')}` },
        { label: fm.title.slice(0,55) + (fm.title.length > 55 ? '…' : ''), current: true },
      ]} />
      <div class="post-hero__inner">
        <div class="post-hero__eyebrow">
          <span class="badge badge--primary">{meta.emoji} {meta.label}</span>
          {fm.breedSlug && (
            <a href={`/breeds/${fm.breedSlug}`} class="post-hero__breed-link">
              ← {breedN} hub
            </a>
          )}
        </div>
        <h1 class="post-hero__title">{fm.title}</h1>
        <p class="post-hero__description">{fm.description}</p>
        <div class="post-hero__meta">
          <time datetime={fm.pubDate.toISOString()}>
            {fm.pubDate.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}
          </time>
          {fm.readTime && (
            <><span class="post-hero__meta-dot" aria-hidden="true" /><span>{fm.readTime} min read</span></>
          )}
          {fm.breedSize && (
            <><span class="post-hero__meta-dot" aria-hidden="true" /><span style="text-transform:capitalize">{fm.breedSize} breed</span></>
          )}
        </div>
      </div>
    </div>
  </div>

  <main class="section">
    <div class="container">
      <div class="blog-layout">

        <article class="blog-content">
          <div class="affiliate-note">
            ℹ️ <strong>Disclosure:</strong> We earn a small commission on qualifying Amazon purchases via our links. This never influences our rankings.
          </div>
          <div class="prose">
            <Content />
          </div>

          {RELATED_LINKS.length > 0 && (
            <div class="related-posts">
              <p class="related-posts__title">More {breedN} guides</p>
              <div class="related-posts__grid">
                {RELATED_LINKS.slice(0,6).map(r => (
                  <a href={r.href} class="related-post-card">
                    <span class="related-post-card__emoji">{r.emoji}</span>
                    <span class="related-post-card__title">{r.label} for {breedN}s →</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </article>

        <aside class="blog-sidebar">

          {top && (
            <div class="sidebar-product">
              <div class="sidebar-product__header">Top Pick</div>
              <div class="sidebar-product__image-wrap">
                {top.image?.includes('media-amazon')
                  ? <img src={top.image} alt={top.name} class="sidebar-product__image" loading="lazy" width="140" height="140" />
                  : <span style="font-size:3rem">⭐</span>
                }
              </div>
              <div class="sidebar-product__body">
                <p class="sidebar-product__name">{top.name}</p>
                {top.rating && (
                  <div class="sidebar-product__rating">
                    <span class="sidebar-product__stars">{'★'.repeat(Math.round(top.rating||4.5))}</span>
                    <span class="sidebar-product__rating-val">{parseFloat(top.rating||4.5).toFixed(1)}/5</span>
                  </div>
                )}
                {top.price > 0 && <p class="sidebar-product__price">${parseFloat(top.price||0).toFixed(2)}</p>}
                {top.asin && top.asin !== 'SUBSCRIPTION' && (
                  <a
                    href={`https://www.amazon.com/dp/${top.asin}/?tag=aiexpertscorn-20`}
                    rel="nofollow sponsored"
                    target="_blank"
                    class="sidebar-product__cta"
                  >
                    Check price on Amazon →
                  </a>
                )}
              </div>
            </div>
          )}

          {fm.breedSlug && links.hub && (
            <div style="border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--space-4)">
              <a
                href={links.hub}
                style="display:block;padding:var(--space-3) var(--space-4);background:var(--color-primary);color:white;border-radius:var(--radius-lg);font-size:var(--text-sm);font-weight:700;text-decoration:none;text-align:center"
              >
                🐾 {breedN} Complete Guide →
              </a>
            </div>
          )}

          {RELATED_LINKS.length > 0 && (
            <div style="border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--space-4)">
              <p style="font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--color-muted);margin-bottom:var(--space-3)">{breedN} guides</p>
              <div style="display:flex;flex-direction:column;gap:var(--space-1)">
                {RELATED_LINKS.slice(0,7).map(r => (
                  <a
                    href={r.href}
                    style="display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--color-body);text-decoration:none;padding:6px var(--space-2);border-radius:var(--radius-md)"
                  >
                    <span>{r.emoji}</span>
                    <span>{r.label} →</span>
                  </a>
                ))}
              </div>
            </div>
          )}

          {fm.updatedDate && (
            <p style="font-size:var(--text-xs);color:var(--color-muted);text-align:center">
              Last updated: {fm.updatedDate.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
            </p>
          )}

        </aside>
      </div>
    </div>
  </main>

</BaseLayout>
