---
/**
 * src/pages/blog/[slug].astro — PupWiki blog article route
 * Sprint 2 refinement: global article styles + reusable commerce suite + richer cluster links.
 */

import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

import masterBreeds from '../../data/master-breeds.json';
import masterCrossbreeds from '../../data/master-crossbreeds.json';
import breedLinkMap from '../../data/breed-link-map.json';
import contentStatus from '../../data/content-status.json';

import BreedImage from '../../components/breed/BreedImage.astro';
import PageBannerSlot from '../../components/affiliate/PageBannerSlot.astro';
import AwinProductSlot from '../../components/affiliate/AwinProductSlot.astro';
import ArticleCommerceSuite from '../../components/blog/ArticleCommerceSuite.astro';
import { getContentCluster } from '../../lib/content/contentClusterConfig';

const SITE = 'https://pupwiki.com';
const ALL_BREEDS = [...(masterBreeds as any[]), ...(masterCrossbreeds as any[])];

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const fm = post.data;

const category = fm.category || 'Guide';
const tags = Array.isArray(fm.tags) ? fm.tags : [];
const pageTitle = fm.seoTitle || fm.title;
const displayTitle = fm.displayTitle || fm.title;

function normalize(value: unknown) {
  return String(value || '').toLowerCase();
}

function slugify(value: string) {
  return String(value || '').toLowerCase().trim().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

function titleCase(value?: string | null) {
  if (!value) return '';
  return String(value).replace(/[-_]+/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
}

function getWordCount(value?: string) {
  return String(value || '').split(/\s+/).filter(Boolean).length;
}

function unique<T>(items: T[]) {
  return Array.from(new Set(items.filter(Boolean)));
}

const bodyWordCount = getWordCount(post.body);
const readTime = fm.readTime || Math.max(4, Math.ceil(bodyWordCount / 220));
const breedSlug = fm.breedSlug || fm.breed_slug || null;
const breed = breedSlug ? ALL_BREEDS.find((item) => item.slug === breedSlug) : null;
const breedName = fm.breedName || fm.breed_name || breed?.name || '';
const links = breedSlug ? (breedLinkMap as any)[breedSlug] || {} : {};
const status = breedSlug ? (contentStatus as any)[breedSlug] || {} : {};
const clusterSlug = fm.cluster || slugify(category);
const cluster = getContentCluster(clusterSlug) || getContentCluster(normalize(category).replace(/\s+/g, '-'));

const isGeneratedSupport = Boolean(fm.generated) || Boolean(fm.breedSlug) || Boolean(fm.breedName) || ['product-roundup', 'breed-support', 'generated-support'].includes(normalize(fm.postType));
const isHealthSensitive = ['health', 'supplements', 'food', 'dog food'].includes(normalize(category)) || tags.some((tag: string) => ['health', 'supplements', 'nutrition', 'medical-warning', 'vet-critical', 'emergency-vet'].includes(normalize(tag)));
const hasUnsafeCommerceTag = tags.some((tag: string) => ['medical-warning', 'vet-critical', 'emergency-vet', 'diagnosis', 'treatment'].includes(normalize(tag)));
const showCommercialMidContent = !isHealthSensitive && !hasUnsafeCommerceTag;
const showProductRoundupCommerce = normalize(fm.postType) === 'product-roundup' && !hasUnsafeCommerceTag;

const canonicalUrl = fm.canonicalUrl || `${SITE}/blog/${post.slug}`;
const heroImage = fm.heroImage || fm.image || breed?.image_url || (Array.isArray(breed?.image_urls) ? breed.image_urls[0] : null) || '';
const breedAltLabel = breedName?.endsWith(' Dog') ? breedName : `${breedName} dog`;
const heroImageAlt = fm.heroImageAlt || fm.imageAlt || (breedName ? `${breedAltLabel} guide` : displayTitle);

const awinTopicTags = unique([
  normalize(category),
  normalize(fm.postType),
  fm.cluster,
  breedSlug,
  breedName,
  breed?.size_category,
  breed?.energy_level,
  breed?.training_level,
  breed?.coat_type,
  ...(cluster?.awinTopicTags || []),
  ...(cluster?.amazonTopicTags || []),
  ...tags,
]).map((item) => String(item).toLowerCase());

const clusterLinks = breedSlug
  ? [
      { key: 'hub', href: links.hub || `/breeds/${breedSlug}`, emoji: '🐾', label: `${breedName || 'Breed'} hub` },
      { key: 'food_post', href: links.food_post, emoji: '🍖', label: 'Food & nutrition' },
      { key: 'toy_post', href: links.toy_post, emoji: '🎾', label: 'Toys & enrichment' },
      { key: 'bed_post', href: links.bed_post, emoji: '🛏️', label: 'Beds & sleep' },
      { key: 'grooming_post', href: links.grooming_post, emoji: '✂️', label: 'Grooming guide' },
      { key: 'health_post', href: links.health_post, emoji: '🩺', label: 'Health context' },
      { key: 'supplement_post', href: links.supplement_post, emoji: '💊', label: 'Supplement considerations' },
      { key: 'training_post', href: links.training_post, emoji: '🦮', label: 'Training guide' },
      { key: 'names_page', href: links.names_page, emoji: '✍️', label: 'Name ideas' },
      { key: 'cost_calculator', href: `/cost-calculator/${breedSlug}`, emoji: '💰', label: 'Cost calculator' },
      { key: 'puppy', href: `/categories/puppy`, emoji: '🐶', label: 'Puppy essentials' },
      { key: 'senior', href: `/categories/senior-dogs`, emoji: '🐕‍🦺', label: 'Senior dog care' },
      { key: 'insurance', href: `/categories/insurance`, emoji: '🛡️', label: 'Insurance planning' },
    ].filter((item) => item.href && item.href !== Astro.url.pathname)
  : [];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: displayTitle,
  description: fm.description,
  image: heroImage || undefined,
  datePublished: new Date(fm.pubDate).toISOString(),
  dateModified: fm.updatedDate ? new Date(fm.updatedDate).toISOString() : new Date(fm.pubDate).toISOString(),
  author: { '@type': 'Organization', name: 'PupWiki', url: SITE },
  publisher: { '@type': 'Organization', name: 'PupWiki', url: SITE },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: `${SITE}/blog` },
    { '@type': 'ListItem', position: 3, name: category, item: `${SITE}/categories/${slugify(category)}` },
    { '@type': 'ListItem', position: 4, name: displayTitle, item: canonicalUrl },
  ],
};

const schema = [articleSchema, breadcrumbSchema];

const relatedToolLinks = [
  { href: '/breeds', icon: '🐕', title: 'Explore dog breeds', text: 'Compare breed traits, size, grooming, training, and owner fit.' },
  { href: '/cost-calculator', icon: '💰', title: 'Estimate dog ownership costs', text: 'Plan puppy, annual, and lifetime costs by breed.' },
  { href: '/dog-names', icon: '✍️', title: 'Find dog name ideas', text: 'Generate, favorite, export, and share name ideas locally.' },
  ...(cluster ? [{ href: `/categories/${cluster.slug}`, icon: cluster.icon, title: `${cluster.shortTitle} hub`, text: cluster.description }] : []),
];
---

<BlogLayout
  title={pageTitle}
  displayTitle={displayTitle}
  description={fm.description}
  canonicalUrl={canonicalUrl}
  pubDate={fm.pubDate}
  updatedDate={fm.updatedDate}
  category={category}
  readTime={readTime}
  heroImage={heroImage}
  heroImageAlt={heroImageAlt}
  schema={schema}
  tags={tags}
  postType={fm.postType || 'general'}
  breedSlug={breedSlug}
  breedName={breedName}
  breedSize={breed?.size_category}
  breedEnergy={breed?.energy_level}
  breedCoat={breed?.coat_type}
  noIndex={fm.noIndex || false}
>
  {isGeneratedSupport && (
    <aside class="article-support-note not-prose" aria-label="Support content note">
      <div>
        <strong>Breed-support guide</strong>
        <p>This article supports PupWiki’s breed research pages. For the complete ownership profile, costs, traits, health context, and related tools, start from the breed hub.</p>
      </div>
      {breedSlug && <a href={links.hub || `/breeds/${breedSlug}`}>View {breedName || 'breed'} hub →</a>}
    </aside>
  )}

  {breed && (
    <aside class="article-breed-card not-prose" aria-label={`${breedName} breed context`}>
      <BreedImage breed={breed} width={220} height={220} variant="card" class="article-breed-card__image" />
      <div class="article-breed-card__body">
        <p class="article-breed-card__eyebrow">Breed context</p>
        <h2>{breedName}</h2>
        <p>Use the main breed hub for traits, owner fit, costs, health context, grooming, training, and related PupWiki tools.</p>
        <div class="article-breed-card__pills">
          {breed.size_category && <span>{titleCase(breed.size_category)} size</span>}
          {breed.energy_level && <span>{titleCase(breed.energy_level)} energy</span>}
          {breed.coat_type && <span>{titleCase(breed.coat_type)} coat</span>}
        </div>
        <a href={links.hub || `/breeds/${breedSlug}`} class="article-breed-card__link">Open full {breedName} guide →</a>
      </div>
    </aside>
  )}

  <Content />

  {showProductRoundupCommerce && (
    <ArticleCommerceSuite
      topicTags={awinTopicTags}
      pageSlug={`/blog/${post.slug}`}
      category={cluster?.slug || normalize(category)}
      breedSize={breed?.size_category || fm.breedSize}
      breedEnergy={breed?.energy_level || fm.breedEnergy}
      breedTraining={breed?.training_level}
      breedCoat={breed?.coat_type || fm.breedCoat}
      heading={cluster ? `${cluster.shortTitle} products and partner resources` : 'Current partner and Amazon.com options'}
      description="Matched from active AWIN data, validated Amazon links, and safe Amazon.com search templates. Always confirm size, availability, formula, seller and fit before purchase."
    />
  )}

  {showCommercialMidContent && (
    <div class="article-partner-strip not-prose">
      <AwinProductSlot
        topicTags={awinTopicTags}
        pageType="blog"
        category={cluster?.slug || normalize(category)}
        breedSize={breed?.size_category}
        breedEnergy={breed?.energy_level}
        breedTraining={breed?.training_level}
        headline="Relevant partner resources"
      />
    </div>
  )}

  {showCommercialMidContent && (
    <PageBannerSlot pageType="blog" placement="mid-content" topic={cluster?.slug || normalize(category)} topicTags={awinTopicTags} compact={false} />
  )}

  {clusterLinks.length > 0 && (
    <section class="article-related-breed not-prose" aria-labelledby="related-breed-guides-title">
      <div class="article-related-breed__header">
        <p>More breed guidance</p>
        <h2 id="related-breed-guides-title">More {breedName} guides</h2>
      </div>
      <div class="article-related-grid">
        {clusterLinks.slice(0, 12).map((item) => (
          <a href={item.href}>
            <span aria-hidden="true">{item.emoji}</span>
            <strong>{item.label}</strong>
            <em aria-hidden="true">→</em>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="article-next-tools not-prose" aria-labelledby="article-next-tools-title">
    <div class="article-next-tools__header">
      <p>Explore next</p>
      <h2 id="article-next-tools-title">Continue with PupWiki tools</h2>
    </div>
    <div class="article-next-tools__grid">
      {relatedToolLinks.slice(0, 4).map((item) => (
        <a href={item.href}>
          <span aria-hidden="true">{item.icon}</span>
          <strong>{item.title}</strong>
          <p>{item.text}</p>
        </a>
      ))}
    </div>
  </section>

  <Fragment slot="sidebar">
    {clusterLinks.length > 0 && (
      <section class="article-custom-sidebar-card">
        <h2>{breedName} links</h2>
        <nav>
          {clusterLinks.slice(0, 9).map((item) => (
            <a href={item.href}>
              <span>{item.emoji}</span>
              <strong>{item.label}</strong>
            </a>
          ))}
        </nav>
      </section>
    )}
  </Fragment>
</BlogLayout>
