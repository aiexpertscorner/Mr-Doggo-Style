---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const CAT_CONFIG = {
  'Dog Food':    { color: '#92400e', bg: '#fef3c7', icon: '🍖' },
  'Food':        { color: '#92400e', bg: '#fef3c7', icon: '🍖' },
  'Toys':        { color: '#065f46', bg: '#d1fae5', icon: '🎾' },
  'Health':      { color: '#1e40af', bg: '#dbeafe', icon: '🩺' },
  'Beds':        { color: '#4c1d95', bg: '#ede9fe', icon: '🛏️' },
  'Grooming':    { color: '#831843', bg: '#fce7f3', icon: '✂️' },
  'Supplements': { color: '#14532d', bg: '#dcfce7', icon: '💊' },
  'Training':    { color: '#1e3a5f', bg: '#e0f2fe', icon: '🦮' },
  'Gear':        { color: '#1e3a5f', bg: '#e0f2fe', icon: '🦮' },
  'Smart Tech':  { color: '#312e81', bg: '#e0e7ff', icon: '📡' },
};

const BREEDS = [
  'labrador-retriever','golden-retriever','german-shepherd-dog',
  'french-bulldog','bulldog','poodle','beagle','rottweiler',
  'dachshund','pembroke-welsh-corgi','australian-shepherd',
  'yorkshire-terrier','boxer','doberman-pinscher','great-dane',
  'siberian-husky','bernese-mountain-dog','shih-tzu','boston-terrier',
  'shetland-sheepdog','pomeranian','chihuahua','maltese','vizsla',
  'weimaraner','bichon-frise','border-collie','havanese',
  'cavalier-king-charles-spaniel','dalmatian','samoyed','pug',
  'chow-chow','newfoundland','akita','mastiff','saint-bernard',
  'irish-setter','collie','whippet','greyhound','bloodhound',
  'basset-hound','alaskan-malamute','rhodesian-ridgeback',
  'great-pyrenees','portuguese-water-dog','shiba-inu',
  'australian-cattle-dog','bull-terrier','staffordshire-bull-terrier',
  'airedale-terrier','scottish-terrier','west-highland-white-terrier',
  'cairn-terrier','border-terrier','soft-coated-wheaten-terrier',
];

function getBreedSlug(slug) {
  const lower = slug.toLowerCase();
  for (const breed of BREEDS) {
    if (lower.includes(breed)) return breed;
  }
  return null;
}

function getPostImage(post) {
  if (post.data.image) return post.data.image;
  const breedSlug = getBreedSlug(post.slug);
  if (breedSlug) return `/images/breeds/${breedSlug}.jpg`;
  const tags = post.data.tags || [];
  for (const tag of tags) {
    const b = getBreedSlug(tag);
    if (b) return `/images/breeds/${b}.jpg`;
  }
  return null;
}

const categories = ['All', ...new Set(sorted.map(p => p.data.category))];
---

<BaseLayout
  title="Expert Dog Product Reviews & Guides 2026 — PupWiki"
  description="Breed-specific product reviews, honest comparisons, and expert health guides. Updated regularly, zero paid placements."
  canonicalUrl="https://pupwiki.com/blog"
>

  <div style="background:linear-gradient(to bottom,#f5e8d0,#fdf8f0);border-bottom:1px solid #e8ccaa">
    <div class="max-w-7xl mx-auto px-4 py-12">
      <h1 class="font-display text-4xl sm:text-5xl font-bold mb-3" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
        Expert Dog Product Reviews
      </h1>
      <p class="font-sans text-lg mb-6 max-w-2xl" style="color:#64748b">
        {sorted.length} guides across food, toys, health, grooming and training — all research-backed, zero paid placements.
      </p>
      <div class="flex flex-wrap gap-2">
        {categories.slice(0, 9).map((cat, i) => (
          <a href={i === 0 ? '/blog' : `/categories/${cat.toLowerCase().replace(/ /g, '-')}`}
            class="font-sans text-sm font-semibold px-4 py-1.5 rounded-full transition-all"
            style={i === 0
              ? 'background:#a0621c;color:white'
              : 'background:white;color:#64748b;border:1px solid #e8ccaa'}>
            {cat}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12">

    {sorted[0] && (
      <div class="mb-12">
        <p class="font-sans text-xs font-bold uppercase tracking-widest mb-4" style="color:#a0621c">Latest guide</p>
        <a href={`/blog/${sorted[0].slug}`}
          class="grid md:grid-cols-2 rounded-3xl overflow-hidden transition-all hover:shadow-xl"
          style="border:1px solid #e8ccaa;background:white;text-decoration:none">
          <div class="relative overflow-hidden flex-shrink-0" style="min-height:280px;background:#fdf8f0">
            {getPostImage(sorted[0]) ? (
              <img src={getPostImage(sorted[0])} alt={sorted[0].data.title}
                width="640" height="400" loading="eager"
                class="w-full h-full object-cover absolute inset-0"
                onerror="this.style.display='none'" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-7xl">
                {(CAT_CONFIG[sorted[0].data.category] || {icon:'🐾'}).icon}
              </div>
            )}
          </div>
          <div class="p-8 flex flex-col justify-center">
            <span class="inline-block font-sans text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-3 self-start"
              style={`background:${(CAT_CONFIG[sorted[0].data.category]||{bg:'#fef3c7'}).bg};color:${(CAT_CONFIG[sorted[0].data.category]||{color:'#92400e'}).color}`}>
              {sorted[0].data.category}
            </span>
            <h2 class="font-display text-2xl font-bold mb-3 leading-snug"
              style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
              {sorted[0].data.title}
            </h2>
            <p class="font-sans text-sm leading-relaxed mb-4" style="color:#64748b">
              {sorted[0].data.description}
            </p>
            <span class="font-sans text-sm font-bold" style="color:#a0621c">Read guide →</span>
          </div>
        </a>
      </div>
    )}

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {sorted.slice(1).map(post => {
        const imgSrc = getPostImage(post);
        const cat = CAT_CONFIG[post.data.category] || { color:'#64748b', bg:'#f1f5f9', icon:'🐾' };
        const dateStr = new Intl.DateTimeFormat('en-US', { month:'short', day:'numeric', year:'numeric' })
          .format(new Date(post.data.pubDate));
        return (
          <a href={`/blog/${post.slug}`}
            class="group rounded-2xl overflow-hidden transition-all hover:-translate-y-1 hover:shadow-lg flex flex-col"
            style="border:1px solid #e8ccaa;background:white;text-decoration:none">
            <div class="relative overflow-hidden flex-shrink-0" style="height:200px;background:#fdf8f0">
              {imgSrc && (
                <img src={imgSrc} alt={post.data.title}
                  width="400" height="200" loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
              )}
              <div class="absolute inset-0 items-center justify-center text-5xl"
                style={imgSrc ? 'display:none' : 'display:flex'}>
                {cat.icon}
              </div>
              <div class="absolute top-3 left-3">
                <span class="font-sans text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-full"
                  style={`background:${cat.bg};color:${cat.color}`}>
                  {post.data.category}
                </span>
              </div>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <h2 class="font-display font-semibold text-base leading-snug mb-2 flex-1 group-hover:text-amber-700 transition-colors"
                style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
                {post.data.title}
              </h2>
              <p class="font-sans text-sm leading-relaxed mb-4" style="color:#64748b;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                {post.data.description}
              </p>
              <div class="flex items-center justify-between mt-auto pt-3" style="border-top:1px solid #f5e8d0">
                <time class="font-sans text-xs" style="color:#94a3b8">{dateStr}</time>
                <span class="font-sans text-xs font-bold" style="color:#a0621c">Read →</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>

  </div>
</BaseLayout>