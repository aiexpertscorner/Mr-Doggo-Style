---
/**
 * pages/blog/index.astro — Blog overview
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard   from '../../components/content/BlogCard.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sorted   = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const featured    = sorted[0];
const restPosts   = sorted.slice(1);

const categories  = ['All', 'Food', 'Toys', 'Health', 'Training', 'Grooming', 'Beds'];
---

<BaseLayout
  title="Expert Dog Product Reviews & Guides — Mr. Doggo Style Blog"
  description="Independent dog product reviews, breed-specific buying guides, comparison posts and expert health insights. Updated weekly."
  canonicalUrl="https://mrdoggostyle.com/blog"
>

  <!-- Page hero -->
  <div class="page-hero">
    <div class="container page-hero__inner">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Blog', current: true }]} />
      <h1 class="page-hero__title">Expert <em>Insights</em></h1>
      <p class="page-hero__desc">
        Data-driven reviews, breed-specific guides and safety-verified product comparisons.
        Updated weekly — zero paid placements.
      </p>
    </div>
  </div>

  <main class="section">
    <div class="container">

      <!-- Category filter tabs -->
      <div class="flex flex-wrap gap-2" style="margin-bottom: var(--space-10)" role="tablist" aria-label="Filter by category">
        {categories.map((cat, i) => (
          <button
            class={`btn btn--sm ${i === 0 ? 'btn--primary' : 'btn--outline'}`}
            data-category={cat.toLowerCase()}
            role="tab"
            aria-selected={i === 0}
            type="button"
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Featured post -->
      {featured && (
        <div style="margin-bottom: var(--space-12)">
          <span class="section-eyebrow">Featured</span>
          <BlogCard
            title={featured.data.title}
            excerpt={featured.data.description ?? ''}
            category={featured.data.category ?? 'Review'}
            href={`/blog/${featured.slug}`}
            pubDate={featured.data.pubDate}
            readTime={featured.data.readTime}
            image={featured.data.heroImage}
            featured={true}
          />
        </div>
      )}

      <!-- Post grid -->
      <div class="section-header">
        <h2 class="section-title">All Posts</h2>
        <span style="font-size: var(--text-sm); color: var(--color-muted)">{allPosts.length} articles</span>
      </div>

      <div class="grid grid-3">
        {(restPosts.length > 0 ? restPosts : sorted).map(post => (
          <BlogCard
            title={post.data.title}
            excerpt={post.data.description ?? ''}
            category={post.data.category ?? 'Review'}
            href={`/blog/${post.slug}`}
            pubDate={post.data.pubDate}
            readTime={post.data.readTime}
            image={post.data.heroImage}
          />
        ))}
      </div>

    </div>
  </main>

</BaseLayout>
