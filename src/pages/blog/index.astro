---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

const sorted = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const CATEGORY_CONFIG: Record<string, { label: string; icon: string; className: string }> = {
  'Dog Food': { label: 'Food & Nutrition', icon: '🍖', className: 'is-food' },
  Food: { label: 'Food & Nutrition', icon: '🍖', className: 'is-food' },
  Toys: { label: 'Toys & Enrichment', icon: '🎾', className: 'is-toys' },
  Health: { label: 'Health & Vet Care', icon: '🩺', className: 'is-health' },
  Beds: { label: 'Sleep & Comfort', icon: '🛏️', className: 'is-beds' },
  Grooming: { label: 'Grooming', icon: '✂️', className: 'is-grooming' },
  Supplements: { label: 'Supplements', icon: '💊', className: 'is-supplements' },
  Training: { label: 'Training', icon: '🦮', className: 'is-training' },
  Gear: { label: 'Training & Gear', icon: '🦮', className: 'is-training' },
  'Smart Tech': { label: 'Smart Tech', icon: '📡', className: 'is-tech' },
  Lifestyle: { label: 'Lifestyle', icon: '🎁', className: 'is-lifestyle' },
};

const BREEDS = [
  'labrador-retriever',
  'golden-retriever',
  'german-shepherd-dog',
  'french-bulldog',
  'bulldog',
  'poodle',
  'beagle',
  'rottweiler',
  'dachshund',
  'pembroke-welsh-corgi',
  'australian-shepherd',
  'yorkshire-terrier',
  'boxer',
  'doberman-pinscher',
  'great-dane',
  'siberian-husky',
  'bernese-mountain-dog',
  'shih-tzu',
  'boston-terrier',
  'shetland-sheepdog',
  'pomeranian',
  'chihuahua',
  'maltese',
  'vizsla',
  'weimaraner',
  'bichon-frise',
  'border-collie',
  'havanese',
  'cavalier-king-charles-spaniel',
  'dalmatian',
  'samoyed',
  'pug',
  'chow-chow',
  'newfoundland',
  'akita',
  'mastiff',
  'saint-bernard',
  'irish-setter',
  'collie',
  'whippet',
  'greyhound',
  'bloodhound',
  'basset-hound',
  'alaskan-malamute',
  'rhodesian-ridgeback',
  'great-pyrenees',
  'portuguese-water-dog',
  'shiba-inu',
  'australian-cattle-dog',
  'bull-terrier',
  'staffordshire-bull-terrier',
  'airedale-terrier',
  'scottish-terrier',
  'west-highland-white-terrier',
  'cairn-terrier',
  'border-terrier',
  'soft-coated-wheaten-terrier',
];

const GENERATED_TITLE_PATTERNS = [
  'best dog food',
  'best food',
  'best toys',
  'best toy',
  'best beds',
  'best bed',
  'best supplements',
  'best supplement',
  'grooming guide',
  'training guide',
  'health problems',
  'health concerns',
  'food for',
  'toys for',
  'beds for',
  'supplements for',
];

const GENERATED_CATEGORIES = [
  'dog food',
  'food',
  'toys',
  'beds',
  'supplements',
  'grooming',
  'training',
];

const FEATURED_SLUG_HINTS = [
  'dog-food-maker-chefpaw',
  'training-tools',
  'gifts-for-dog-lovers',
  'first-dog',
  'dog-cost',
  'insurance',
  'dna',
];

function normalize(value: unknown) {
  return String(value || '').toLowerCase();
}

function getBreedSlug(value: string) {
  const lower = value.toLowerCase();

  for (const breed of BREEDS) {
    if (lower.includes(breed)) return breed;
  }

  return null;
}

function isLikelyGeneratedBreedPost(post: any) {
  const title = normalize(post.data.title);
  const description = normalize(post.data.description);
  const postType = normalize(post.data.postType);
  const category = normalize(post.data.category);
  const slug = normalize(post.slug);
  const tags = Array.isArray(post.data.tags) ? post.data.tags.map(normalize).join(' ') : '';

  const hasBreedContext = Boolean(
    post.data.breedSlug ||
    post.data.breedName ||
    getBreedSlug(slug) ||
    getBreedSlug(title) ||
    getBreedSlug(tags)
  );

  const isProductRoundup =
    postType === 'product-roundup' ||
    GENERATED_CATEGORIES.includes(category);

  const hasGeneratedPattern = GENERATED_TITLE_PATTERNS.some((pattern) =>
    title.includes(pattern) || description.includes(pattern)
  );

  return hasBreedContext && (isProductRoundup || hasGeneratedPattern);
}

function isLikelyEditorial(post: any) {
  const slug = normalize(post.slug);
  const title = normalize(post.data.title);
  const postType = normalize(post.data.postType);

  if (postType === 'general' || postType === 'how-to' || postType === 'comparison') return true;

  return FEATURED_SLUG_HINTS.some((hint) => slug.includes(hint) || title.includes(hint));
}

function getCategory(post: any) {
  const raw = post.data.category || 'Guide';
  return CATEGORY_CONFIG[raw] || {
    label: raw,
    icon: '🐾',
    className: 'is-default',
  };
}

function getPostImage(post: any) {
  if (post.data.heroImage) return post.data.heroImage;
  if (post.data.image) return post.data.image;

  const breedSlug = getBreedSlug(post.slug);
  if (breedSlug) return `/images/breeds/${breedSlug}.jpg`;

  const tags = post.data.tags || [];
  for (const tag of tags) {
    const match = getBreedSlug(String(tag));
    if (match) return `/images/breeds/${match}.jpg`;
  }

  return null;
}

function formatDate(value: Date | string) {
  return new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(new Date(value));
}

const editorialPosts = sorted.filter((post) => !isLikelyGeneratedBreedPost(post));
const preferredEditorial = editorialPosts.filter(isLikelyEditorial);
const fallbackEditorial = editorialPosts.filter((post) => !preferredEditorial.includes(post));

const curatedPosts = [...preferredEditorial, ...fallbackEditorial].slice(0, 24);
const featuredPost = curatedPosts[0] ?? editorialPosts[0] ?? sorted[0] ?? null;
const visiblePosts = curatedPosts.filter((post) => post.slug !== featuredPost?.slug).slice(0, 12);

const hiddenGeneratedCount = sorted.filter(isLikelyGeneratedBreedPost).length;

const topicCards = [
  {
    title: 'Breed Research',
    text: 'Compare traits, care needs, temperament, owner fit, and long-term expectations.',
    href: '/breeds',
    icon: '🐕',
  },
  {
    title: 'Costs & Planning',
    text: 'Understand puppy costs, food, grooming, insurance, vet care, and lifetime ownership.',
    href: '/cost-calculator',
    icon: '💰',
  },
  {
    title: 'Food & Nutrition',
    text: 'Compare food options carefully without relying on label hype or unsupported claims.',
    href: '/categories/dog-food',
    icon: '🍖',
  },
  {
    title: 'Training & Behavior',
    text: 'Practical guidance for matching dog energy, training needs, and owner experience.',
    href: '/categories/training',
    icon: '🦮',
  },
  {
    title: 'Health & Vet Care',
    text: 'Breed health context, planning notes, and when to involve a veterinarian.',
    href: '/categories/health',
    icon: '🩺',
  },
  {
    title: 'Dog Owner Tools',
    text: 'Use PupWiki tools for names, costs, comparisons, and ownership decisions.',
    href: '/dog-names',
    icon: '🔎',
  },
];

const toolCards = [
  {
    title: 'Dog Cost Calculator',
    text: 'Estimate annual and lifetime costs by breed.',
    href: '/cost-calculator',
    icon: '💰',
  },
  {
    title: 'Breed Explorer',
    text: 'Research pure breeds and mixed breeds.',
    href: '/breeds',
    icon: '🐾',
  },
  {
    title: 'Dog Name Generator',
    text: 'Find breed-inspired names and save favorites locally.',
    href: '/dog-names',
    icon: '✍️',
  },
];

const trustLinks = [
  { href: '/how-we-test', label: 'How we research guides' },
  { href: '/disclosure', label: 'Affiliate disclosure' },
  { href: '/privacy', label: 'Privacy policy' },
  { href: '/contact', label: 'Contact PupWiki' },
];
---

<BaseLayout
  title="PupWiki Dog Guides — Breed Research, Care, Costs & Ownership"
  description="Practical dog ownership guides from PupWiki. Research breeds, compare costs, plan care, understand training needs, and make smarter dog-parent decisions."
  canonicalUrl="https://pupwiki.com/blog"
  pageType="collection"
>
  <main class="blog-page">
    <section class="blog-hero" aria-labelledby="blog-title">
      <div class="blog-container">
        <nav class="blog-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span>Guides</span>
        </nav>

        <p class="blog-eyebrow">PupWiki guides</p>

        <h1 id="blog-title">
          Practical dog guides for better ownership decisions.
        </h1>

        <p class="blog-hero__subtitle">
          Research breeds, compare care needs, plan ownership costs, understand training fit,
          and make smarter decisions before and after bringing a dog home.
        </p>

        <div class="blog-hero__meta" aria-label="Blog quality notes">
          <span>{curatedPosts.length} curated guides shown</span>
          <span>{hiddenGeneratedCount} breed-support guides hidden from this feed</span>
          <span>Breed pages remain the main research hubs</span>
        </div>
      </div>
    </section>

    <section class="blog-main">
      <div class="blog-container">
        <section class="blog-section blog-section--topics" aria-labelledby="topics-title">
          <div class="blog-section__header">
            <p class="blog-eyebrow">Start here</p>
            <h2 id="topics-title">Explore by decision type</h2>
            <p>
              The blog now highlights broader editorial guidance. Breed-specific generated support
              content is kept out of this feed and used where it belongs: breed hubs, tools, and related-guide sections.
            </p>
          </div>

          <div class="blog-topic-grid">
            {topicCards.map((card) => (
              <a href={card.href} class="blog-topic-card">
                <span aria-hidden="true">{card.icon}</span>
                <strong>{card.title}</strong>
                <p>{card.text}</p>
              </a>
            ))}
          </div>
        </section>

        {featuredPost && (
          <section class="blog-section blog-section--featured" aria-labelledby="featured-title">
            <div class="blog-section__header">
              <p class="blog-eyebrow">Featured guide</p>
              <h2 id="featured-title">Latest practical guide</h2>
            </div>

            <a href={`/blog/${featuredPost.slug}`} class="blog-featured-card">
              <div class="blog-featured-card__media">
                {getPostImage(featuredPost) ? (
                  <img
                    src={getPostImage(featuredPost)}
                    alt={featuredPost.data.heroImageAlt || featuredPost.data.title}
                    width="760"
                    height="520"
                    loading="eager"
                    decoding="async"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='grid'"
                  />
                ) : null}

                <div class="blog-image-fallback" style={getPostImage(featuredPost) ? 'display:none' : 'display:grid'}>
                  <span>{getCategory(featuredPost).icon}</span>
                </div>
              </div>

              <div class="blog-featured-card__body">
                <span class:list={['blog-category-pill', getCategory(featuredPost).className]}>
                  {getCategory(featuredPost).icon} {getCategory(featuredPost).label}
                </span>

                <h3>{featuredPost.data.title}</h3>
                <p>{featuredPost.data.description}</p>

                <div class="blog-card-meta">
                  <time datetime={new Date(featuredPost.data.pubDate).toISOString()}>
                    {formatDate(featuredPost.data.updatedDate ?? featuredPost.data.pubDate)}
                  </time>
                  <span>Read guide →</span>
                </div>
              </div>
            </a>
          </section>
        )}

        {visiblePosts.length > 0 && (
          <section class="blog-section" aria-labelledby="latest-title">
            <div class="blog-section__header">
              <p class="blog-eyebrow">Editorial feed</p>
              <h2 id="latest-title">Recent curated guides</h2>
              <p>
                A smaller, cleaner feed of broader dog-owner guidance. Repetitive breed-product pages are intentionally excluded here.
              </p>
            </div>

            <div class="blog-card-grid">
              {visiblePosts.map((post) => {
                const category = getCategory(post);
                const image = getPostImage(post);

                return (
                  <a href={`/blog/${post.slug}`} class="blog-card">
                    <div class="blog-card__media">
                      {image ? (
                        <img
                          src={image}
                          alt={post.data.heroImageAlt || post.data.title}
                          width="420"
                          height="260"
                          loading="lazy"
                          decoding="async"
                          onerror="this.style.display='none';this.nextElementSibling.style.display='grid'"
                        />
                      ) : null}

                      <div class="blog-image-fallback" style={image ? 'display:none' : 'display:grid'}>
                        <span>{category.icon}</span>
                      </div>

                      <span class:list={['blog-category-pill', category.className]}>
                        {category.icon} {category.label}
                      </span>
                    </div>

                    <div class="blog-card__body">
                      <h3>{post.data.title}</h3>
                      <p>{post.data.description}</p>

                      <div class="blog-card-meta">
                        <time datetime={new Date(post.data.pubDate).toISOString()}>
                          {formatDate(post.data.updatedDate ?? post.data.pubDate)}
                        </time>
                        <span>Read →</span>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        )}

        <section class="blog-section blog-section--tools" aria-labelledby="tools-title">
          <div class="blog-section__header">
            <p class="blog-eyebrow">Useful tools</p>
            <h2 id="tools-title">Plan with PupWiki tools</h2>
          </div>

          <div class="blog-tool-grid">
            {toolCards.map((tool) => (
              <a href={tool.href} class="blog-tool-card">
                <span aria-hidden="true">{tool.icon}</span>
                <strong>{tool.title}</strong>
                <p>{tool.text}</p>
              </a>
            ))}
          </div>
        </section>

        <section class="blog-section blog-section--trust" aria-labelledby="trust-title">
          <div class="blog-section__header">
            <p class="blog-eyebrow">Trust & transparency</p>
            <h2 id="trust-title">How PupWiki handles guides and recommendations</h2>
            <p>
              PupWiki uses affiliate links on some pages, but product or service placement should be clearly disclosed.
              Health-sensitive content is general information and should not replace veterinary advice.
            </p>
          </div>

          <div class="blog-trust-links">
            {trustLinks.map((link) => (
              <a href={link.href}>{link.label} →</a>
            ))}
          </div>
        </section>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .blog-page {
    background:
      radial-gradient(circle at 88% 4%, rgba(255, 122, 0, 0.1), transparent 24rem),
      radial-gradient(circle at 8% 2%, rgba(21, 54, 95, 0.08), transparent 22rem),
      var(--color-bg);
    color: var(--color-body);
  }

  .blog-container {
    width: min(100%, var(--max-width));
    margin-inline: auto;
    padding-inline: var(--content-padding-mobile);
  }

  .blog-hero {
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(255, 250, 243, 0.98) 0%, #ffffff 78%);
  }

  .blog-hero .blog-container {
    padding-block: clamp(2.5rem, 7vw, 5.75rem);
  }

  .blog-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin-bottom: var(--space-5);
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .blog-breadcrumb a {
    color: var(--color-primary);
    font-weight: var(--weight-semi);
    text-decoration: none;
  }

  .blog-breadcrumb a:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .blog-eyebrow {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    margin: 0;
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    background: var(--color-accent-subtle);
    padding: 0.54rem 0.85rem;
    color: var(--color-accent-hover);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-none);
    text-transform: uppercase;
  }

  .blog-hero h1 {
    max-width: 12ch;
    margin: var(--space-5) 0 0;
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: clamp(2.75rem, 11vw, 5.5rem);
    font-weight: var(--weight-bold);
    letter-spacing: -0.055em;
    line-height: 0.96;
    text-wrap: balance;
  }

  .blog-hero__subtitle {
    max-width: 48rem;
    margin: var(--space-5) 0 0;
    color: var(--color-body-soft);
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2.2vw, var(--text-lg));
    line-height: var(--leading-relaxed);
    text-wrap: pretty;
  }

  .blog-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }

  .blog-hero__meta span {
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.78);
    padding: 0.5rem 0.72rem;
    color: var(--color-body-soft);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    line-height: 1;
    box-shadow: var(--shadow-xs);
  }

  .blog-main {
    padding-block: clamp(var(--space-8), 6vw, var(--space-14));
  }

  .blog-section {
    border: 1px solid var(--card-border);
    border-radius: var(--radius-3xl);
    background: rgba(255, 255, 255, 0.92);
    padding: var(--space-5);
    box-shadow: var(--shadow-card);
  }

  .blog-section + .blog-section {
    margin-top: var(--space-8);
  }

  .blog-section--topics,
  .blog-section--featured,
  .blog-section--tools {
    border-color: var(--color-border-accent);
    background:
      radial-gradient(circle at 94% 8%, rgba(255, 122, 0, 0.1), transparent 18rem),
      rgba(255, 255, 255, 0.94);
  }

  .blog-section--trust {
    background: var(--color-bg-cool);
    border-color: rgba(21, 54, 95, 0.18);
  }

  .blog-section__header {
    margin-bottom: var(--space-5);
  }

  .blog-section__header h2 {
    margin: var(--space-3) 0 0;
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }

  .blog-section__header p:not(.blog-eyebrow) {
    max-width: 48rem;
    margin: var(--space-3) 0 0;
    color: var(--color-body-soft);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .blog-topic-grid,
  .blog-card-grid,
  .blog-tool-grid,
  .blog-trust-links {
    display: grid;
    gap: var(--space-4);
  }

  .blog-topic-card,
  .blog-tool-card,
  .blog-card,
  .blog-featured-card {
    color: var(--color-heading);
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .blog-topic-card,
  .blog-tool-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: #ffffff;
    padding: var(--space-4);
    box-shadow: var(--shadow-xs);
  }

  .blog-topic-card:hover,
  .blog-tool-card:hover,
  .blog-card:hover,
  .blog-featured-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .blog-topic-card span,
  .blog-tool-card span {
    display: block;
    margin-bottom: var(--space-3);
    font-size: 1.75rem;
    line-height: 1;
  }

  .blog-topic-card strong,
  .blog-tool-card strong {
    display: block;
    color: var(--color-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-black);
    line-height: var(--leading-tight);
  }

  .blog-topic-card p,
  .blog-tool-card p {
    margin: var(--space-2) 0 0;
    color: var(--color-body-soft);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .blog-featured-card,
  .blog-card {
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-3xl);
    background: #ffffff;
    box-shadow: var(--shadow-xs);
  }

  .blog-featured-card {
    display: grid;
  }

  .blog-featured-card__media,
  .blog-card__media {
    position: relative;
    overflow: hidden;
    min-height: 16rem;
    background: var(--color-bg-muted);
  }

  .blog-card__media {
    height: 13rem;
    min-height: 13rem;
  }

  .blog-featured-card__media img,
  .blog-card__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-image-fallback {
    position: absolute;
    inset: 0;
    place-items: center;
    background:
      radial-gradient(circle at 30% 20%, var(--color-accent-light), transparent 55%),
      var(--color-bg-muted);
  }

  .blog-image-fallback span {
    font-size: clamp(3rem, 11vw, 5rem);
    line-height: 1;
  }

  .blog-featured-card__body,
  .blog-card__body {
    padding: var(--space-5);
  }

  .blog-featured-card__body h3,
  .blog-card__body h3 {
    margin: var(--space-4) 0 0;
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    text-wrap: balance;
  }

  .blog-card__body h3 {
    font-size: var(--text-lg);
  }

  .blog-featured-card__body p,
  .blog-card__body p {
    margin: var(--space-3) 0 0;
    color: var(--color-body-soft);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .blog-card__body p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .blog-category-pill {
