---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('blog');
const sorted = all.sort((a,b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const categories = [...new Set(sorted.map(p => p.data.category).filter(Boolean))];
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>ALL REVIEWS | MR. DOGGO STYLE</title>
  <meta name="description" content="All dog product reviews — honest, expert-tested, zero paid placements. Dog food, toys, beds, training gear, grooming tools."/>
  <link rel="canonical" href="https://mrdoggostyle.com/blog"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo+Black&family=Barlow+Condensed:wght@400;600;700&family=Space+Mono:wght@400&display=swap" rel="stylesheet"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    :root{--midnight:#0A0A0A;--concrete:#222222;--concrete-light:#2E2E2E;--lime:#CCFF00;--ash:#888;--smoke:#AAA;--offwhite:#F0F0F0}
    *{box-sizing:border-box} html{background:var(--midnight)}
    body{font-family:'Barlow Condensed',sans-serif;background:var(--midnight);color:var(--offwhite);margin:0;overflow-x:hidden}
    body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:998;opacity:.5}
    .btn-lime{display:inline-block;background:var(--lime);color:var(--midnight);font-family:'Archivo Black',sans-serif;font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;padding:.5rem 1.1rem;border:2px solid var(--midnight);box-shadow:3px 3px 0 var(--midnight);text-decoration:none;transition:all .1s}
    .btn-lime:hover{transform:translate(-2px,-2px);box-shadow:5px 5px 0 var(--midnight)}
    .btn-lime.active{background:var(--lime);pointer-events:none}
    .filter-btn{font-family:'Archivo Black',sans-serif;font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;padding:.4rem .9rem;border:2px solid rgba(255,255,255,.15);background:transparent;color:var(--smoke);cursor:pointer;transition:all .15s}
    .filter-btn:hover,.filter-btn.active{background:var(--lime);color:var(--midnight);border-color:var(--midnight)}
    ::selection{background:var(--lime);color:var(--midnight)}
    ::-webkit-scrollbar{width:4px} ::-webkit-scrollbar-track{background:var(--midnight)} ::-webkit-scrollbar-thumb{background:var(--concrete-light)} ::-webkit-scrollbar-thumb:hover{background:var(--lime)}
  </style>
</head>
<body>
<Header/>

<!-- Hero -->
<div style="background:var(--concrete);border-bottom:2px solid rgba(255,255,255,.08);padding:4rem 1.5rem">
  <div style="max-width:1400px;margin:0 auto">
    <span style="font-family:'Space Mono',monospace;font-size:.6rem;text-transform:uppercase;letter-spacing:.12em;color:var(--lime)">{sorted.length} EXPERT REVIEWS</span>
    <h1 style="font-family:'Anton',sans-serif;font-size:clamp(3rem,8vw,6rem);text-transform:uppercase;color:var(--offwhite);margin:.2rem 0 1rem;letter-spacing:-.02em;line-height:.9">
      ALL REVIEWS.<br/><span style="color:var(--lime)">ZERO FLUFF.</span>
    </h1>
    <p style="font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;color:var(--smoke);max-width:560px;margin:0">
      Every review is independent, research-backed, and updated regularly. No brand has ever paid us for placement.
    </p>
  </div>
</div>

<!-- Filters -->
<div style="max-width:1400px;margin:0 auto;padding:2rem 1.5rem">
  <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:2rem;align-items:center">
    <span style="font-family:'Space Mono',monospace;font-size:.55rem;text-transform:uppercase;letter-spacing:.08em;color:var(--ash);margin-right:.25rem">FILTER:</span>
    <button class="filter-btn active" data-cat="">ALL</button>
    {categories.map(cat => (
      <button class="filter-btn" data-cat={cat}>{cat.toUpperCase()}</button>
    ))}
  </div>

  <!-- Count -->
  <p style="font-family:'Space Mono',monospace;font-size:.6rem;text-transform:uppercase;letter-spacing:.06em;color:var(--ash);margin:0 0 1.5rem">
    SHOWING <strong id="shown" style="color:var(--lime)">{sorted.length}</strong> OF {sorted.length} REVIEWS
  </p>

  <!-- Grid -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem" id="blog-grid">
    {sorted.map((post, i) => (
      <article
        class="blog-card"
        data-cat={post.data.category}
        style="background:var(--concrete);border:2px solid rgba(255,255,255,.1);overflow:hidden;display:flex;flex-direction:column;transition:all .15s"
        onmouseover="this.style.borderColor='var(--lime)';this.style.transform='translate(-2px,-2px)';this.style.boxShadow='4px 4px 0 var(--lime)'"
        onmouseout="this.style.borderColor='rgba(255,255,255,.1)';this.style.transform='';this.style.boxShadow=''">
        <div style="background:var(--concrete-light);height:140px;display:flex;align-items:center;justify-content:center;font-size:3.5rem;border-bottom:1px solid rgba(255,255,255,.06);position:relative">
          🐾
          {i < 3 && <span style="position:absolute;top:8px;right:8px;background:var(--lime);color:var(--midnight);font-family:'Archivo Black',sans-serif;font-size:.5rem;text-transform:uppercase;padding:.15rem .5rem;letter-spacing:.08em">NEW</span>}
        </div>
        <div style="padding:1rem;flex:1;display:flex;flex-direction:column;gap:.4rem">
          <span style="font-family:'Archivo Black',sans-serif;font-size:.6rem;text-transform:uppercase;letter-spacing:.1em;color:var(--lime)">{post.data.category?.toUpperCase()}</span>
          <h2 style="font-family:'Archivo Black',sans-serif;font-size:.85rem;text-transform:uppercase;color:var(--offwhite);margin:0;line-height:1.2;flex:1">
            <a href={`/blog/${post.slug}`} style="text-decoration:none;color:inherit">{post.data.title}</a>
          </h2>
          <p style="font-family:'Barlow Condensed',sans-serif;font-size:.9rem;color:var(--ash);margin:0;line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">{post.data.description}</p>
          <div style="display:flex;align-items:center;justify-content:space-between;margin-top:.4rem">
            <span style="font-family:'Space Mono',monospace;font-size:.5rem;color:var(--ash);text-transform:uppercase">
              {new Date(post.data.pubDate).toLocaleDateString('en-US',{month:'short',year:'numeric'}).toUpperCase()}
            </span>
            <a href={`/blog/${post.slug}`} style="font-family:'Archivo Black',sans-serif;font-size:.6rem;text-transform:uppercase;color:var(--lime);text-decoration:none;letter-spacing:.06em">READ →</a>
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- No results -->
  <div id="no-results" style="display:none;text-align:center;padding:4rem 1rem">
    <div style="font-size:4rem;margin-bottom:1rem">🐾</div>
    <p style="font-family:'Archivo Black',sans-serif;font-size:1rem;text-transform:uppercase;color:var(--smoke)">NO REVIEWS IN THIS CATEGORY YET.</p>
    <button onclick="resetFilter()" class="btn-lime" style="margin-top:1rem">SHOW ALL →</button>
  </div>
</div>

<Footer/>

<script>
  const cards = document.querySelectorAll('.blog-card');
  const btns  = document.querySelectorAll('.filter-btn');
  const shown = document.getElementById('shown');
  const noRes = document.getElementById('no-results');

  function filter(cat) {
    let count = 0;
    cards.forEach(c => {
      const show = !cat || c.dataset.cat === cat;
      c.style.display = show ? '' : 'none';
      if (show) count++;
    });
    if (shown) shown.textContent = count;
    if (noRes) noRes.style.display = count === 0 ? 'block' : 'none';
    btns.forEach(b => b.classList.toggle('active', b.dataset.cat === cat));
  }

  btns.forEach(b => b.addEventListener('click', () => filter(b.dataset.cat)));
  window.resetFilter = () => filter('');
</script>
</body>
</html>
