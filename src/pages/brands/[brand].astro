---
import BaseLayout        from '../../layouts/BaseLayout.astro';
import Breadcrumb        from '../../components/primitives/Breadcrumb.astro';
import brandsData        from '../../data/brands.json';
import productIndex      from '../../data/product-index.json';
import masterBreeds      from '../../data/master-breeds.json';
import AwinProductSlot   from '../../components/affiliate/AwinProductSlot.astro';

const SITE = 'https://pupwiki.com';

export function getStaticPaths() {
  return (brandsData as any[]).map(b => ({ params: { brand: b.slug } }));
}

const { brand: slug } = Astro.params;
const brand = (brandsData as any[]).find(b => b.slug === slug);
if (!brand) return Astro.redirect('/brands');

const brandProducts = Object.values(productIndex as any)
  .filter((p: any) => (p.name || '').toLowerCase().includes(brand.name.toLowerCase().split(' ')[0].toLowerCase())) as any[];

const matchingBreeds = (masterBreeds as any[])
  .filter(b => {
    const picks = b.product_picks || {};
    return Object.values(picks).some((id: any) => {
      const prod = (productIndex as any)[id];
      return prod && (prod.name || '').toLowerCase().includes(brand.name.toLowerCase().split(' ')[0]);
    });
  })
  .slice(0, 8);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: brand.name,
  url: `https://${brand.domain}`,
  logo: `${SITE}${brand.logo_url}`,
  description: `${brand.name} dog products — expert reviews and best picks for your breed.`,
});

const categoryLinks = [
  ['/categories/dog-food',    '🍖', 'Dog Food'],
  ['/categories/toys',        '🎾', 'Toys'],
  ['/categories/beds',        '🛏️', 'Beds'],
  ['/categories/health',      '🩺', 'Health'],
  ['/categories/supplements', '💊', 'Supplements'],
  ['/categories/grooming',    '✂️', 'Grooming'],
  ['/categories/training',    '🦮', 'Training & Gear'],
  ['/categories/smart-tech',  '📡', 'Smart Tech'],
];
---

<BaseLayout
  title={`${brand.name} Dog Products — Reviews, Best Picks & Breed Guides 2026`}
  description={`Expert reviews of all ${brand.name} dog products. Find the best ${brand.name} ${brand.category_label.toLowerCase()} for your breed — with independent recommendations.`}
  canonicalUrl={`${SITE}/brands/${slug}`}
  structuredData={JSON.parse(jsonLd)}
>

<!-- Hero band -->
<div class="brand-hero-band">
  <div class="container">
    <Breadcrumb crumbs={[
      { label: 'Home',   href: '/' },
      { label: 'Brands', href: '/brands' },
      { label: brand.name },
    ]} />

    <div class="brand-hero-inner">
      <!-- Logo -->
      <div class="brand-logo-wrap">
        <img
          src={brand.logo_url}
          alt={`${brand.name} logo`}
          width="128"
          height="128"
          loading="eager"
          class="brand-logo-img"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <span class="brand-logo-fallback" aria-hidden="true">🏷️</span>
      </div>

      <!-- Info -->
      <div class="brand-hero-info">
        <div class="tag-row">
          <span class="badge" style="background:var(--color-accent);color:white;border-color:transparent">
            {brand.category_label}
          </span>
          {brand.speciality && (
            <span class="badge" style="background:var(--color-warning-light);color:var(--color-warning);border-color:rgba(217,119,6,.2)">
              {brand.speciality}
            </span>
          )}
          {brand.featured && (
            <span class="badge badge--success">⭐ Editor's favourite</span>
          )}
        </div>

        <h1 class="brand-hero-title">{brand.name}</h1>
        <p class="brand-hero-desc">
          Expert reviews and best-pick recommendations for all {brand.name} dog products — independently tested and rated.
        </p>

        <div class="btn-row">
          <a href={`https://${brand.domain}`} rel="nofollow" target="_blank" class="btn btn--secondary">
            🌐 Visit {brand.name} →
          </a>
          <a href="/categories/dog-food" class="btn btn--outline">
            Browse all dog food →
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Main content -->
<div class="container page-shell">
  <div class="brand-layout">

    <!-- Main column -->
    <main class="brand-main stack">

      <!-- Products -->
      {brandProducts.length > 0 && (
        <section>
          <span class="eyebrow">Product reviews</span>
          <h2 class="section-title" style="margin-top:var(--space-2)">{brand.name} Products We've Reviewed</h2>
          <div class="auto-grid" style="margin-top:var(--space-6)">
            {brandProducts.slice(0, 8).map((p: any) => (
              <div class="card">
                <div class="card__media" style="height:140px;aspect-ratio:unset">
                  <img src={brand.logo_url} alt={brand.name} width="80" height="80" loading="lazy"
                    class="brand-product-logo" onerror="this.style.display='none'" />
                </div>
                <div class="card__body">
                  <span class="card__eyebrow">{(p.category_key || '').replace(/-/g, ' ')}</span>
                  <h3 class="card__title" style="font-size:var(--text-sm)">{p.name}</h3>
                  <div class="cluster">
                    <span class="brand-stars" aria-label={`${p.rating || 4.5} stars`}>
                      {'★'.repeat(Math.round(parseFloat(p.rating || 4.5)))}
                    </span>
                    <span class="text-muted" style="font-size:var(--text-xs)">{parseFloat(p.rating || 4.5).toFixed(1)}/5</span>
                    {p.score && <span class="badge badge--accent" style="font-size:0.65rem">{p.score}/10</span>}
                  </div>
                  {p.verdict && <p class="card__desc" style="font-size:var(--text-xs);font-style:italic">{p.verdict.slice(0, 80)}…</p>}
                </div>
                <div class="card__footer">
                  <span class="font-bold" style="color:var(--color-heading);font-size:var(--text-base)">
                    {p.price ? `$${parseFloat(p.price).toFixed(2)}` : '—'}
                  </span>
                  <a href={`https://${brand.domain}`} rel="nofollow" target="_blank"
                    class="btn btn--secondary btn--sm">View →</a>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Breed matches -->
      {matchingBreeds.length > 0 && (
        <section>
          <span class="eyebrow">Breed matches</span>
          <h2 class="section-title" style="margin-top:var(--space-2)">Breeds That Love {brand.name}</h2>
          <div class="auto-grid auto-grid--tight" style="margin-top:var(--space-6);--auto-grid-min:140px">
            {matchingBreeds.map((b: any) => (
              <a href={`/breeds/${b.slug}`} class="card card--interactive breed-mini-card">
                <div class="card__media" style="height:80px;aspect-ratio:unset">
                  {b.image_url
                    ? <img src={b.image_url} alt={b.name} width="160" height="80" loading="lazy" onerror="this.parentElement.innerHTML='<span class=breed-mini-fallback>🐕</span>'" />
                    : <span class="breed-mini-fallback">🐕</span>
                  }
                </div>
                <div class="card__body" style="padding:var(--space-3)">
                  <p class="card__title" style="font-size:var(--text-xs)">{b.name}</p>
                  <p class="card__desc" style="font-size:var(--text-xs)">{b.size_category}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- About the brand -->
      <section class="card" style="padding:var(--space-6)">
        <h2 class="section-title" style="margin-bottom:var(--space-5)">About {brand.name}</h2>
        <div class="split split--2">
          <div>
            <p class="font-bold" style="color:var(--color-heading);margin-bottom:var(--space-3)">Brand overview</p>
            <dl class="brand-spec-list">
              {[
                ['Category',    brand.category_label],
                ['Speciality',  brand.speciality],
                ['Website',     brand.domain],
                ['Trust score', `${brand.trust_score}/10`],
              ].filter(([, v]) => v).map(([k, v]) => (
                <div class="brand-spec-row">
                  <dt class="text-muted">{k}</dt>
                  <dd class="font-semi" style="color:var(--color-heading)">{v}</dd>
                </div>
              ))}
            </dl>
          </div>
          <div>
            <p class="font-bold" style="color:var(--color-heading);margin-bottom:var(--space-3)">Official website</p>
            <div class="stack stack--tight">
              <a href={`https://${brand.domain}`} rel="nofollow" target="_blank"
                class="card brand-site-link" style="padding:var(--space-3)">
                <span class="font-semi" style="color:var(--color-primary)">🌐 {brand.name} official</span>
                <span class="text-muted" style="font-size:var(--text-xs)">{brand.domain} →</span>
              </a>
              <a href="/categories/dog-food"
                class="card brand-site-link" style="padding:var(--space-3)">
                <span class="font-semi" style="color:var(--color-accent)">🍖 Dog food guides</span>
                <span class="text-muted" style="font-size:var(--text-xs)">Compare all brands →</span>
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <!-- Sidebar -->
    <aside class="brand-sidebar">
      <div class="brand-sidebar-inner">

        <!-- Logo card -->
        <div class="card" style="overflow:hidden;border-color:var(--color-accent)">
          <div style="background:var(--color-accent);padding:var(--space-3) var(--space-4);text-align:center">
            <p style="color:white;font-size:var(--text-xs);font-weight:var(--weight-bold);text-transform:uppercase;letter-spacing:var(--tracking-label)">{brand.name}</p>
          </div>
          <div style="padding:var(--space-5);display:flex;align-items:center;justify-content:center;height:120px">
            <img src={brand.logo_url} alt={brand.name} width="120" height="80" loading="lazy"
              class="brand-sidebar-logo"
              onerror="this.parentElement.innerHTML='<span style=font-size:3rem>🏷️</span>'" />
          </div>
          <div style="padding:var(--space-2) var(--space-4) var(--space-4);display:flex;flex-direction:column;gap:var(--space-2)">
            <a href={`https://${brand.domain}`} rel="nofollow" target="_blank"
              class="btn btn--secondary" style="justify-content:center">
              Visit {brand.name} →
            </a>
            <a href="/categories/dog-food" class="btn btn--outline" style="justify-content:center">
              Dog food guides →
            </a>
          </div>
        </div>

        <!-- AWIN slot -->
        <AwinProductSlot topicTags={[brand.category_key ?? 'food', 'nutrition']} pageType="brand" />

        <!-- Category nav -->
        <div class="card" style="padding:var(--space-4)">
          <p class="eyebrow" style="margin-bottom:var(--space-3)">Browse by category</p>
          <nav>
            {categoryLinks.map(([href, emoji, label]) => (
              <a href={href} class="brand-cat-link">
                <span>{emoji}</span><span>{label} →</span>
              </a>
            ))}
          </nav>
        </div>

        <a href="/brands" class="btn btn--outline" style="width:100%;justify-content:center">
          All brands directory →
        </a>

      </div>
    </aside>

  </div>
</div>

</BaseLayout>

<style>
/* Brand hero band */
.brand-hero-band {
  background: linear-gradient(to bottom, var(--color-bg-warm), var(--color-bg-soft));
  border-bottom: 1px solid var(--color-border-warm);
  padding-block: var(--space-10) var(--space-12);
}

.brand-hero-inner {
  margin-top: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

@media (min-width: 640px) {
  .brand-hero-inner {
    flex-direction: row;
    align-items: center;
    gap: var(--space-8);
  }
}

.brand-logo-wrap {
  flex-shrink: 0;
  width: 6rem;
  height: 6rem;
  border-radius: var(--radius-2xl);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: white;
  border: 1px solid var(--color-border-warm);
  box-shadow: var(--shadow-card);
}

@media (min-width: 640px) {
  .brand-logo-wrap { width: 8rem; height: 8rem; }
}

.brand-logo-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 0.75rem;
}

.brand-logo-fallback {
  display: none;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
}

.brand-hero-info { flex: 1; min-width: 0; }

.brand-hero-title {
  font-size: var(--text-h1);
  color: var(--color-heading);
  margin-block: var(--space-3) var(--space-2);
  line-height: var(--leading-tight);
}

.brand-hero-desc {
  color: var(--color-muted);
  font-size: var(--text-base);
  line-height: var(--leading-relaxed);
  margin-bottom: var(--space-4);
}

/* Layout */
.brand-layout {
  display: grid;
  gap: var(--space-10);
}

@media (min-width: 1024px) {
  .brand-layout {
    grid-template-columns: 1fr 280px;
    align-items: start;
  }
}

.brand-main { min-width: 0; }

.brand-sidebar { display: none; }
@media (min-width: 1024px) {
  .brand-sidebar { display: block; }
}

.brand-sidebar-inner {
  position: sticky;
  top: var(--space-20);
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

/* Product logo in card */
.brand-product-logo {
  object-fit: contain;
  max-height: 4rem;
  opacity: 0.7;
  margin: auto;
}

/* Stars */
.brand-stars {
  color: var(--color-warning);
  font-size: var(--text-xs);
  letter-spacing: 0.05em;
}

/* Breed mini card */
.breed-mini-card { text-decoration: none; }
.breed-mini-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  font-size: 2rem;
}

/* About section */
.brand-spec-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.brand-spec-row {
  display: flex;
  justify-content: space-between;
  gap: var(--space-3);
  padding-block: var(--space-2);
  border-bottom: 1px solid var(--color-border-soft);
}

.brand-spec-row:last-child { border-bottom: none; }

.brand-site-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-decoration: none;
  transition: var(--transition-hover);
}

/* Sidebar */
.brand-sidebar-logo {
  object-fit: contain;
  max-height: 5rem;
}

/* Category nav */
.brand-cat-link {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-2);
  border-radius: var(--radius-lg);
  color: var(--color-heading);
  font-size: var(--text-sm);
  text-decoration: none;
  transition: background var(--transition-base), color var(--transition-base);
}

.brand-cat-link:hover {
  background: var(--color-bg-muted);
  color: var(--color-primary);
}
</style>
