---
import BaseLayout from '../../layouts/BaseLayout.astro';
import brandsData from '../../data/brands.json';

const brands = brandsData as any[];
const featured = brands.filter(b => b.featured);
const byCategory: Record<string, any[]> = {};
for (const b of brands) {
  const cat = b.category_label || 'Other';
  if (!byCategory[cat]) byCategory[cat] = [];
  byCategory[cat].push(b);
}
const categories = Object.keys(byCategory).sort();
---

<BaseLayout
  title="Dog Product Brands Directory 2026 — 100+ Expert-Reviewed Brands"
  description="Browse all dog product brands reviewed on PupWiki. Find the best brands for food, toys, beds, health, training and more."
  canonicalUrl="https://pupwiki.com/brands"
>

  <div style="background:linear-gradient(to bottom,#f5e8d0,#fdf8f0);border-bottom:1px solid #e8ccaa">
    <div class="max-w-7xl mx-auto px-4 py-12">
      <nav class="font-sans text-sm mb-5" style="color:#a0621c">
        <a href="/" style="color:#a0621c" class="hover:underline">Home</a>
        <span style="color:#d4a574"> › </span>
        <span style="color:#5c340a">Brands</span>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-3" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
        Dog Brand Directory
      </h1>
      <p class="font-sans text-lg mb-5" style="color:#64748b">
        {brands.length} brands reviewed — find the right brand for your dog's needs.
      </p>
      <div class="flex flex-wrap gap-2">
        <span class="font-sans text-xs font-bold px-3 py-1 rounded-full" style="background:#a0621c;color:white">{brands.length} brands</span>
        <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style="background:#fef3c7;color:#92400e">Chewy + Amazon links</span>
        <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style="background:#f0fdf4;color:#15803d">No paid placements</span>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12 space-y-14">

    <!-- Featured brands -->
    <section>
      <p class="font-sans text-xs font-bold uppercase tracking-widest mb-2" style="color:#a0621c">Editor's favourites</p>
      <h2 class="font-display text-3xl font-bold mb-6" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
        Top-Rated Brands
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
        {featured.map(b => (
          <a href={`/brands/${b.slug}`}
            class="group rounded-2xl p-4 text-center transition-all hover:-translate-y-1 hover:shadow-md"
            style="border:1px solid #e8ccaa;background:white;text-decoration:none">
            <div class="w-16 h-16 rounded-xl flex items-center justify-center mx-auto mb-3" style="background:#fdf8f0">
              <img src={b.logo_url} alt={b.name} width="48" height="48" loading="lazy"
                class="object-contain max-h-12"
                onerror="this.parentElement.innerHTML='<span style=font-size:1.5rem>🏷️</span>'" />
            </div>
            <p class="font-sans font-bold text-sm" style="color:#1e293b">{b.name}</p>
            <p class="font-sans text-xs mt-0.5" style="color:#94a3b8">{b.category_label}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- By category -->
    {categories.map(cat => (
      <section>
        <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          {cat} Brands
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
          {byCategory[cat].sort((a,b) => a.name.localeCompare(b.name)).map(b => (
            <a href={`/brands/${b.slug}`}
              class="group flex items-center gap-2.5 p-3 rounded-xl transition-all hover:shadow-sm"
              style="border:1px solid #e8ccaa;background:white;text-decoration:none"
              onmouseover="this.style.borderColor='#a0621c'"
              onmouseout="this.style.borderColor='#e8ccaa'">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background:#fdf8f0">
                <img src={b.logo_url} alt={b.name} width="32" height="32" loading="lazy"
                  class="object-contain max-h-7"
                  onerror="this.parentElement.innerHTML='<span style=font-size:0.9rem>🏷️</span>'" />
              </div>
              <div class="min-w-0">
                <p class="font-sans font-bold text-xs truncate" style="color:#1e293b">{b.name}</p>
                <p class="font-sans text-xs" style="color:#94a3b8">{b.speciality}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

  </div>
</BaseLayout>
