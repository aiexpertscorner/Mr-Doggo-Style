---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AwinProductSlot from '../../components/affiliate/AwinProductSlot.astro';
import brandsData from '../../data/brands.json';

const brands = brandsData as any[];
const featured = brands.filter(b => b.featured);
const byCategory: Record<string, any[]> = {};
for (const b of brands) {
  const cat = b.category_label || 'Other';
  if (!byCategory[cat]) byCategory[cat] = [];
  byCategory[cat].push(b);
}
const categories = Object.keys(byCategory).sort();

const SITE = 'https://pupwiki.com';
const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',   item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Brands', item: `${SITE}/brands` },
  ],
});
---

<BaseLayout
  title="Dog Product Brands Directory 2026 — 100+ Expert-Reviewed Brands"
  description="Browse all dog product brands reviewed on PupWiki. Find the best brands for food, toys, beds, health, training and more."
  canonicalUrl="https://pupwiki.com/brands"
>
<script type="application/ld+json" set:html={breadcrumbLd} />

  <div style={`background:linear-gradient(to bottom,var(--color-surface-warm),var(--color-bg-soft));border-bottom:1px solid var(--color-border-warm)`}>
    <div class="max-w-7xl mx-auto px-4 py-12">
      <nav class="font-sans text-sm mb-5" style={`color:var(--color-accent)`}>
        <a href="/" style={`color:var(--color-accent)`} class="hover:underline">Home</a>
        <span style={`color:var(--color-accent-light)`}> › </span>
        <span style={`color:var(--color-accent-active)`}>Brands</span>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-3" style={`font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)`}>
        Dog Brand Directory
      </h1>
      <p class="font-sans text-lg mb-5" style={`color:var(--color-muted)`}>
        {brands.length} brands reviewed — find the right brand for your dog's needs.
      </p>
      <div class="flex flex-wrap gap-2">
        <span class="font-sans text-xs font-bold px-3 py-1 rounded-full" style={`background:var(--color-accent);color:white`}>{brands.length} brands</span>
        <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style={`background:var(--color-success-light);color:var(--color-success)`}>No paid placements</span>
        <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style={`background:var(--color-bg-soft);color:var(--color-body-soft)`}>AWIN-first recommendations</span>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12 space-y-14">

    <!-- Featured brands -->
    <section>
      <p class="font-sans text-xs font-bold uppercase tracking-widest mb-2" style={`color:var(--color-accent)`}>Editor's favourites</p>
      <h2 class="font-display text-3xl font-bold mb-6" style={`font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)`}>
        Top-Rated Brands
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
        {featured.map(b => (
          <a href={`/brands/${b.slug}`}
            class="group rounded-2xl p-4 text-center transition-all hover:-translate-y-1 hover:shadow-md"
            style={`border:1px solid var(--color-border-warm);background:white;text-decoration:none`}>
            <div class="w-16 h-16 rounded-xl flex items-center justify-center mx-auto mb-3" style={`background:var(--color-bg-soft)`}>
              <img src={b.logo_url} alt={b.name} width="48" height="48" loading="lazy"
                class="object-contain max-h-12"
                onerror="this.parentElement.innerHTML='<span style=font-size:1.5rem>🏷️</span>'" />
            </div>
            <p class="font-sans font-bold text-sm" style={`color:var(--color-heading)`}>{b.name}</p>
            <p class="font-sans text-xs mt-0.5" style={`color:var(--color-subtle)`}>{b.category_label}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- AWIN product slot -->
    <AwinProductSlot topicTags={['food', 'nutrition', 'fresh-food']} pageType="brand" />

    <!-- By category -->
    {categories.map(cat => (
      <section>
        <h2 class="font-display text-2xl font-bold mb-5" style={`font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)`}>
          {cat} Brands
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
          {byCategory[cat].sort((a,b) => a.name.localeCompare(b.name)).map(b => (
            <a href={`/brands/${b.slug}`}
              class="group flex items-center gap-2.5 p-3 rounded-xl transition-all hover:shadow-sm"
              style={`border:1px solid var(--color-border-warm);background:white;text-decoration:none`}>
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style={`background:var(--color-bg-soft)`}>
                <img src={b.logo_url} alt={b.name} width="32" height="32" loading="lazy"
                  class="object-contain max-h-7"
                  onerror="this.parentElement.innerHTML='<span style=font-size:0.9rem>🏷️</span>'" />
              </div>
              <div class="min-w-0">
                <p class="font-sans font-bold text-xs truncate" style={`color:var(--color-heading)`}>{b.name}</p>
                <p class="font-sans text-xs" style={`color:var(--color-subtle)`}>{b.speciality}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

  </div>
</BaseLayout>
