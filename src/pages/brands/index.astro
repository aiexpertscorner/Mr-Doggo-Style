---
import BaseLayout      from '../../layouts/BaseLayout.astro';
import Breadcrumb      from '../../components/primitives/Breadcrumb.astro';
import AwinProductSlot from '../../components/affiliate/AwinProductSlot.astro';
import brandsData      from '../../data/brands.json';

const brands = brandsData as any[];
const featured = brands.filter(b => b.featured);
const byCategory: Record<string, any[]> = {};
for (const b of brands) {
  const cat = b.category_label || 'Other';
  if (!byCategory[cat]) byCategory[cat] = [];
  byCategory[cat].push(b);
}
const categories = Object.keys(byCategory).sort();

const SITE = 'https://pupwiki.com';
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',   item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Brands', item: `${SITE}/brands` },
  ],
};
---

<BaseLayout
  title="Dog Product Brands Directory 2026 — 100+ Expert-Reviewed Brands"
  description="Browse all dog product brands reviewed on PupWiki. Find the best brands for food, toys, beds, health, training and more."
  canonicalUrl="https://pupwiki.com/brands"
  structuredData={breadcrumbLd}
>

<!-- Hero band -->
<div class="brands-hero-band">
  <div class="container">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Brands' }]} />

    <h1 class="brands-hero-title">Dog Brand Directory</h1>
    <p class="brands-hero-desc">
      {brands.length} brands reviewed — find the right brand for your dog's needs.
    </p>
    <div class="tag-row" style="margin-top:var(--space-4)">
      <span class="badge" style="background:var(--color-accent);color:white;border-color:transparent">{brands.length} brands</span>
      <span class="badge badge--success">No paid placements</span>
      <span class="badge">Dog-care brand matches</span>
    </div>
  </div>
</div>

<!-- Main content -->
<div class="container page-shell">
  <div class="stack">

    <!-- Featured brands -->
    <section>
      <span class="eyebrow">Editor's favourites</span>
      <h2 class="section-title" style="margin-top:var(--space-2)">Top-Rated Brands</h2>
      <div class="brands-featured-grid" style="margin-top:var(--space-6)">
        {featured.map(b => (
          <a href={`/brands/${b.slug}`} class="brand-logo-card card card--interactive">
            <div class="brand-logo-card__img-wrap">
              <img src={b.logo_url} alt={b.name} width="48" height="48" loading="lazy"
                class="brand-logo-card__img"
                onerror="this.parentElement.innerHTML='<span class=brand-logo-card__fallback>🏷️</span>'" />
            </div>
            <p class="brand-logo-card__name">{b.name}</p>
            <p class="brand-logo-card__cat">{b.category_label}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- AWIN slot -->
    <AwinProductSlot topicTags={['food', 'nutrition', 'fresh-food']} pageType="brand" />

    <!-- By category -->
    {categories.map(cat => (
      <section>
        <h2 class="section-title">{cat} Brands</h2>
        <div class="brands-cat-grid" style="margin-top:var(--space-5)">
          {byCategory[cat].sort((a, b) => a.name.localeCompare(b.name)).map(b => (
            <a href={`/brands/${b.slug}`} class="brand-row-card card card--interactive">
              <div class="brand-row-card__logo">
                <img src={b.logo_url} alt={b.name} width="32" height="32" loading="lazy"
                  class="brand-row-card__img"
                  onerror="this.parentElement.innerHTML='<span>🏷️</span>'" />
              </div>
              <div class="truncate">
                <p class="brand-row-card__name truncate">{b.name}</p>
                <p class="brand-row-card__spec">{b.speciality}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

  </div>
</div>

</BaseLayout>

<style>
.brands-hero-band {
  background: linear-gradient(to bottom, var(--color-bg-warm), var(--color-bg-soft));
  border-bottom: 1px solid var(--color-border-warm);
  padding-block: var(--space-10) var(--space-12);
}

.brands-hero-title {
  font-size: var(--text-h1);
  color: var(--color-heading);
  margin-top: var(--space-4);
  line-height: var(--leading-tight);
}

.brands-hero-desc {
  font-size: var(--text-lg);
  color: var(--color-muted);
  margin-top: var(--space-3);
}

/* Featured brand logos */
.brands-featured-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: var(--space-4);
}

.brand-logo-card {
  padding: var(--space-4);
  text-align: center;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
}

.brand-logo-card__img-wrap {
  width: 4rem;
  height: 4rem;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-muted);
  overflow: hidden;
}

.brand-logo-card__img {
  object-fit: contain;
  max-height: 3rem;
}

.brand-logo-card__fallback {
  font-size: 1.5rem;
}

.brand-logo-card__name {
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
  color: var(--color-heading);
  line-height: var(--leading-snug);
}

.brand-logo-card__cat {
  font-size: var(--text-xs);
  color: var(--color-subtle);
}

/* Category brand rows */
.brands-cat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: var(--space-3);
}

.brand-row-card {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3);
  text-decoration: none;
  min-width: 0;
}

.brand-row-card__logo {
  width: 2rem;
  height: 2rem;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-muted);
  flex-shrink: 0;
  overflow: hidden;
}

.brand-row-card__img {
  object-fit: contain;
  max-height: 1.75rem;
}

.brand-row-card__name {
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  color: var(--color-heading);
}

.brand-row-card__spec {
  font-size: var(--text-xs);
  color: var(--color-subtle);
}
</style>
