---
import BaseLayout from '../../layouts/BaseLayout.astro';

const SITE = 'https://pupwiki.com';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',   item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: `${SITE}/guides` },
    { '@type': 'ListItem', position: 3, name: 'First Dog Guide', item: `${SITE}/guides/first-dog` },
  ],
});

const steps = [
  {
    number: '01',
    title: 'Find the right breed',
    description: 'Every breed has different energy levels, grooming needs, space requirements, and temperaments. Match your lifestyle before you commit.',
    cards: [
      { icon: '🐾', label: 'Breed Match Quiz', desc: 'Answer 8 questions to find your ideal match', href: '/breed-quiz' },
      { icon: '🔍', label: 'Browse all breeds', desc: 'Filter 277+ breeds by size, energy, coat and group', href: '/breeds' },
      { icon: '🧬', label: 'Explore mixed breeds', desc: 'Crossbreeds and designer dogs explained', href: '/breeds?type=mixed' },
    ],
  },
  {
    number: '02',
    title: 'Plan the real costs',
    description: 'The purchase price is just the beginning. Factor in food, vet care, grooming, insurance, and training before you decide.',
    cards: [
      { icon: '💰', label: 'Cost calculator', desc: 'Breed-specific annual and lifetime cost breakdown', href: '/cost-calculator' },
      { icon: '🏥', label: 'Pet insurance guide', desc: 'Compare coverage options for your breed', href: '/categories/dog-health' },
      { icon: '🍖', label: 'Food costs by breed', desc: 'Feeding costs for small to giant breeds', href: '/categories/dog-food' },
    ],
  },
  {
    number: '03',
    title: 'Prepare your home',
    description: 'Before your dog arrives, you need the right supplies and a safe environment. Here\'s what to have ready on day one.',
    cards: [
      { icon: '🛏️', label: 'Beds & crates', desc: 'Top-rated beds and crates by size', href: '/categories/dog-beds' },
      { icon: '🎾', label: 'Toys & enrichment', desc: 'Keep your dog stimulated and happy', href: '/categories/dog-toys' },
      { icon: '🪮', label: 'Grooming essentials', desc: 'Brushes, shampoos, and coat care by breed', href: '/categories/dog-grooming' },
    ],
  },
  {
    number: '04',
    title: 'Train from day one',
    description: 'Early training prevents problem behaviour. Start with basic commands and socialisation in the first few weeks.',
    cards: [
      { icon: '🎓', label: 'Training guides', desc: 'Positive reinforcement methods that work', href: '/categories/dog-training' },
      { icon: '❤️', label: 'Health basics', desc: 'Vaccination schedule, vet visits, and parasite prevention', href: '/categories/dog-health' },
      { icon: '📋', label: 'Puppy checklist', desc: 'Everything to buy before bringing your puppy home', href: '/blog' },
    ],
  },
];
---

<BaseLayout
  title="First Dog Guide — Everything You Need Before Getting a Dog"
  description="Planning to get your first dog? This step-by-step guide covers choosing the right breed, calculating real costs, preparing your home, and training from day one."
  canonicalUrl={`${SITE}/guides/first-dog`}
  pageType="website"
>
  <script type="application/ld+json" set:html={breadcrumbLd} />

  <!-- Hero -->
  <div style="background:linear-gradient(180deg,var(--color-bg-cool) 0%,white 100%);border-bottom:1px solid var(--color-border)">
    <div class="max-w-4xl mx-auto px-5 py-12 sm:py-16">
      <nav class="font-sans text-sm mb-6 flex flex-wrap gap-1.5" style="color:var(--color-subtle)">
        <a href="/" class="hover:underline" style="color:var(--color-accent)">Home</a><span>›</span>
        <span style="color:var(--color-muted)">First Dog Guide</span>
      </nav>
      <p class="font-sans text-xs font-bold uppercase tracking-wider mb-3" style="color:var(--color-primary)">Getting started</p>
      <h1 class="font-display font-black mb-4" style="font-size:var(--text-h1);line-height:var(--leading-tight);color:var(--color-heading);font-family:'Playfair Display',Georgia,serif">
        Your first dog —<br>a complete guide
      </h1>
      <p class="font-sans text-lg mb-6" style="color:var(--color-body-soft);max-width:52ch;line-height:var(--leading-relaxed)">
        Getting a dog is one of the most rewarding decisions you can make — but preparation makes all the difference. Follow these four steps before you bring one home.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/breed-quiz"
          class="font-sans font-bold text-sm px-5 py-3 rounded-full"
          style="background:var(--color-cta);color:white;text-decoration:none">
          Take the breed quiz →
        </a>
        <a href="/breeds"
          class="font-sans font-bold text-sm px-5 py-3 rounded-full"
          style="background:white;border:2px solid var(--color-primary);color:var(--color-primary);text-decoration:none">
          Browse all breeds
        </a>
      </div>
    </div>
  </div>

  <!-- Steps -->
  <div class="max-w-4xl mx-auto px-5 py-12 sm:py-16 space-y-16">

    {steps.map(step => (
      <section>
        <div class="flex items-start gap-4 mb-6">
          <span class="font-display font-black text-4xl flex-shrink-0" style="color:var(--color-primary-light);font-family:'Playfair Display',Georgia,serif;line-height:1">
            {step.number}
          </span>
          <div>
            <h2 class="font-display text-2xl font-bold mb-2" style="font-family:'Playfair Display',Georgia,serif;color:var(--color-heading)">
              {step.title}
            </h2>
            <p class="font-sans text-sm" style="color:var(--color-muted);max-width:58ch">{step.description}</p>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          {step.cards.map(card => (
            <a href={card.href}
              class="rounded-2xl p-5 hover:shadow-md transition-shadow"
              style="background:white;border:1px solid var(--color-border);text-decoration:none;display:block">
              <span style="font-size:1.75rem;display:block;margin-bottom:var(--space-3)">{card.icon}</span>
              <p class="font-sans font-bold text-sm mb-1" style="color:var(--color-heading)">{card.label}</p>
              <p class="font-sans text-xs" style="color:var(--color-muted)">{card.desc}</p>
            </a>
          ))}
        </div>
      </section>
    ))}

    <!-- Bottom CTA -->
    <section class="rounded-3xl p-8 text-center" style="background:var(--color-surface-navy);color:white">
      <p class="font-sans text-xs font-bold uppercase tracking-wider mb-3" style="color:var(--color-accent)">Ready to find your match?</p>
      <h2 class="font-display text-3xl font-black mb-3" style="font-family:'Playfair Display',Georgia,serif">
        Start with the breed quiz
      </h2>
      <p class="font-sans text-sm mb-6" style="color:rgba(255,255,255,0.75);max-width:42ch;margin-left:auto;margin-right:auto">
        8 quick questions match you with breeds that fit your home, lifestyle, and experience level.
      </p>
      <a href="/breed-quiz"
        class="inline-block font-sans font-bold text-sm px-6 py-3 rounded-full"
        style="background:var(--color-cta);color:white;text-decoration:none">
        Take the breed quiz →
      </a>
    </section>

  </div>
</BaseLayout>
