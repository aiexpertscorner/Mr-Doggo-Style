---
import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';
---
<!DOCTYPE html>
<html lang="en"><head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>AFFILIATE DISCLOSURE | MR. DOGGO STYLE</title>
  <meta name="description" content="Full affiliate disclosure and editorial policy for Mr. Doggo Style."/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo+Black&family=Barlow+Condensed:wght@400;600;700&family=Source+Serif+4:wght@400&family=Space+Mono:wght@400&display=swap" rel="stylesheet"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <style>
    :root{--midnight:#0A0A0A;--concrete:#222222;--lime:#CCFF00;--ash:#888;--smoke:#AAA;--offwhite:#F0F0F0}
    *{box-sizing:border-box} html{background:var(--midnight)} body{font-family:'Barlow Condensed',sans-serif;background:var(--midnight);color:var(--offwhite);margin:0}
    .prose{font-family:'Source Serif 4',Georgia,serif;color:var(--smoke);font-size:1.05rem;line-height:1.8;max-width:680px}
    .prose h2{font-family:'Archivo Black',sans-serif;text-transform:uppercase;color:var(--offwhite);font-size:1.25rem;border-bottom:2px solid var(--concrete);padding-bottom:.4rem;margin-top:2rem}
    .prose a{color:var(--lime)} .prose strong{color:var(--offwhite)} ::selection{background:var(--lime);color:var(--midnight)}
    .notice{border:2px solid rgba(204,255,0,.3);background:rgba(204,255,0,.05);padding:1rem;font-family:'Space Mono',monospace;font-size:.65rem;color:var(--lime);text-transform:uppercase;letter-spacing:.04em;margin-bottom:2rem}
  </style>
</head>
<body>
<Header/>
<div style="background:var(--concrete);border-bottom:2px solid rgba(255,255,255,.08);padding:4rem 1.5rem">
  <div style="max-width:900px;margin:0 auto">
    <h1 style="font-family:'Anton',sans-serif;font-size:clamp(2.5rem,7vw,5rem);text-transform:uppercase;color:var(--offwhite);margin:0;letter-spacing:-.02em;line-height:.9">
      AFFILIATE<br/><span style="color:var(--lime)">DISCLOSURE.</span>
    </h1>
  </div>
</div>
<div style="max-width:900px;margin:0 auto;padding:3rem 1.5rem">
  <div class="notice">LAST UPDATED: JANUARY 2026 — FTC COMPLIANT</div>
  <div class="prose">
    <h2>Amazon Associates Program</h2>
    <p>Mr. Doggo Style (mrdoggostyle.com) is a participant in the Amazon Services LLC Associates Program. When you click our product links and purchase on Amazon, we earn a small commission at no additional cost to you.</p>
    <h2>How This Affects Our Reviews</h2>
    <p>It doesn't. We include real pros AND cons. We sometimes recommend against popular products. We never accept payment from brands for placement. Our Amazon Associate tag is <strong>aiexpertscorn-20</strong>.</p>
    <h2>Price Accuracy</h2>
    <p>Amazon prices change frequently. Prices shown on this site are approximate. Always verify on Amazon before purchasing.</p>
    <h2>FTC Compliance</h2>
    <p>In accordance with 16 CFR Part 255, we disclose all material connections between us and the products we discuss. The <code style="background:var(--concrete);padding:.1rem .3rem;color:var(--lime)">rel="nofollow sponsored"</code> attribute is applied to all affiliate links on this site.</p>
    <h2>Contact</h2>
    <p>Questions about our affiliate policy: <strong>hello@mrdoggostyle.com</strong></p>
  </div>
</div>
<Footer/>
</body></html>
