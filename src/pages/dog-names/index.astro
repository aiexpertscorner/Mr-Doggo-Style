---
import NameLayout from '../../layouts/NameLayout.astro';
import NameHero from '../../components/names/NameHero.astro';
import NameGeneratorPanel from '../../components/names/NameGeneratorPanel.astro';
import FeaturedBreedNameGrid from '../../components/names/FeaturedBreedNameGrid.astro';
import BreedNameDirectory from '../../components/names/BreedNameDirectory.astro';
import { getDogNamesIndexData } from '../../lib/names/name-data';
import { buildDogNamesIndexJsonLd } from '../../lib/names/name-schema';
import { getNamingMethodSummary } from '../../lib/names/name-copy';

const data = getDogNamesIndexData();
const structuredData = buildDogNamesIndexJsonLd(data);
---

<NameLayout
  title="Dog Name Generator & Breed Name Ideas"
  description={`Find dog names by breed, style, inspiration, and sound. Browse ${data.stats.breedCount} breed name guides and generate ideas you can shortlist, copy, share, or export.`}
  canonicalPath="/dog-names"
  structuredData={structuredData}
  pageType="collection"
>
  <NameHero stats={data.stats} breeds={data.breeds}>
    <NameGeneratorPanel
      slot="generator"
      id="dog-names-index-generator"
      breeds={data.breeds}
      names={data.generatorNames}
      categories={data.categories}
      inspirations={data.inspirations}
      compact
    />
  </NameHero>

  <div class="pw-names__container">
    <section class="pw-names__section" aria-labelledby="dog-names-method-title">
      <div class="pw-names__section-header">
        <p class="pw-names__eyebrow">How it works</p>
        <h2 id="dog-names-method-title">Name ideas built for real life</h2>
        <p>{getNamingMethodSummary()} The goal is not just a cute list—it is a name that sounds clear, fits your dog, and still feels good after you say it every day.</p>
      </div>
    </section>

    <FeaturedBreedNameGrid breeds={data.featuredBreeds} />
    <BreedNameDirectory byLetter={data.byLetter} letters={data.letters} breedCount={data.stats.breedCount} />
  </div>

  <script type="module" src="/scripts/pupwiki-name-generator.mjs"></script>
</NameLayout>
