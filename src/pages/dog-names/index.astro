---
import BaseLayout   from '../../layouts/BaseLayout.astro';
import masterBreeds from '../../data/master-breeds.json';

const breeds = masterBreeds as any[];
const byLetter: Record<string,any[]> = {};
for (const b of breeds) {
  const l = b.name[0].toUpperCase();
  if (!byLetter[l]) byLetter[l] = [];
  byLetter[l].push(b);
}
const letters = Object.keys(byLetter).sort();

const featured = breeds
  .filter(b => b.akc_popularity && b.akc_popularity <= 30 && b.image_url)
  .sort((a,b) => (a.akc_popularity||999)-(b.akc_popularity||999))
  .slice(0,12);
---

<BaseLayout
  title="Dog Names by Breed 2026 — 277 Breeds, 7,000+ Names"
  description="Find the perfect name for your dog matched to their breed personality. Boy and girl names curated for every breed."
  canonicalUrl="https://pupwiki.com/dog-names"
>

<!-- Hero -->
<div style="background:linear-gradient(135deg,#3d2206 0%,#7d4a10 50%,#a0621c 100%);position:relative;overflow:hidden">
  <div style="position:absolute;inset:0;background:radial-gradient(circle at 20% 50%,rgba(255,255,255,0.05),transparent 60%)"></div>
  <div class="max-w-7xl mx-auto px-4 py-16 sm:py-24 relative">
    <div class="max-w-3xl">
      <span class="inline-block font-sans text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-4" style="background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.9)">Name finder</span>
      <h1 class="font-display text-5xl sm:text-6xl md:text-7xl font-bold leading-none mb-5" style="font-family:'Playfair Display',Georgia,serif;color:white">
        Find the<br/><span style="color:#fbbf24">perfect name</span><br/>for your dog.
      </h1>
      <p class="font-sans text-lg sm:text-xl mb-8 max-w-xl" style="color:rgba(255,255,255,0.8)">
        {breeds.length} breed-matched lists. Boy and girl names curated for personality, temperament, and style.
      </p>
      <div class="relative max-w-md">
        <input type="search" id="hero-search" placeholder="Search your breed (e.g. Golden Retriever)…"
          class="w-full font-sans text-base px-5 py-4 rounded-2xl pr-12 focus:outline-none focus:ring-2"
          style="background:white;color:#1e293b;--tw-ring-color:#fbbf24;box-shadow:0 4px 24px rgba(0,0,0,0.2)"
          autocomplete="off" />
        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xl pointer-events-none">🔍</span>
        <div id="search-dropdown" class="hidden absolute left-0 right-0 top-full mt-2 rounded-2xl overflow-hidden z-50"
          style="background:white;box-shadow:0 12px 40px rgba(0,0,0,0.2);max-height:300px;overflow-y:auto"></div>
      </div>
    </div>
  </div>
</div>

<!-- Stats -->
<div style="background:#fdf8f0;border-bottom:1px solid #e8ccaa">
  <div class="max-w-7xl mx-auto px-4 py-4">
    <div class="flex flex-wrap gap-6 font-sans text-sm" style="color:#64748b">
      <span>🐕 <strong style="color:#1e293b">{breeds.length}</strong> breeds</span>
      <span>✍️ <strong style="color:#1e293b">7,000+</strong> curated names</span>
      <span>🎯 <strong style="color:#1e293b">Personality-matched</strong></span>
      <span>📅 <strong style="color:#1e293b">Updated 2026</strong></span>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 py-12 space-y-14">

  <!-- Featured breeds -->
  <section>
    <div class="flex items-end justify-between mb-6">
      <div>
        <p class="font-sans text-xs font-bold uppercase tracking-widest mb-1" style="color:#a0621c">Popular breeds</p>
        <h2 class="font-display text-3xl font-bold" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">Top Breed Name Guides</h2>
      </div>
      <a href="/breeds" class="font-sans text-sm font-semibold hover:underline" style="color:#a0621c">All breeds →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      {featured.map((b:any) => (
        <a href={`/dog-names/${b.slug}`} class="group rounded-2xl overflow-hidden flex flex-col transition-all hover:-translate-y-1 hover:shadow-md" style="border:1px solid #e8ccaa;background:white;text-decoration:none">
          <div style="height:110px;background:#fdf8f0;overflow:hidden">
            {b.image_url
              ? <img src={b.image_url} alt={b.name} width="160" height="110" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" onerror="this.parentElement.innerHTML='<div style=display:flex;align-items:center;justify-content:center;height:100%;font-size:2.5rem>🐕</div>'" />
              : <div class="flex items-center justify-center h-full text-4xl">🐕</div>
            }
          </div>
          <div class="p-3">
            <p class="font-sans text-xs font-bold leading-tight" style="color:#1e293b">{b.name}</p>
            {b.akc_popularity && <p class="font-sans text-xs mt-0.5" style="color:#94a3b8">#{b.akc_popularity} popular</p>}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- A–Z Directory -->
  <section>
    <div class="mb-6">
      <p class="font-sans text-xs font-bold uppercase tracking-widest mb-1" style="color:#a0621c">All {breeds.length} breeds</p>
      <h2 class="font-display text-3xl font-bold" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">Browse All Breed Name Guides</h2>
    </div>
    <div class="flex flex-wrap gap-1 mb-8">
      {letters.map(l => (
        <a href={`#letter-${l}`} class="font-sans text-xs font-bold w-8 h-8 flex items-center justify-center rounded-lg transition-all hover:text-white hover:bg-bark-600"
          style="border:1px solid #e8ccaa;color:#64748b;text-decoration:none"
          onmouseover="this.style.background='#a0621c';this.style.color='white'"
          onmouseout="this.style.background='';this.style.color='#64748b'">{l}</a>
      ))}
    </div>
    <div class="space-y-8">
      {letters.map(l => (
        <div id={`letter-${l}`}>
          <div class="flex items-center gap-3 mb-4">
            <span class="font-display text-3xl font-black" style="color:#a0621c;font-family:'Playfair Display',Georgia,serif">{l}</span>
            <div class="flex-1 h-px" style="background:#e8ccaa"></div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-2">
            {byLetter[l].sort((a:any,b:any)=>a.name.localeCompare(b.name)).map((b:any) => (
              <a href={`/dog-names/${b.slug}`} class="flex items-center gap-2 px-3 py-2 rounded-xl font-sans text-sm font-medium transition-all"
                style="border:1px solid transparent;color:#1e293b;text-decoration:none"
                onmouseover="this.style.borderColor='#e8ccaa';this.style.background='#fdf8f0';this.style.color='#a0621c'"
                onmouseout="this.style.borderColor='transparent';this.style.background='';this.style.color='#1e293b'">
                {b.image_url && (
                  <img src={b.image_url} alt={b.name} width="24" height="24" loading="lazy"
                    class="rounded-full object-cover flex-shrink-0" style="width:24px;height:24px;border:1px solid #e8ccaa"
                    onerror="this.style.display='none'" />
                )}
                <span class="truncate">{b.name}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

</div>

<script define:vars={{ breedList: masterBreeds.map((b:any) => ({ name:b.name, slug:b.slug, img:(b as any).image_url||'' })) }}>
  const input    = document.getElementById('hero-search');
  const dropdown = document.getElementById('search-dropdown');
  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    if (!q || q.length < 2) { dropdown.classList.add('hidden'); return; }
    const hits = breedList.filter((b:any) => b.name.toLowerCase().includes(q)).slice(0, 8);
    if (!hits.length) { dropdown.classList.add('hidden'); return; }
    dropdown.innerHTML = hits.map((b:any) => `
      <a href="/dog-names/${b.slug}" style="display:flex;align-items:center;gap:12px;padding:10px 16px;text-decoration:none;color:#1e293b;border-bottom:1px solid #f5e8d0" onmouseover="this.style.background='#fdf8f0'" onmouseout="this.style.background=''">
        ${b.img ? `<img src="${b.img}" alt="${b.name}" style="width:36px;height:36px;object-fit:cover;border-radius:50%;border:1px solid #e8ccaa" onerror="this.style.display='none'" />` : '<span style="width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:1.2rem">🐕</span>'}
        <span style="font-family:DM Sans,sans-serif;font-weight:600;font-size:0.875rem">${b.name} names →</span>
      </a>`).join('');
    dropdown.classList.remove('hidden');
  });
  document.addEventListener('click', e => {
    if (!input?.contains(e.target) && !dropdown?.contains(e.target)) dropdown?.classList.add('hidden');
  });
</script>
</BaseLayout>
