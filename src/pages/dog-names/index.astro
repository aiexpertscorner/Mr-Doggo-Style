---
import BaseLayout from '../../layouts/BaseLayout.astro';
import masterBreeds from '../../data/master-breeds.json';
import allNamesData from '../../data/dog-names.json';

type DogNameEntry = {
  name: string;
  gender: string;
  category: string;
  inspiration: string;
  rank: number;
  letter?: string;
  enriched?: boolean;
};

const breeds = masterBreeds as any[];
const allNames = allNamesData as DogNameEntry[];

const byLetter: Record<string, any[]> = {};

for (const b of breeds) {
  const letter = b.name[0].toUpperCase();
  if (!byLetter[letter]) byLetter[letter] = [];
  byLetter[letter].push(b);
}

const letters = Object.keys(byLetter).sort();

const featured = breeds
  .filter((b) => b.akc_popularity && b.akc_popularity <= 30 && b.image_url)
  .sort((a, b) => (a.akc_popularity || 999) - (b.akc_popularity || 999))
  .slice(0, 12);

const categories = Array.from(new Set(allNames.map((item) => item.category).filter(Boolean))).sort();
const inspirations = Array.from(new Set(allNames.map((item) => item.inspiration).filter(Boolean))).sort();

const breedList = breeds.map((b: any) => ({
  name: b.name,
  slug: b.slug,
  img: b.image_url || '',
  size: b.size_category || '',
  energy: b.energy_level || '',
  temperament: b.temperament || '',
  styles: b.name_styles || [],
  inspirations: b.name_inspirations || [],
}));

const generatorNames = allNames.map((item) => ({
  name: item.name,
  gender: item.gender,
  category: item.category,
  inspiration: item.inspiration,
  rank: item.rank || 9999,
  letter: item.letter || item.name?.[0]?.toUpperCase() || '',
  enriched: Boolean(item.enriched),
}));
---

<BaseLayout
  title="Dog Names by Breed 2026 — 277 Breeds, 7,000+ Names"
  description="Find the perfect name for your dog matched to their breed personality. Boy and girl names curated for every breed."
  canonicalUrl="https://pupwiki.com/dog-names"
  bodyClass="dog-names-page bg-white text-slate-900"
>
  <main class="dog-names">
    <section class="dog-names-hero" aria-labelledby="dog-names-title">
      <div class="dog-names-container">
        <div class="dog-names-hero__grid">
          <div class="dog-names-hero__content">
            <p class="dog-names-eyebrow">Name finder</p>

            <h1 id="dog-names-title" class="dog-names-hero__title">
              Find the
              <span>perfect name</span>
              for your dog.
            </h1>

            <p class="dog-names-hero__subtitle">
              {breeds.length} breed-matched lists. Boy, girl, and flexible name ideas curated for personality,
              temperament, inspiration, and style.
            </p>

            <div class="dog-names-search" role="search">
              <label class="sr-only" for="hero-search">Search your breed</label>
              <input
                type="search"
                id="hero-search"
                placeholder="Search your breed (e.g. Golden Retriever)…"
                autocomplete="off"
              />
              <span class="dog-names-search__icon" aria-hidden="true">🔍</span>
              <div id="search-dropdown" class="dog-names-search__dropdown" hidden></div>
            </div>
          </div>

          <aside class="dog-name-generator" aria-labelledby="global-generator-title">
            <div class="dog-name-generator__header">
              <p class="dog-names-eyebrow">Local name generator</p>
              <h2 id="global-generator-title">Generate dog names</h2>
              <span>No account needed. Favorites stay on this device.</span>
            </div>

            <form class="dog-name-generator__controls" data-name-generator-form>
              <div class="dog-name-field">
                <label for="gen-breed">Breed fit</label>
                <select id="gen-breed" data-gen-breed>
                  <option value="">Any breed</option>
                  {breeds
                    .slice()
                    .sort((a: any, b: any) => a.name.localeCompare(b.name))
                    .map((breed: any) => (
                      <option value={breed.slug}>{breed.name}</option>
                    ))}
                </select>
              </div>

              <div class="dog-name-field">
                <label for="gen-gender">Name type</label>
                <select id="gen-gender" data-gen-gender>
                  <option value="any">Any</option>
                  <option value="boy">Boy</option>
                  <option value="girl">Girl</option>
                  <option value="neutral">Flexible / neutral</option>
                </select>
              </div>

              <div class="dog-name-field">
                <label for="gen-category">Style</label>
                <select id="gen-category" data-gen-category>
                  <option value="">Any style</option>
                  {categories.map((category) => (
                    <option value={category}>{category}</option>
                  ))}
                </select>
              </div>

              <div class="dog-name-field">
                <label for="gen-inspiration">Inspiration</label>
                <select id="gen-inspiration" data-gen-inspiration>
                  <option value="">Any inspiration</option>
                  {inspirations.map((inspiration) => (
                    <option value={inspiration}>{inspiration}</option>
                  ))}
                </select>
              </div>

              <div class="dog-name-field">
                <label for="gen-length">Name length</label>
                <select id="gen-length" data-gen-length>
                  <option value="any">Any length</option>
                  <option value="short">Short / easy call</option>
                  <option value="one-two">1–2 syllables</option>
                  <option value="long">Longer / distinctive</option>
                </select>
              </div>

              <div class="dog-name-field">
                <label for="gen-starts">Starts with</label>
                <input id="gen-starts" data-gen-starts maxlength="1" placeholder="Optional letter" />
              </div>

              <label class="dog-name-check">
                <input type="checkbox" data-gen-avoid-commands checked />
                <span>Avoid command-sounding names</span>
              </label>

              <label class="dog-name-check">
                <input type="checkbox" data-gen-breed-fit checked />
                <span>Boost breed-matched style</span>
              </label>

              <div class="dog-name-generator__actions">
                <button type="submit" class="dog-name-button dog-name-button--primary">
                  Generate names
                  <span aria-hidden="true">→</span>
                </button>
                <button type="button" class="dog-name-button dog-name-button--secondary" data-gen-surprise>
                  Surprise me
                </button>
              </div>
            </form>

            <div class="dog-name-generator__output" aria-live="polite">
              <div class="dog-name-generator__output-header">
                <div>
                  <h3>Generated names</h3>
                  <p data-gen-summary>Pick options and generate your first list.</p>
                </div>
                <button type="button" data-gen-copy class="dog-name-icon-button" aria-label="Copy generated names">
                  Copy
                </button>
              </div>

              <div class="dog-name-results" data-gen-results></div>

              <div class="dog-name-generator__utility">
                <button type="button" data-gen-save-all>Save all</button>
                <button type="button" data-gen-export>Export favorites</button>
                <button type="button" data-gen-share>Share</button>
              </div>
            </div>

            <div class="dog-name-favorites">
              <div class="dog-name-favorites__header">
                <h3>Favorites</h3>
                <button type="button" data-gen-clear-favorites>Clear</button>
              </div>
              <div class="dog-name-favorites__list" data-gen-favorites></div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="dog-names-stats" aria-label="Dog name finder statistics">
      <div class="dog-names-container">
        <div class="dog-names-stats__grid">
          <span>🐕 <strong>{breeds.length}</strong> breeds</span>
          <span>✍️ <strong>{allNames.length.toLocaleString()}+</strong> name entries</span>
          <span>🎯 <strong>Breed-aware generator</strong></span>
          <span>💾 <strong>Local favorites</strong></span>
        </div>
      </div>
    </section>

    <div class="dog-names-container dog-names-main">
      <section class="dog-names-section" aria-labelledby="featured-breeds-title">
        <div class="dog-names-section__header">
          <div>
            <p class="dog-names-eyebrow">Popular breeds</p>
            <h2 id="featured-breeds-title">Top Breed Name Guides</h2>
          </div>

          <a href="/breeds" class="dog-names-section__link">
            All breeds →
          </a>
        </div>

        <div class="dog-names-featured-grid">
          {featured.map((b: any) => (
            <a href={`/dog-names/${b.slug}`} class="dog-name-breed-card">
              <div class="dog-name-breed-card__media">
                {b.image_url ? (
                  <>
                    <img
                      src={b.image_url}
                      alt={b.name}
                      width="220"
                      height="150"
                      loading="lazy"
                      decoding="async"
                      data-dog-name-image
                    />
                    <div class="dog-name-breed-card__fallback" hidden>🐕</div>
                  </>
                ) : (
                  <div class="dog-name-breed-card__fallback dog-name-breed-card__fallback--visible">🐕</div>
                )}
              </div>

              <div class="dog-name-breed-card__body">
                <h3>{b.name}</h3>
                {b.akc_popularity && <p>#{b.akc_popularity} popular</p>}
              </div>
            </a>
          ))}
        </div>
      </section>

      <section class="dog-names-section" aria-labelledby="all-breeds-title">
        <div class="dog-names-section__header dog-names-section__header--stack">
          <p class="dog-names-eyebrow">All {breeds.length} breeds</p>
          <h2 id="all-breeds-title">Browse All Breed Name Guides</h2>
        </div>

        <nav class="dog-names-letter-nav" aria-label="Browse breeds by letter">
          {letters.map((letter) => (
            <a href={`#letter-${letter}`}>{letter}</a>
          ))}
        </nav>

        <div class="dog-names-letter-groups">
          {letters.map((letter) => (
            <section id={`letter-${letter}`} class="dog-names-letter-group" aria-labelledby={`letter-${letter}-title`}>
              <div class="dog-names-letter-group__header">
                <h3 id={`letter-${letter}-title`}>{letter}</h3>
                <span aria-hidden="true"></span>
              </div>

              <div class="dog-names-directory-grid">
                {byLetter[letter].sort((a: any, b: any) => a.name.localeCompare(b.name)).map((b: any) => (
                  <a href={`/dog-names/${b.slug}`} class="dog-names-directory-link">
                    {b.image_url && (
                      <img
                        src={b.image_url}
                        alt=""
                        width="28"
                        height="28"
                        loading="lazy"
                        decoding="async"
                        data-dog-name-avatar
                      />
                    )}
                    <span>{b.name}</span>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>
    </div>
  </main>

  <script define:vars={{ breedList, generatorNames }}>
    const STORAGE_KEY = 'pupwiki:dog-name-favorites:v1';
    const LAST_OPTIONS_KEY = 'pupwiki:dog-name-generator-options:v1';

    const input = document.getElementById('hero-search');
    const dropdown = document.getElementById('search-dropdown');

    const form = document.querySelector('[data-name-generator-form]');
    const resultsEl = document.querySelector('[data-gen-results]');
    const summaryEl = document.querySelector('[data-gen-summary]');
    const favoritesEl = document.querySelector('[data-gen-favorites]');

    const controls = {
      breed: document.querySelector('[data-gen-breed]'),
      gender: document.querySelector('[data-gen-gender]'),
      category: document.querySelector('[data-gen-category]'),
      inspiration: document.querySelector('[data-gen-inspiration]'),
      length: document.querySelector('[data-gen-length]'),
      starts: document.querySelector('[data-gen-starts]'),
      avoidCommands: document.querySelector('[data-gen-avoid-commands]'),
      breedFit: document.querySelector('[data-gen-breed-fit]'),
    };

    const COMMAND_WORDS = ['sit', 'stay', 'no', 'down', 'come', 'heel', 'drop', 'leave', 'wait', 'off'];
    let currentResults = [];

    const escapeHtml = (value) =>
      String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');

    const normalize = (value) => String(value || '').toLowerCase().replace(/[^a-z]/g, '');

    const estimateSyllables = (name) => {
      const cleaned = normalize(name);
      if (!cleaned) return 1;
      const groups = cleaned.match(/[aeiouy]+/g) || [];
      let count = groups.length || 1;
      if (cleaned.endsWith('e') && count > 1) count -= 1;
      return Math.max(1, count);
    };

    const soundsLikeCommand = (name) => {
      const cleaned = normalize(name);
      return COMMAND_WORDS.some((command) => cleaned === command || cleaned.includes(command));
    };

    const getFavorites = () => {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      } catch {
        return [];
      }
    };

    const setFavorites = (favorites) => {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(favorites.slice(0, 80)));
      renderFavorites();
    };

    const favoriteKey = (item) => `${item.name}|${item.gender}|${item.category}`;

    const addFavorite = (item) => {
      const favorites = getFavorites();
      const key = favoriteKey(item);
      if (!favorites.some((fav) => favoriteKey(fav) === key)) {
        favorites.unshift({ ...item, savedAt: new Date().toISOString() });
        setFavorites(favorites);
      }
    };

    const removeFavorite = (key) => {
      setFavorites(getFavorites().filter((fav) => favoriteKey(fav) !== key));
    };

    const getOptions = () => ({
      breed: controls.breed?.value || '',
      gender: controls.gender?.value || 'any',
      category: controls.category?.value || '',
      inspiration: controls.inspiration?.value || '',
      length: controls.length?.value || 'any',
      starts: (controls.starts?.value || '').trim().slice(0, 1).toUpperCase(),
      avoidCommands: Boolean(controls.avoidCommands?.checked),
      breedFit: Boolean(controls.breedFit?.checked),
    });

    const saveOptions = () => {
      localStorage.setItem(LAST_OPTIONS_KEY, JSON.stringify(getOptions()));
    };

    const loadOptions = () => {
      try {
        const options = JSON.parse(localStorage.getItem(LAST_OPTIONS_KEY) || '{}');
        Object.entries(options).forEach(([key, value]) => {
          if (!controls[key]) return;
          if (controls[key].type === 'checkbox') controls[key].checked = Boolean(value);
          else controls[key].value = value;
        });
      } catch {
        // Ignore invalid stored options.
      }
    };

    const getBreed = (slug) => breedList.find((breed) => breed.slug === slug);

    const scoreName = (item, options, breed) => {
      let score = 1000 - Number(item.rank || 999);

      if (item.enriched) score += 20;
      if (options.gender !== 'any' && options.gender !== 'neutral' && item.gender === options.gender) score += 120;
      if (options.gender === 'neutral') score += item.name.length <= 6 ? 60 : 0;
      if (options.category && item.category === options.category) score += 180;
      if (options.inspiration && item.inspiration === options.inspiration) score += 160;
      if (options.starts && item.name.toUpperCase().startsWith(options.starts)) score += 140;

      if (breed && options.breedFit) {
        if (Array.isArray(breed.styles) && breed.styles.includes(item.category)) score += 220;
        if (Array.isArray(breed.inspirations) && breed.inspirations.includes(item.inspiration)) score += 180;

        const temperament = String(breed.temperament || '').toLowerCase();
        if (temperament.includes('friendly') && ['Cute', 'Classic', 'Trendy'].includes(item.category)) score += 50;
        if ((temperament.includes('loyal') || temperament.includes('protective')) && item.category === 'Tough') score += 70;
        if ((temperament.includes('intelligent') || temperament.includes('smart')) && ['Mythology', 'Human'].includes(item.inspiration)) score += 55;
        if (breed.energy === 'active' && ['Tough', 'Trendy'].includes(item.category)) score += 45;
        if (breed.energy === 'calm' && ['Classic', 'Cute'].includes(item.category)) score += 45;
      }

      const syllables = estimateSyllables(item.name);
      if (options.length === 'short' && item.name.length <= 5) score += 140;
      if (options.length === 'one-two' && syllables <= 2) score += 130;
      if (options.length === 'long' && item.name.length >= 7) score += 120;

      score += Math.random() * 18;
      return score;
    };

    const filterPool = (options) => {
      const breed = getBreed(options.breed);

      return generatorNames
        .filter((item) => {
          if (!item.name) return false;
          if (options.gender !== 'any' && options.gender !== 'neutral' && item.gender !== options.gender) return false;
          if (options.category && item.category !== options.category) return false;
          if (options.inspiration && item.inspiration !== options.inspiration) return false;
          if (options.starts && !item.name.toUpperCase().startsWith(options.starts)) return false;
          if (options.avoidCommands && soundsLikeCommand(item.name)) return false;

          const syllables = estimateSyllables(item.name);
          if (options.length === 'short' && item.name.length > 5) return false;
          if (options.length === 'one-two' && syllables > 2) return false;
          if (options.length === 'long' && item.name.length < 7) return false;

          return true;
        })
        .map((item) => ({
          ...item,
          syllables: estimateSyllables(item.name),
          score: scoreName(item, options, breed),
          breedName: breed?.name || '',
        }))
        .sort((a, b) => b.score - a.score);
    };

    const renderResults = (items, options) => {
      currentResults = items.slice(0, 12);

      if (!resultsEl || !summaryEl) return;

      if (!currentResults.length) {
        summaryEl.textContent = 'No names matched those filters. Try removing one option.';
        resultsEl.innerHTML = '<p class="dog-name-empty">No matching names yet.</p>';
        return;
      }

      const breed = getBreed(options.breed);
      const bits = [
        breed?.name || 'Any breed',
        options.gender !== 'any' ? options.gender : 'all name types',
        options.category || 'any style',
        options.inspiration || 'any inspiration',
      ];

      summaryEl.textContent = bits.join(' · ');

      resultsEl.innerHTML = currentResults
        .map(
          (item, index) => `
            <article class="dog-name-result-card">
              <div>
                <span>#${index + 1}</span>
                <h4>${escapeHtml(item.name)}</h4>
                <p>${escapeHtml(item.gender)} · ${escapeHtml(item.category)} · ${escapeHtml(item.inspiration)} · ${item.syllables} syll.</p>
              </div>
              <button type="button" data-save-name="${escapeHtml(favoriteKey(item))}">♡</button>
            </article>
          `
        )
        .join('');

      resultsEl.querySelectorAll('[data-save-name]').forEach((button, index) => {
        button.addEventListener('click', () => {
          addFavorite(currentResults[index]);
          button.textContent = '♥';
        });
      });
    };

    const generate = () => {
      const options = getOptions();
      saveOptions();
      renderResults(filterPool(options), options);
    };

    const surprise = () => {
      const random = (arr) => arr[Math.floor(Math.random() * arr.length)];

      controls.gender.value = random(['any', 'boy', 'girl', 'neutral']);
      controls.category.value = random(['', ...new Set(generatorNames.map((item) => item.category).filter(Boolean))]);
      controls.inspiration.value = random(['', ...new Set(generatorNames.map((item) => item.inspiration).filter(Boolean))]);
      controls.length.value = random(['any', 'short', 'one-two', 'long']);
      controls.starts.value = '';
      controls.avoidCommands.checked = true;
      controls.breedFit.checked = true;

      generate();
    };

    const renderFavorites = () => {
      if (!favoritesEl) return;

      const favorites = getFavorites();

      if (!favorites.length) {
        favoritesEl.innerHTML = '<p class="dog-name-empty">No favorites yet. Tap ♡ on generated names.</p>';
        return;
      }

      favoritesEl.innerHTML = favorites
        .map(
          (item) => `
            <div class="dog-name-favorite-item">
              <span>${escapeHtml(item.name)}</span>
              <button type="button" data-remove-favorite="${escapeHtml(favoriteKey(item))}" aria-label="Remove ${escapeHtml(item.name)}">×</button>
            </div>
          `
        )
        .join('');

      favoritesEl.querySelectorAll('[data-remove-favorite]').forEach((button) => {
        button.addEventListener('click', () => removeFavorite(button.dataset.removeFavorite));
      });
    };

    const namesText = (items) => items.map((item) => item.name).join(', ');

    const copyGenerated = async () => {
      const text = namesText(currentResults);
      if (!text) return;
      await navigator.clipboard?.writeText(text);
    };

    const saveAll = () => {
      currentResults.forEach(addFavorite);
      renderFavorites();
    };

    const exportFavorites = () => {
      const favorites = getFavorites();
      const rows = [
        ['name', 'gender', 'category', 'inspiration', 'source_breed', 'saved_at'],
        ...favorites.map((item) => [
          item.name,
          item.gender,
          item.category,
          item.inspiration,
          item.breedName || '',
          item.savedAt || '',
        ]),
      ];

      const csv = rows
        .map((row) => row.map((cell) => `"${String(cell || '').replaceAll('"', '""')}"`).join(','))
        .join('\n');

      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = 'pupwiki-dog-name-favorites.csv';
      link.click();
      URL.revokeObjectURL(url);
    };

    const shareNames = async () => {
      const favorites = getFavorites();
      const list = favorites.length ? favorites : currentResults;
      const text = `My PupWiki dog name ideas: ${namesText(list)}`;

      if (navigator.share) {
        await navigator.share({ title: 'PupWiki dog name ideas', text, url: window.location.href });
      } else {
        await navigator.clipboard?.writeText(`${text}\n${window.location.href}`);
      }
    };

    function hideDropdown() {
      if (!dropdown) return;
      dropdown.hidden = true;
      dropdown.innerHTML = '';
    }

    function showDropdown(hits) {
      if (!dropdown) return;

      dropdown.innerHTML = hits
        .map((breed) => {
          const image = breed.img
            ? `<img src="${escapeHtml(breed.img)}" alt="" loading="lazy" decoding="async" />`
            : `<span class="dog-names-search__fallback">🐕</span>`;

          return `
            <a href="/dog-names/${encodeURIComponent(breed.slug)}" class="dog-names-search__result">
              ${image}
              <span>${escapeHtml(breed.name)} names →</span>
            </a>
          `;
        })
        .join('');

      dropdown.hidden = false;
    }

    input?.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();

      if (!q || q.length < 2) {
        hideDropdown();
        return;
      }

      const hits = breedList.filter((breed) => breed.name.toLowerCase().includes(q)).slice(0, 8);

      if (!hits.length) {
        hideDropdown();
        return;
      }

      showDropdown(hits);
    });

    document.addEventListener('click', (event) => {
      if (!input?.contains(event.target) && !dropdown?.contains(event.target)) {
        hideDropdown();
      }
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      generate();
    });

    document.querySelector('[data-gen-surprise]')?.addEventListener('click', surprise);
    document.querySelector('[data-gen-copy]')?.addEventListener('click', copyGenerated);
    document.querySelector('[data-gen-save-all]')?.addEventListener('click', saveAll);
    document.querySelector('[data-gen-export]')?.addEventListener('click', exportFavorites);
    document.querySelector('[data-gen-share]')?.addEventListener('click', shareNames);
    document.querySelector('[data-gen-clear-favorites]')?.addEventListener('click', () => setFavorites([]));

    controls.starts?.addEventListener('input', () => {
      controls.starts.value = controls.starts.value.replace(/[^a-z]/gi, '').slice(0, 1).toUpperCase();
    });

    document.querySelectorAll('[data-dog-name-image]').forEach((image) => {
      image.addEventListener('error', () => {
        const fallback = image.nextElementSibling;
        image.hidden = true;
        if (fallback) fallback.hidden = false;
      });
    });

