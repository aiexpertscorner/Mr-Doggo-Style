---
import BaseLayout from '../../layouts/BaseLayout.astro';
import masterBreeds from '../../data/master-breeds.json';
import allNamesData from '../../data/dog-names.json';
import breedLinkMap from '../../data/breed-link-map.json';
import productIndex from '../../data/product-index.json';

const SITE = 'https://pupwiki.com';
const TAG = 'aiexpertscorn-20';

export function getStaticPaths() {
  return (masterBreeds as any[]).map((b) => ({ params: { breed: b.slug } }));
}

const { breed: slug } = Astro.params;
const b = (masterBreeds as any[]).find((x) => x.slug === slug);

if (!b) return Astro.redirect('/dog-names');

const links = (breedLinkMap as any)[slug] || {};
const rank = b.ranking_data || {};
const styles = b.name_styles || ['Classic', 'Trendy'];
const insps = b.name_inspirations || ['Classic Pet', 'Nature'];
const n = b.name;

const foodId = b.product_picks?.['dog-food'];
const foodProd = foodId ? (productIndex as any)[foodId] : null;

type NameEntry = {
  name: string;
  gender: string;
  category: string;
  inspiration: string;
  rank: number;
  letter?: string;
  enriched?: boolean;
};

const allNames = allNamesData as NameEntry[];

function filterNames(gender: string, count: number) {
  return allNames
    .filter((x) => x.gender === gender && (styles.includes(x.category) || insps.includes(x.inspiration)))
    .sort((a, b) => (a.rank || 9999) - (b.rank || 9999))
    .slice(0, count);
}

function getByCategory(cat: string, count = 12) {
  return allNames
    .filter((x) => x.category === cat)
    .sort((a, b) => (a.rank || 9999) - (b.rank || 9999))
    .slice(0, count)
    .map((x) => x.name);
}

function getByInspiration(insp: string, count = 12) {
  return allNames
    .filter((x) => x.inspiration === insp)
    .sort((a, b) => (a.rank || 9999) - (b.rank || 9999))
    .slice(0, count)
    .map((x) => x.name);
}

const boys = filterNames('boy', 20);
const girls = filterNames('girl', 20);

const THEMES = [
  styles.includes('Tough') && {
    id: 'tough',
    label: '💪 Tough & Strong',
    names: getByCategory('Tough', 10),
  },
  styles.includes('Cute') && {
    id: 'cute',
    label: '🌸 Cute & Sweet',
    names: getByCategory('Cute', 10),
  },
  styles.includes('Classic') && {
    id: 'classic',
    label: '⭐ Classic & Timeless',
    names: getByCategory('Classic', 10),
  },
  styles.includes('Trendy') && {
    id: 'trendy',
    label: '✨ Trendy & Modern',
    names: getByCategory('Trendy', 10),
  },
  insps.includes('Nature') && {
    id: 'nature',
    label: '🌿 Nature-Inspired',
    names: getByInspiration('Nature', 10),
  },
  insps.includes('Mythology') && {
    id: 'myth',
    label: '⚡ Mythology & Legends',
    names: getByInspiration('Mythology', 10),
  },
].filter(Boolean) as any[];

if (!THEMES.find((theme) => theme.id === 'nature')) {
  THEMES.push({
    id: 'nature',
    label: '🌿 Nature-Inspired',
    names: getByInspiration('Nature', 10),
  });
}

if (!THEMES.find((theme) => theme.id === 'classic')) {
  THEMES.push({
    id: 'classic',
    label: '⭐ Classic Names',
    names: getByCategory('Classic', 10),
  });
}

const temp = (b.temperament || '').toLowerCase();

const personality = temp.includes('friendly')
  ? 'friendly, outgoing'
  : temp.includes('loyal') || temp.includes('protective')
    ? 'loyal, protective'
    : temp.includes('intelligent') || temp.includes('smart')
      ? 'intelligent, quick-learning'
      : temp.includes('gentle')
        ? 'gentle, even-tempered'
        : `${b.energy_level}-energy`;

const intel_note = rank.intelligence_rank
  ? `Ranked #${rank.intelligence_rank} in canine intelligence, ${n}s learn their name quickly — 1–2 syllable names ending in a vowel work best.`
  : `${n}s respond best to 1–2 syllable names ending in a vowel (Bella, Milo, Daisy).`;

const relatedBreeds = (masterBreeds as any[])
  .filter((x) => x.slug !== slug && x.size_category === b.size_category && x.image_url)
  .slice(0, 4);

const topNames = [...boys.slice(0, 3).map((x: any) => x.name), ...girls.slice(0, 3).map((x: any) => x.name)];

const profileRows = [
  ['Size', b.size_category],
  ['Energy', b.energy_level],
  ['Training', b.training_level],
  rank.intelligence_rank ? ['Intelligence', `#${rank.intelligence_rank} worldwide`] : null,
  b.origin_country ? ['Origin', b.origin_country] : null,
].filter(Boolean) as string[][];

const guideLinks = [
  links.hub && { href: links.hub, emoji: '🐾', label: `${n} complete guide` },
  links.food_post && { href: links.food_post, emoji: '🍖', label: `Best food for ${n}s` },
  links.toy_post && { href: links.toy_post, emoji: '🎾', label: `Best toys for ${n}s` },
  links.health_post && { href: links.health_post, emoji: '🩺', label: `${n} health guide` },
  links.training_post && { href: links.training_post, emoji: '🦮', label: `Training a ${n}` },
].filter(Boolean) as any[];

const categories = Array.from(new Set(allNames.map((item) => item.category).filter(Boolean))).sort();
const inspirations = Array.from(new Set(allNames.map((item) => item.inspiration).filter(Boolean))).sort();

const generatorNames = allNames.map((item) => ({
  name: item.name,
  gender: item.gender,
  category: item.category,
  inspiration: item.inspiration,
  rank: item.rank || 9999,
  letter: item.letter || item.name?.[0]?.toUpperCase() || '',
  enriched: Boolean(item.enriched),
}));

const generatorBreed = {
  slug,
  name: n,
  size: b.size_category || '',
  energy: b.energy_level || '',
  temperament: b.temperament || '',
  styles,
  inspirations: insps,
};

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `Best boy names for ${n}s?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Top boy names: ${boys.slice(0, 5).map((x) => x.name).join(', ')}.`,
      },
    },
    {
      '@type': 'Question',
      name: `Best girl names for ${n}s?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Top girl names: ${girls.slice(0, 5).map((x) => x.name).join(', ')}.`,
      },
    },
  ],
});
---

<BaseLayout
  title={`Best ${n} Names 2026 — ${boys[0]?.name}, ${girls[0]?.name} & More Boy & Girl Picks`}
  description={`${boys.length + girls.length}+ names for ${n}s matched to their ${personality} personality. Ranked lists, themed collections, and expert naming tips.`}
  canonicalUrl={`${SITE}/dog-names/${slug}`}
  bodyClass="dog-name-detail-page bg-white text-slate-900"
>
  <script type="application/ld+json" set:html={jsonLd} />

  <main class="dog-name-detail">
    <section class="dog-name-detail-hero" aria-labelledby="dog-name-detail-title">
      <div class="dog-name-detail-container">
        <nav class="dog-name-detail-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/dog-names">Dog Names</a>
          <span aria-hidden="true">›</span>
          <span>{n}</span>
        </nav>

        <div class="dog-name-detail-hero__grid">
          {b.image_url && (
            <div class="dog-name-detail-hero__media">
              <img
                src={b.image_url}
                alt={`${n} dog`}
                width="320"
                height="320"
                loading="eager"
                decoding="async"
                data-dog-name-detail-image
              />

              {rank.intelligence_rank && rank.intelligence_rank <= 20 && (
                <span class="dog-name-detail-hero__badge" aria-label="Highly intelligent breed">
                  🧠
                </span>
              )}
            </div>
          )}

          <div class="dog-name-detail-hero__content">
            <div class="dog-name-detail-hero__pills" aria-label={`${n} name attributes`}>
              {styles.map((style: string) => (
                <span class="dog-name-pill dog-name-pill--accent">{style}</span>
              ))}

              {insps.slice(0, 2).map((insp: string) => (
                <span class="dog-name-pill dog-name-pill--warm">{insp}</span>
              ))}

              <span class="dog-name-pill dog-name-pill--success">{boys.length + girls.length}+ names</span>
            </div>

            <h1 id="dog-name-detail-title" class="dog-name-detail-hero__title">
              Best
              <span>{n}</span>
              Names
              <em>2026</em>
            </h1>

            <p class="dog-name-detail-hero__subtitle">
              {n}s are {personality} dogs. Names curated from 7,000+ entries, filtered and ranked for this breed's
              temperament and style.
            </p>

            <div class="dog-name-detail-hero__top-picks" aria-label={`Top ${n} name picks`}>
              <span>Top picks:</span>
              {topNames.map((name: string) => (
                <strong>{name}</strong>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="dog-name-detail-main">
      <div class="dog-name-detail-container">
        <div class="dog-name-detail-layout">
          <div class="dog-name-detail-content">
            <section class="dog-name-generator-panel" aria-labelledby="breed-generator-title">
              <div class="dog-name-generator-panel__intro">
                <p class="dog-name-detail-eyebrow">Breed-aware generator</p>
                <h2 id="breed-generator-title">Generate {n} name ideas</h2>
                <span>
                  Local-only favorites. No account, no backend, no saved user profile.
                </span>
              </div>

              <form class="breed-name-generator" data-breed-name-generator>
                <div class="dog-name-field">
                  <label for="breed-gen-gender">Name type</label>
                  <select id="breed-gen-gender" data-gen-gender>
                    <option value="any">Any</option>
                    <option value="boy">Boy</option>
                    <option value="girl">Girl</option>
                    <option value="neutral">Flexible / neutral</option>
                  </select>
                </div>

                <div class="dog-name-field">
                  <label for="breed-gen-category">Style</label>
                  <select id="breed-gen-category" data-gen-category>
                    <option value="">Best breed fit</option>
                    {categories.map((category) => (
                      <option value={category}>{category}</option>
                    ))}
                  </select>
                </div>

                <div class="dog-name-field">
                  <label for="breed-gen-inspiration">Inspiration</label>
                  <select id="breed-gen-inspiration" data-gen-inspiration>
                    <option value="">Best breed fit</option>
                    {inspirations.map((inspiration) => (
                      <option value={inspiration}>{inspiration}</option>
                    ))}
                  </select>
                </div>

                <div class="dog-name-field">
                  <label for="breed-gen-length">Name length</label>
                  <select id="breed-gen-length" data-gen-length>
                    <option value="one-two">1–2 syllables</option>
                    <option value="short">Short / easy call</option>
                    <option value="any">Any length</option>
                    <option value="long">Longer / distinctive</option>
                  </select>
                </div>

                <div class="dog-name-field">
                  <label for="breed-gen-starts">Starts with</label>
                  <input id="breed-gen-starts" data-gen-starts maxlength="1" placeholder="Optional letter" />
                </div>

                <label class="dog-name-check">
                  <input type="checkbox" data-gen-avoid-commands checked />
                  <span>Avoid command-sounding names</span>
                </label>

                <label class="dog-name-check">
                  <input type="checkbox" data-gen-breed-fit checked />
                  <span>Boost {n} style match</span>
                </label>

                <div class="dog-name-generator-actions">
                  <button type="submit" class="dog-name-button dog-name-button--primary">
                    Generate {n} names
                    <span aria-hidden="true">→</span>
                  </button>
                  <button type="button" class="dog-name-button dog-name-button--secondary" data-gen-surprise>
                    Surprise me
                  </button>
                </div>
              </form>

              <div class="dog-name-generator-output" aria-live="polite">
                <div class="dog-name-generator-output__header">
                  <div>
                    <h3>Generated names</h3>
                    <p data-gen-summary>Breed-matched ideas for {n}.</p>
                  </div>
                  <button type="button" data-gen-copy class="dog-name-icon-button">Copy</button>
                </div>

                <div class="dog-name-results" data-gen-results></div>

                <div class="dog-name-generator-utility">
                  <button type="button" data-gen-save-all>Save all</button>
                  <button type="button" data-gen-export>Export favorites</button>
                  <button type="button" data-gen-share>Share</button>
                </div>
              </div>

              <div class="dog-name-favorites">
                <div class="dog-name-favorites__header">
                  <h3>Local favorites</h3>
                  <button type="button" data-gen-clear-favorites>Clear</button>
                </div>
                <div class="dog-name-favorites__list" data-gen-favorites></div>
              </div>
            </section>

            <section class="dog-name-tabs" aria-label={`${n} boy and girl names`}>
              <div class="dog-name-tabs__buttons" role="tablist" aria-label="Name gender tabs">
                <button
                  id="tab-boys"
                  class="dog-name-tab is-active"
                  type="button"
                  role="tab"
                  aria-selected="true"
                  aria-controls="panel-boys"
                  data-tab-target="boys"
                >
                  🐾 Boy Names ({boys.length})
                </button>

                <button
                  id="tab-girls"
                  class="dog-name-tab"
                  type="button"
                  role="tab"
                  aria-selected="false"
                  aria-controls="panel-girls"
                  data-tab-target="girls"
                >
                  🌸 Girl Names ({girls.length})
                </button>
              </div>

              <div id="panel-boys" class="dog-name-tab-panel" role="tabpanel" aria-labelledby="tab-boys">
                <div class="dog-name-grid">
                  {boys.map((entry: any, i: number) => (
                    <article class:list={['dog-name-card', i < 3 && 'dog-name-card--featured']}>
                      <div class="dog-name-card__top">
                        <span>#{i + 1}</span>
                        {i < 3 && <em>{i === 0 ? '🥇' : i === 1 ? '🥈' : '🥉'}</em>}
                      </div>

                      <h2>{entry.name}</h2>
                      <p>{entry.category}</p>
                    </article>
                  ))}
                </div>

                <p class="dog-name-tab-panel__note">
                  Top {boys.length} boy names for {n}s, ranked by popularity and breed match.
                </p>
              </div>

              <div id="panel-girls" class="dog-name-tab-panel" role="tabpanel" aria-labelledby="tab-girls" hidden>
                <div class="dog-name-grid">
                  {girls.map((entry: any, i: number) => (
                    <article class:list={['dog-name-card', 'dog-name-card--girl', i < 3 && 'dog-name-card--featured']}>
                      <div class="dog-name-card__top">
                        <span>#{i + 1}</span>
                        {i < 3 && <em>{i === 0 ? '🥇' : i === 1 ? '🥈' : '🥉'}</em>}
                      </div>

                      <h2>{entry.name}</h2>
                      <p>{entry.category}</p>
                    </article>
                  ))}
                </div>

                <p class="dog-name-tab-panel__note">
                  Top {girls.length} girl names for {n}s, ranked by popularity and breed match.
                </p>
              </div>
            </section>

            {THEMES.length > 0 && (
              <section class="dog-name-section" aria-labelledby="theme-title">
                <p class="dog-name-detail-eyebrow">By style</p>
                <h2 id="theme-title">Names by Theme</h2>

                <div class="dog-name-theme-grid">
                  {THEMES.slice(0, 6).map((theme: any) => (
                    <article class:list={['dog-name-theme-card', `is-theme-${theme.id}`]}>
                      <h3>{theme.label}</h3>
                      <div>
                        {theme.names.map((name: string) => (
                          <span>{name}</span>
                        ))}
                      </div>
                    </article>
                  ))}
                </div>
              </section>
            )}

            <section class="dog-name-guide" aria-labelledby="naming-guide-title">
              <div class="dog-name-guide__header">
                <span aria-hidden="true">📖</span>
                <h2 id="naming-guide-title">How to Name Your {n}</h2>
              </div>

              <div class="dog-name-guide__grid">
                {[
                  {
                    icon: '✂️',
                    title: 'Keep it short — 1–2 syllables',
                    body: `${n}s distinguish their name most easily when it's short and ends in a vowel (Bella, Milo, Luna, Charlie).`,
                  },
                  {
                    icon: '🚫',
                    title: 'Avoid command sounds',
                    body: `Names sounding like "sit," "stay," "no," "down," or "come" create confusion. Avoid names rhyming with family members too.`,
                  },
                  {
                    icon: '🎤',
                    title: 'Test it in three tones',
                    body: `Excited ("Milo!"), firm ("Milo, no!"), and calling ("Come, Milo!"). A good name works in all three.`,
                  },
                  {
                    icon: '🧠',
                    title: 'Intelligence matters',
                    body: intel_note,
                  },
                  {
                    icon: '📅',
                    title: 'Give it a week',
                    body: `Use the name consistently for 5–7 days before deciding if it fits. Most names grow on owners quickly.`,
                  },
                  {
                    icon: '🔄',
                    title: 'Changing a name is easy',
                    body: `Dogs adapt within 1–2 weeks when you pair the new name with high-value treats consistently.`,
                  },
                ].map((tip) => (
                  <article class="dog-name-tip">
                    <span aria-hidden="true">{tip.icon}</span>
                    <div>
                      <h3>{tip.title}</h3>
                      <p>{tip.body}</p>
                    </div>
                  </article>
                ))}
              </div>
            </section>

            <section class="dog-name-section" aria-labelledby="trait-title">
              <p class="dog-name-detail-eyebrow">Match by personality</p>
              <h2 id="trait-title">Names by {n} Personality Trait</h2>

              <div class="dog-name-table-wrap">
                <table class="dog-name-table">
                  <thead>
                    <tr>
                      <th>Trait</th>
                      <th>Suggested Names</th>
                    </tr>
                  </thead>
                  <tbody>
                    {[
                      ['Energetic', 'Atlas, Blaze, Chase, Dash, Rocket, Ziggy, Bolt, Flash'],
                      ['Gentle', 'Biscuit, Daisy, Dove, Maple, Willow, Honey, Sage, Fern'],
                      ['Loyal', 'Ace, Duke, Faith, Honor, Ranger, Sterling, Valor, Rex'],
                      ['Intelligent', 'Archer, Einstein, Pixel, Tesla, Vega, Newton, Sage'],
                      ['Playful', 'Bingo, Gizmo, Noodle, Pickle, Sprout, Waffles, Bubbles'],
                      ['Regal', 'Apollo, Caesar, Duchess, Empress, Baron, Athena, Rex'],
                    ].map(([trait, names]) => (
                      <tr>
                        <td>{trait}</td>
                        <td>{names}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>

            <section class="dog-name-section dog-name-faq" aria-labelledby="faq-title">
              <p class="dog-name-detail-eyebrow">Common questions</p>
              <h2 id="faq-title">{n} Naming FAQs</h2>

              {[
                [
                  `What are the best names for a ${n}?`,
                  `Based on the ${n}'s ${personality} character, top picks are ${boys
                    .slice(0, 3)
                    .map((x: any) => x.name)
                    .join(', ')} (boys) and ${girls
                    .slice(0, 3)
                    .map((x: any) => x.name)
                    .join(', ')} (girls).`,
                ],
                [`How many syllables should my ${n}'s name have?`, `1–2 syllables is ideal. ${intel_note}`],
                [
                  `Can I change my ${n}'s name after adoption?`,
                  `Yes — dogs adapt within 1–2 weeks with consistent positive reinforcement. Pair the new name with treats every time your dog responds.`,
                ],
                [
                  `What names should I avoid for a ${n}?`,
                  `Avoid names rhyming with "sit," "stay," "no," "down," or "come." Also avoid names too similar to family members' names.`,
                ],
              ].map(([q, a]) => (
                <details>
                  <summary>
                    <span>{q}</span>
                    <em class="faq-icon" aria-hidden="true">+</em>
                  </summary>
                  <p>{a}</p>
                </details>
              ))}
            </section>

            {relatedBreeds.length > 0 && (
              <section class="dog-name-section" aria-labelledby="related-title">
                <p class="dog-name-detail-eyebrow">Similar breeds</p>
                <h2 id="related-title">Names for Similar Breeds</h2>

                <div class="dog-name-related-grid">
                  {relatedBreeds.map((rb: any) => (
                    <a href={`/dog-names/${rb.slug}`} class="dog-name-related-card">
                      <div>
                        <img
                          src={rb.image_url}
                          alt={rb.name}
                          width="200"
                          height="120"
                          loading="lazy"
                          decoding="async"
                          data-related-image
                        />
                      </div>
                      <p>{rb.name} names →</p>
                    </a>
                  ))}
                </div>
              </section>
            )}
          </div>

          <aside class="dog-name-sidebar" aria-label={`${n} naming sidebar`}>
            <div class="dog-name-sidebar-card dog-name-sidebar-card--highlight">
              <p class="dog-name-detail-eyebrow">Top {n} Names</p>

              <div class="dog-name-sidebar-list">
                <h2>Boys</h2>
                {boys.slice(0, 5).map((entry: any, i: number) => (
                  <div>
                    <span>#{i + 1}</span>
                    <strong>{entry.name}</strong>
                    <em>{entry.category}</em>
                  </div>
                ))}
              </div>

              <div class="dog-name-sidebar-list">
                <h2>Girls</h2>
                {girls.slice(0, 5).map((entry: any, i: number) => (
                  <div>
                    <span>#{i + 1}</span>
                    <strong>{entry.name}</strong>
                    <em>{entry.category}</em>
                  </div>
                ))}
              </div>
            </div>

            <div class="dog-name-sidebar-card">
              <p class="dog-name-detail-eyebrow">{n} profile</p>

              <dl>
                {profileRows.map((row: any) => (
                  <div>
                    <dt>{row[0]}</dt>
                    <dd>{row[1]}</dd>
                  </div>
                ))}
              </dl>
            </div>

            {guideLinks.length > 0 && (
              <div class="dog-name-sidebar-card">
                <p class="dog-name-detail-eyebrow">{n} Guides</p>

                <nav class="dog-name-sidebar-nav" aria-label={`${n} related guides`}>
                  {guideLinks.map((item: any) => (
                    <a href={item.href}>
                      <span>{item.emoji}</span>
                      <span>{item.label} →</span>
                    </a>
                  ))}
                </nav>
              </div>
            )}

            <a href="/dog-names" class="dog-name-sidebar-cta">
              Browse all breed names →
            </a>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <script define:vars={{ generatorNames, generatorBreed }}>
    const STORAGE_KEY = 'pupwiki:dog-name-favorites:v1';
    const LAST_OPTIONS_KEY = `pupwiki:dog-name-generator-options:${generatorBreed.slug}`;

    const form = document.querySelector('[data-breed-name-generator]');
    const resultsEl = document.querySelector('[data-gen-results]');
    const summaryEl = document.querySelector('[data-gen-summary]');
    const favoritesEl = document.querySelector('[data-gen-favorites]');

    const controls = {
      gender: document.querySelector('[data-gen-gender]'),
      category: document.querySelector('[data-gen-category]'),
      inspiration: document.querySelector('[data-gen-inspiration]'),
      length: document.querySelector('[data-gen-length]'),
      starts: document.querySelector('[data-gen-starts]'),
      avoidCommands: document.querySelector('[data-gen-avoid-commands]'),
      breedFit: document.querySelector('[data-gen-breed-fit]'),
    };

    const COMMAND_WORDS = ['sit', 'stay', 'no', 'down', 'come', 'heel', 'drop', 'leave', 'wait', 'off'];
    let currentResults = [];

    const escapeHtml = (value) =>
      String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');

    const normalize = (value) => String(value || '').toLowerCase().replace(/[^a-z]/g, '');

    const estimateSyllables = (name) => {
      const cleaned = normalize(name);
      if (!cleaned) return 1;
      const groups = cleaned.match(/[aeiouy]+/g) || [];
      let count = groups.length || 1;
      if (cleaned.endsWith('e') && count > 1) count -= 1;
      return Math.max(1, count);
    };

    const soundsLikeCommand = (name) => {
      const cleaned = normalize(name);
      return COMMAND_WORDS.some((command) => cleaned === command || cleaned.includes(command));
    };

    const getFavorites = () => {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      } catch {
        return [];
      }
    };

    const setFavorites = (favorites) => {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(favorites.slice(0, 80)));
      renderFavorites();
    };

    const favoriteKey = (item) => `${item.name}|${item.gender}|${item.category}`;

    const addFavorite = (item) => {
      const favorites = getFavorites();
      const key = favoriteKey(item);
      if (!favorites.some((fav) => favoriteKey(fav) === key)) {
        favorites.unshift({ ...item, sourceBreed: generatorBreed.name, sourceSlug: generatorBreed.slug, savedAt: new Date().toISOString() });
        setFavorites(favorites);
      }
    };

    const removeFavorite = (key) => {
      setFavorites(getFavorites().filter((fav) => favoriteKey(fav) !== key));
    };

    const getOptions = () => ({
      gender: controls.gender?.value || 'any',
      category: controls.category?.value || '',
      inspiration: controls.inspiration?.value || '',
      length: controls.length?.value || 'one-two',
      starts: (controls.starts?.value || '').trim().slice(0, 1).toUpperCase(),
      avoidCommands: Boolean(controls.avoidCommands?.checked),
      breedFit: Boolean(controls.breedFit?.checked),
    });

    const saveOptions = () => {
      localStorage.setItem(LAST_OPTIONS_KEY, JSON.stringify(getOptions()));
    };

    const loadOptions = () => {
      try {
        const options = JSON.parse(localStorage.getItem(LAST_OPTIONS_KEY) || '{}');
        Object.entries(options).forEach(([key, value]) => {
          if (!controls[key]) return;
          if (controls[key].type === 'checkbox') controls[key].checked = Boolean(value);
          else controls[key].value = value;
        });
      } catch {
        // Ignore invalid stored options.
      }
    };

    const scoreName = (item, options) => {
      let score = 1000 - Number(item.rank || 999);

      if (item.enriched) score += 20;
      if (options.gender !== 'any' && options.gender !== 'neutral' && item.gender === options.gender) score += 120;
      if (options.gender === 'neutral') score += item.name.length <= 6 ? 60 : 0;
      if (options.category && item.category === options.category) score += 180;
      if (options.inspiration && item.inspiration === options.inspiration) score += 160;
      if (options.starts && item.name.toUpperCase().startsWith(options.starts)) score += 140;

      if (options.breedFit) {
        if (Array.isArray(generatorBreed.styles) && generatorBreed.styles.includes(item.category)) score += 240;
        if (Array.isArray(generatorBreed.inspirations) && generatorBreed.inspirations.includes(item.inspiration)) score += 200;

        const temperament = String(generatorBreed.temperament || '').toLowerCase();
        if (temperament.includes('friendly') && ['Cute', 'Classic', 'Trendy'].includes(item.category)) score += 55;
        if ((temperament.includes('loyal') || temperament.includes('protective')) && item.category === 'Tough') score += 75;
        if ((temperament.includes('intelligent') || temperament.includes('smart')) && ['Mythology', 'Human'].includes(item.inspiration)) score += 60;
        if (generatorBreed.energy === 'active' && ['Tough', 'Trendy'].includes(item.category)) score += 50;
        if (generatorBreed.energy === 'calm' && ['Classic', 'Cute'].includes(item.category)) score += 50;
      }

      const syllables = estimateSyllables(item.name);
      if (options.length === 'short' && item.name.length <= 5) score += 140;
      if (options.length === 'one-two' && syllables <= 2) score += 130;
      if (options.length === 'long' && item.name.length >= 7) score += 120;

      score += Math.random() * 18;
      return score;
    };

    const filterPool = (options) =>
      generatorNames
        .filter((item) => {
          if (!item.name) return false;
          if (options.gender !== 'any' && options.gender !== 'neutral' && item.gender !== options.gender) return false;
          if (options.category && item.category !== options.category) return false;
          if (options.inspiration && item.inspiration !== options.inspiration) return false;
          if (options.starts && !item.name.toUpperCase().startsWith(options.starts)) return false;
          if (options.avoidCommands && soundsLikeCommand(item.name)) return false;

          const syllables = estimateSyllables(item.name);
          if (options.length === 'short' && item.name.length > 5) return false;
          if (options.length === 'one-two' && syllables > 2) return false;
          if (options.length === 'long' && item.name.length < 7) return false;

          return true;
        })
        .map((item) => ({
          ...item,
          syllables: estimateSyllables(item.name),
          score: scoreName(item, options),
          breedName: generatorBreed.name,
        }))
        .sort((a, b) => b.score - a.score);

    const renderResults = (items, options) => {
      currentResults = items.slice(0, 12);

      if (!resultsEl || !summaryEl) return;

      if (!currentResults.length) {
        summaryEl.textContent = 'No names matched those filters. Try removing one option.';
        resultsEl.innerHTML = '<p class="dog-name-empty">No matching names yet.</p>';
        return;
      }

      const bits = [
        generatorBreed.name,
        options.gender !== 'any' ? options.gender : 'all name types',
        options.category || 'breed-fit style',
        options.inspiration || 'breed-fit inspiration',
      ];

      summaryEl.textContent = bits.join(' · ');

      resultsEl.innerHTML = currentResults
        .map(
          (item, index) => `
            <article class="dog-name-result-card">
              <div>
                <span>#${index + 1}</span>
                <h4>${escapeHtml(item.name)}</h4>
                <p>${escapeHtml(item.gender)} · ${escapeHtml(item.category)} · ${escapeHtml(item.inspiration)} · ${item.syllables} syll.</p>
              </div>
              <button type="button" data-save-name="${escapeHtml(favoriteKey(item))}">♡</button>
            </article>
          `
        )
        .join('');

      resultsEl.querySelectorAll('[data-save-name]').forEach((button, index) => {
        button.addEventListener('click', () => {
          addFavorite(currentResults[index]);
          button.textContent = '♥';
        });
      });
    };

    const generate = () => {
      const options = getOptions();
      saveOptions();
      renderResults(filterPool(options), options);
    };

    const surprise = () => {
      const random = (arr) => arr[Math.floor(Math.random() * arr.length)];

      controls.gender.value = random(['any', 'boy', 'girl', 'neutral']);
      controls.category.value = random(['', ...new Set(generatorNames.map((item) => item.category).filter(Boolean))]);
      controls.inspiration.value = random(['', ...new Set(generatorNames.map((item) => item.inspiration).filter(Boolean))]);
      controls.length.value = random(['any', 'short', 'one-two', 'long']);
      controls.starts.value = '';
      controls.avoidCommands.checked = true;
      controls.breedFit.checked = true;

      generate();
    };

    const renderFavorites = () => {
      if (!favoritesEl) return;

      const favorites = getFavorites();

      if (!favorites.length) {
        favoritesEl.innerHTML = '<p class="dog-name-empty">No favorites yet. Tap ♡ on generated names.</p>';
        return;
      }

      favoritesEl.innerHTML = favorites
        .map(
          (item) => `
            <div class="dog-name-favorite-item">
              <span>${escapeHtml(item.name)}</span>
              <button type="button" data-remove-favorite="${escapeHtml(favoriteKey(item))}" aria-label="Remove ${escapeHtml(item.name)}">×</button>
            </div>
          `
        )
        .join('');

      favoritesEl.querySelectorAll('[data-remove-favorite]').forEach((button) => {
        button.addEventListener('click', () => removeFavorite(button.dataset.removeFavorite));
      });
    };

    const namesText = (items) => items.map((item) => item.name).join(', ');

    const copyGenerated = async () => {
      const text = namesText(currentResults);
      if (!text) return;
      await navigator.clipboard?.writeText(text);
    };

    const saveAll = () => {
      currentResults.forEach(addFavorite);
      renderFavorites();
    };

    const exportFavorites = () => {
      const favorites = getFavorites();
      const rows = [
        ['name', 'gender', 'category', 'inspiration', 'source_breed', 'saved_at'],
        ...favorites.map((item) => [
          item.name,
          item.gender,
          item.category,
          item.inspiration,
          item.sourceBreed || generatorBreed.name,
          item.savedAt || '',
        ]),
      ];

      const csv = rows
        .map((row) => row.map((cell) => `"${String(cell || '').replaceAll('"', '""')}"`).join(','))
        .join('\n');

      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `pupwiki-${generatorBreed.slug}-name-favorites.csv`;
      link.click();
      URL.revokeObjectURL(url);
    };

    const shareNames = async () => {
      const favorites = getFavorites();
      const list = favorites.length ? favorites : currentResults;
      const text = `My ${generatorBreed.name} name ideas from PupWiki: ${namesText(list)}`;

      if (navigator.share) {
        await navigator.share({ title: `${generatorBreed.name} dog name ideas`, text, url: window.location.href });
      } else {
        await navigator.clipboard?.writeText(`${text}\n${window.location.href}`);
      }
    };

    function showTab(tab) {
      const boysPanel = document.getElementById('panel-boys');
      const girlsPanel = document.getElementById('panel-girls');
      const boysButton = document.getElementById('tab-boys');
      const girlsButton = document.getElementById('tab-girls');

      if (!boysPanel || !girlsPanel || !boysButton || !girlsButton) return;

      const showBoys = tab === 'boys';

      boysPanel.hidden = !showBoys;
      girlsPanel.hidden = showBoys;

      boysButton.classList.toggle('is-active', showBoys);
      girlsButton.classList.toggle('is-active', !showBoys);

      boysButton.setAttribute('aria-selected', String(showBoys));
      girlsButton.setAttribute('aria-selected', String(!showBoys));
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      generate();
    });

    document.querySelector('[data-gen-surprise]')?.addEventListener('click', surprise);
    document.querySelector('[data-gen-copy]')?.addEventListener('click', copyGenerated);
    document.querySelector('[data-gen-save-all]')?.addEventListener('click', saveAll);
    document.querySelector('[data-gen-export]')?.addEventListener('click', exportFavorites);
    document.querySelector('[data-gen-share]')?.addEventListener('click', shareNames);
    document.querySelector('[data-gen-clear-favorites]')?.addEventListener('click', () => setFavorites([]));

    controls.starts?.addEventListener('input', () => {
      controls.starts.value = controls.starts.value.replace(/[^a-z]/gi, '').slice(0, 1).toUpperCase();
    });

    document.querySelectorAll('[data-tab-target]').forEach((button) => {
      button.addEventListener('click', () => showTab(button.dataset.tabTarget));
    });

    document.querySelectorAll('details').forEach((el) => {
      el.addEventListener('toggle', () => {
        const icon = el.querySelector('.faq-icon');
        if (icon) icon.textContent = el.open ? '−' : '+';
      });
    });

    document.querySelectorAll('[data-dog-name-detail-image], [data-related-image]').forEach((image) => {
      image.addEventListener('error', () => {
        image.hidden = true;
      });
    });

    loadOptions();
    renderFavorites();
    generate();
  </script>
</BaseLayout>

