---
import BaseLayout from '../../layouts/BaseLayout.astro';
import masterBreeds from '../../data/master-breeds.json';
import allNamesData from '../../data/dog-names.json';
import enrichedNamesRaw from '../../data/dog-names-enriched.json';
import breedLinkMap from '../../data/breed-link-map.json';
import AwinProductSlot from '../../components/affiliate/AwinProductSlot.astro';

const SITE = 'https://pupwiki.com';

export function getStaticPaths() {
  return (masterBreeds as any[]).map((b) => ({ params: { breed: b.slug } }));
}

const { breed: slug } = Astro.params;
const b = (masterBreeds as any[]).find((x) => x.slug === slug);

if (!b) return Astro.redirect('/dog-names');

const links = (breedLinkMap as any)[slug] || {};
const rank = b.ranking_data || {};
const styles = b.name_styles || ['Classic', 'Trendy'];
const insps = b.name_inspirations || ['Classic Pet', 'Nature'];
const n = b.name;

type NameEntry = {
  name: string;
  gender: string;
  category: string;
  inspiration: string;
  rank: number;
  enriched: boolean;
};

const allNames = allNamesData as NameEntry[];

function filterNames(gender: string, count: number) {
  return allNames
    .filter((x) => x.gender === gender && (styles.includes(x.category) || insps.includes(x.inspiration)))
    .sort((a, b) => (a.rank || 9999) - (b.rank || 9999))
    .slice(0, count);
}

function getByCategory(cat: string, count = 12) {
  return allNames
    .filter((x) => x.category === cat)
    .sort((a, b) => (a.rank || 9999) - (b.rank || 9999))
    .slice(0, count)
    .map((x) => x.name);
}

function getByInspiration(insp: string, count = 12) {
  return allNames
    .filter((x) => x.inspiration === insp)
    .sort((a, b) => (a.rank || 9999) - (b.rank || 9999))
    .slice(0, count)
    .map((x) => x.name);
}

const boys = filterNames('boy', 20);
const girls = filterNames('girl', 20);

type EnrichedName = { name: string; gender: string; category: string; inspiration: string; rank: number; };
const enrichedNames = enrichedNamesRaw as EnrichedName[];
const INSPIRATION_BUCKETS = [
  { key: 'Nature',      label: 'Nature & Outdoors',  emoji: '🌿' },
  { key: 'Sports',      label: 'Sports & Adventure',  emoji: '⚽' },
  { key: 'Human',       label: 'Human Names',          emoji: '👤' },
  { key: 'Classic Pet', label: 'Classic Pet Names',    emoji: '⭐' },
];
const inspirationSections = INSPIRATION_BUCKETS.map(bucket => ({
  ...bucket,
  names: enrichedNames
    .filter(x => x.inspiration === bucket.key)
    .sort((a, b) => (a.rank || 9999) - (b.rank || 9999))
    .slice(0, 8)
    .map(x => x.name),
})).filter(b => b.names.length >= 4);

const THEMES = [
  styles.includes('Tough') && {
    id: 'tough',
    label: '💪 Tough & Strong',
    names: getByCategory('Tough', 10),
  },
  styles.includes('Cute') && {
    id: 'cute',
    label: '🌸 Cute & Sweet',
    names: getByCategory('Cute', 10),
  },
  styles.includes('Classic') && {
    id: 'classic',
    label: '⭐ Classic & Timeless',
    names: getByCategory('Classic', 10),
  },
  styles.includes('Trendy') && {
    id: 'trendy',
    label: '✨ Trendy & Modern',
    names: getByCategory('Trendy', 10),
  },
  insps.includes('Nature') && {
    id: 'nature',
    label: '🌿 Nature-Inspired',
    names: getByInspiration('Nature', 10),
  },
  insps.includes('Mythology') && {
    id: 'myth',
    label: '⚡ Mythology & Legends',
    names: getByInspiration('Mythology', 10),
  },
].filter(Boolean) as any[];

if (!THEMES.find((theme) => theme.id === 'nature')) {
  THEMES.push({
    id: 'nature',
    label: '🌿 Nature-Inspired',
    names: getByInspiration('Nature', 10),
  });
}

if (!THEMES.find((theme) => theme.id === 'classic')) {
  THEMES.push({
    id: 'classic',
    label: '⭐ Classic Names',
    names: getByCategory('Classic', 10),
  });
}

const temp = (b.temperament || '').toLowerCase();

const personality = temp.includes('friendly')
  ? 'friendly, outgoing'
  : temp.includes('loyal') || temp.includes('protective')
    ? 'loyal, protective'
    : temp.includes('intelligent') || temp.includes('smart')
      ? 'intelligent, quick-learning'
      : temp.includes('gentle')
        ? 'gentle, even-tempered'
        : `${b.energy_level}-energy`;

const intel_note = rank.intelligence_rank
  ? `Ranked #${rank.intelligence_rank} in canine intelligence, ${n}s learn their name quickly — 1–2 syllable names ending in a vowel work best.`
  : `${n}s respond best to 1–2 syllable names ending in a vowel (Bella, Milo, Daisy).`;

const relatedBreeds = (masterBreeds as any[])
  .filter((x) => x.slug !== slug && x.size_category === b.size_category && x.image_url)
  .slice(0, 4);

const topNames = [...boys.slice(0, 3).map((x: any) => x.name), ...girls.slice(0, 3).map((x: any) => x.name)];

const profileRows = [
  ['Size', b.size_category],
  ['Energy', b.energy_level],
  ['Training', b.training_level],
  rank.intelligence_rank ? ['Intelligence', `#${rank.intelligence_rank} worldwide`] : null,
  b.origin_country ? ['Origin', b.origin_country] : null,
].filter(Boolean) as string[][];

const guideLinks = [
  links.hub && { href: links.hub, emoji: '🐾', label: `${n} complete guide` },
  links.food_post && { href: links.food_post, emoji: '🍖', label: `Best food for ${n}s` },
  links.toy_post && { href: links.toy_post, emoji: '🎾', label: `Best toys for ${n}s` },
  links.health_post && { href: links.health_post, emoji: '🩺', label: `${n} health guide` },
  links.training_post && { href: links.training_post, emoji: '🦮', label: `Training a ${n}` },
].filter(Boolean) as any[];

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',       item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Dog Names',  item: `${SITE}/dog-names` },
    { '@type': 'ListItem', position: 3, name: `${n} Names`, item: `${SITE}/dog-names/${slug}` },
  ],
});

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `Best boy names for ${n}s?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Top boy names: ${boys.slice(0, 5).map((x) => x.name).join(', ')}.`,
      },
    },
    {
      '@type': 'Question',
      name: `Best girl names for ${n}s?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Top girl names: ${girls.slice(0, 5).map((x) => x.name).join(', ')}.`,
      },
    },
  ],
});
---

<BaseLayout
  title={`Best ${n} Names 2026 — ${boys[0]?.name}, ${girls[0]?.name} & More Boy & Girl Picks`}
  description={`${boys.length + girls.length}+ names for ${n}s matched to their ${personality} personality. Ranked lists, themed collections, and expert naming tips.`}
  canonicalUrl={`${SITE}/dog-names/${slug}`}
  bodyClass="dog-name-detail-page bg-white text-slate-900"
>
  <script type="application/ld+json" set:html={breadcrumbLd} />
  <script type="application/ld+json" set:html={jsonLd} />

  <main class="dog-name-detail">
    <section class="dog-name-detail-hero" aria-labelledby="dog-name-detail-title">
      <div class="dog-name-detail-container">
        <nav class="dog-name-detail-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/dog-names">Dog Names</a>
          <span aria-hidden="true">›</span>
          <span>{n}</span>
        </nav>

        <div class="dog-name-detail-hero__grid">
          {b.image_url && (
            <div class="dog-name-detail-hero__media">
              <img
                src={b.image_url}
                alt={`${n} dog`}
                width="320"
                height="320"
                loading="eager"
                decoding="async"
                data-dog-name-detail-image
              />

              {rank.intelligence_rank && rank.intelligence_rank <= 20 && (
                <span class="dog-name-detail-hero__badge" aria-label="Highly intelligent breed">
                  🧠
                </span>
              )}
            </div>
          )}

          <div class="dog-name-detail-hero__content">
            <div class="dog-name-detail-hero__pills" aria-label={`${n} name attributes`}>
              {styles.map((style: string) => (
                <span class="dog-name-pill dog-name-pill--accent">{style}</span>
              ))}

              {insps.slice(0, 2).map((insp: string) => (
                <span class="dog-name-pill dog-name-pill--warm">{insp}</span>
              ))}

              <span class="dog-name-pill dog-name-pill--success">{boys.length + girls.length}+ names</span>
            </div>

            <h1 id="dog-name-detail-title" class="dog-name-detail-hero__title">
              Best
              <span>{n}</span>
              Names
              <em>2026</em>
            </h1>

            <p class="dog-name-detail-hero__subtitle">
              {n}s are {personality} dogs. Names curated from 7,000+ entries, filtered and ranked for this breed's
              temperament and style.
            </p>

            <div class="dog-name-detail-hero__top-picks" aria-label={`Top ${n} name picks`}>
              <span>Top picks:</span>
              {topNames.map((name: string) => (
                <strong>{name}</strong>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="dog-name-detail-main">
      <div class="dog-name-detail-container">
        <div class="dog-name-detail-layout">
          <div class="dog-name-detail-content">
            <section class="dog-name-tabs" aria-label={`${n} boy and girl names`}>
              <div class="dog-name-tabs__buttons" role="tablist" aria-label="Name gender tabs">
                <button
                  id="tab-boys"
                  class="dog-name-tab is-active"
                  type="button"
                  role="tab"
                  aria-selected="true"
                  aria-controls="panel-boys"
                  data-tab-target="boys"
                >
                  🐾 Boy Names ({boys.length})
                </button>

                <button
                  id="tab-girls"
                  class="dog-name-tab"
                  type="button"
                  role="tab"
                  aria-selected="false"
                  aria-controls="panel-girls"
                  data-tab-target="girls"
                >
                  🌸 Girl Names ({girls.length})
                </button>
              </div>

              <div id="panel-boys" class="dog-name-tab-panel" role="tabpanel" aria-labelledby="tab-boys">
                <div class="dog-name-grid">
                  {boys.map((entry: any, i: number) => (
                    <article class:list={['dog-name-card', i < 3 && 'dog-name-card--featured']}>
                      <div class="dog-name-card__top">
                        <span>#{i + 1}</span>
                        {i < 3 && <em>{i === 0 ? '🥇' : i === 1 ? '🥈' : '🥉'}</em>}
                      </div>

                      <h2>{entry.name}</h2>
                      <p>{entry.category}</p>
                    </article>
                  ))}
                </div>

                <p class="dog-name-tab-panel__note">
                  Top {boys.length} boy names for {n}s, ranked by popularity and breed match.
                </p>
              </div>

              <div id="panel-girls" class="dog-name-tab-panel" role="tabpanel" aria-labelledby="tab-girls" hidden>
                <div class="dog-name-grid">
                  {girls.map((entry: any, i: number) => (
                    <article class:list={['dog-name-card', 'dog-name-card--girl', i < 3 && 'dog-name-card--featured']}>
                      <div class="dog-name-card__top">
                        <span>#{i + 1}</span>
                        {i < 3 && <em>{i === 0 ? '🥇' : i === 1 ? '🥈' : '🥉'}</em>}
                      </div>

                      <h2>{entry.name}</h2>
                      <p>{entry.category}</p>
                    </article>
                  ))}
                </div>

                <p class="dog-name-tab-panel__note">
                  Top {girls.length} girl names for {n}s, ranked by popularity and breed match.
                </p>
              </div>
            </section>

            {THEMES.length > 0 && (
              <section class="dog-name-section" aria-labelledby="theme-title">
                <p class="dog-name-detail-eyebrow">By style</p>
                <h2 id="theme-title">Names by Theme</h2>

                <div class="dog-name-theme-grid">
                  {THEMES.slice(0, 6).map((theme: any) => (
                    <article class:list={['dog-name-theme-card', `is-theme-${theme.id}`]}>
                      <h3>{theme.label}</h3>
                      <div>
                        {theme.names.map((name: string) => (
                          <span>{name}</span>
                        ))}
                      </div>
                    </article>
                  ))}
                </div>
              </section>
            )}

            <section class="dog-name-guide" aria-labelledby="naming-guide-title">
              <div class="dog-name-guide__header">
                <span aria-hidden="true">📖</span>
                <h2 id="naming-guide-title">How to Name Your {n}</h2>
              </div>

              <div class="dog-name-guide__grid">
                {[
                  {
                    icon: '✂️',
                    title: 'Keep it short — 1–2 syllables',
                    body: `${n}s distinguish their name most easily when it's short and ends in a vowel (Bella, Milo, Luna, Charlie).`,
                  },
                  {
                    icon: '🚫',
                    title: 'Avoid command sounds',
                    body: `Names sounding like "sit," "stay," "no," "down," or "come" create confusion. Avoid names rhyming with family members too.`,
                  },
                  {
                    icon: '🎤',
                    title: 'Test it in three tones',
                    body: `Excited ("Milo!"), firm ("Milo, no!"), and calling ("Come, Milo!"). A good name works in all three.`,
                  },
                  {
                    icon: '🧠',
                    title: 'Intelligence matters',
                    body: intel_note,
                  },
                  {
                    icon: '📅',
                    title: 'Give it a week',
                    body: `Use the name consistently for 5–7 days before deciding if it fits. Most names grow on owners quickly.`,
                  },
                  {
                    icon: '🔄',
                    title: 'Changing a name is easy',
                    body: `Dogs adapt within 1–2 weeks when you pair the new name with high-value treats consistently.`,
                  },
                ].map((tip) => (
                  <article class="dog-name-tip">
                    <span aria-hidden="true">{tip.icon}</span>
                    <div>
                      <h3>{tip.title}</h3>
                      <p>{tip.body}</p>
                    </div>
                  </article>
                ))}
              </div>
            </section>

            <section class="dog-name-section" aria-labelledby="trait-title">
              <p class="dog-name-detail-eyebrow">Match by personality</p>
              <h2 id="trait-title">Names by {n} Personality Trait</h2>

              <div class="dog-name-table-wrap">
                <table class="dog-name-table">
                  <thead>
                    <tr>
                      <th>Trait</th>
                      <th>Suggested Names</th>
                    </tr>
                  </thead>
                  <tbody>
                    {[
                      ['Energetic', 'Atlas, Blaze, Chase, Dash, Rocket, Ziggy, Bolt, Flash'],
                      ['Gentle', 'Biscuit, Daisy, Dove, Maple, Willow, Honey, Sage, Fern'],
                      ['Loyal', 'Ace, Duke, Faith, Honor, Ranger, Sterling, Valor, Rex'],
                      ['Intelligent', 'Archer, Einstein, Pixel, Tesla, Vega, Newton, Sage'],
                      ['Playful', 'Bingo, Gizmo, Noodle, Pickle, Sprout, Waffles, Bubbles'],
                      ['Regal', 'Apollo, Caesar, Duchess, Empress, Baron, Athena, Rex'],
                    ].map(([trait, names]) => (
                      <tr>
                        <td>{trait}</td>
                        <td>{names}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>

            {inspirationSections.length > 0 && (
              <section class="dog-name-section">
                <p class="dog-name-detail-eyebrow">Popular name themes</p>
                <h2 class="font-sans text-xl font-bold mb-5" style="color:var(--color-heading)">
                  Dog Names by Inspiration
                </h2>
                <div class="grid sm:grid-cols-2 gap-5">
                  {inspirationSections.map(bucket => (
                    <div class="rounded-2xl p-5" style="background:white;border:1px solid var(--color-border-warm)">
                      <p class="font-sans font-bold text-sm mb-3" style="color:var(--color-heading)">
                        {bucket.emoji} {bucket.label}
                      </p>
                      <div class="flex flex-wrap gap-2">
                        {bucket.names.map(name => (
                          <span class="font-sans text-xs px-2.5 py-1 rounded-full"
                            style="background:var(--color-bg-soft);color:var(--color-heading)">{name}</span>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </section>
            )}

            <section class="dog-name-section dog-name-faq" aria-labelledby="faq-title">
              <p class="dog-name-detail-eyebrow">Common questions</p>
              <h2 id="faq-title">{n} Naming FAQs</h2>

              {[
                [
                  `What are the best names for a ${n}?`,
                  `Based on the ${n}'s ${personality} character, top picks are ${boys
                    .slice(0, 3)
                    .map((x: any) => x.name)
                    .join(', ')} (boys) and ${girls
                    .slice(0, 3)
                    .map((x: any) => x.name)
                    .join(', ')} (girls).`,
                ],
                [`How many syllables should my ${n}'s name have?`, `1–2 syllables is ideal. ${intel_note}`],
                [
                  `Can I change my ${n}'s name after adoption?`,
                  `Yes — dogs adapt within 1–2 weeks with consistent positive reinforcement. Pair the new name with treats every time your dog responds.`,
                ],
                [
                  `What names should I avoid for a ${n}?`,
                  `Avoid names rhyming with "sit," "stay," "no," "down," or "come." Also avoid names too similar to family members' names.`,
                ],
              ].map(([q, a]) => (
                <details>
                  <summary>
                    <span>{q}</span>
                    <em class="faq-icon" aria-hidden="true">+</em>
                  </summary>
                  <p>{a}</p>
                </details>
              ))}
            </section>

            {relatedBreeds.length > 0 && (
              <section class="dog-name-section" aria-labelledby="related-title">
                <p class="dog-name-detail-eyebrow">Similar breeds</p>
                <h2 id="related-title">Names for Similar Breeds</h2>

                <div class="dog-name-related-grid">
                  {relatedBreeds.map((rb: any) => (
                    <a href={`/dog-names/${rb.slug}`} class="dog-name-related-card">
                      <div>
                        <img
                          src={rb.image_url}
                          alt={rb.name}
                          width="200"
                          height="120"
                          loading="lazy"
                          decoding="async"
                          data-related-image
                        />
                      </div>
                      <p>{rb.name} names →</p>
                    </a>
                  ))}
                </div>
              </section>
            )}
          </div>

          <aside class="dog-name-sidebar" aria-label={`${n} naming sidebar`}>
            <div class="dog-name-sidebar-card dog-name-sidebar-card--highlight">
              <p class="dog-name-detail-eyebrow">Top {n} Names</p>

              <div class="dog-name-sidebar-list">
                <h2>Boys</h2>
                {boys.slice(0, 5).map((entry: any, i: number) => (
                  <div>
                    <span>#{i + 1}</span>
                    <strong>{entry.name}</strong>
                    <em>{entry.category}</em>
                  </div>
                ))}
              </div>

              <div class="dog-name-sidebar-list">
                <h2>Girls</h2>
                {girls.slice(0, 5).map((entry: any, i: number) => (
                  <div>
                    <span>#{i + 1}</span>
                    <strong>{entry.name}</strong>
                    <em>{entry.category}</em>
                  </div>
                ))}
              </div>
            </div>

            <div class="dog-name-sidebar-card">
              <p class="dog-name-detail-eyebrow">{n} profile</p>

              <dl>
                {profileRows.map((row: any) => (
                  <div>
                    <dt>{row[0]}</dt>
                    <dd>{row[1]}</dd>
                  </div>
                ))}
              </dl>
            </div>

            {guideLinks.length > 0 && (
              <div class="dog-name-sidebar-card">
                <p class="dog-name-detail-eyebrow">{n} Guides</p>

                <nav class="dog-name-sidebar-nav" aria-label={`${n} related guides`}>
                  {guideLinks.map((item: any) => (
                    <a href={item.href}>
                      <span>{item.emoji}</span>
                      <span>{item.label} →</span>
                    </a>
                  ))}
                </nav>
              </div>
            )}

            <AwinProductSlot topicTags={['gift', 'portrait', 'custom', 'lifestyle']} pageType="dog-names" />

            <a href="/dog-names" class="dog-name-sidebar-cta">
              Browse all breed names →
            </a>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <script>
    function showTab(tab) {
      const boysPanel = document.getElementById('panel-boys');
      const girlsPanel = document.getElementById('panel-girls');
      const boysButton = document.getElementById('tab-boys');
      const girlsButton = document.getElementById('tab-girls');

      if (!boysPanel || !girlsPanel || !boysButton || !girlsButton) return;

      const showBoys = tab === 'boys';

      boysPanel.hidden = !showBoys;
      girlsPanel.hidden = showBoys;

      boysButton.classList.toggle('is-active', showBoys);
      girlsButton.classList.toggle('is-active', !showBoys);

      boysButton.setAttribute('aria-selected', String(showBoys));
      girlsButton.setAttribute('aria-selected', String(!showBoys));
    }

    document.querySelectorAll('[data-tab-target]').forEach((button) => {
      button.addEventListener('click', () => showTab(button.dataset.tabTarget));
    });

    document.querySelectorAll('details').forEach((el) => {
      el.addEventListener('toggle', () => {
        const icon = el.querySelector('.faq-icon');
        if (icon) icon.textContent = el.open ? '−' : '+';
      });
    });

    document.querySelectorAll('[data-dog-name-detail-image], [data-related-image]').forEach((image) => {
      image.addEventListener('error', () => {
        image.hidden = true;
      });
    });
  </script>
</BaseLayout>

<style>
  .dog-name-detail {
    background:
      radial-gradient(circle at 88% 4%, rgba(255, 122, 0, 0.1), transparent 24rem),
      radial-gradient(circle at 8% 2%, rgba(21, 54, 95, 0.08), transparent 22rem),
      var(--color-bg);
    color: var(--color-body);
  }

  .dog-name-detail-container {
    width: min(100%, var(--max-width));
    margin-inline: auto;
    padding-inline: var(--content-padding-mobile);
  }

  .dog-name-detail-hero {
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(255, 250, 243, 0.98) 0%, #ffffff 78%);
  }

  .dog-name-detail-hero .dog-name-detail-container {
    padding-block: clamp(2.35rem, 7vw, 5.75rem);
  }

  .dog-name-detail-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin-bottom: var(--space-5);
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .dog-name-detail-breadcrumb a {
    color: var(--color-primary);
    font-weight: var(--weight-semi);
    text-decoration: none;
  }

  .dog-name-detail-breadcrumb a:hover {
    color: var(--color-accent);
