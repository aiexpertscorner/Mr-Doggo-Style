---
import BaseLayout    from '../../layouts/BaseLayout.astro';
import masterBreeds  from '../../data/master-breeds.json';
import allNamesData  from '../../data/dog-names.json';
import breedLinkMap  from '../../data/breed-link-map.json';
import productIndex  from '../../data/product-index.json';

const SITE = 'https://mrdoggostyle.com';
const TAG  = 'aiexpertscorn-20';

export function getStaticPaths() {
  return (masterBreeds as any[]).map(b => ({ params: { breed: b.slug } }));
}

const { breed: slug } = Astro.params;
const b = (masterBreeds as any[]).find(x => x.slug === slug);
if (!b) return Astro.redirect('/dog-names');

const links  = (breedLinkMap as any)[slug] || {};
const rank   = b.ranking_data || {};
const styles = b.name_styles       || ['Classic', 'Trendy'];
const insps  = b.name_inspirations || ['Classic Pet', 'Nature'];
const n      = b.name;

const foodId   = b.product_picks?.['dog-food'];
const foodProd = foodId ? (productIndex as any)[foodId] : null;

type NameEntry = { name:string; gender:string; category:string; inspiration:string; rank:number; enriched:boolean };
const allNames = allNamesData as NameEntry[];

function filterNames(gender: string, count: number) {
  return allNames
    .filter(x => x.gender === gender && (styles.includes(x.category) || insps.includes(x.inspiration)))
    .sort((a, b) => (a.rank||9999) - (b.rank||9999))
    .slice(0, count);
}
function getByCategory(cat: string, count = 12) {
  return allNames.filter(x=>x.category===cat).sort((a,b)=>(a.rank||9999)-(b.rank||9999)).slice(0,count).map(x=>x.name);
}
function getByInspiration(insp: string, count = 12) {
  return allNames.filter(x=>x.inspiration===insp).sort((a,b)=>(a.rank||9999)-(b.rank||9999)).slice(0,count).map(x=>x.name);
}

const boys  = filterNames('boy',  20);
const girls = filterNames('girl', 20);

const THEMES = [
  styles.includes('Tough')    && { id:'tough',   label:'💪 Tough & Strong',    bg:'#fef2f2', color:'#dc2626', names: getByCategory('Tough', 10)      },
  styles.includes('Cute')     && { id:'cute',    label:'🌸 Cute & Sweet',       bg:'#fdf4ff', color:'#a21caf', names: getByCategory('Cute', 10)       },
  styles.includes('Classic')  && { id:'classic', label:'⭐ Classic & Timeless', bg:'#fefce8', color:'#854d0e', names: getByCategory('Classic', 10)    },
  styles.includes('Trendy')   && { id:'trendy',  label:'✨ Trendy & Modern',    bg:'#eff6ff', color:'#1d4ed8', names: getByCategory('Trendy', 10)     },
  insps.includes('Nature')    && { id:'nature',  label:'🌿 Nature-Inspired',    bg:'#f0fdf4', color:'#15803d', names: getByInspiration('Nature', 10)  },
  insps.includes('Mythology') && { id:'myth',    label:'⚡ Mythology & Legends', bg:'#ede9fe', color:'#5b21b6', names: getByInspiration('Mythology',10) },
].filter(Boolean) as any[];

if (!THEMES.find(t=>t.id==='nature'))   THEMES.push({ id:'nature',  label:'🌿 Nature-Inspired', bg:'#f0fdf4', color:'#15803d', names: getByInspiration('Nature',10)  });
if (!THEMES.find(t=>t.id==='classic'))  THEMES.push({ id:'classic', label:'⭐ Classic Names',   bg:'#fefce8', color:'#854d0e', names: getByCategory('Classic',10)    });

const temp        = (b.temperament||'').toLowerCase();
const personality = temp.includes('friendly') ? 'friendly, outgoing'
  : temp.includes('loyal')||temp.includes('protective') ? 'loyal, protective'
  : temp.includes('intelligent')||temp.includes('smart') ? 'intelligent, quick-learning'
  : temp.includes('gentle') ? 'gentle, even-tempered'
  : `${b.energy_level}-energy`;

const intel_note = rank.intelligence_rank
  ? `Ranked #${rank.intelligence_rank} in canine intelligence, ${n}s learn their name quickly — 1–2 syllable names ending in a vowel work best.`
  : `${n}s respond best to 1–2 syllable names ending in a vowel (Bella, Milo, Daisy).`;

const relatedBreeds = (masterBreeds as any[])
  .filter(x => x.slug !== slug && x.size_category === b.size_category && x.image_url)
  .slice(0, 4);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type":"Question","name":`Best boy names for ${n}s?`,
      "acceptedAnswer":{"@type":"Answer","text":`Top boy names: ${boys.slice(0,5).map(x=>x.name).join(', ')}.`} },
    { "@type":"Question","name":`Best girl names for ${n}s?`,
      "acceptedAnswer":{"@type":"Answer","text":`Top girl names: ${girls.slice(0,5).map(x=>x.name).join(', ')}.`} },
  ]
});
---

<BaseLayout
  title={`Best ${n} Names 2026 — ${boys[0]?.name}, ${girls[0]?.name} & More Boy & Girl Picks`}
  description={`${boys.length + girls.length}+ names for ${n}s matched to their ${personality} personality. Ranked lists, themed collections, and expert naming tips.`}
  canonicalURL={`${SITE}/dog-names/${slug}`}
>
<script type="application/ld+json" set:html={jsonLd} />

<!-- HERO -->
<div style="background:linear-gradient(to bottom,#f5e8d0,#fdf8f0);border-bottom:1px solid #e8ccaa">
  <div class="max-w-7xl mx-auto px-4 py-10 sm:py-14">
    <nav class="font-sans text-sm mb-5 flex flex-wrap gap-1.5" style="color:#94a3b8">
      <a href="/" style="color:#a0621c" class="hover:underline">Home</a><span>›</span>
      <a href="/dog-names" style="color:#a0621c" class="hover:underline">Dog Names</a><span>›</span>
      <span style="color:#475569">{n}</span>
    </nav>
    <div class="flex flex-col sm:flex-row sm:items-start gap-8">
      {b.image_url && (
        <div class="flex-shrink-0 relative">
          <img src={b.image_url} alt={`${n} dog`} width="180" height="180" loading="eager"
            class="w-40 h-40 sm:w-44 sm:h-44 object-cover rounded-3xl shadow-lg"
            style="border:3px solid #e8ccaa"
            onerror="this.parentElement.style.display='none'" />
          {rank.intelligence_rank && rank.intelligence_rank <= 20 && (
            <span class="absolute -top-2 -right-2 font-sans text-xs font-black w-9 h-9 rounded-full flex items-center justify-center shadow-md" style="background:#fbbf24;color:#1e293b">🧠</span>
          )}
        </div>
      )}
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap gap-2 mb-3">
          {styles.map((s:string) => <span class="font-sans text-xs font-bold px-3 py-1 rounded-full" style="background:#a0621c;color:white">{s}</span>)}
          {insps.slice(0,2).map((i:string) => <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style="background:#fef3c7;color:#92400e">{i}</span>)}
          <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style="background:#f0fdf4;color:#15803d">{boys.length+girls.length}+ names</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-bold mb-2 leading-tight" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          Best <span style="color:#a0621c">{n}</span> Names <span class="font-sans text-xl font-normal" style="color:#94a3b8">2026</span>
        </h1>
        <p class="font-sans text-base leading-relaxed max-w-2xl mb-4" style="color:#475569">
          {n}s are {personality} dogs. Names curated from 7,000+ entries, filtered and ranked for this breed's temperament and style.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="font-sans text-xs font-medium" style="color:#64748b">Top picks:</span>
          {[...boys.slice(0,3).map((x:any)=>x.name), ...girls.slice(0,3).map((x:any)=>x.name)].map((name:string) => (
            <span class="font-sans text-sm font-bold px-2.5 py-1 rounded-lg" style="background:white;border:1px solid #e8ccaa;color:#1e293b">{name}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MAIN -->
<div class="max-w-7xl mx-auto px-4 py-10">
  <div class="lg:grid lg:grid-cols-[1fr_290px] lg:gap-10 items-start">
    <div class="space-y-12 min-w-0">

      <!-- TABBED NAME LISTS -->
      <section>
        <div class="flex items-center gap-1 mb-6 p-1 rounded-2xl" style="background:#f5e8d0">
          <button id="tab-boys" class="flex-1 font-sans text-sm font-bold py-2.5 px-4 rounded-xl transition-all" style="background:#a0621c;color:white"
            onclick="window.showTab('boys')">
            🐾 Boy Names ({boys.length})
          </button>
          <button id="tab-girls" class="flex-1 font-sans text-sm font-bold py-2.5 px-4 rounded-xl transition-all" style="background:transparent;color:#7d4a10"
            onclick="window.showTab('girls')">
            🌸 Girl Names ({girls.length})
          </button>
        </div>

        <div id="panel-boys">
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 mb-5">
            {boys.map((entry:any, i:number) => (
              <div class="rounded-xl p-3" style={`background:${i<3?'linear-gradient(135deg,#fdf8f0,#fef3c7)':'white'};border:${i<3?'2px solid #fbbf24':'1px solid #e8ccaa'}`}>
                <div class="flex justify-between items-start mb-1">
                  <span class="font-sans text-xs font-bold" style="color:#94a3b8">#{i+1}</span>
                  {i<3 && <span class="text-xs">{i===0?'🥇':i===1?'🥈':'🥉'}</span>}
                </div>
                <p class="font-sans font-black text-base leading-tight" style="color:#1e293b">{entry.name}</p>
                <p class="font-sans text-xs mt-0.5" style="color:#94a3b8">{entry.category}</p>
              </div>
            ))}
          </div>
          <p class="font-sans text-sm text-center" style="color:#94a3b8">Top {boys.length} boy names for {n}s, ranked by popularity and breed match.</p>
        </div>

        <div id="panel-girls" class="hidden">
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 mb-5">
            {girls.map((entry:any, i:number) => (
              <div class="rounded-xl p-3" style={`background:${i<3?'linear-gradient(135deg,#fdf4ff,#fce7f3)':'white'};border:${i<3?'2px solid #e879f9':'1px solid #e8ccaa'}`}>
                <div class="flex justify-between items-start mb-1">
                  <span class="font-sans text-xs font-bold" style="color:#94a3b8">#{i+1}</span>
                  {i<3 && <span class="text-xs">{i===0?'🥇':i===1?'🥈':'🥉'}</span>}
                </div>
                <p class="font-sans font-black text-base leading-tight" style="color:#1e293b">{entry.name}</p>
                <p class="font-sans text-xs mt-0.5" style="color:#94a3b8">{entry.category}</p>
              </div>
            ))}
          </div>
          <p class="font-sans text-sm text-center" style="color:#94a3b8">Top {girls.length} girl names for {n}s, ranked by popularity and breed match.</p>
        </div>
      </section>

      <!-- THEMED LISTS -->
      {THEMES.length > 0 && (
        <section>
          <p class="font-sans text-xs font-bold uppercase tracking-widest mb-1" style="color:#a0621c">By style</p>
          <h2 class="font-display text-2xl font-bold mb-6" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">Names by Theme</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {THEMES.slice(0,6).map((theme:any) => (
              <div class="rounded-2xl p-5" style={`background:${theme.bg};border:1px solid ${theme.color}30`}>
                <h3 class="font-sans font-bold text-sm mb-3" style={`color:${theme.color}`}>{theme.label}</h3>
                <div class="flex flex-wrap gap-1.5">
                  {theme.names.map((name:string) => (
                    <span class="font-sans text-sm font-semibold px-2.5 py-1 rounded-full" style={`background:white;color:${theme.color};border:1px solid ${theme.color}30`}>{name}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- NAMING GUIDE -->
      <section class="rounded-3xl overflow-hidden" style="border:1px solid #e8ccaa">
        <div class="px-6 py-5 flex items-center gap-3" style="background:linear-gradient(135deg,#3d2206,#7d4a10)">
          <span class="text-2xl">📖</span>
          <h2 class="font-display text-xl font-bold text-white" style="font-family:'Playfair Display',Georgia,serif">How to Name Your {n}</h2>
        </div>
        <div class="p-6 grid sm:grid-cols-2 gap-5" style="background:white">
          {([
            { icon:'✂️', title:'Keep it short — 1–2 syllables', body:`${n}s distinguish their name most easily when it's short and ends in a vowel (Bella, Milo, Luna, Charlie).` },
            { icon:'🚫', title:'Avoid command sounds',           body:`Names sounding like "sit," "stay," "no," "down," or "come" create confusion. Avoid names rhyming with family members too.` },
            { icon:'🎤', title:'Test it in three tones',         body:`Excited ("Milo!"), firm ("Milo, no!"), and calling ("Come, Milo!"). A good name works in all three.` },
            { icon:'🧠', title:'Intelligence matters',           body:intel_note },
            { icon:'📅', title:'Give it a week',                 body:`Use the name consistently for 5–7 days before deciding if it fits. Most names grow on owners quickly.` },
            { icon:'🔄', title:'Changing a name is easy',        body:`Dogs adapt within 1–2 weeks when you pair the new name with high-value treats consistently.` },
          ] as any[]).map(tip => (
            <div class="flex gap-3">
              <span class="text-xl flex-shrink-0 mt-0.5">{tip.icon}</span>
              <div>
                <p class="font-sans font-bold text-sm mb-1" style="color:#1e293b">{tip.title}</p>
                <p class="font-sans text-sm leading-relaxed" style="color:#64748b">{tip.body}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- NAME BY TRAIT -->
      <section>
        <p class="font-sans text-xs font-bold uppercase tracking-widest mb-1" style="color:#a0621c">Match by personality</p>
        <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">Names by {n} Personality Trait</h2>
        <div class="rounded-2xl overflow-hidden" style="border:1px solid #e8ccaa">
          <table class="w-full font-sans text-sm">
            <thead><tr style="background:#f5e8d0">
              <th class="text-left px-4 py-3 font-bold" style="color:#5c340a">Trait</th>
              <th class="text-left px-4 py-3 font-bold" style="color:#5c340a">Suggested Names</th>
            </tr></thead>
            <tbody>
              {([
                ['Energetic', 'Atlas, Blaze, Chase, Dash, Rocket, Ziggy, Bolt, Flash'],
                ['Gentle',    'Biscuit, Daisy, Dove, Maple, Willow, Honey, Sage, Fern'],
                ['Loyal',     'Ace, Duke, Faith, Honor, Ranger, Sterling, Valor, Rex'],
                ['Intelligent','Archer, Einstein, Pixel, Tesla, Vega, Newton, Sage'],
                ['Playful',   'Bingo, Gizmo, Noodle, Pickle, Sprout, Waffles, Bubbles'],
                ['Regal',     'Apollo, Caesar, Duchess, Empress, Baron, Athena, Rex'],
              ] as [string,string][]).map(([trait, names], i) => (
                <tr style={`background:${i%2===0?'white':'#fdf8f0'};border-top:1px solid #f5e8d0`}>
                  <td class="px-4 py-3 font-semibold" style="color:#1e293b;white-space:nowrap">{trait}</td>
                  <td class="px-4 py-3" style="color:#475569">{names}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <p class="font-sans text-xs font-bold uppercase tracking-widest mb-1" style="color:#a0621c">Common questions</p>
        <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">{n} Naming FAQs</h2>
        <div class="space-y-2">
          {([
            [`What are the best names for a ${n}?`,
             `Based on the ${n}'s ${personality} character, top picks are ${boys.slice(0,3).map((x:any)=>x.name).join(', ')} (boys) and ${girls.slice(0,3).map((x:any)=>x.name).join(', ')} (girls).`],
            [`How many syllables should my ${n}'s name have?`,
             `1–2 syllables is ideal. ${intel_note}`],
            [`Can I change my ${n}'s name after adoption?`,
             `Yes — dogs adapt within 1–2 weeks with consistent positive reinforcement. Pair the new name with treats every time your dog responds.`],
            [`What names should I avoid for a ${n}?`,
             `Avoid names rhyming with "sit," "stay," "no," "down," or "come." Also avoid names too similar to family members' names.`],
          ] as [string,string][]).map(([q,a]) => (
            <details class="rounded-xl overflow-hidden" style="border:1px solid #e8ccaa;background:white">
              <summary class="p-4 font-sans font-semibold text-sm cursor-pointer" style="color:#1e293b;list-style:none;display:flex;justify-content:space-between;align-items:center">
                <span>{q}</span><span class="faq-icon ml-3 flex-shrink-0 text-lg font-light" style="color:#a0621c">+</span>
              </summary>
              <div class="px-4 pb-4 pt-3 font-sans text-sm leading-relaxed" style="color:#475569;border-top:1px solid #f5e8d0">{a}</div>
            </details>
          ))}
        </div>
      </section>

      <!-- RELATED BREEDS -->
      {relatedBreeds.length > 0 && (
        <section>
          <p class="font-sans text-xs font-bold uppercase tracking-widest mb-1" style="color:#a0621c">Similar breeds</p>
          <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">Names for Similar Breeds</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            {relatedBreeds.map((rb:any) => (
              <a href={`/dog-names/${rb.slug}`} class="rounded-2xl overflow-hidden transition-all hover:-translate-y-1" style="border:1px solid #e8ccaa;background:white;text-decoration:none">
                <div style="height:80px;overflow:hidden;background:#fdf8f0">
                  <img src={rb.image_url} alt={rb.name} width="160" height="80" loading="lazy" class="w-full h-full object-cover"
                    onerror="this.parentElement.innerHTML='<div style=display:flex;align-items:center;justify-content:100%;height:100%;font-size:2rem>🐕</div>'" />
                </div>
                <div class="p-3"><p class="font-sans text-xs font-bold" style="color:#1e293b">{rb.name} names →</p></div>
              </a>
            ))}
          </div>
        </section>
      )}

    </div>

    <!-- SIDEBAR -->
    <aside class="hidden lg:block">
      <div class="sticky space-y-5" style="top:80px">

        <div class="rounded-2xl overflow-hidden" style="border:2px solid #a0621c;background:white">
          <div class="px-4 py-3" style="background:#a0621c">
            <p class="font-sans text-xs font-bold uppercase tracking-wider text-white">Top {n} Names</p>
          </div>
          <div class="p-4">
            <p class="font-sans text-xs font-bold uppercase tracking-wider mb-2" style="color:#94a3b8">Boys</p>
            <div class="space-y-1.5 mb-4">
              {boys.slice(0,5).map((entry:any, i:number) => (
                <div class="flex items-center gap-2">
                  <span class="font-sans text-xs w-5 text-right flex-shrink-0" style="color:#94a3b8">#{i+1}</span>
                  <span class="font-sans font-bold text-sm flex-1" style="color:#1e293b">{entry.name}</span>
                  <span class="font-sans text-xs" style="color:#94a3b8">{entry.category}</span>
                </div>
              ))}
            </div>
            <p class="font-sans text-xs font-bold uppercase tracking-wider mb-2" style="color:#94a3b8">Girls</p>
            <div class="space-y-1.5">
              {girls.slice(0,5).map((entry:any, i:number) => (
                <div class="flex items-center gap-2">
                  <span class="font-sans text-xs w-5 text-right flex-shrink-0" style="color:#94a3b8">#{i+1}</span>
                  <span class="font-sans font-bold text-sm flex-1" style="color:#1e293b">{entry.name}</span>
                  <span class="font-sans text-xs" style="color:#94a3b8">{entry.category}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="rounded-2xl p-4" style="border:1px solid #e8ccaa;background:#fdf8f0">
          <p class="font-sans text-xs font-bold uppercase tracking-wider mb-3" style="color:#94a3b8">{n} profile</p>
          <div class="space-y-2 font-sans text-sm">
            {([
              ['Size', b.size_category],
              ['Energy', b.energy_level],
              ['Training', b.training_level],
              rank.intelligence_rank ? ['Intelligence', `#${rank.intelligence_rank} worldwide`] : null,
              b.origin_country ? ['Origin', b.origin_country] : null,
            ] as any[]).filter(Boolean).map((row:any) => (
              <div class="flex justify-between gap-2 pb-1.5" style="border-bottom:1px solid #e8ccaa">
                <span style="color:#64748b">{row[0]}</span>
                <span class="font-semibold capitalize" style="color:#1e293b">{row[1]}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl p-4" style="border:1px solid #e8ccaa;background:white">
          <p class="font-sans text-xs font-bold uppercase tracking-wider mb-3" style="color:#94a3b8">{n} Guides</p>
          <div class="space-y-0.5">
            {([
              links.hub           && { href:links.hub,           emoji:'🐾', label:`${n} complete guide` },
              links.food_post     && { href:links.food_post,     emoji:'🍖', label:`Best food for ${n}s` },
              links.toy_post      && { href:links.toy_post,      emoji:'🎾', label:`Best toys for ${n}s` },
              links.health_post   && { href:links.health_post,   emoji:'🩺', label:`${n} health guide`   },
              links.training_post && { href:links.training_post, emoji:'🦮', label:`Training a ${n}`     },
            ] as any[]).filter(Boolean).map((c:any) => (
              <a href={c.href} class="flex items-center gap-2 px-2 py-2 rounded-lg font-sans text-sm hover:bg-amber-50 transition-colors"
                style="color:#1e293b;text-decoration:none">
                <span>{c.emoji}</span><span>{c.label} →</span>
              </a>
            ))}
          </div>
        </div>

        <a href="/dog-names" class="block text-center rounded-2xl py-3 font-sans text-sm font-bold"
          style="border:2px solid #a0621c;color:#a0621c;text-decoration:none;background:white">
          Browse all breed names →
        </a>

      </div>
    </aside>
  </div>
</div>

<script>
  function showTab(tab: string) {
    const boys  = document.getElementById('panel-boys')!;
    const girls = document.getElementById('panel-girls')!;
    const btnB  = document.getElementById('tab-boys')!  as HTMLElement;
    const btnG  = document.getElementById('tab-girls')! as HTMLElement;
    if (tab === 'boys') {
      boys.classList.remove('hidden'); girls.classList.add('hidden');
      btnB.style.background='#a0621c'; btnB.style.color='white';
      btnG.style.background='transparent'; btnG.style.color='#7d4a10';
    } else {
      girls.classList.remove('hidden'); boys.classList.add('hidden');
      btnG.style.background='#a0621c'; btnG.style.color='white';
      btnB.style.background='transparent'; btnB.style.color='#7d4a10';
    }
  }
  (window as any).showTab = showTab;
  document.querySelectorAll('details').forEach(el => {
    el.addEventListener('toggle', () => {
      const icon = el.querySelector('.faq-icon') as HTMLElement;
      if (icon) icon.textContent = el.open ? '−' : '+';
    });
  });
</script>
</BaseLayout>
