---
import BaseLayout from '../layouts/BaseLayout.astro';

const SITE    = 'https://pupwiki.com';
const UPDATED = 'April 27, 2026';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',        item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'About',       item: `${SITE}/about` },
    { '@type': 'ListItem', position: 3, name: 'How We Test', item: `${SITE}/how-we-test` },
  ],
});

const processSteps = [
  {
    n: '01',
    title: 'Define the use case',
    body:
      'We start by defining what the product category is meant to solve. A dog bed for a senior Great Dane needs different criteria than a travel carrier for a toy breed.',
  },
  {
    n: '02',
    title: 'Map criteria to dog needs',
    body:
      'We compare products against relevant factors such as breed size, life stage, coat type, activity level, chewing behavior, comfort, safety, and owner use case.',
  },
  {
    n: '03',
    title: 'Research the market',
    body:
      'We review manufacturer information, product specifications, retailer listings, verified buyer feedback, recall or safety context where relevant, and comparable alternatives.',
  },
  {
    n: '04',
    title: 'Score practical fit',
    body:
      'Products are assessed for quality, usability, value, durability signals, breed-size match, and likely fit for real dog owners.',
  },
  {
    n: '05',
    title: 'Check health-sensitive claims',
    body:
      'For food, supplements, dental care, flea and tick products, and health-adjacent topics, we use cautious language and encourage readers to consult a veterinarian for dog-specific decisions.',
  },
  {
    n: '06',
    title: 'Disclose trade-offs',
    body:
      'Recommendations should explain who a product is best for, who should skip it, and what limitations or recurring complaints appear in available evidence.',
  },
  {
    n: '07',
    title: 'Update when needed',
    body:
      'We aim to update guides when product availability, formulas, pricing, safety context, or better alternatives change.',
  },
];

const summarySteps = [
  { step: '01', label: 'Research', icon: '🔍' },
  { step: '02', label: 'Compare', icon: '⚖️' },
  { step: '03', label: 'Score', icon: '📊' },
  { step: '04', label: 'Explain', icon: '📝' },
];

const scoringRows = [
  {
    factor: 'Practical fit',
    detail: 'How well the product fits the target dog size, life stage, use case, and owner need.',
    weight: '30%',
  },
  {
    factor: 'Quality signals',
    detail: 'Materials, ingredients, construction, transparency, certifications, and durability indicators.',
    weight: '25%',
  },
  {
    factor: 'Owner feedback patterns',
    detail: 'Recurring themes from available customer feedback, with attention to long-term issues and repeated complaints.',
    weight: '20%',
  },
  {
    factor: 'Value for money',
    detail: 'Price compared with similar alternatives at the same quality level.',
    weight: '15%',
  },
  {
    factor: 'Brand and safety context',
    detail: 'Recall history, customer support, product transparency, and known safety considerations where relevant.',
    weight: '10%',
  },
];

const dontRows = [
  'Accept payment from brands in exchange for guaranteed ranking positions.',
  'Rank products only by commission rate.',
  'Hide paid brand relationships from readers.',
  'Treat star ratings as the only quality signal.',
  'Make medical claims that should be made by a veterinarian.',
  'Recommend products that appear to have credible safety concerns without clearly explaining the risk.',
];

const contentTypes = [
  {
    title: 'Breed-specific product guides',
    text:
      'We adapt recommendations to breed size, activity level, coat needs, likely use case, and common owner concerns.',
  },
  {
    title: 'Dog food and nutrition content',
    text:
      'We compare ingredients, life-stage suitability, sourcing/transparency signals, recall context, and practical owner needs. We do not replace veterinary nutrition advice.',
  },
  {
    title: 'Health-adjacent recommendations',
    text:
      'We use conservative wording, include disclaimers, and avoid presenting general information as a diagnosis or treatment plan.',
  },
  {
    title: 'Cost and planning tools',
    text:
      'Tools are designed as planning estimates. Real costs vary by location, dog age, health, lifestyle, insurance provider, and product choices.',
  },
];

const correctionRows = [
  'A product has changed formula, size, material, price, or availability.',
  'A recommendation contains outdated information.',
  'A source, recall, or safety concern should be reviewed.',
  'A product is incorrectly matched to a breed size or use case.',
];
---

<BaseLayout
  title="How We Test & Review Dog Products — PupWiki Methodology"
  description="How PupWiki researches, compares, scores, and recommends dog products and care resources. Learn how we handle brand links, product claims, health-sensitive topics, and corrections."
  canonicalUrl={`${SITE}/how-we-test`}
  pageType="website"
>
  <script type="application/ld+json" set:html={breadcrumbLd} />
  <main class="methodology-page">
    <section class="methodology-hero" aria-labelledby="methodology-title">
      <div class="methodology-container">
        <nav class="methodology-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/about">About</a>
          <span aria-hidden="true">›</span>
          <span>How We Test</span>
        </nav>

        <p class="methodology-eyebrow">Our methodology</p>

        <h1 id="methodology-title" class="methodology-hero__title">
          How we research, compare, and review dog products.
        </h1>

        <p class="methodology-hero__subtitle">
          Our goal is to help dog owners make practical decisions with clear criteria,
          transparent limitations, and visible reader-support notes.
        </p>

        <div class="methodology-hero__meta">
          <span>Last updated: {UPDATED}</span>
          <span>No paid ranking placements</span>
          <span>Brand links disclosed</span>
        </div>
      </div>
    </section>

    <section class="methodology-main">
      <div class="methodology-container">
        <article class="methodology-intro-card">
          <p>
            PupWiki publishes breed guides, care resources, product guides, cost tools, and decision-support
            content for dog owners. Some articles may include reader-supported brand links, but our editorial goal is to
            recommend useful, relevant options rather than simply promote the highest-paying partner.
          </p>

          <p>
            We do not claim that every product is physically tested by PupWiki unless a specific page clearly says so.
            Many recommendations are based on structured research, product data, buyer feedback patterns,
            safety context, and breed-specific suitability.
          </p>
        </article>

        <div class="methodology-layout">
          <aside class="methodology-toc" aria-label="Methodology sections">
            <h2>On this page</h2>
            <nav>
              <a href="#short-version">Short version</a>
              <a href="#process">Our process</a>
              <a href="#scoring">Scoring model</a>
              <a href="#content-types">Content types</a>
              <a href="#affiliate-policy">Reader-support policy</a>
              <a href="#health">Health-sensitive topics</a>
              <a href="#dont-do">What we do not do</a>
              <a href="#corrections">Corrections</a>
            </nav>
          </aside>

          <div class="methodology-content">
            <section id="short-version" class="methodology-section">
              <p class="methodology-eyebrow">The short version</p>
              <h2>Our review process at a glance</h2>

              <div class="methodology-summary-grid">
                {summarySteps.map((step) => (
                  <article>
                    <span aria-hidden="true">{step.icon}</span>
                    <strong>{step.step}</strong>
                    <p>{step.label}</p>
                  </article>
                ))}
              </div>

              <p>
                Every guide should answer the same basic reader questions: what is this best for,
                who should avoid it, what are the trade-offs, and how confident are we in the available information?
              </p>
            </section>

            <section id="process" class="methodology-section">
              <p class="methodology-eyebrow">In detail</p>
              <h2>Our process, step by step</h2>

              <div class="methodology-step-list">
                {processSteps.map((step) => (
                  <article class="methodology-step">
                    <div class="methodology-step__number">{step.n}</div>
                    <div>
                      <h3>{step.title}</h3>
                      <p>{step.body}</p>
                    </div>
                  </article>
                ))}
              </div>
            </section>

            <section id="scoring" class="methodology-section">
              <p class="methodology-eyebrow">Scoring</p>
              <h2>How our product scores are calculated</h2>

              <p>
                When a product guide uses scores or rankings, the score is a weighted editorial estimate.
                Weights may vary by category, but the model below explains the default framework.
              </p>

              <div class="methodology-table-wrap">
                <table class="methodology-table">
                  <thead>
                    <tr>
                      <th>Factor</th>
                      <th>What we evaluate</th>
                      <th>Typical weight</th>
                    </tr>
                  </thead>
                  <tbody>
                    {scoringRows.map((row) => (
                      <tr>
                        <td>{row.factor}</td>
                        <td>{row.detail}</td>
                        <td>{row.weight}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>

              <p class="methodology-muted">
                Scores are not medical advice, safety guarantees, or professional veterinary recommendations.
                They are editorial tools to help readers compare options more quickly.
              </p>
            </section>

            <section id="content-types" class="methodology-section">
              <p class="methodology-eyebrow">Content types</p>
              <h2>How methodology changes by topic</h2>

              <div class="methodology-card-grid">
                {contentTypes.map((item) => (
                  <article>
                    <h3>{item.title}</h3>
                    <p>{item.text}</p>
                  </article>
                ))}
              </div>
            </section>

            <section id="affiliate-policy" class="methodology-section methodology-section--highlight">
              <p class="methodology-eyebrow">Reader-support note</p>
              <h2>How brand links affect our work</h2>

              <p>
                PupWiki may earn commissions when readers click some brand links or buy from partner websites.
                This helps fund content production, data work, tools, and site maintenance.
              </p>

              <div class="methodology-callout">
                <strong>Editorial rule</strong>
                <p>
                  Paid brand relationships should not guarantee a product’s position, score, or inclusion.
                  If an unpaid option appears to be the best fit for a reader, our content should be able
                  to say that clearly.
                </p>
              </div>

              <p>
                We disclose paid brand relationships on relevant pages and provide more detail on our
                <a href="/disclosure">reader-support policy</a> page.
              </p>
            </section>

            <section id="health" class="methodology-section">
              <p class="methodology-eyebrow">Health-sensitive topics</p>
              <h2>Food, supplements, medical, and safety-related topics</h2>

              <p>
                Some dog topics can affect health, safety, or medical decisions. For these topics, PupWiki aims
                to use cautious wording, cite reputable sources when available, and avoid presenting general
                information as a diagnosis or treatment plan.
              </p>

              <ul class="methodology-check-list">
                <li>We encourage readers to consult a veterinarian for dog-specific health decisions.</li>
                <li>We avoid claiming that a product treats, cures, or prevents disease unless supported by appropriate evidence and wording.</li>
                <li>We flag known uncertainty or developing scientific debate where relevant.</li>
                <li>We treat recalls, safety alerts, and formula changes as reasons to review or update content.</li>
              </ul>
            </section>

            <section id="dont-do" class="methodology-section methodology-section--danger">
              <p class="methodology-eyebrow">Standards</p>
              <h2>What we explicitly do not do</h2>

              <div class="methodology-dont-list">
                {dontRows.map((item) => (
                  <div>
                    <span aria-hidden="true">×</span>
                    <p>{item}</p>
                  </div>
                ))}
              </div>
            </section>

            <section id="corrections" class="methodology-section">
              <p class="methodology-eyebrow">Corrections</p>
              <h2>Spotted an error or outdated recommendation?</h2>

              <p>
                We take corrections seriously. Product markets change quickly, and reader feedback helps us
                improve accuracy.
              </p>

              <div class="methodology-card-grid">
                {correctionRows.map((item) => (
                  <article>
                    <h3>{item}</h3>
                    <p>Send us the page URL and the specific detail you believe should be reviewed.</p>
                  </article>
                ))}
              </div>

              <a href="/contact" class="methodology-button">
                Contact us
                <span aria-hidden="true">→</span>
              </a>
            </section>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .methodology-page {
    background:
      radial-gradient(circle at 88% 4%, rgba(255, 122, 0, 0.1), transparent 24rem),
      radial-gradient(circle at 8% 2%, rgba(21, 54, 95, 0.08), transparent 22rem),
      var(--color-bg);
    color: var(--color-body);
  }

  .methodology-container {
    width: min(100%, var(--max-width));
    margin-inline: auto;
    padding-inline: var(--content-padding-mobile);
  }

  .methodology-hero {
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(255, 250, 243, 0.98) 0%, #ffffff 78%);
  }

  .methodology-hero .methodology-container {
    padding-block: clamp(2.5rem, 7vw, 5.75rem);
  }

  .methodology-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin-bottom: var(--space-5);
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .methodology-breadcrumb a {
    color: var(--color-primary);
    font-weight: var(--weight-semi);
    text-decoration: none;
  }

  .methodology-breadcrumb a:hover {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .methodology-eyebrow {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    margin: 0;
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    background: var(--color-accent-subtle);
    padding: 0.54rem 0.85rem;
    color: var(--color-accent-hover);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-none);
    text-transform: uppercase;
  }

  .methodology-hero__title {
    max-width: 13ch;
    margin: var(--space-5) 0 0;
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 11vw, 5.35rem);
    font-weight: var(--weight-bold);
    letter-spacing: -0.055em;
    line-height: 0.96;
    text-wrap: balance;
  }

  .methodology-hero__subtitle {
    max-width: 48rem;
    margin: var(--space-5) 0 0;
    color: var(--color-body-soft);
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2.2vw, var(--text-lg));
    line-height: var(--leading-relaxed);
    text-wrap: pretty;
  }

  .methodology-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }

  .methodology-hero__meta span {
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.78);
    padding: 0.5rem 0.72rem;
    color: var(--color-body-soft);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    line-height: 1;
    box-shadow: var(--shadow-xs);
  }

  .methodology-main {
    padding-block: clamp(var(--space-8), 6vw, var(--space-14));
  }

  .methodology-intro-card {
    max-width: 58rem;
    margin-bottom: var(--space-8);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-3xl);
    background: rgba(255, 255, 255, 0.9);
    padding: var(--space-5);
    box-shadow: var(--shadow-card);
  }

  .methodology-intro-card p {
    margin: 0;
    color: var(--color-body-soft);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .methodology-intro-card p + p {
    margin-top: var(--space-4);
  }

  .methodology-layout {
    display: grid;
    gap: var(--space-8);
    align-items: start;
  }

  .methodology-toc {
    display: none;
  }

  .methodology-content {
    display: grid;
    gap: var(--space-6);
    min-width: 0;
  }

  .methodology-section {
    scroll-margin-top: 7rem;
    border: 1px solid var(--card-border);
    border-radius: var(--radius-3xl);
    background: rgba(255, 255, 255, 0.92);
    padding: var(--space-5);
    box-shadow: var(--shadow-card);
  }

  .methodology-section--highlight {
    border-color: var(--color-border-accent);
    background:
      radial-gradient(circle at 92% 10%, rgba(255, 122, 0, 0.12), transparent 18rem),
      rgba(255, 255, 255, 0.94);
  }

  .methodology-section--danger {
    border-color: rgba(220, 38, 38, 0.22);
    background:
      radial-gradient(circle at 92% 10%, rgba(220, 38, 38, 0.08), transparent 18rem),
      rgba(255, 255, 255, 0.94);
  }

  .methodology-section h2 {
    margin: var(--space-3) 0 var(--space-4);
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }

  .methodology-section h3 {
    margin: 0 0 var(--space-2);
    color: var(--color-heading);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--weight-black);
    line-height: var(--leading-tight);
  }

  .methodology-section p,
  .methodology-section li {
    color: var(--color-body-soft);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }

  .methodology-section p {
    margin: 0;
  }

  .methodology-section p + p {
    margin-top: var(--space-4);
  }

  .methodology-section a {
    color: var(--color-primary);
    font-weight: var(--weight-bold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .methodology-section a:hover {
    color: var(--color-accent-hover);
  }

  .methodology-summary-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
    margin-block: var(--space-5);
  }

  .methodology-summary-grid article {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: var(--color-bg-soft);
    padding: var(--space-4);
    text-align: center;
    box-shadow: var(--shadow-xs);
  }

  .methodology-summary-grid span {
    display: block;
    font-size: 1.8rem;
    line-height: 1;
  }

  .methodology-summary-grid strong {
    display: block;
    margin-top: var(--space-3);
    color: var(--color-accent-hover);
    font-size: var(--text-xs);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
  }

  .methodology-summary-grid p {
    margin-top: var(--space-1);
    color: var(--color-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-black);
    line-height: var(--leading-tight);
  }

  .methodology-step-list {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }

  .methodology-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-4);
  }

  .methodology-step:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .methodology-step__number {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border-radius: var(--radius-full);
    background: var(--color-accent);
    color: #ffffff;
    font-size: var(--text-xs);
    font-weight: var(--weight-black);
    line-height: 1;
    box-shadow: var(--shadow-accent);
  }

  .methodology-step p {
    font-size: var(--text-sm);
  }

  .methodology-table-wrap {
    overflow-x: auto;
    margin-block: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: #ffffff;
  }

  .methodology-table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .methodology-table th,
  .methodology-table td {
    border-bottom: 1px solid var(--color-border);
    padding: 0.9rem 1rem;
    text-align: left;
    vertical-align: top;
  }

  .methodology-table th {
    background: var(--color-bg-soft);
    color: var(--color-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-black);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .methodology-table td:first-child {
    color: var(--color-heading);
    font-weight: var(--weight-black);
  }

  .methodology-table td:last-child {
    color: var(--color-accent-hover);
    font-weight: var(--weight-black);
    text-align: right;
    white-space: nowrap;
  }

  .methodology-table tbody tr:nth-child(even) {
    background: var(--color-bg-soft);
  }

  .methodology-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .methodology-muted {
    color: var(--color-muted) !important;
    font-size: var(--text-sm) !important;
  }

  .methodology-card-grid {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .methodology-card-grid article {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: var(--color-bg-soft);
    padding: var(--space-4);
  }

  .methodology-card-grid p {
    font-size: var(--text-sm);
  }

  .methodology-callout {
    margin-block: var(--space-5);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-2xl);
    background: var(--color-accent-subtle);
    padding: var(--space-4);
  }

  .methodology-callout strong {
    display: block;
    margin-bottom: var(--space-2);
    color: var(--color-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-black);
  }

  .methodology-callout p {
    color: var(--color-body);
    font-size: var(--text-sm);
  }

  .methodology-check-list {
    display: grid;
    gap: var(--space-2);
    margin-top: var(--space-5);
    padding-left: 0;
    list-style: none;
  }

  .methodology-check-list li {
    position: relative;
    border: 1px solid rgba(4, 120, 87, 0.18);
    border-radius: var(--radius-xl);
    background: var(--color-success-light);
    padding: 0.75rem 0.85rem 0.75rem 2.25rem;
    color: var(--color-body);
    font-size: var(--text-sm);
  }

  .methodology-check-list li::before {
    content: '✓';
    position: absolute;
    left: 0.85rem;
    top: 0.75rem;
    color: var(--color-success);
    font-weight: var(--weight-black);
  }

  .methodology-dont-list {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .methodology-dont-list div {
    display: grid;
    grid-template-columns: auto 1fr;
