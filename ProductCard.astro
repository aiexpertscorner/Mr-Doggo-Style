---
/**
 * ProductCard.astro — v2
 * Priority: local_image > amazon CDN > clearbit brand logo > emoji
 * Works with or without Amazon API
 */
export interface Props {
  name:        string;
  asin:        string;
  price?:      number;
  rating?:     number;
  reviewCount?: number;
  ourScore?:   number;
  verdict?:    string;
  pros?:       string[];
  cons?:       string[];
  badge?:      string;
  features?:   string[];
  image?:      string;       // Amazon CDN URL (may fail)
  local_image?: string;      // /images/products/{id}.jpg (always works)
  product_id?: string;       // for local_image lookup
  tag?:        string;
}

const {
  name, asin, price, rating = 4.5, reviewCount,
  ourScore, verdict, pros = [], cons = [], badge,
  features = [], image, local_image, product_id,
  tag = 'aiexpertscorn-20',
} = Astro.props;

const url   = `https://www.amazon.com/dp/${asin}/?tag=${tag}`;
const stars = Math.round(rating);
const scoreColor = ourScore
  ? (ourScore >= 9 ? '#16a34a' : ourScore >= 7 ? '#d97706' : '#dc2626')
  : '#6b7280';

// Image source priority
const localSrc = local_image || (product_id ? `/images/products/${product_id}.jpg` : null);
const amazonSrc = image?.includes('media-amazon') ? image : null;

// Brand emoji mapping for last-resort fallback
const BRAND_EMOJI: Record<string, string> = {
  'food': '🍖', 'dog-food': '🍖', 'food': '🍖',
  'toy': '🎾', 'toys': '🎾', 'chew': '🦴',
  'bed': '🛏️', 'beds': '🛏️',
  'health': '🩺', 'supplement': '💊', 'supplements': '💊',
  'training': '🦮', 'grooming': '✂️', 'travel': '✈️',
  'smart': '📡', 'gps': '📍',
};
const nameLower = name.toLowerCase();
const fallbackEmoji = Object.entries(BRAND_EMOJI).find(([k]) => nameLower.includes(k))?.[1] || '🐾';

const reviewSchema = JSON.stringify({
  "@context":    "https://schema.org",
  "@type":       "Review",
  "itemReviewed": {
    "@type":  "Product",
    "name":   name,
    ...(price ? { "offers": { "@type": "Offer", "price": price, "priceCurrency": "USD", "url": url } } : {}),
  },
  "reviewRating": {
    "@type":       "Rating",
    "ratingValue": ourScore || rating,
    "bestRating":  ourScore ? 10 : 5,
    "worstRating": 1,
  },
  "author":     { "@type": "Organization", "name": "Mr. Doggo Style" },
  "reviewBody": verdict,
});
---

<div class="not-prose bg-white rounded-2xl border overflow-hidden shadow-sm hover:shadow-md transition-shadow" style="border-color:#f5e8d0">
  <script type="application/ld+json" set:html={reviewSchema} />

  {badge && (
    <div class="font-sans text-xs font-bold uppercase tracking-wider text-center py-1.5 text-white" style="background:#f59e0b">
      {badge}
    </div>
  )}

  <div class="p-5">
    <div class="flex items-start gap-4 mb-4">

      <!-- Product image with layered fallbacks -->
      <div class="flex-shrink-0 w-20 h-20 rounded-xl overflow-hidden flex items-center justify-center" style="background:linear-gradient(135deg,#fdf8f0,#fef3c7)">
        {localSrc ? (
          <img
            src={localSrc}
            alt={name}
            width="80"
            height="80"
            loading="lazy"
            class="w-full h-full object-contain"
            id={`img-${asin}`}
            onerror={`this.style.display='none';document.getElementById('fallback-${asin}').style.display='flex'`}
          />
        ) : amazonSrc ? (
          <img
            src={amazonSrc}
            alt={name}
            width="80"
            height="80"
            loading="lazy"
            class="w-full h-full object-contain"
            id={`img-${asin}`}
            onerror={`this.style.display='none';document.getElementById('fallback-${asin}').style.display='flex'`}
          />
        ) : null}
        <div
          id={`fallback-${asin}`}
          class="w-full h-full items-center justify-center text-3xl"
          style={localSrc || amazonSrc ? 'display:none' : 'display:flex'}
        >
          {fallbackEmoji}
        </div>
      </div>

      <!-- Name + rating -->
      <div class="flex-1 min-w-0">
        <h3 class="font-display font-semibold text-slate-900 leading-snug mb-1" style="font-family:'Playfair Display',Georgia,serif;font-size:0.95rem">
          {name}
        </h3>
        <div class="flex flex-wrap items-center gap-2 font-sans text-sm">
          <span style="color:#f59e0b">{'★'.repeat(stars)}{'☆'.repeat(5-stars)}</span>
          <span style="color:#6b7280">{rating.toFixed(1)}{reviewCount ? ` (${reviewCount.toLocaleString()})` : ''}</span>
          {price && <span class="font-bold" style="color:#7d4a10">${price.toFixed(2)}</span>}
        </div>
      </div>

      {ourScore && (
        <div class="text-center flex-shrink-0">
          <div class="font-sans font-black text-2xl leading-none" style={`color:${scoreColor}`}>
            {ourScore}<span class="text-xs font-normal" style="color:#9ca3af">/10</span>
          </div>
          <div class="font-sans text-xs mt-0.5" style="color:#9ca3af">Score</div>
        </div>
      )}
    </div>

    {verdict && (
      <p class="font-sans text-sm italic mb-3 pl-3" style="color:#374151;border-left:3px solid #fbbf24">
        {verdict}
      </p>
    )}

    {features.length > 0 && (
      <ul class="mb-3 space-y-1">
        {features.slice(0, 3).map(f => (
          <li class="font-sans text-sm flex items-start gap-2" style="color:#374151">
            <span style="color:#f59e0b;flex-shrink:0">✓</span>{f}
          </li>
        ))}
      </ul>
    )}

    {(pros.length > 0 || cons.length > 0) && (
      <div class="grid grid-cols-2 gap-2 mb-3 font-sans text-xs">
        {pros.length > 0 && (
          <div class="rounded-xl p-3" style="background:#f0fdf4">
            <p class="font-bold mb-1" style="color:#15803d">✅ Pros</p>
            {pros.slice(0, 3).map(p => <p style="color:#166534" class="mb-0.5">{p}</p>)}
          </div>
        )}
        {cons.length > 0 && (
          <div class="rounded-xl p-3" style="background:#fef2f2">
            <p class="font-bold mb-1" style="color:#b91c1c">❌ Cons</p>
            {cons.slice(0, 3).map(c => <p style="color:#991b1b" class="mb-0.5">{c}</p>)}
          </div>
        )}
      </div>
    )}

    {asin !== 'SUBSCRIPTION' ? (
      <a
        href={url}
        rel="nofollow sponsored"
        target="_blank"
        class="block text-center font-sans font-bold text-sm py-3 rounded-xl text-white btn-amazon"
        style="background:linear-gradient(135deg,#FF9900,#e88700)"
      >
        Check Price on Amazon ›
      </a>
    ) : (
      <a
        href="#"
        class="block text-center font-sans font-bold text-sm py-3 rounded-xl text-white"
        style="background:linear-gradient(135deg,#a0621c,#7d4a10)"
      >
        View Subscription →
      </a>
    )}
  </div>
</div>
