# =============================================================
# PupWiki .gitignore
# Keep source/content/data intentionally trackable.
# Use .claudeignore for Claude context slimming; do not hide source files here.
# =============================================================

# Dependencies
node_modules/
.pnpm-store/
.yarn/
.npm/

# Astro / build output
dist/
.output/
out/
build/
.astro/
.cache/

# Hosting / deployment local state
.wrangler/
.vercel/
.netlify/

# Environment variables / secrets
.env
.env.*
!.env.example
!.env.sample

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Test / coverage output
coverage/
playwright-report/
test-results/
.lighthouseci/

# Temporary/local script output
.tmp/
tmp/
temp/
scripts/tmp/
scripts/output/
scripts/exports/
scripts/.cache/

# Local exports and screenshots
exports/
export/
screenshots/
screenshot/

# Local prompt packs / downloadable working artifacts
claude_code_migration_pack*/
*_prompt_pack*/
*.zip
*.docx
*.pdf
*.xlsx
*.xls

# Accidental token/style copies
src/styles/tokens copy.css
src/styles/* copy.css

# Do NOT ignore source markdown/content/data globally.
# These are intentionally trackable when they belong to the site:
# - *.md
# - src/content/blog/
# - src/data/
# - docs/
