# PupWiki local environment template
# Copy to .env.local and fill real values locally.
# Never commit .env.local or real secrets.

# Cloudflare deploy
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# AWIN affiliate sync
AWIN_OAUTH2_TOKEN=
AWIN_PRODUCT_FEED_API_KEY=
AWIN_PUBLISHER_ID=2861861
AWIN_COUNTRY_CODE=US
AWIN_FETCH_CREATIVES=false

# Optional: paste the full feedList URL from Awin UI instead of relying on inferred endpoints.
# Use placeholders or the real URL locally only.
# AWIN_PRODUCT_FEED_LIST_URL=https://ui.awin.com/productdata-darwin-download/publisher/2861861/<apiKey>/1/feedList

# Amazon affiliate sync/rendering
PUBLIC_AMAZON_TAG=
PUBLIC_ENABLE_AMAZON_BUTTONS=true

# Analytics / newsletter
PUBLIC_GA_MEASUREMENT_ID=
PUBLIC_EMAILOCTOPUS_URL=
