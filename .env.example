# Copy this file to .env and fill in your values
# .env is gitignored — never commit real keys

# Google Analytics 4
# Get from: https://analytics.google.com > Admin > Data Streams > Measurement ID
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Amazon Associates Tag
# Default tag is set in components but you can override here
PUBLIC_AMAZON_TAG=aiexpertscorn-20

# Newsletter Integration (choose one)
# Mailchimp action URL (from your list's embedded form)
PUBLIC_MAILCHIMP_URL=https://yourlist.us1.list-manage.com/subscribe/post?u=XXXXX&id=XXXXX

# ConvertKit form action
PUBLIC_CONVERTKIT_URL=https://app.convertkit.com/forms/XXXXXXX/subscriptions

# EmailOctopus
PUBLIC_EMAILOCTOPUS_URL=https://emailoctopus.com/lists/XXXXX/members/embedded/1.3/add
