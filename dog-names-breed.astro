---
/**
 * dog-names/[breed].astro — Breed-specific name generator
 * Uses dog-names.json filtered by breed name_styles + name_inspirations
 */
import BaseLayout   from '../../layouts/BaseLayout.astro';
import masterBreeds from '../../data/master-breeds.json';
import allNamesData from '../../data/dog-names.json';
import breedLinkMap from '../../data/breed-link-map.json';

export function getStaticPaths() {
  return (masterBreeds as any[]).map(b => ({ params: { breed: b.slug } }));
}

const { breed: slug } = Astro.params;
const b     = (masterBreeds as any[]).find(x => x.slug === slug);
if (!b) return Astro.redirect('/dog-names');

const links  = (breedLinkMap as any)[slug] || {};
const styles = b.name_styles        || ['Classic','Trendy'];
const insps  = b.name_inspirations  || ['Classic Pet','Nature'];
const rank   = b.ranking_data       || {};
const n      = b.name;

type NameEntry = { name:string; gender:string; category:string; inspiration:string; rank:number; enriched:boolean };
const allNames = allNamesData as NameEntry[];

function filterNames(gender: string, count: number): string[] {
  return allNames
    .filter(x => x.gender === gender && (styles.includes(x.category) || insps.includes(x.inspiration)))
    .sort((a,b) => (a.rank||9999)-(b.rank||9999))
    .slice(0, count).map(x => x.name);
}
function getByCategory(cat: string, count: number): string[] {
  return allNames.filter(x => x.category === cat).sort((a,b)=>(a.rank||9999)-(b.rank||9999)).slice(0,count).map(x=>x.name);
}
function getByInspiration(insp: string, count: number): string[] {
  return allNames.filter(x => x.inspiration === insp).sort((a,b)=>(a.rank||9999)-(b.rank||9999)).slice(0,count).map(x=>x.name);
}

const boys   = filterNames('boy',  15);
const girls  = filterNames('girl', 15);
const nature = getByInspiration('Nature', 10);
const myth   = getByInspiration('Mythology', 10);
const tough  = getByCategory('Tough', 10);
const cute   = getByCategory('Cute', 10);

const temp  = (b.temperament||'').toLowerCase();
const personality = temp.includes('friendly') ? 'friendly, social'
  : temp.includes('loyal')||temp.includes('protective') ? 'loyal, protective'
  : temp.includes('intelligent')||temp.includes('smart') ? 'intelligent, sharp'
  : temp.includes('gentle')||temp.includes('calm') ? 'gentle, calm'
  : `${b.energy_level}-energy`;

const intel_note = rank.intelligence_rank
  ? `${n}s rank #${rank.intelligence_rank} in canine intelligence (${rank.intelligence_label||'above average'}) — they learn their name quickly. Short names (1–2 syllables) work best.`
  : `${n}s respond best to 1–2 syllable names ending in a vowel sound.`;
---

<BaseLayout
  title={`Best ${n} Names 2026 — ${styles.join(' & ')} Picks for Boys & Girls`}
  description={`The best names for ${n}s matched to their ${personality} personality. ${styles.join(' and ')} options, plus themed lists.`}
  canonicalURL={`https://mrdoggostyle.com/dog-names/${slug}`}
>

  <!-- Hero -->
  <div style="background:linear-gradient(to bottom,#f5e8d0,#fdf8f0);border-bottom:1px solid #e8ccaa">
    <div class="max-w-7xl mx-auto px-4 py-10">
      <nav class="font-sans text-sm mb-4" style="color:#a0621c">
        <a href="/" style="color:#a0621c" class="hover:underline">Home</a>
        <span style="color:#d4a574"> › </span>
        <a href="/dog-names" style="color:#a0621c" class="hover:underline">Dog Names</a>
        <span style="color:#d4a574"> › </span>
        <span style="color:#5c340a">{n} Names</span>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-3" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
        Best {n} Names 2026
      </h1>
      <p class="font-sans text-lg mb-4" style="color:#64748b">
        {n}s are {personality} dogs — these names are matched to their character and breed profile.
      </p>
      <div class="flex flex-wrap gap-2">
        {styles.map((s: string) => <span class="font-sans text-xs font-bold px-3 py-1 rounded-full" style="background:#a0621c;color:white">{s}</span>)}
        {insps.map((i: string)  => <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style="background:#fef3c7;color:#92400e">{i}</span>)}
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-10">
    <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-10">

      <div class="space-y-10">

        <!-- Boy names -->
        <section>
          <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
            Top Boy Names for {n}s
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
            {boys.slice(0,15).map((name,i) => (
              <div class="rounded-xl p-3 text-center" style="background:white;border:1px solid #e8ccaa">
                <p class="font-sans text-xs mb-1" style="color:#94a3b8">#{i+1}</p>
                <p class="font-sans font-bold text-base" style="color:#1e293b">{name}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Girl names -->
        <section>
          <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
            Top Girl Names for {n}s
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
            {girls.slice(0,15).map((name,i) => (
              <div class="rounded-xl p-3 text-center" style="background:white;border:1px solid #e8ccaa">
                <p class="font-sans text-xs mb-1" style="color:#94a3b8">#{i+1}</p>
                <p class="font-sans font-bold text-base" style="color:#1e293b">{name}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Themed lists -->
        <section>
          <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
            Names by Theme
          </h2>
          <div class="grid sm:grid-cols-2 gap-5">
            {insps.includes('Nature') && (
              <div class="rounded-2xl p-5" style="background:white;border:1px solid #e8ccaa">
                <h3 class="font-sans font-bold text-base mb-3" style="color:#1e293b">🌿 Nature Names</h3>
                <div class="flex flex-wrap gap-2">
                  {nature.map(name => <span class="font-sans text-sm px-3 py-1 rounded-full" style="background:#f0fdf4;color:#15803d">{name}</span>)}
                </div>
              </div>
            )}
            {insps.includes('Mythology') && (
              <div class="rounded-2xl p-5" style="background:white;border:1px solid #e8ccaa">
                <h3 class="font-sans font-bold text-base mb-3" style="color:#1e293b">⚡ Mythology Names</h3>
                <div class="flex flex-wrap gap-2">
                  {myth.map(name => <span class="font-sans text-sm px-3 py-1 rounded-full" style="background:#ede9fe;color:#5b21b6">{name}</span>)}
                </div>
              </div>
            )}
            {styles.includes('Tough') && (
              <div class="rounded-2xl p-5" style="background:white;border:1px solid #e8ccaa">
                <h3 class="font-sans font-bold text-base mb-3" style="color:#1e293b">💪 Tough Names</h3>
                <div class="flex flex-wrap gap-2">
                  {tough.map(name => <span class="font-sans text-sm px-3 py-1 rounded-full" style="background:#fef2f2;color:#dc2626">{name}</span>)}
                </div>
              </div>
            )}
            <div class="rounded-2xl p-5" style="background:white;border:1px solid #e8ccaa">
              <h3 class="font-sans font-bold text-base mb-3" style="color:#1e293b">🌸 Cute Names</h3>
              <div class="flex flex-wrap gap-2">
                {cute.map(name => <span class="font-sans text-sm px-3 py-1 rounded-full" style="background:#fdf4ff;color:#a21caf">{name}</span>)}
              </div>
            </div>
          </div>
        </section>

        <!-- Naming guide -->
        <section class="rounded-2xl p-6" style="background:white;border:1px solid #e8ccaa">
          <h2 class="font-display text-xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
            How to Pick the Right Name for Your {n}
          </h2>
          <div class="space-y-4 font-sans text-sm" style="color:#475569">
            <div class="flex gap-3">
              <span style="color:#a0621c;font-weight:bold;flex-shrink:0">1.</span>
              <div><strong style="color:#1e293b">Keep it short — 1–2 syllables.</strong> {n}s distinguish their name from surrounding sounds most easily when it's short and ends in a vowel sound (Bella, Milo, Luna, Charlie).</div>
            </div>
            <div class="flex gap-3">
              <span style="color:#a0621c;font-weight:bold;flex-shrink:0">2.</span>
              <div><strong style="color:#1e293b">Avoid command sounds.</strong> Names that sound like "sit," "stay," "no," "down," or "come" create confusion. Also avoid names rhyming with family members.</div>
            </div>
            <div class="flex gap-3">
              <span style="color:#a0621c;font-weight:bold;flex-shrink:0">3.</span>
              <div><strong style="color:#1e293b">Test it aloud in three tones.</strong> Excited ("Milo!"), firm ("Milo, no!"), and calling ("Come here, Milo!"). A good name works in all three.</div>
            </div>
            <div class="flex gap-3">
              <span style="color:#a0621c;font-weight:bold;flex-shrink:0">4.</span>
              <div><strong style="color:#1e293b">Intelligence matters.</strong> {intel_note}</div>
            </div>
          </div>
        </section>

        <!-- FAQ -->
        <section>
          <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
            Frequently Asked Questions
          </h2>
          <div class="space-y-2">
            {[
              [`What names work best for ${n}s?`, `Based on the ${n}'s ${personality} personality, the best names are ${styles[0].toLowerCase()} in style — names like ${boys[0]}, ${boys[1]}, ${boys[2]} for boys and ${girls[0]}, ${girls[1]}, ${girls[2]} for girls.`],
              [`Can I change my ${n}'s name?`, `Yes — dogs adapt to new names within 1–2 weeks when done correctly. Pair the new name with high-value treats consistently for the first 5–7 days.`],
              [`What are the most popular ${n} names?`, `Max, Buddy, Cooper, Charlie (boys) and Bella, Luna, Daisy, Lucy (girls) consistently top the lists. They're short, distinct, and age well.`],
            ].map(([q, a]) => (
              <details class="rounded-xl overflow-hidden" style="border:1px solid #e8ccaa;background:white">
                <summary class="p-4 font-sans font-semibold text-sm cursor-pointer flex justify-between items-center" style="color:#1e293b;list-style:none">
                  {q}
                  <span style="color:#a0621c;font-size:1.2rem;flex-shrink:0">+</span>
                </summary>
                <div class="px-4 pb-4 font-sans text-sm" style="color:#475569;border-top:1px solid #f5e8d0">{a}</div>
              </details>
            ))}
          </div>
        </section>

      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky space-y-5" style="top:80px">

          <!-- Top picks summary -->
          <div class="rounded-2xl overflow-hidden" style="border:2px solid #a0621c;background:white">
            <div class="px-4 py-2 font-sans text-xs font-bold uppercase tracking-wider text-white" style="background:#a0621c">
              Top {n} Names
            </div>
            <div class="p-4">
              <p class="font-sans text-xs font-bold uppercase tracking-wider mb-2" style="color:#94a3b8">Boys</p>
              <div class="space-y-1 mb-4">
                {boys.slice(0,5).map((name,i) => (
                  <div class="flex items-center gap-2 font-sans text-sm">
                    <span style="color:#94a3b8;width:20px">#{i+1}</span>
                    <strong style="color:#1e293b">{name}</strong>
                  </div>
                ))}
              </div>
              <p class="font-sans text-xs font-bold uppercase tracking-wider mb-2" style="color:#94a3b8">Girls</p>
              <div class="space-y-1">
                {girls.slice(0,5).map((name,i) => (
                  <div class="flex items-center gap-2 font-sans text-sm">
                    <span style="color:#94a3b8;width:20px">#{i+1}</span>
                    <strong style="color:#1e293b">{name}</strong>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Related guides -->
          <div class="rounded-2xl p-4" style="border:1px solid #e8ccaa;background:white">
            <p class="font-sans text-xs font-bold uppercase tracking-wider mb-3" style="color:#94a3b8">{n} Guides</p>
            <div class="space-y-1">
              {links.hub && <a href={links.hub} class="flex items-center gap-2 px-2 py-2 rounded-lg font-sans text-sm" style="color:#1e293b;text-decoration:none">🐾 {n} complete guide →</a>}
              {links.food_post && <a href={links.food_post} class="flex items-center gap-2 px-2 py-2 rounded-lg font-sans text-sm" style="color:#1e293b;text-decoration:none">🍖 Best food for {n}s →</a>}
              {links.toy_post  && <a href={links.toy_post}  class="flex items-center gap-2 px-2 py-2 rounded-lg font-sans text-sm" style="color:#1e293b;text-decoration:none">🎾 Best toys for {n}s →</a>}
              {links.health_post && <a href={links.health_post} class="flex items-center gap-2 px-2 py-2 rounded-lg font-sans text-sm" style="color:#1e293b;text-decoration:none">🩺 {n} health guide →</a>}
            </div>
          </div>

        </div>
      </aside>

    </div>
  </div>

</BaseLayout>
