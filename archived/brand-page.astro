---
/**
 * brands/[brand].astro — Brand hub page
 * Shows logo, all products, breed matches, dual Amazon + Chewy CTAs
 */
import BaseLayout   from '../../layouts/BaseLayout.astro';
import brandsData   from '../../data/brands.json';
import productIndex from '../../data/product-index.json';
import masterBreeds from '../../data/master-breeds.json';

const AMAZON_TAG = 'aiexpertscorn-20';
const SITE       = 'https://mrdoggostyle.com';

export function getStaticPaths() {
  return (brandsData as any[]).map(b => ({ params: { brand: b.slug } }));
}

const { brand: slug } = Astro.params;
const brand = (brandsData as any[]).find(b => b.slug === slug);
if (!brand) return Astro.redirect('/brands');

// Products from this brand
const brandProducts = Object.values(productIndex as any)
  .filter((p: any) => {
    const name = (p.name || '').toLowerCase();
    return name.includes(brand.name.toLowerCase().split(' ')[0].toLowerCase());
  }) as any[];

// Top breeds that match this brand's category
const matchingBreeds = (masterBreeds as any[])
  .filter(b => {
    const picks = b.product_picks || {};
    return Object.values(picks).some((id: any) => {
      const prod = (productIndex as any)[id];
      return prod && (prod.name||'').toLowerCase().includes(brand.name.toLowerCase().split(' ')[0]);
    });
  })
  .slice(0, 8);

const hasLogo = brand.logo_url && brand.logo_url !== '';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": brand.name,
  "url": `https://${brand.domain}`,
  "logo": `${SITE}${brand.logo_url}`,
  "description": `${brand.name} dog products — expert reviews and best picks for your breed.`,
});
---

<BaseLayout
  title={`${brand.name} Dog Products — Reviews, Best Picks & Breed Guides 2026`}
  description={`Expert reviews of all ${brand.name} dog products. Find the best ${brand.name} ${brand.category_label.toLowerCase()} for your breed, with Chewy and Amazon price comparisons.`}
  canonicalURL={`${SITE}/brands/${slug}`}
>
<script type="application/ld+json" set:html={jsonLd} />

<!-- Hero -->
<div style="background:linear-gradient(to bottom,#f5e8d0,#fdf8f0);border-bottom:1px solid #e8ccaa">
  <div class="max-w-7xl mx-auto px-4 py-10 sm:py-14">
    <nav class="font-sans text-sm mb-6 flex items-center gap-1.5" style="color:#94a3b8">
      <a href="/" style="color:#a0621c" class="hover:underline">Home</a>
      <span>›</span>
      <a href="/brands" style="color:#a0621c" class="hover:underline">Brands</a>
      <span>›</span>
      <span style="color:#475569">{brand.name}</span>
    </nav>

    <div class="flex flex-col sm:flex-row sm:items-center gap-6 sm:gap-8">
      <!-- Logo -->
      <div class="flex-shrink-0 w-24 h-24 sm:w-32 sm:h-32 rounded-2xl flex items-center justify-center shadow-md overflow-hidden" style="background:white;border:1px solid #e8ccaa">
        <img
          src={brand.logo_url}
          alt={`${brand.name} logo`}
          width="128"
          height="128"
          loading="eager"
          class="w-full h-full object-contain p-3"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <span style="display:none;align-items:center;justify-content:center;width:100%;height:100%;font-size:2.5rem">🏷️</span>
      </div>

      <!-- Info -->
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap gap-2 mb-3">
          <span class="font-sans text-xs font-bold px-3 py-1 rounded-full" style="background:#a0621c;color:white">
            {brand.category_label}
          </span>
          {brand.speciality && (
            <span class="font-sans text-xs font-semibold px-3 py-1 rounded-full" style="background:#fef3c7;color:#92400e">
              {brand.speciality}
            </span>
          )}
          {brand.featured && (
            <span class="font-sans text-xs font-bold px-3 py-1 rounded-full" style="background:#f0fdf4;color:#15803d">
              ⭐ Editor's favourite
            </span>
          )}
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-bold mb-2 leading-tight" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          {brand.name}
        </h1>
        <p class="font-sans text-base leading-relaxed mb-4" style="color:#64748b">
          Expert reviews and best-pick recommendations for all {brand.name} dog products — compared across Chewy and Amazon to find you the best price.
        </p>

        <!-- Dual CTA -->
        <div class="flex flex-wrap gap-3">
          <a href={brand.chewy_url} rel="nofollow sponsored" target="_blank"
            class="inline-flex items-center gap-2 font-sans font-bold text-sm px-5 py-2.5 rounded-xl text-white transition-all hover:-translate-y-0.5"
            style="background:linear-gradient(135deg,#0052cc,#003d99);box-shadow:0 2px 8px rgba(0,82,204,0.3)">
            <span>🔵</span> Shop on Chewy →
          </a>
          <a href={brand.amazon_search} rel="nofollow sponsored" target="_blank"
            class="inline-flex items-center gap-2 font-sans font-bold text-sm px-5 py-2.5 rounded-xl text-white transition-all hover:-translate-y-0.5 btn-amazon"
            style="background:linear-gradient(135deg,#FF9900,#e88700);box-shadow:0 2px 8px rgba(255,153,0,0.3)">
            <span>🟡</span> Find on Amazon.com →
          </a>
          <a href={`https://${brand.domain}`} rel="nofollow" target="_blank"
            class="inline-flex items-center gap-2 font-sans font-medium text-sm px-5 py-2.5 rounded-xl transition-all hover:underline"
            style="border:1px solid #e8ccaa;color:#64748b;background:white">
            Official site →
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Main -->
<div class="max-w-7xl mx-auto px-4 py-10">
  <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-10">

    <div class="space-y-10 min-w-0">

      <!-- Products from this brand -->
      {brandProducts.length > 0 && (
        <section>
          <p class="font-sans text-xs font-bold uppercase tracking-widest mb-2" style="color:#a0621c">Product reviews</p>
          <h2 class="font-display text-2xl font-bold mb-6" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
            {brand.name} Products We've Reviewed
          </h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {brandProducts.slice(0, 8).map((p: any) => (
              <div class="rounded-2xl overflow-hidden flex flex-col" style="border:1px solid #e8ccaa;background:white">
                <!-- Product image -->
                <div class="flex items-center justify-center p-4" style="background:#fdf8f0;height:140px">
                  {p.image?.includes('media-amazon') ? (
                    <img src={p.image} alt={p.name} width="120" height="120" loading="lazy"
                      class="object-contain max-h-28"
                      onerror={`this.style.display='none';this.nextElementSibling.style.display='block'`} />
                  ) : null}
                  <img src={brand.logo_url} alt={brand.name} width="80" height="80" loading="lazy"
                    class="object-contain max-h-16 opacity-60"
                    style={p.image?.includes('media-amazon') ? 'display:none' : ''}
                    onerror="this.style.display='none'" />
                </div>

                <div class="p-4 flex flex-col flex-1 gap-2">
                  <p class="font-sans text-xs font-bold uppercase tracking-wider" style="color:#a0621c">
                    {(p.category_key||'').replace(/-/g,' ')}
                  </p>
                  <h3 class="font-sans font-bold text-sm leading-tight" style="color:#1e293b">{p.name}</h3>
                  <div class="flex items-center gap-1">
                    <span style="color:#f59e0b;font-size:0.7rem">{'★'.repeat(Math.round(p.rating||4.5))}</span>
                    <span class="font-sans text-xs" style="color:#64748b">{parseFloat(p.rating||4.5).toFixed(1)}/5</span>
                    {p.score && <span class="font-sans text-xs font-bold ml-1" style="color:#a0621c">{p.score}/10</span>}
                  </div>
                  {p.verdict && (
                    <p class="font-sans text-xs italic leading-relaxed" style="color:#64748b">{p.verdict.slice(0,80)}…</p>
                  )}

                  <!-- Dual CTA inline -->
                  <div class="mt-auto pt-2 flex gap-2" style="border-top:1px solid #f5e8d0">
                    <span class="font-sans font-black text-base" style="color:#1e293b">
                      {p.price ? `$${parseFloat(p.price).toFixed(2)}` : '—'}
                    </span>
                    <div class="flex gap-1.5 ml-auto">
                      {p.chewy_id && (
                        <a href={`https://www.chewy.com/dp/${p.chewy_id}?ref=impact`}
                          rel="nofollow sponsored" target="_blank"
                          class="font-sans text-xs font-bold px-2.5 py-1.5 rounded-lg text-white"
                          style="background:#0052cc">
                          Chewy
                        </a>
                      )}
                      {p.asin && p.asin !== 'SUBSCRIPTION' && (
                        <a href={`https://www.amazon.com/dp/${p.asin}/?tag=${AMAZON_TAG}`}
                          rel="nofollow sponsored" target="_blank"
                          class="font-sans text-xs font-bold px-2.5 py-1.5 rounded-lg text-white btn-amazon"
                          style="background:linear-gradient(135deg,#FF9900,#e88700)">
                          Amazon
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Breeds matched to this brand -->
      {matchingBreeds.length > 0 && (
        <section>
          <p class="font-sans text-xs font-bold uppercase tracking-widest mb-2" style="color:#a0621c">Breed matches</p>
          <h2 class="font-display text-2xl font-bold mb-6" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
            Breeds That Love {brand.name}
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            {matchingBreeds.map((b: any) => (
              <a href={`/breeds/${b.slug}`}
                class="rounded-2xl overflow-hidden transition-all hover:-translate-y-1 hover:shadow-md"
                style="border:1px solid #e8ccaa;background:white;text-decoration:none">
                <div style="height:80px;background:#fdf8f0;overflow:hidden">
                  {b.image_url ? (
                    <img src={b.image_url} alt={b.name} width="160" height="80" loading="lazy"
                      class="w-full h-full object-cover"
                      onerror="this.parentElement.innerHTML='<div style=display:flex;align-items:center;justify-content:center;height:100%;font-size:2rem>🐕</div>'" />
                  ) : (
                    <div class="flex items-center justify-center h-full text-3xl">🐕</div>
                  )}
                </div>
                <div class="p-2.5">
                  <p class="font-sans text-xs font-bold" style="color:#1e293b">{b.name}</p>
                  <p class="font-sans text-xs" style="color:#94a3b8">{b.size_category}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- About the brand -->
      <section class="rounded-3xl p-7" style="background:white;border:1px solid #e8ccaa">
        <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          About {brand.name}
        </h2>
        <div class="grid sm:grid-cols-2 gap-6 font-sans text-sm">
          <div>
            <p class="font-bold mb-3" style="color:#1e293b">Brand overview</p>
            <div class="space-y-2">
              {[
                ['Category', brand.category_label],
                ['Speciality', brand.speciality],
                ['Website', brand.domain],
                ['Trust score', `${brand.trust_score}/10`],
              ].map(([k,v]) => v && (
                <div class="flex justify-between gap-2 pb-1.5" style="border-bottom:1px solid #f5e8d0">
                  <span style="color:#64748b">{k}</span>
                  <span class="font-semibold" style="color:#1e293b">{v}</span>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="font-bold mb-3" style="color:#1e293b">Where to buy</p>
            <div class="space-y-2">
              <a href={brand.chewy_url} rel="nofollow sponsored" target="_blank"
                class="flex items-center justify-between p-3 rounded-xl transition-all hover:shadow-sm"
                style="border:1px solid #e8ccaa;text-decoration:none">
                <span class="font-semibold" style="color:#0052cc">🔵 Chewy</span>
                <span class="text-xs" style="color:#94a3b8">Shop all {brand.name} →</span>
              </a>
              <a href={brand.amazon_search} rel="nofollow sponsored" target="_blank"
                class="flex items-center justify-between p-3 rounded-xl transition-all hover:shadow-sm"
                style="border:1px solid #e8ccaa;text-decoration:none">
                <span class="font-semibold" style="color:#FF9900">🟡 Amazon</span>
                <span class="text-xs" style="color:#94a3b8">Search {brand.name} →</span>
              </a>
              <a href={`https://${brand.domain}`} rel="nofollow" target="_blank"
                class="flex items-center justify-between p-3 rounded-xl transition-all hover:shadow-sm"
                style="border:1px solid #e8ccaa;text-decoration:none">
                <span class="font-semibold" style="color:#64748b">🌐 Official site</span>
                <span class="text-xs" style="color:#94a3b8">{brand.domain} →</span>
              </a>
            </div>
          </div>
        </div>
      </section>

    </div>

    <!-- Sidebar -->
    <aside class="hidden lg:block">
      <div class="sticky space-y-5" style="top:80px">

        <!-- Logo card -->
        <div class="rounded-2xl overflow-hidden text-center" style="border:2px solid #a0621c;background:white">
          <div class="px-4 py-3" style="background:#a0621c">
            <p class="font-sans text-xs font-bold uppercase tracking-wider text-white">{brand.name}</p>
          </div>
          <div class="p-5 flex items-center justify-center" style="height:120px">
            <img src={brand.logo_url} alt={brand.name} width="120" height="80" loading="lazy"
              class="object-contain max-h-20"
              onerror="this.parentElement.innerHTML='<span style=font-size:3rem>🏷️</span>'" />
          </div>
          <div class="px-4 pb-4 flex flex-col gap-2">
            <a href={brand.chewy_url} rel="nofollow sponsored" target="_blank"
              class="block text-center font-sans font-bold text-sm py-2.5 rounded-xl text-white"
              style="background:linear-gradient(135deg,#0052cc,#003d99)">
              Shop on Chewy →
            </a>
            <a href={brand.amazon_search} rel="nofollow sponsored" target="_blank"
              class="block text-center font-sans font-bold text-sm py-2.5 rounded-xl text-white btn-amazon"
              style="background:linear-gradient(135deg,#FF9900,#e88700)">
              Search on Amazon.com →
            </a>
          </div>
        </div>

        <!-- Category nav -->
        <div class="rounded-2xl p-4" style="border:1px solid #e8ccaa;background:white">
          <p class="font-sans text-xs font-bold uppercase tracking-wider mb-3" style="color:#94a3b8">Browse by category</p>
          <div class="space-y-1">
            {[
              ['/categories/dog-food',    '🍖', 'Dog Food'],
              ['/categories/toys',        '🎾', 'Toys'],
              ['/categories/beds',        '🛏️', 'Beds'],
              ['/categories/health',      '🩺', 'Health'],
              ['/categories/supplements', '💊', 'Supplements'],
              ['/categories/grooming',    '✂️', 'Grooming'],
              ['/categories/training',    '🦮', 'Training & Gear'],
              ['/categories/smart-tech',  '📡', 'Smart Tech'],
            ].map(([href, emoji, label]) => (
              <a href={href} class="flex items-center gap-2 px-2 py-2 rounded-lg font-sans text-sm transition-colors hover:bg-amber-50"
                style="color:#1e293b;text-decoration:none">
                <span>{emoji}</span><span>{label} →</span>
              </a>
            ))}
          </div>
        </div>

        <!-- Browse all brands -->
        <a href="/brands" class="block text-center rounded-2xl py-3 font-sans text-sm font-bold transition-all hover:bg-amber-50"
          style="border:1px solid #e8ccaa;color:#a0621c;text-decoration:none;background:white">
          All brands directory →
        </a>

      </div>
    </aside>
  </div>
</div>

</BaseLayout>
