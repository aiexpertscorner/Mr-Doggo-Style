---
/**
 * cost-calculator/[breed].astro
 * Breed-specific lifetime cost of ownership calculator
 * Targets: "how much does a [breed] cost" (high commercial intent)
 */
import BaseLayout   from '../../layouts/BaseLayout.astro';
import masterBreeds from '../../data/master-breeds.json';
import productIndex from '../../data/product-index.json';
import breedLinkMap from '../../data/breed-link-map.json';

const AMAZON_TAG = 'aiexpertscorn-20';
const SITE       = 'https://mrdoggostyle.com';

export function getStaticPaths() {
  return (masterBreeds as any[]).map(b => ({ params: { breed: b.slug } }));
}

const { breed: slug } = Astro.params;
const b     = (masterBreeds as any[]).find(x => x.slug === slug);
if (!b) return Astro.redirect('/breeds');

const links = (breedLinkMap as any)[slug] || {};
const rank  = b.ranking_data || {};
const life  = b.life_expectancy || {};
const wt    = b.weight || {};
const n     = b.name;

// ── Cost estimates per size/energy tier ──────────────────────
const SIZE_COSTS = {
  small:  { food_annual: 600,  vet_annual: 600,  grooming_annual: 400, supplies_one_time: 400, spay_neuter: 300 },
  medium: { food_annual: 900,  vet_annual: 800,  grooming_annual: 500, supplies_one_time: 500, spay_neuter: 400 },
  large:  { food_annual: 1400, vet_annual: 1000, grooming_annual: 700, supplies_one_time: 700, spay_neuter: 500 },
  giant:  { food_annual: 2000, vet_annual: 1400, grooming_annual: 900, supplies_one_time: 900, spay_neuter: 700 },
};
const COAT_GROOMING_MULT = { double: 1.4, long: 1.6, silky: 1.5, wiry: 1.5, curly: 1.7, corded: 2.0, short: 0.8, wavy: 1.2, medium: 1.0 };
const ENERGY_HEALTH_MULT = { active: 1.3, regular: 1.0, calm: 0.9 };

const base  = SIZE_COSTS[b.size_category] || SIZE_COSTS.medium;
const gmult = COAT_GROOMING_MULT[b.coat_type] || 1.0;
const hmult = ENERGY_HEALTH_MULT[b.energy_level] || 1.0;
const lifespan = rank.longevity_years || ((life.min||10) + (life.max||14)) / 2;

// Use ranking data if available, else estimate
const annual_food  = rank.annual_food_cost || base.food_annual;
const annual_vet   = Math.round(base.vet_annual * hmult);
const annual_groom = Math.round(base.grooming_annual * gmult);
const annual_toys  = b.energy_level === 'active' ? 400 : b.energy_level === 'calm' ? 150 : 250;
const annual_other = 200; // insurance contribution, misc
const annual_total = annual_food + annual_vet + annual_groom + annual_toys + annual_other;

const one_time_puppy  = base.supplies_one_time;
const one_time_spay   = base.spay_neuter;
const one_time_total  = one_time_puppy + one_time_spay + 200; // 200 for initial vet visit

const lifetime_est = rank.lifetime_cost_usd || Math.round(one_time_total + (annual_total * lifespan));
const puppy_price_low  = b.size_category === 'small' ? 500 : b.size_category === 'large' || b.size_category === 'giant' ? 1200 : 800;
const puppy_price_high = puppy_price_low * 2.5;

// Cost breakdown items
const COST_ITEMS = [
  { label: 'Dog food',             annual: annual_food,  icon: '🍖', note: `Based on ${b.size_category} breed feeding requirements` },
  { label: 'Veterinary care',      annual: annual_vet,   icon: '🩺', note: `${b.energy_level} energy breeds have ${hmult > 1 ? 'higher' : 'typical'} vet costs` },
  { label: 'Grooming',             annual: annual_groom, icon: '✂️', note: `${b.coat_type} coat requires ${gmult > 1.3 ? 'frequent' : 'regular'} grooming` },
  { label: 'Toys & enrichment',    annual: annual_toys,  icon: '🎾', note: `${b.energy_level === 'active' ? 'Active breeds need more mental stimulation' : 'Standard toy rotation'}` },
  { label: 'Other (misc/insurance)',annual: annual_other, icon: '💰', note: 'Training, boarding, pet insurance contributions' },
];

// Top products for sidebar
const foodProd = b.product_picks?.['dog-food'] ? (productIndex as any)[b.product_picks['dog-food']] : null;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `How much does a ${n} cost per year?`,
      "acceptedAnswer": { "@type": "Answer", "text": `A ${n} costs approximately $${annual_total.toLocaleString()} per year in ongoing expenses, including food ($${annual_food.toLocaleString()}), veterinary care ($${annual_vet.toLocaleString()}), grooming ($${annual_groom.toLocaleString()}), and toys ($${annual_toys.toLocaleString()}).` }
    },
    {
      "@type": "Question",
      "name": `What is the lifetime cost of a ${n}?`,
      "acceptedAnswer": { "@type": "Answer", "text": `The estimated lifetime cost of owning a ${n} is $${lifetime_est.toLocaleString()}, based on an average lifespan of ${lifespan} years and annual expenses of $${annual_total.toLocaleString()}.` }
    },
    {
      "@type": "Question",
      "name": `How much does a ${n} puppy cost?`,
      "acceptedAnswer": { "@type": "Answer", "text": `${n} puppies from reputable breeders typically cost $${puppy_price_low.toLocaleString()}–$${puppy_price_high.toLocaleString()}. Rescue or rehoming fees are usually $50–$500.` }
    }
  ]
});
---

<BaseLayout
  title={`How Much Does a ${n} Cost? 2026 Complete Cost Breakdown`}
  description={`Full ${n} cost of ownership: puppy price $${puppy_price_low.toLocaleString()}–$${puppy_price_high.toLocaleString()}, annual costs $${annual_total.toLocaleString()}/yr, lifetime estimate $${lifetime_est.toLocaleString()}. Includes food, vet, grooming and toys.`}
  canonicalURL={`${SITE}/cost-calculator/${slug}`}
>
<script type="application/ld+json" set:html={jsonLd} />

<!-- Hero -->
<div style="background:linear-gradient(to bottom,#f5e8d0,#fdf8f0);border-bottom:1px solid #e8ccaa">
  <div class="max-w-7xl mx-auto px-4 py-10 sm:py-14">
    <nav class="font-sans text-sm mb-5 flex flex-wrap gap-1.5" style="color:#94a3b8">
      <a href="/" style="color:#a0621c" class="hover:underline">Home</a><span>›</span>
      <a href="/breeds" style="color:#a0621c" class="hover:underline">Breeds</a><span>›</span>
      <a href={`/breeds/${slug}`} style="color:#a0621c" class="hover:underline">{n}</a><span>›</span>
      <span style="color:#475569">Cost Calculator</span>
    </nav>

    <div class="flex flex-col sm:flex-row sm:items-start gap-6">
      {b.image_url && (
        <img src={b.image_url} alt={n} width="120" height="120" loading="eager"
          class="w-24 h-24 sm:w-32 sm:h-32 object-cover rounded-2xl flex-shrink-0"
          style="border:2px solid #e8ccaa"
          onerror="this.style.display='none'" />
      )}
      <div>
        <span class="inline-block font-sans text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-3" style="background:#a0621c;color:white">
          Cost calculator
        </span>
        <h1 class="font-display text-4xl sm:text-5xl font-bold mb-2 leading-tight" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          How Much Does a <span style="color:#a0621c">{n}</span> Cost?
        </h1>
        <p class="font-sans text-lg leading-relaxed max-w-2xl" style="color:#64748b">
          Complete 2026 cost breakdown — puppy price, annual expenses, and lifetime estimate based on breed size, coat type, and energy level.
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Main -->
<div class="max-w-7xl mx-auto px-4 py-10">
  <div class="lg:grid lg:grid-cols-[1fr_300px] lg:gap-10">

    <div class="space-y-10 min-w-0">

      <!-- Summary cards -->
      <section>
        <div class="grid sm:grid-cols-3 gap-4">
          <div class="rounded-2xl p-5 text-center" style="background:linear-gradient(135deg,#3d2206,#7d4a10);color:white">
            <p class="font-sans text-xs font-bold uppercase tracking-wider mb-2 opacity-80">Puppy price</p>
            <p class="font-display text-3xl font-black" style="font-family:'Playfair Display',Georgia,serif">
              ${puppy_price_low.toLocaleString()}–${puppy_price_high.toLocaleString()}
            </p>
            <p class="font-sans text-xs mt-1 opacity-70">From reputable breeder</p>
          </div>
          <div class="rounded-2xl p-5 text-center" style="background:linear-gradient(135deg,#a0621c,#c07835);color:white">
            <p class="font-sans text-xs font-bold uppercase tracking-wider mb-2 opacity-80">Annual cost</p>
            <p class="font-display text-3xl font-black" style="font-family:'Playfair Display',Georgia,serif">
              ${annual_total.toLocaleString()}
            </p>
            <p class="font-sans text-xs mt-1 opacity-70">Per year ongoing</p>
          </div>
          <div class="rounded-2xl p-5 text-center" style="background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#1e293b">
            <p class="font-sans text-xs font-bold uppercase tracking-wider mb-2 opacity-70">Lifetime total</p>
            <p class="font-display text-3xl font-black" style="font-family:'Playfair Display',Georgia,serif">
              ${lifetime_est.toLocaleString()}
            </p>
            <p class="font-sans text-xs mt-1 opacity-60">Over ~{lifespan} years</p>
          </div>
        </div>
      </section>

      <!-- Annual cost breakdown -->
      <section>
        <p class="font-sans text-xs font-bold uppercase tracking-widest mb-2" style="color:#a0621c">Annual breakdown</p>
        <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          {n} Annual Cost Breakdown
        </h2>
        <div class="rounded-2xl overflow-hidden" style="border:1px solid #e8ccaa">
          {COST_ITEMS.map((item, i) => {
            const pct = Math.round((item.annual / annual_total) * 100);
            return (
              <div class="p-4 flex items-center gap-4" style={`background:${i%2===0?'white':'#fdf8f0'};border-bottom:1px solid #f5e8d0`}>
                <span style="font-size:1.5rem;flex-shrink:0">{item.icon}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex justify-between items-center mb-1">
                    <p class="font-sans font-bold text-sm" style="color:#1e293b">{item.label}</p>
                    <p class="font-sans font-black text-base flex-shrink-0 ml-2" style="color:#a0621c">${item.annual.toLocaleString()}/yr</p>
                  </div>
                  <div class="h-1.5 rounded-full overflow-hidden mb-1" style="background:#e8ccaa">
                    <div class="h-full rounded-full" style={`width:${pct}%;background:#a0621c`}></div>
                  </div>
                  <p class="font-sans text-xs" style="color:#94a3b8">{item.note}</p>
                </div>
              </div>
            );
          })}
          <div class="p-4 flex items-center justify-between" style="background:#f5e8d0">
            <p class="font-sans font-black text-base" style="color:#5c340a">Total annual cost</p>
            <p class="font-display font-black text-2xl" style="font-family:'Playfair Display',Georgia,serif;color:#3d2206">
              ${annual_total.toLocaleString()}
            </p>
          </div>
        </div>
        <p class="font-sans text-xs mt-3" style="color:#94a3b8">
          * Estimates based on {n} breed profile ({b.size_category} size, {b.energy_level} energy, {b.coat_type} coat). Actual costs vary by location, lifestyle, and individual dog health.
        </p>
      </section>

      <!-- First year costs -->
      <section>
        <p class="font-sans text-xs font-bold uppercase tracking-widest mb-2" style="color:#a0621c">First year</p>
        <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          First Year Cost for a {n}
        </h2>
        <div class="rounded-2xl overflow-hidden" style="border:1px solid #e8ccaa;background:white">
          {[
            { label: 'Puppy / adoption fee',   low: puppy_price_low,     high: puppy_price_high,    note: 'Reputable breeder or rescue' },
            { label: 'Initial vet visit',      low: 150,                 high: 300,                 note: 'Health check, vaccines, microchip' },
            { label: 'Spay / neuter',          low: base.spay_neuter-100,high: base.spay_neuter+200,note: 'Recommended around 6–12 months' },
            { label: 'Supplies (one-time)',     low: base.supplies_one_time, high: base.supplies_one_time * 1.5, note: 'Crate, bed, bowls, leash, collar, toys' },
            { label: 'Food (year 1)',           low: annual_food,         high: annual_food * 1.2,   note: 'Puppy food typically costs more' },
            { label: 'Training classes',       low: 150,                 high: 400,                 note: 'Puppy classes + basic obedience' },
          ].map((row, i) => (
            <div class="flex items-center justify-between px-5 py-3 font-sans text-sm" style={`border-bottom:1px solid #f5e8d0;background:${i%2===0?'white':'#fdf8f0'}`}>
              <div>
                <p class="font-semibold" style="color:#1e293b">{row.label}</p>
                <p class="text-xs" style="color:#94a3b8">{row.note}</p>
              </div>
              <p class="font-bold flex-shrink-0 ml-4" style="color:#a0621c">
                ${row.low.toLocaleString()}–${row.high.toLocaleString()}
              </p>
            </div>
          ))}
          <div class="px-5 py-4 flex justify-between" style="background:#f5e8d0">
            <p class="font-sans font-black" style="color:#5c340a">First year total estimate</p>
            <p class="font-display font-black text-xl" style="font-family:'Playfair Display',Georgia,serif;color:#3d2206">
              ${(puppy_price_low + 150 + base.spay_neuter + base.supplies_one_time + annual_food + 200).toLocaleString()}–
              ${(puppy_price_high + 400 + base.spay_neuter + 400 + base.supplies_one_time * 1.5 + annual_food * 1.2 + 400).toLocaleString()}
            </p>
          </div>
        </div>
      </section>

      <!-- Lifetime cost table -->
      <section>
        <p class="font-sans text-xs font-bold uppercase tracking-widest mb-2" style="color:#a0621c">Long-term view</p>
        <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          {n} Lifetime Cost Projection
        </h2>
        <div class="rounded-2xl overflow-hidden" style="border:1px solid #e8ccaa">
          <table class="w-full font-sans text-sm">
            <thead><tr style="background:#f5e8d0">
              <th class="text-left px-5 py-3 font-bold" style="color:#5c340a">Year</th>
              <th class="text-right px-5 py-3 font-bold" style="color:#5c340a">Annual cost</th>
              <th class="text-right px-5 py-3 font-bold" style="color:#5c340a">Cumulative</th>
            </tr></thead>
            <tbody>
              {Array.from({length: Math.min(Math.ceil(lifespan), 15)}, (_, i) => {
                const yr = i + 1;
                const cost = yr === 1 ? annual_total + one_time_total + puppy_price_low : annual_total;
                const cumul = yr === 1 ? cost : (annual_total * yr) + one_time_total + puppy_price_low;
                return (
                  <tr style={`background:${i%2===0?'white':'#fdf8f0'};border-top:1px solid #f5e8d0`}>
                    <td class="px-5 py-3" style="color:#1e293b">
                      Year {yr}{yr === 1 ? ' (puppy)' : yr >= Math.ceil(lifespan - 2) ? ' (senior)' : ''}
                    </td>
                    <td class="px-5 py-3 text-right font-semibold" style="color:#475569">
                      ${cost.toLocaleString()}
                    </td>
                    <td class="px-5 py-3 text-right font-bold" style="color:#a0621c">
                      ${cumul.toLocaleString()}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Ways to save -->
      <section class="rounded-3xl p-7" style="background:white;border:1px solid #e8ccaa">
        <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          How to Reduce {n} Ownership Costs
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            { icon:'🍖', tip:'Buy food in bulk', save:'$100–300/yr', detail:'Subscribe & Save on Chewy saves 5–35% on food orders' },
            { icon:'🩺', tip:'Pet insurance',    save:'$0–5,000/yr', detail:'Monthly premiums of $30–80 can save thousands on unexpected vet bills' },
            { icon:'🎾', tip:'Rotate toys',      save:'$100–200/yr', detail:'Rotating 8–12 toys keeps novelty high without constant buying' },
            { icon:'✂️', tip:'Learn to groom',   save:'$200–600/yr', detail:'Basic grooming at home between professional sessions reduces costs significantly' },
            { icon:'💊', tip:'Preventive health', save:'$200–800/yr', detail:'Quality food, dental care, and exercise reduce vet costs over a lifetime' },
            { icon:'🐾', tip:'Adopt vs buy',     save:'$1,000–3,000', detail:'Rescue or rehoming fees are $50–500 vs $800–4,000+ from breeders' },
          ].map(item => (
            <div class="flex gap-3 items-start p-3 rounded-xl" style="background:#f0fdf4;border:1px solid #bbf7d0">
              <span style="font-size:1.25rem;flex-shrink:0">{item.icon}</span>
              <div>
                <p class="font-sans font-bold text-sm" style="color:#1e293b">{item.tip}</p>
                <p class="font-sans text-xs font-bold mb-1" style="color:#16a34a">Save {item.save}</p>
                <p class="font-sans text-xs leading-relaxed" style="color:#166534">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          Frequently Asked Questions
        </h2>
        <div class="space-y-2">
          {[
            [`How much does a ${n} puppy cost?`,
             `${n} puppies from reputable breeders typically cost $${puppy_price_low.toLocaleString()}–$${puppy_price_high.toLocaleString()}. Show-line dogs from championship bloodlines can cost more. Rescue and rehoming fees are typically $50–500.`],
            [`How much does a ${n} cost per month?`,
             `Ongoing monthly costs for a ${n} are approximately $${Math.round(annual_total/12).toLocaleString()}, covering food ($${Math.round(annual_food/12).toLocaleString()}), vet contributions ($${Math.round(annual_vet/12).toLocaleString()}), and other regular expenses.`],
            [`Is the ${n} an expensive breed to own?`,
             `${b.size_category === 'large' || b.size_category === 'giant' ? `As a ${b.size_category} breed, ${n}s have above-average ongoing costs — primarily due to food volume and potential orthopaedic health costs.` : `${n}s have ${b.size_category === 'small' ? 'relatively manageable' : 'moderate'} ongoing costs compared to larger breeds, though ${b.coat_type === 'long' || b.coat_type === 'curly' || b.coat_type === 'wiry' ? `grooming costs are higher due to their ${b.coat_type} coat.` : 'costs are fairly typical for the breed size.'}`}`],
            [`What is the biggest cost of owning a ${n}?`,
             `For ${n}s, the biggest ongoing cost is typically ${annual_food > annual_vet ? `food ($${annual_food.toLocaleString()}/yr)` : `veterinary care ($${annual_vet.toLocaleString()}/yr)`}. The largest single expense is usually the initial puppy purchase price of $${puppy_price_low.toLocaleString()}–$${puppy_price_high.toLocaleString()}.`],
          ].map(([q, a]) => (
            <details class="rounded-xl overflow-hidden" style="border:1px solid #e8ccaa;background:white">
              <summary class="p-4 font-sans font-semibold text-sm cursor-pointer flex justify-between items-center" style="color:#1e293b;list-style:none">
                <span>{q}</span>
                <span class="faq-icon ml-3 flex-shrink-0 text-lg font-light" style="color:#a0621c">+</span>
              </summary>
              <div class="px-4 pb-4 pt-3 font-sans text-sm leading-relaxed" style="color:#475569;border-top:1px solid #f5e8d0">{a}</div>
            </details>
          ))}
        </div>
      </section>

      <!-- Related guides -->
      <section>
        <h2 class="font-display text-2xl font-bold mb-5" style="font-family:'Playfair Display',Georgia,serif;color:#1e293b">
          {n} Guides to Reduce Your Costs
        </h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {[
            links.food_post     && { href: links.food_post,     emoji:'🍖', label:`Best food for ${n}s — save on nutrition without compromising quality` },
            links.grooming_post && { href: links.grooming_post, emoji:'✂️', label:`${n} grooming guide — DIY tips to reduce professional costs` },
            links.supplement_post && { href: links.supplement_post, emoji:'💊', label:`Best supplements for ${n}s — prevention beats expensive treatment` },
            links.training_post && { href: links.training_post, emoji:'🦮', label:`Training a ${n} — avoid costly behavioural problems early` },
            links.health_post   && { href: links.health_post,   emoji:'🩺', label:`${n} health guide — know the risks before they become bills` },
            links.hub           && { href: links.hub,           emoji:'🐾', label:`Complete ${n} care guide` },
          ].filter(Boolean).map((c: any) => (
            <a href={c.href}
              class="flex items-center gap-3 p-3 rounded-xl transition-all hover:shadow-sm"
              style="border:1px solid #e8ccaa;background:white;text-decoration:none"
              onmouseover="this.style.borderColor='#a0621c';this.style.background='#fdf8f0'"
              onmouseout="this.style.borderColor='#e8ccaa';this.style.background='white'">
              <span>{c.emoji}</span>
              <span class="font-sans text-sm" style="color:#1e293b">{c.label} →</span>
            </a>
          ))}
        </div>
      </section>

    </div>

    <!-- Sidebar -->
    <aside class="hidden lg:block">
      <div class="sticky space-y-5" style="top:80px">

        <!-- Quick summary -->
        <div class="rounded-2xl overflow-hidden" style="border:2px solid #a0621c;background:white">
          <div class="px-4 py-3" style="background:#a0621c">
            <p class="font-sans text-xs font-bold uppercase tracking-wider text-white">{n} Cost Summary</p>
          </div>
          <div class="p-4 space-y-3 font-sans text-sm">
            {[
              ['Puppy price',     `$${puppy_price_low.toLocaleString()}–$${puppy_price_high.toLocaleString()}`],
              ['Annual food',     `$${annual_food.toLocaleString()}`],
              ['Annual vet',      `$${annual_vet.toLocaleString()}`],
              ['Annual grooming', `$${annual_groom.toLocaleString()}`],
              ['Annual toys',     `$${annual_toys.toLocaleString()}`],
              ['Total per year',  `$${annual_total.toLocaleString()}`],
              ['Lifetime est.',   `$${lifetime_est.toLocaleString()}`],
            ].map(([label, value], i) => (
              <div class="flex justify-between gap-2 pb-2" style={`border-bottom:${i < 6 ? '1px solid #f5e8d0' : 'none'}`}>
                <span style="color:#64748b">{label}</span>
                <strong style={`color:${i === 5 ? '#a0621c' : '#1e293b'};font-size:${i === 5 ? '1.05rem' : '0.875rem'}`}>{value}</strong>
              </div>
            ))}
          </div>
        </div>

        <!-- Top food recommendation -->
        {foodProd && foodProd.asin && foodProd.asin !== 'SUBSCRIPTION' && (
          <div class="rounded-2xl overflow-hidden" style="border:1px solid #e8ccaa;background:white">
            <div class="px-4 py-2 font-sans text-xs font-bold uppercase tracking-wider" style="background:#f5e8d0;color:#5c340a">
              Reduce food costs
            </div>
            <div class="p-4">
              <p class="font-sans text-xs italic mb-2" style="color:#64748b">
                Subscribe & Save on Chewy saves 5–35% vs buying monthly
              </p>
              {foodProd.image?.includes('media-amazon') && (
                <div class="flex justify-center mb-3">
                  <img src={foodProd.image} alt={foodProd.name} width="80" height="80" loading="lazy"
                    class="object-contain max-h-20" onerror="this.style.display='none'" />
                </div>
              )}
              <p class="font-sans font-bold text-sm mb-1" style="color:#1e293b">{foodProd.name}</p>
              <p class="font-sans font-black text-lg mb-2" style="color:#a0621c">
                ${parseFloat(foodProd.price||0).toFixed(2)}
              </p>
              <a href={`https://www.chewy.com/s?query=${encodeURIComponent(foodProd.name)}&ref=impact`}
                rel="nofollow sponsored" target="_blank"
                class="block text-center font-sans font-bold text-xs py-2.5 rounded-xl text-white mb-2"
                style="background:linear-gradient(135deg,#0052cc,#003d99)">
                Subscribe on Chewy (save up to 35%) →
              </a>
              <a href={`https://www.amazon.com/dp/${foodProd.asin}/?tag=${AMAZON_TAG}`}
                rel="nofollow sponsored" target="_blank"
                class="block text-center font-sans font-medium text-xs py-2 rounded-xl"
                style="border:1px solid #e8ccaa;color:#64748b">
                Find at Amazon.com →
              </a>
            </div>
          </div>
        )}

        <!-- Breed quick facts -->
        <div class="rounded-2xl p-4" style="border:1px solid #e8ccaa;background:#fdf8f0">
          <p class="font-sans text-xs font-bold uppercase tracking-wider mb-3" style="color:#94a3b8">{n} profile</p>
          <div class="space-y-2 font-sans text-sm">
            {[
              ['Size',      b.size_category],
              ['Energy',    b.energy_level],
              ['Coat',      b.coat_type],
              ['Lifespan',  `${life.min||'?'}–${life.max||'?'} years`],
              rank.longevity_years ? ['Avg lifespan', `${rank.longevity_years} years`] : null,
            ].filter(Boolean).map((row: any) => (
              <div class="flex justify-between gap-2 pb-1.5" style="border-bottom:1px solid #e8ccaa">
                <span style="color:#64748b">{row[0]}</span>
                <span class="font-semibold capitalize" style="color:#1e293b">{row[1]}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </aside>
  </div>
</div>

<script>
  document.querySelectorAll('details').forEach(el => {
    el.addEventListener('toggle', () => {
      const icon = el.querySelector('.faq-icon') as HTMLElement;
      if (icon) icon.textContent = el.open ? '−' : '+';
    });
  });
</script>

</BaseLayout>
