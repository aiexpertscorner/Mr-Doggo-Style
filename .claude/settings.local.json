{
  "permissions": {
    "allow": [
      "Bash(xargs ls *)",
      "Bash(awk '{print $9, \"\\(\" $5 \"\\)\"}')",
      "Bash(xargs -I {} sh -c 'stat -c \"%s %n\" {} 2>/dev/null || stat -f \"%z %N\" {} 2>/dev/null')",
      "Bash(awk '{printf \"%-8d %s\\\\n\", $1, $2}')",
      "Bash(awk 'NR>1')",
      "Bash(awk '{print $2}')",
      "Bash(npm run *)",
      "Bash(grep -r \"home\\\\.css\\\\|home.css\" public/styles/ -l)",
      "Bash(ls public/styles/pages/)",
      "Bash(ls public/styles/components/)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  }
}
